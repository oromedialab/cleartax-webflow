---
// BlogPRArticles.astro
// PR Articles Section located below the Newsletter section on the Blog page.
---

<section class="bg-[#F3F0F8] py-24 px-6 md:px-8 border-t border-[#E2E8F0] text-left">
  <div class="max-w-[1200px] mx-auto premium-reveal">
    <!-- Header Title -->
    <h2 class="text-3xl md:text-4xl font-extrabold text-[#0C111D] font-manrope mb-10 tracking-tight">
      PR Articles
    </h2>

    <!-- Top Row: Featured and Small PR items -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">
      <!-- Left Column: Large Featured Card -->
      <a 
        href="#" 
        class="group relative flex flex-col justify-end overflow-hidden rounded-2xl bg-slate-900 aspect-[16/10] shadow-md border border-[#E2E8F0]/50"
      >
        <!-- Background Image -->
        <img 
          src="https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=800&auto=format&fit=crop" 
          alt="List of Approved & Pre-Approved e-Invoicing Providers in France" 
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
        />
        
        <!-- Dark overlay to ensure text contrast -->
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"></div>

        <!-- Semi-transparent bottom info bar -->
        <div class="relative w-full bg-[#16213E]/85 backdrop-blur-md border-t border-white/10 px-6 py-6 md:py-8 flex flex-col justify-center">
          <h3 class="text-lg md:text-2xl font-extrabold text-white leading-tight font-manrope">
            List of Approved & Pre-Approved e-Invoicing Providers in France (PA/PDP 2026)
          </h3>
        </div>
      </a>

      <!-- Right Column: List of Two Smaller Articles -->
      <div class="flex flex-col justify-between gap-8 lg:gap-0 py-1">
        <!-- Smaller Article 1 -->
        <a href="#" class="group flex gap-5 md:gap-6 items-start">
          <!-- White Square Left -->
          <div class="w-[100px] h-[100px] md:w-[120px] md:h-[120px] bg-white rounded-2xl flex-shrink-0 border border-[#E2E8F0] shadow-sm flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:border-[#6355D8]/30 group-hover:shadow-md">
            <svg class="w-10 h-10 text-[#98A2B3] group-hover:text-[#6355D8] transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 012 2v8a2 2 0 01-2 2h-3m-6 0h.01m-2-4h.01M9 16h.01M9 12h.01M7 12h.01M7 16h.01M7 8h10M7 12h10" />
            </svg>
          </div>
          <!-- Info Right -->
          <div class="flex flex-col">
            <h4 class="text-base md:text-lg font-bold text-[#0F172A] leading-snug group-hover:text-[#6355D8] transition-colors duration-200 font-manrope">
              ClearTax GST achieves Built for NetSuite status
            </h4>
            <p class="text-sm text-[#475467] mt-2 leading-relaxed font-inter line-clamp-2">
              ClearTax GST's SuiteApp supports e-invoicing and GST compliance within the Oracle NetSuite ecosystem.
            </p>
            <div class="text-xs text-[#667085] mt-2.5 font-bold uppercase tracking-wider font-inter flex items-center gap-2">
              <span>Press Release</span>
              <span class="text-[#D0D5DD]">|</span>
              <span>27 Sept, 2021</span>
            </div>
          </div>
        </a>

        <!-- Divider for mobile/tablet if needed, built-in spacing on desktop -->
        <div class="w-full h-px bg-[#E2E8F0] lg:hidden"></div>

        <!-- Smaller Article 2 -->
        <a href="#" class="group flex gap-5 md:gap-6 items-start">
          <!-- White Square Left -->
          <div class="w-[100px] h-[100px] md:w-[120px] md:h-[120px] bg-white rounded-2xl flex-shrink-0 border border-[#E2E8F0] shadow-sm flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:border-[#6355D8]/30 group-hover:shadow-md">
            <svg class="w-10 h-10 text-[#98A2B3] group-hover:text-[#6355D8] transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 012 2v8a2 2 0 01-2 2h-3m-6 0h.01m-2-4h.01M9 16h.01M9 12h.01M7 12h.01M7 16h.01M7 8h10M7 12h10" />
            </svg>
          </div>
          <!-- Info Right -->
          <div class="flex flex-col">
            <h4 class="text-base md:text-lg font-bold text-[#0F172A] leading-snug group-hover:text-[#6355D8] transition-colors duration-200 font-manrope">
              ClearTax acquires CimplyFive to strengthen CFO compliance suite
            </h4>
            <p class="text-sm text-[#475467] mt-2 leading-relaxed font-inter line-clamp-2">
              The acquisition strengthens Clear's CFO offerings across compliance, automation, and enterprise finance operations.
            </p>
            <div class="text-xs text-[#667085] mt-2.5 font-bold uppercase tracking-wider font-inter flex items-center gap-2">
              <span>Press Release</span>
              <span class="text-[#D0D5DD]">|</span>
              <span>6 Jul, 2022</span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Divider Line -->
    <div class="border-t border-[#D2D6DF] my-12 opacity-60"></div>

    <!-- Bottom Row: 4 Card Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card 1 (Blog) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-2xl overflow-hidden mb-3.5 border border-[#E2E8F0]/30">
            <img 
              src="https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=800&auto=format&fit=crop" 
              alt="E-Invoicing in France 2026" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#1D2939]/70 backdrop-blur-md text-white text-[11px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10 font-inter">
              Blog
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-[#0F172A] font-bold text-sm leading-snug group-hover:text-[#6355D8] transition-colors duration-200 line-clamp-3 font-manrope">
            E-Invoicing in France 2026: Timeline, Requirements, Guidelines & Format
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-4 text-[11px] text-[#667085] font-bold uppercase tracking-wider font-inter">
          <span>8 min read</span>
          <span class="text-[#6355D8] group-hover:text-[#4F41C9] transition-colors duration-200 flex items-center gap-1 font-extrabold normal-case">
            Read Blog ↗
          </span>
        </div>
      </a>

      <!-- Card 2 (Case Study) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-2xl overflow-hidden mb-3.5 border border-[#E2E8F0]/30">
            <img 
              src="https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=800&auto=format&fit=crop" 
              alt="Unified E-Invoicing for a Global Conglomerate" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#1D2939]/70 backdrop-blur-md text-white text-[11px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10 font-inter">
              Case Study
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-[#0F172A] font-bold text-sm leading-snug group-hover:text-[#6355D8] transition-colors duration-200 line-clamp-3 font-manrope">
            Unified E-Invoicing for a Global Conglomerate Spread Across 37 Countries
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-4 text-[11px] text-[#667085] font-bold uppercase tracking-wider font-inter">
          <span>8 min read</span>
        </div>
      </a>

      <!-- Card 3 (Whitepaper) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-2xl overflow-hidden mb-3.5 border border-[#E2E8F0]/30">
            <img 
              src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=800&auto=format&fit=crop" 
              alt="France e-Invoicing RFP template & checklist" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#1D2939]/70 backdrop-blur-md text-white text-[11px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10 font-inter">
              Whitepaper
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-[#0F172A] font-bold text-sm leading-snug group-hover:text-[#6355D8] transition-colors duration-200 line-clamp-3 font-manrope">
            France e-Invoicing RFP template & checklist: How to select the right PA for 2026
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-4 text-[11px] text-[#667085] font-bold uppercase tracking-wider font-inter">
          <span>8 min read</span>
        </div>
      </a>

      <!-- Card 4 (Whitepaper) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-2xl overflow-hidden mb-3.5 border border-[#E2E8F0]/30">
            <img 
              src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=800&auto=format&fit=crop" 
              alt="France 2026 e-invoicing mandate" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#1D2939]/70 backdrop-blur-md text-white text-[11px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10 font-inter">
              Whitepaper
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-[#0F172A] font-bold text-sm leading-snug group-hover:text-[#6355D8] transition-colors duration-200 line-clamp-3 font-manrope">
            France 2026 e-invoicing mandate: A complete compliance roadmap
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-4 text-[11px] text-[#667085] font-bold uppercase tracking-wider font-inter">
          <span>8 min read</span>
        </div>
      </a>
    </div>
  </div>
</section>
