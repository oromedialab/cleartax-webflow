---
// BlogPRArticles.astro
// PR Articles Section located below the Newsletter section on the Blog page.
---

<section class="bg-[#F3F1F9] py-25 px-6 md:px-8 text-left">
  <div class="max-w-[1280px] mx-auto premium-reveal">
    <!-- Header Title -->
    <h2 class="text-[26px] sm:text-[32px] lg:text-[44px] font-semibold text-black mb-12">
      PR Articles
    </h2>

    <!-- Top Row: Featured and Small PR items -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Left Column: Large Featured Card -->
      <a 
        href="#" 
        class="group relative flex flex-col justify-end overflow-hidden rounded-lg aspect-[16/10]"
      >
        <!-- Background Image -->
        <img 
          src="https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=800&auto=format&fit=crop" 
          alt="List of Approved & Pre-Approved e-Invoicing Providers in France" 
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
        />

        <!-- Semi-transparent bottom info bar -->
        <div class="relative w-full bg-white/20 backdrop-blur-xl p-6 md:p-8 flex flex-col justify-center">
          <h3 class="text-lg md:text-[26px] font-medium text-white leading-[1.14]">
            List of Approved & Pre-Approved e-Invoicing Providers in France (PA/PDP 2026)
          </h3>
        </div>
      </a>

      <!-- Right Column: List of Two Smaller Articles -->
      <div class="flex flex-col justify-between gap-8">
        <!-- Smaller Article 1 -->
        <a href="#" class="group flex gap-5 md:gap-7 items-start">
          <!-- White Square Left -->
          <div class="max-w-[220px] w-full max-h-[200px] h-full bg-white rounded-2xl flex-shrink-0 border border-[#E2E8F0] shadow-sm flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:border-[#6355D8]/30 group-hover:shadow-md">
            <svg class="w-10 h-10 text-[#98A2B3] group-hover:text-[#6355D8] transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 012 2v8a2 2 0 01-2 2h-3m-6 0h.01m-2-4h.01M9 16h.01M9 12h.01M7 12h.01M7 16h.01M7 8h10M7 12h10" />
            </svg>
          </div>
          <!-- Info Right -->
          <div class="flex flex-col">
            <h4 class="text-base md:text-lg font-medium text-black transition-colors duration-200">
              ClearTax GST achieves Built for NetSuite status
            </h4>
            <p class="text-base md:text-lg text-black/80 mt-3">
              ClearTax GST's SuiteApp supports e-invoicing and GST compliance within the Oracle NetSuite ecosystem.
            </p>
            <div class="text-base text-black/80 mt-5 flex items-center gap-3">
              <span>Press Release</span>
              <span class="text-black/80">|</span>
              <span>27 Sept, 2021</span>
            </div>
          </div>
        </a>

        <!-- Divider for mobile/tablet if needed, built-in spacing on desktop -->
        <div class="w-full h-px bg-[#E2E8F0] lg:hidden"></div>

        <!-- Smaller Article 2 -->
        <a href="#" class="group flex gap-5 md:gap-7 items-start">
          <!-- White Square Left -->
          <div class="max-w-[220px] w-full max-h-[200px] h-full bg-white rounded-2xl flex-shrink-0 border border-[#E2E8F0] shadow-sm flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:border-[#6355D8]/30 group-hover:shadow-md">
            <svg class="w-10 h-10 text-[#98A2B3] group-hover:text-[#6355D8] transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 012 2v8a2 2 0 01-2 2h-3m-6 0h.01m-2-4h.01M9 16h.01M9 12h.01M7 12h.01M7 16h.01M7 8h10M7 12h10" />
            </svg>
          </div>
          <!-- Info Right -->
          <div class="flex flex-col">
            <h4 class="text-base md:text-lg font-medium text-black transition-colors duration-200">
              ClearTax GST achieves Built for NetSuite status
            </h4>
            <p class="text-base md:text-lg text-black/80 mt-3">
              ClearTax GST’s SuiteApp supports e-invoicing and GST compliance within the Oracle NetSuite ecosystem.
            </p>
            <div class="text-base text-black/80 mt-5 flex items-center gap-3">
              <span>Press Release</span>
              <span class="text-black/80">|</span>
              <span>6 Jul, 2022</span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- Divider Line -->
    <div class="border-t border-black/20 my-12"></div>

    <!-- Bottom Row: 4 Card Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-7">
      <!-- Card 1 (Blog) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-xl overflow-hidden mb-5 border-none">
            <img 
              src="https://images.unsplash.com/photo-1639762681485-074b7f938ba0?q=80&w=800&auto=format&fit=crop" 
              alt="E-Invoicing in France 2026" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#3389791A] backdrop-blur-md text-[#F5F5F5] text-base font-normal px-3 py-2 rounded-lg border border-white/10">
              Blog
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-black font-medium text-lg leading-normal transition-colors duration-200 line-clamp-3">
            E-Invoicing in France 2026: Timeline, Requirements, Guidelines & Format
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-3 text-base text-black font-normal">
          <span>8 min read</span>
          <span class="text-black opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-1 group-hover:translate-x-0 flex items-center gap-1 font-normal">
            Read Blog ↗
          </span>
        </div>
      </a>

      <!-- Card 2 (Case Study) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-xl overflow-hidden mb-5 border-none">
            <img 
              src="https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?q=80&w=800&auto=format&fit=crop" 
              alt="Unified E-Invoicing for a Global Conglomerate" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#3389791A] backdrop-blur-md text-[#F5F5F5] text-base font-normal px-3 py-2 rounded-lg border border-white/10">
              Case Study
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-black font-medium text-lg leading-normal transition-colors duration-200 line-clamp-3">
            Unified E-Invoicing for a Global Conglomerate Spread Across 37 Countries
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-3 text-base text-black font-normal">
          <span>8 min read</span>
          <span class="text-black opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-1 group-hover:translate-x-0 flex items-center gap-1 font-normal">
            Read Case Study ↗
          </span>
        </div>
      </a>

      <!-- Card 3 (Whitepaper) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-xl overflow-hidden mb-5 border-none">
            <img 
              src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=800&auto=format&fit=crop" 
              alt="France e-Invoicing RFP template & checklist" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#3389791A] backdrop-blur-md text-[#F5F5F5] text-base font-normal px-3 py-2 rounded-lg border border-white/10">
              Whitepaper
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-black font-medium text-lg leading-normal transition-colors duration-200 line-clamp-3">
            France e-Invoicing RFP template & checklist: How to select the right PA for 2026
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-3 text-base text-black font-normal">
          <span>8 min read</span>
          <span class="text-black opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-1 group-hover:translate-x-0 flex items-center gap-1 font-normal">
            Read Whitepaper ↗
          </span>
        </div>
      </a>

      <!-- Card 4 (Whitepaper) -->
      <a href="#" class="group flex flex-col justify-between h-full">
        <div class="flex flex-col">
          <!-- Rounded Image with Overlay Badge -->
          <div class="relative aspect-[1.5] w-full rounded-xl overflow-hidden mb-5 border-none">
            <img 
              src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=800&auto=format&fit=crop" 
              alt="France 2026 e-invoicing mandate" 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
            <span class="absolute bottom-3 left-3 bg-[#3389791A] backdrop-blur-md text-[#F5F5F5] text-base font-normal px-3 py-2 rounded-lg border border-white/10">
              Whitepaper
            </span>
          </div>
          <!-- Title -->
          <h4 class="text-black font-medium text-lg leading-normal transition-colors duration-200 line-clamp-3">
            France 2026 e-invoicing mandate: A complete compliance roadmap
          </h4>
        </div>
        <!-- Footer -->
        <div class="flex justify-between items-center mt-3 text-base text-black font-normal">
          <span>8 min read</span>
          <span class="text-black opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-1 group-hover:translate-x-0 flex items-center gap-1 font-normal">
            Read Whitepaper ↗
          </span>
        </div>
      </a>
    </div>
  </div>
</section>
