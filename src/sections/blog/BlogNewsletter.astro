---
// BlogNewsletter.astro
---

<section class="relative overflow-hidden bg-[#070216] py-20 px-6 lg:px-8 border-t border-white/5 text-left">
  <!-- Glowing backgrounds -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(99,85,216,0.12),transparent_70%)] pointer-events-none"></div>
  <div class="absolute inset-0 opacity-15 bg-[radial-gradient(1px_1px_at_20px_30px,#fff,transparent),radial-gradient(1.5px_1.5px_at_60px_70px,#fff,transparent),radial-gradient(1px_1px_at_100px_110px,#fff,transparent),radial-gradient(1px_1px_at_140px_40px,#fff,transparent)] bg-[size:120px_120px] pointer-events-none"></div>

  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <!-- Left Column: Title & Excerpt -->
    <div class="lg:col-span-6 space-y-4">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight font-heading">
        Stay ahead of every<br/>compliance update
      </h2>
      <p class="text-[#A59FCF]/80 text-[14px] sm:text-[15px] leading-relaxed font-light max-w-md">
        Get expert insights, e-invoicing updates, and tax compliance guides delivered to your inbox.
      </p>
    </div>

    <!-- Right Column: Subscription Form -->
    <div class="lg:col-span-6 w-full max-w-lg lg:ml-auto">
      <form class="space-y-4" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
        <!-- Input Block -->
        <div class="space-y-2">
          <label for="newsletter-email" class="block text-xs font-semibold text-white tracking-wide">
            Your email address
          </label>
          <input 
            type="email" 
            id="newsletter-email"
            placeholder="i.e; johndoe@email.com" 
            required
            class="w-full px-4 py-3.5 bg-black/40 border border-white/10 hover:border-white/20 focus:border-[#6355D8] rounded-[10px] text-white placeholder-[#5C567A] focus:outline-none focus:ring-1 focus:ring-[#6355D8]/50 transition-all text-sm"
          />
        </div>

        <!-- Custom Checkbox Consent -->
        <div class="flex items-start gap-3">
          <div class="relative flex items-center mt-0.5 select-none">
            <input 
              type="checkbox" 
              id="newsletter-agree" 
              required
              class="peer opacity-0 absolute h-4 w-4 cursor-pointer z-10"
            />
            <div class="h-4 w-4 border border-white/20 rounded bg-transparent peer-checked:bg-[#6355D8] peer-checked:border-[#6355D8] flex items-center justify-center transition-all duration-200">
              <svg class="h-2.5 w-2.5 text-white scale-0 peer-checked:scale-100 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
          </div>
          <label for="newsletter-agree" class="text-[11px] leading-relaxed text-[#8E87B0] font-normal cursor-pointer select-none">
            I agree to ClearTax's <a href="#" class="underline text-slate-300 hover:text-white transition-colors">Privacy Policy</a> & <a href="#" class="underline text-slate-300 hover:text-white transition-colors">Terms of Service</a>. I consent to receiving communications about ClearTax products, compliance insights & e-invoicing updates.
          </label>
        </div>

        <!-- Subscribe Action Button -->
        <button 
          type="submit" 
          class="w-full py-3.5 bg-gradient-to-r from-[#1E0B91] to-[#724FAB] hover:from-[#2610B5] hover:to-[#815CC0] text-white font-semibold rounded-full transition-all duration-300 shadow-lg shadow-black/25 text-sm tracking-wide flex items-center justify-center"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
</section>

<style is:global>
  /* BlogNewsletter specific custom styles */
</style>
