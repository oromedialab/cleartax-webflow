---
// BlogNewsletter.astro
---

<section class="blog-newsletter-section relative overflow-hidden py-12 px-6 lg:px-8 text-left">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex max-md:flex-col max-md:gap-8 justify-between gap-12 items-center">
        <!-- Left Column: Title & Excerpt -->
        <div class="lg:col-span-6 max-w-[407px] w-full">
          <h2 class="blog-newsletter-title text-3xl sm:text-4xl font-medium leading-[1.18] font-heading mb-4" style="background: linear-gradient(99.83deg, #CC9DFF 0%, #FFFFFF 44.73%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            Stay ahead of every compliance update
          </h2>
          <p class="text-white text-base">
            Get expert insights, e-invoicing updates, and tax compliance guides delivered to your inbox.
          </p>
        </div>

        <!-- Right Column: Subscription Form -->
        <div class="lg:col-span-6 w-full max-w-lg lg:ml-auto">
          <form class="space-y-4" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
            <!-- Input Block -->
            <div class="">
              <label for="newsletter-email" class="block text-base text-white leading-normal mb-2">
                Your email address
              </label>
              <input 
                type="email" 
                id="newsletter-email"
                placeholder="i.e; johndoe@email.com" 
                required
                class="w-full px-4 py-3.5 bg-transparent border border-[#F5F5F5] hover:border-white/20 focus:border-[#6355D8] rounded-lg text-white placeholder-white/48 focus:outline-none focus:ring-1 focus:ring-[#6355D8]/50 transition-all text-base"
              />
            </div>

            <!-- Custom Checkbox Consent -->
            <div class="flex items-start gap-3 mt-7 mb-4">
              <div class="relative flex items-center mt-0.5 select-none">
                <input 
                  type="checkbox" 
                  id="newsletter-agree" 
                  required
                  class="peer opacity-0 absolute h-4 w-4 cursor-pointer z-10"
                />
                <div class="h-4 w-4 border border-white/20 rounded bg-transparent peer-checked:bg-[#6355D8] peer-checked:border-[#6355D8] flex items-center justify-center transition-all duration-200">
                  <svg class="h-2.5 w-2.5 text-white scale-0 peer-checked:scale-100 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <label for="newsletter-agree" class="text-xs text-white/50 font-normal cursor-pointer select-none">
                I agree to ClearTax's <a href="#" class="underline text-white/80 hover:text-white transition-colors">Privacy Policy</a> & <a href="#" class="underline text-slate-300 hover:text-white transition-colors">Terms of Service</a>. I consent to receiving communications about ClearTax products, compliance insights & e-invoicing updates.
              </label>
            </div>

            <!-- Subscribe Action Button -->
            <button 
              type="submit" 
              class="w-full py-2.5 border-none bg-gradient-to-r from-[#110072] to-[#7A5698] text-white cursor-pointer rounded-full transition-all duration-300 hover:-translate-y-0.5 text-base flex items-center justify-center"
            >
              Subscribe
            </button>
          </form>
        </div>
    </div>
  </div>
</section>

<style is:global>
  /* BlogNewsletter specific custom styles */
  .blog-newsletter-section {
    background: linear-gradient(180deg, #120420 0%, rgba(45, 10, 78, 0.2) 49.83%, #000000 100%), linear-gradient(0deg, #120420, #120420), linear-gradient(0deg, #FFFFFF, #FFFFFF);
  }

  .blog-newsletter-title {
    background: linear-gradient(99.83deg, #CC9DFF 0%, #FFFFFF 44.73%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
