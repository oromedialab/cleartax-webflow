<style is:global>
  /* BlogGrid smooth slide & fade filter transitions */
  .blog-card-wrapper {
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 1;
    transform: translateY(0) scale(1);
    display: block;
  }

  .blog-card-wrapper.filtered-out {
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    const searchInput = document.getElementById("blog-search-input");
    const selectTopic = document.getElementById("filter-topic");
    const selectCountry = document.getElementById("filter-country");
    const selectLanguage = document.getElementById("filter-language");
    const cards = document.querySelectorAll(".blog-card-wrapper");
    const loadMoreBtn = document.getElementById("load-more-btn");
    const loadMoreContainer = document.getElementById("load-more-container");

    if (cards.length === 0) return;

    let visibleLimit = 9;

    // Setup Custom Dropdowns
    const dropdownContainers = document.querySelectorAll(".custom-dropdown-container");
    dropdownContainers.forEach((container) => {
      const trigger = container.querySelector(".custom-dropdown-trigger");
      const menu = container.querySelector(".custom-dropdown-menu");
      const label = container.querySelector(".trigger-label");
      const nativeSelect = container.querySelector("select");
      const svgArrow = trigger.querySelector("svg");

      if (!trigger || !menu || !nativeSelect) return;

      // Toggle dropdown open state
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        
        // Close all other dropdowns
        document.querySelectorAll(".custom-dropdown-menu").forEach((otherMenu) => {
          if (otherMenu !== menu) {
            otherMenu.classList.add("hidden");
            otherMenu.classList.remove("flex", "flex-col", "opacity-100", "scale-100");
            otherMenu.previousElementSibling?.querySelector("svg")?.classList.remove("rotate-180");
          }
        });

        const isHidden = menu.classList.contains("hidden");
        if (isHidden) {
          menu.classList.remove("hidden");
          // Small delay to trigger animation
          requestAnimationFrame(() => {
            menu.classList.add("flex", "flex-col", "opacity-100", "scale-100");
          });
          svgArrow.classList.add("rotate-180");
        } else {
          menu.classList.remove("flex", "flex-col", "opacity-100", "scale-100");
          menu.classList.add("hidden");
          svgArrow.classList.remove("rotate-180");
        }
      });

      // Handle item click
      const items = menu.querySelectorAll(".dropdown-item");
      items.forEach((item) => {
        item.addEventListener("click", () => {
          const val = item.getAttribute("data-value") || "all";
          
          // Update trigger label: if reset/all selected, show default placeholder text
          const defaultLabels = {
            "filter-topic": "By Topic",
            "filter-country": "By Country",
            "filter-language": "By Language"
          };
          
          if (val === "all") {
            label.textContent = defaultLabels[nativeSelect.id];
          } else {
            label.textContent = item.textContent;
          }

          // Update hidden native select value and dispatch change event
          nativeSelect.value = val;
          nativeSelect.dispatchEvent(new Event("change"));

          // Close dropdown
          menu.classList.remove("flex", "flex-col", "opacity-100", "scale-100");
          menu.classList.add("hidden");
          svgArrow.classList.remove("rotate-180");
        });
      });
    });

    // Close dropdowns on outside click
    document.addEventListener("click", () => {
      document.querySelectorAll(".custom-dropdown-menu").forEach((menu) => {
        menu.classList.add("hidden");
        menu.classList.remove("flex", "flex-col", "opacity-100", "scale-100");
        menu.previousElementSibling?.querySelector("svg")?.classList.remove("rotate-180");
      });
    });

    function filterAndPaginate() {
      const query = searchInput ? searchInput.value.toLowerCase().trim() : "";
      const topic = selectTopic ? selectTopic.value : "all";
      const country = selectCountry ? selectCountry.value : "all";
      const language = selectLanguage ? selectLanguage.value : "all";

      let matchedCount = 0;

      cards.forEach((card) => {
        const cardTopic = card.getAttribute("data-topic");
        const cardCountry = card.getAttribute("data-country");
        const cardLanguage = card.getAttribute("data-language");
        const cardTitle = card.getAttribute("data-title") || "";

        const matchesQuery = query === "" || cardTitle.includes(query);
        const matchesTopic = topic === "all" || cardTopic === topic;
        const matchesCountry = country === "all" || cardCountry === country;
        const matchesLanguage = language === "all" || cardLanguage === language;

        if (matchesQuery && matchesTopic && matchesCountry && matchesLanguage) {
          matchedCount++;
          if (matchedCount <= visibleLimit) {
            card.style.display = "block";
            // Allow layout frame recalculation for opacity transition
            requestAnimationFrame(() => {
              card.classList.remove("filtered-out");
            });
          } else {
            card.classList.add("filtered-out");
            setTimeout(() => {
              if (card.classList.contains("filtered-out")) {
                card.style.display = "none";
              }
            }, 300);
          }
        } else {
          card.classList.add("filtered-out");
          setTimeout(() => {
            if (card.classList.contains("filtered-out")) {
              card.style.display = "none";
            }
          }, 300);
        }
      });

      // Show/hide Load More button based on pagination matches
      if (loadMoreContainer) {
        if (matchedCount > visibleLimit) {
          loadMoreContainer.style.display = "flex";
        } else {
          loadMoreContainer.style.display = "none";
        }
      }
    }

    // Event Listeners
    if (searchInput) searchInput.addEventListener("input", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectTopic) selectTopic.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectCountry) selectCountry.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectLanguage) selectLanguage.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        visibleLimit += 9;
        filterAndPaginate();
      });
    }

    // Initial load pagination
    filterAndPaginate();
  })();
</script>
