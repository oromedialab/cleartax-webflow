  <!-- Unified Borderless Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7 blog-posts-grid">
    {posts.map((post) => (
      <div 
        class="blog-card-wrapper group cursor-pointer"
        data-topic={post.topic}
        data-country={post.country}
        data-language={post.language}
