<section class="py-16 px-6 lg:px-8 max-w-[1200px] mx-auto">
  <!-- Search & Filter Bar -->
  <div class="flex flex-col md:flex-row items-center justify-between gap-4 mb-10 pb-6 border-b border-gray-100">
    <!-- Left: Search Pill Input -->
    <div class="relative w-full md:w-80">
      <span class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-slate-400">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </span>
      <input 
        type="text" 
        id="blog-search-input"
        placeholder="Search anything here..." 
        class="w-full pl-10 pr-4 py-2.5 rounded-full bg-[#F1F5F9] border-none outline-none text-sm text-slate-800 placeholder-slate-400 focus:bg-white focus:ring-1 focus:ring-[#6355D8]/20 transition-all border border-transparent focus:border-[#6355D8]/30"
      />
    </div>

    <!-- Right: Dropdown Controls -->
    <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
      <!-- By Topic -->
      <div class="relative min-w-[120px]">
        <select id="filter-topic" class="appearance-none w-full bg-white border border-slate-200 hover:border-slate-300 rounded-full px-4 py-2.5 pr-8 text-xs font-semibold text-[#0F172A] outline-none cursor-pointer transition-colors">
          <option value="all">By Topic</option>
          <option value="e-invoicing">E-Invoicing</option>
          <option value="compliance">Compliance</option>
          <option value="tax-tech">Tax Tech</option>
          <option value="guides">Guides</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-500">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>

      <!-- By Country -->
      <div class="relative min-w-[120px]">
        <select id="filter-country" class="appearance-none w-full bg-white border border-slate-200 hover:border-slate-300 rounded-full px-4 py-2.5 pr-8 text-xs font-semibold text-[#0F172A] outline-none cursor-pointer transition-colors">
          <option value="all">By Country</option>
          <option value="france">France</option>
          <option value="germany">Germany</option>
          <option value="malaysia">Malaysia</option>
          <option value="uae">UAE</option>
          <option value="saudi-arabia">Saudi Arabia</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-500">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>

      <!-- By Language -->
      <div class="relative min-w-[120px]">
        <select id="filter-language" class="appearance-none w-full bg-white border border-slate-200 hover:border-slate-300 rounded-full px-4 py-2.5 pr-8 text-xs font-semibold text-[#0F172A] outline-none cursor-pointer transition-colors">
          <option value="all">By Language</option>
          <option value="english">English</option>
          <option value="french">French</option>
          <option value="german">German</option>
          <option value="arabic">Arabic</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center pr-3.5 pointer-events-none text-slate-500">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Unified Borderless Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 blog-posts-grid">
    {posts.map((post) => (
      <div 
        class="blog-card-wrapper group cursor-pointer"
        data-topic={post.topic}
        data-country={post.country}
        data-language={post.language}
        data-title={post.title.toLowerCase()}
      >
        <article class="flex flex-col text-left">
          <!-- Card Image & Overlay badge -->
          <div class="relative aspect-[16/10] w-full overflow-hidden rounded-[12px] bg-slate-100">
            <img 
              src={post.image} 
              alt={post.title} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-103"
              loading="lazy"
            />
            <span class="absolute bottom-3 left-3 bg-black/40 backdrop-blur-sm text-white text-[10px] font-bold px-2.5 py-0.7 rounded uppercase tracking-wider">
              Blog
            </span>
          </div>

          <!-- Card Content -->
          <h3 class="text-[15px] sm:text-[16px] font-bold text-[#171E28] leading-snug tracking-tight line-clamp-2 mt-4 group-hover:text-[#6355D8] transition-colors duration-300">
            {post.title}
          </h3>

          <!-- Card Footer -->
          <div class="flex items-center justify-between mt-4">
            <div class="flex items-center gap-2">
              <img src={post.authorAvatar} alt={post.authorName} class="w-6 h-6 rounded-full object-cover" />
              <span class="text-xs text-[#64748B] font-semibold">{post.authorName}</span>
            </div>

            <span class="read-blog-btn inline-flex items-center gap-1 text-xs font-bold text-[#6355D8] opacity-0 translate-x-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
              Read Blog
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </span>
          </div>
        </article>
      </div>
    ))}
  </div>

  <!-- Load More Button -->
  <div class="flex justify-center mt-14" id="load-more-container">
    <button 
      id="load-more-btn"
      class="px-7 py-3 rounded-full border border-slate-200 text-slate-700 font-bold text-xs hover:border-[#6355D8] hover:text-[#6355D8] bg-white transition-all duration-300 hover:shadow-sm"
    >
      Load More
    </button>
  </div>
</section>

<style is:global>
  /* BlogGrid smooth slide & fade filter transitions */
  .blog-card-wrapper {
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 1;
    transform: translateY(0) scale(1);
    display: block;
  }

  .blog-card-wrapper.filtered-out {
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    const searchInput = document.getElementById("blog-search-input");
    const selectTopic = document.getElementById("filter-topic");
    const selectCountry = document.getElementById("filter-country");
    const selectLanguage = document.getElementById("filter-language");
    const cards = document.querySelectorAll(".blog-card-wrapper");
    const loadMoreBtn = document.getElementById("load-more-btn");
    const loadMoreContainer = document.getElementById("load-more-container");

    if (cards.length === 0) return;

    let visibleLimit = 9;

    function filterAndPaginate() {
      const query = searchInput ? searchInput.value.toLowerCase().trim() : "";
      const topic = selectTopic ? selectTopic.value : "all";
      const country = selectCountry ? selectCountry.value : "all";
      const language = selectLanguage ? selectLanguage.value : "all";

      let matchedCount = 0;

      cards.forEach((card) => {
        const cardTopic = card.getAttribute("data-topic");
        const cardCountry = card.getAttribute("data-country");
        const cardLanguage = card.getAttribute("data-language");
        const cardTitle = card.getAttribute("data-title") || "";

        const matchesQuery = query === "" || cardTitle.includes(query);
        const matchesTopic = topic === "all" || cardTopic === topic;
        const matchesCountry = country === "all" || cardCountry === country;
        const matchesLanguage = language === "all" || cardLanguage === language;

        if (matchesQuery && matchesTopic && matchesCountry && matchesLanguage) {
          matchedCount++;
          if (matchedCount <= visibleLimit) {
            card.style.display = "block";
            // Allow layout frame recalculation for opacity transition
            requestAnimationFrame(() => {
              card.classList.remove("filtered-out");
            });
          } else {
            card.classList.add("filtered-out");
            setTimeout(() => {
              if (card.classList.contains("filtered-out")) {
                card.style.display = "none";
              }
            }, 300);
          }
        } else {
          card.classList.add("filtered-out");
          setTimeout(() => {
            if (card.classList.contains("filtered-out")) {
              card.style.display = "none";
            }
          }, 300);
        }
      });

      // Show/hide Load More button based on pagination matches
      if (loadMoreContainer) {
        if (matchedCount > visibleLimit) {
          loadMoreContainer.style.display = "flex";
        } else {
          loadMoreContainer.style.display = "none";
        }
      }
    }

    // Event Listeners
    if (searchInput) searchInput.addEventListener("input", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectTopic) selectTopic.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectCountry) selectCountry.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });
    if (selectLanguage) selectLanguage.addEventListener("change", () => {
      visibleLimit = 9;
      filterAndPaginate();
    });

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        visibleLimit += 9;
        filterAndPaginate();
      });
    }

    // Initial load pagination
    filterAndPaginate();
  })();
</script>
