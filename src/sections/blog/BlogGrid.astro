              <g clip-path="url(#clip0_205_18964)">
              <path d="M15.609 9.18629L7.2135 17.5818L5.83398 16.2023L14.2295 7.80677H6.82977V5.85583H17.56V16.5861H15.609V9.18629Z" fill="#0E74FB"/>
