                      <path d="M60 10 L103 35 L103 85 L60 110 L17 85 L17 35 Z" fill="url(#crystalGrad)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
                      <path d="M60 20 L94 40 L94 80 L60 100 L26 80 L26 40 Z" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
                      <defs>
                        <linearGradient id="crystalGrad" x1="17" y1="10" x2="103" y2="110" gradientUnits="userSpaceOnUse">
                          <stop offset="0%" stop-color="#C084FC" stop-opacity="0.7" />
                          <stop offset="35%" stop-color="#818CF8" stop-opacity="0.6" />
                          <stop offset="70%" stop-color="#38BDF8" stop-opacity="0.5" />
                          <stop offset="100%" stop-color="#F43F5E" stop-opacity="0.7" />
                        </linearGradient>
                      </defs>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
