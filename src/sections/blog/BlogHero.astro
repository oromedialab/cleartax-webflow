---
// BlogHero.astro
// Swiper Featured Blog Carousel Hero Section (UI Initiative Custom Carousel Slider Layout)
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>

<section class="blog-hero-section bg-gradient-to-b from-[#F8FAFC] to-white pt-16 pb-20 px-4 md:px-6 overflow-hidden border-b border-[#E2E8F0] text-gray-900">
  <!-- Centered Header -->
  <div class="max-w-[1200px] mx-auto text-center mb-12 premium-reveal">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold font-heading text-[#171E28] leading-tight mb-4">
      Explore E-Invoicing <span class="text-[#6355D8]">Blogs And Insights</span>
    </h1>
    <p class="text-gray-500 max-w-2xl mx-auto text-sm sm:text-base font-light leading-relaxed">
      Read the latest Blogs, expert insights, mandate updates, and practical guides for staying compliant across global markets.
    </p>
  </div>

  <!-- Swiper Outer Wrapper -->
  <div class="blog-hero-swiper-outer w-full max-w-[1200px] mx-auto relative premium-reveal" style="transition-delay: 150ms;">
    <!-- Swiper Container -->
    <div class="swiper blog-hero-swiper">
      <div class="swiper-wrapper">
        <!-- Slide 1 (UAE) -->
        <div class="swiper-slide select-none">
          <div class="swiper-carousel-animate-opacity w-full h-full">
            <div class="featured-card w-full h-full bg-white rounded-2xl overflow-hidden border border-[#E2E8F0] shadow-sm relative group">
              <!-- Full bleed background image -->
              <img 
                src="https://images.unsplash.com/photo-1582407947304-fd86f028f716?q=80&w=1200&auto=format&fit=crop" 
                alt="UAE E-Invoicing" 
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <!-- White-to-transparent gradient fade from the left -->
              <div class="absolute inset-0 bg-gradient-to-r from-white via-white/95 via-white/80 to-transparent z-10"></div>
              
              <!-- Content Overlay (Top-level z-index) -->
              <div class="absolute inset-0 z-20 flex flex-col md:flex-row w-full h-full">
                <!-- Left panel with text content -->
                <div class="w-full md:w-[48%] p-8 md:p-10 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-4">
                    <span class="px-2.5 py-1 bg-[#6355D8]/10 text-[#6355D8] text-[10px] font-bold uppercase tracking-wider rounded-md">
                      E-Invoicing
                    </span>
                    <span class="text-xs text-gray-700 font-semibold">By Rajan Rauniyar</span>
                    <span class="text-gray-400 font-light text-xs">&bull;</span>
                    <span class="text-xs text-gray-700 font-semibold flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 text-[#6355D8]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      32 Minutes
                    </span>
                  </div>
                  <h2 class="text-xl sm:text-2xl md:text-3xl font-extrabold font-heading text-[#171E28] leading-tight mb-4 group-hover:text-[#6355D8] transition-colors">
                    UAE E-Invoicing: Requirements, Timeline & Updates
                  </h2>
                  <p class="text-gray-600 text-sm font-light leading-relaxed mb-6 hidden md:block">
                    Complete roadmap of the upcoming UAE e-invoicing mandate. Learn about the requirements, Phase 1 timeline, technical guidelines, and how to prepare.
                  </p>
                  <div>
                    <a href="#" class="inline-flex items-center gap-2 text-sm font-bold text-[#6355D8] hover:text-[#4F46E5] transition-colors group/btn">
                      Read Article
                      <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
                <!-- Right space for image visibility -->
                <div class="hidden md:block w-full md:w-[52%] relative">
                  <!-- Crystal hexagon overlay -->
