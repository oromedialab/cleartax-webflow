---
/**
 * Comparison Section
 * 4-column capability comparison: Capability | ERP Native | Desktop Tool | ClearTax Seamless
 * Column titles sit OUTSIDE the cards; only the row data is wrapped in the grey/white cards.
 */
interface Row {
    capability: string;
    erp: string;
    desktop: string;
    clear: string;
    erpCross?: boolean;
    desktopCross?: boolean;
}

const rows: Row[] = [
    {
        capability: "Trial Balance & GL Reconciliation",
        erp: "Not For TDS",
        erpCross: true,
        desktop: "",
        desktopCross: true,
        clear: "Automated",
    },
    {
        capability: "Net-Off Advances, Provisions, Reversals",
        erp: "Manual",
        desktop: "Manual Excel",
        clear: "Auto",
    },
    {
        capability: "200+ Pre-Filing Validations",
        erp: "",
        erpCross: true,
        desktop: "Partial",
        clear: "",
    },
    {
        capability: "FVU For 5M+ Deductions",
        erp: "",
        erpCross: true,
        desktop: "Crashes",
        desktopCross: true,
        clear: "30 Mins",
    },
    {
        capability: "26AS Many:Many Reconciliation",
        erp: "",
        erpCross: true,
        desktop: "",
        desktopCross: true,
        clear: "Best-Fit AI",
    },
    {
        capability: "AI Section Variance Detection",
        erp: "",
        erpCross: true,
        desktop: "",
        desktopCross: true,
        clear: "Clause 34",
    },
    {
        capability: "Cloud-Based, No Crashes",
        erp: "N/A",
        desktop: "",
        desktopCross: true,
        clear: "99.9% Uptime",
    },
];

const CrossIcon = "/images/clear-compliance-cloud/x.png";

const CheckIcon = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 9.9339C20 15.4202 15.5228 19.8677 10 19.8677C4.47716 19.8677 0 15.4202 0 9.9339C0 4.44763 4.47716 0.00012207 10 0.00012207C15.5228 0.00012207 20 4.44763 20 9.9339Z" fill="#655DFF"/><path d="M14.198 7.1111L8.51264 12.7588L5.80615 10.0703" stroke="white" stroke-width="1.66667" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<section id="comparison-comp" class="bg-white py-12 pb-0 lg:py-[100px] w-full">
    <div class="max-w-[var(--container-max)] mx-auto px-4 lg:px-6">
        <!-- Centered header -->
        <div class="text-center mb-12">
            <h2
                id="comparison-comp-title"
                class="!font-semibold text-[#000000] !leading-[1.18] !m-0 max-md:text-[28px] max-lg:text-[26px] text-[44px]"
            >
                Not An ERP Module.
                <span class="text-[#655DFF]">Not A Desktop Tool.</span>
            </h2>
            <p
                class="text-[#000000]/80 text-lg max-md:text-base leading-[1.44] max-w-[774px] mx-auto mt-4 lg:mt-6"
            >
                Every step from ERP data extraction to government filing and
                audit readiness — one platform.
            </p>
        </div>

        <!-- Desktop View (Hidden on mobile) -->
        <div class="hidden lg:block">
            <div class="grid grid-cols-[1.2fr_3.1fr] items-start gap-0">
                <!-- Column 1: Capability (no card) -->
                <div class="flex flex-col min-w-0">
                    <h3
                        class="text-[22px] font-medium leading-[1.3] text-black mb-6 flex flex-col justify-start gap-1 min-h-[48px]"
                    >
                        Capability
                    </h3>
                    <ul class="list-none m-0 p-0 flex flex-col">
                        {
                            rows.map((row) => (
                                <li class="text-[16px] leading-[1.4] text-black h-[55px] flex items-center border-b border-black/16 last:border-0 font-medium">
                                    {row.capability}
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <!-- Column 2: Combined ERP, Desktop & ClearTax Grid -->
                <div class="flex flex-col min-w-0">
                    <!-- Unified Header Grid -->
                    <div class="grid grid-cols-[2fr_1.1fr] items-start gap-0">
                        <div class="grid grid-cols-2 gap-8 px-8">
                            <h3
                                class="text-lg font-medium leading-[1.3] text-black mb-4 flex flex-col justify-start gap-1 min-h-[48px] text-left items-start"
                            >
                                ERP Native
                                <span
                                    class="text-base font-normal text-black/70"
                                    >SAP / Oracle</span
                                >
                            </h3>
                            <h3
                                class="text-lg font-medium leading-[1.3] text-black mb-4 flex flex-col justify-start gap-1 min-h-[48px] text-left items-start"
                            >
                                Desktop Tool
                                <span
                                    class="text-base font-normal text-black/70"
                                    >Winman / KDK</span
                                >
                            </h3>
                        </div>
                        <h3
                            class="text-[22px] font-medium leading-[1.3] text-black mb-5 block min-h-[48px] pl-8"
                        >
                            ClearTax <span class="text-[#655DFF]">Seamless</span
                            >
                        </h3>
                    </div>

                    <div
                        class="bg-[#f4f2f9] rounded-[16px] border border-black/16 relative z-[1] lg:shadow-[inset_0_4px_8px_rgba(0,0,0,0.08)] box-shadow-[0px_2px_6px_rgba(0,0,0,0.08)] grid grid-cols-[2fr_1.1fr] items-stretch gap-0 py-[2px] pr-[2px]"
                    >
                        <!-- Left side: ERP Native + Desktop Tool -->
                        <ul class="list-none m-0 p-0 flex flex-col">
                            {
                                rows.map((row) => (
                                    <li class="grid grid-cols-2 border-b border-[#000000]/10 last:border-0">
                                        <div class="py-[16px] px-8 flex items-center gap-[10px] h-[55px] text-base leading-[1.4] text-black/80">
                                            {row.erpCross && (
                                                <img
                                                    src={CrossIcon}
                                                    alt="X"
                                                    class="w-3.5 h-3.5"
                                                />
                                            )}
                                            {row.erp && <span>{row.erp}</span>}
                                        </div>
                                        <div class="py-[16px] px-8 flex items-center gap-[10px] h-[55px] text-base leading-[1.4] text-black/80">
                                            {row.desktopCross && (
                                                <img
                                                    src={CrossIcon}
                                                    alt="X"
                                                    class="w-3.5 h-3.5"
                                                />
                                            )}
                                            {row.desktop && (
                                                <span>{row.desktop}</span>
                                            )}
                                        </div>
                                    </li>
                                ))
                            }
                        </ul>

                        <!-- White Card: ClearTax Seamless -->
                        <div
                            class="bg-white rounded-[16px] shadow-[0_24px_60px_rgba(15,17,49,0.08),0_4px_14px_rgba(15,17,49,0.04)] relative z-[2] overflow-hidden"
                        >
                            <ul class="list-none m-0 p-0 flex flex-col">
                                {
                                    rows.map((row) => (
                                        <li class="border-b border-black/16 last:border-0">
                                            <div class="py-[16px] px-8 lg:text-lg h-[55px] flex items-center gap-3 text-black font-medium leading-[1.4]">
                                                <span
                                                    class="inline-flex items-center justify-center shrink-0"
                                                    set:html={CheckIcon}
                                                />
                                                {row.clear && (
                                                    <span>{row.clear}</span>
                                                )}
                                            </div>
                                        </li>
                                    ))
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mobile View (Hidden on desktop) -->
        <div
            class="lg:hidden group"
            id="comparison-mobile-container"
            data-active-tab="clear"
        >
            <!-- Mobile Tabs -->
            <div class="mb-8 flex justify-center">
                <div
                    class="flex p-1 rounded-full gap-1 border border-black/[0.08]"
                >
                    <button
                        class="cmp-tab-btn border-none bg-transparent py-2 px-4 rounded-full text-[13px] font-semibold text-black/40 cursor-pointer transition-all duration-300 data-[active=true]:bg-[#110072]/20 data-[active=true]:text-[#110072]"
                        data-tab="erp">ERP Native</button
                    >
                    <button
                        class="cmp-tab-btn border-none bg-transparent py-2 px-4 rounded-full text-[13px] font-semibold text-black/40 cursor-pointer transition-all duration-300 data-[active=true]:bg-[#110072]/20 data-[active=true]:text-[#110072]"
                        data-tab="desktop">Desktop Tool</button
                    >
                    <button
                        class="cmp-tab-btn border-none bg-transparent py-2 px-4 rounded-full text-[13px] font-semibold text-black/40 cursor-pointer transition-all duration-300 data-[active=true]:bg-[#110072]/20 data-[active=true]:text-[#110072]"
                        data-tab="clear"
                        data-active="true">ClearTax Seamless</button
                    >
                </div>
            </div>

            <div class="grid grid-cols-2 bg-[#F4F2F9] -mx-4 px-4 py-7 gap-0">
                <!-- Column 1: Capability -->
                <div class="flex flex-col min-w-0">
                    <h3
                        class="text-[16px] font-semibold mb-3 flex flex-col justify-center min-h-[40px] px-2 text-center items-center"
                    >
                        Capability
                    </h3>
                    <ul class="list-none m-0 p-0 flex flex-col">
                        {
                            rows.map((row) => (
                                <li class="p-3 text-[16px] min-h-[64px] flex items-center border-b border-black/5 last:border-0 pr-0">
                                    {row.capability}
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <!-- Column 2: The Comparison Data (Toggled by JS) -->
                <div class="flex flex-col min-w-0">
                    <!-- ERP Native Header -->
                    <div class="hidden group-data-[active-tab=erp]:block">
                        <h3
                            class="text-[16px] font-medium mb-3 flex flex-col justify-center min-h-[40px] px-2 text-center items-center"
                        >
                            ERP Native
                            <span class="text-sm font-normal text-black/50"
                                >SAP / Oracle</span
                            >
                        </h3>
                    </div>
                    <!-- Desktop Tool Header -->
                    <div class="hidden group-data-[active-tab=desktop]:block">
                        <h3
                            class="text-[16px] font-medium mb-3 flex flex-col justify-center min-h-[40px] px-2 text-center items-center"
                        >
                            Desktop Tool
                            <span class="text-sm font-normal text-black/50"
                                >Winman / KDK</span
                            >
                        </h3>
                    </div>
                    <!-- ClearTax Header -->
                    <div class="hidden group-data-[active-tab=clear]:block">
                        <h3
                            class="text-[16px] font-medium mb-3 flex flex-col justify-center min-h-[40px] px-2 text-center items-center"
                        >
                            ClearTax <span class="text-[#655DFF]">Seamless</span
                            >
                        </h3>
                    </div>

                    <!-- Comparison Card -->
                    <div class="relative">
                        <!-- Grey Card (ERP/Desktop) -->
                        <div
                            class="hidden group-data-[active-tab=erp]:block group-data-[active-tab=desktop]:block bg-[#FFFFFF] rounded-[12px] border border-[#000000]/16 relative z-[1]"
                        >
                            <ul class="list-none m-0 p-0 flex flex-col">
                                {
                                    rows.map((row) => (
                                        <li class="min-h-[64px] border-b border-[#000000]/16 last:border-0 grid grid-cols-1">
                                            <div class="hidden group-data-[active-tab=erp]:flex p-3 text-[13px] items-center gap-[10px] text-black/80 justify-start">
                                                {row.erpCross && (
                                                    <img
                                                        src={CrossIcon}
                                                        alt="X"
                                                        class="w-3.5 h-3.5"
                                                    />
                                                )}
                                                {row.erp && (
                                                    <span>{row.erp}</span>
                                                )}
                                            </div>
                                            <div class="hidden group-data-[active-tab=desktop]:flex p-3 text-[13px] items-center gap-[10px] text-black/80 justify-start">
                                                {row.desktopCross && (
                                                    <img
                                                        src={CrossIcon}
                                                        alt="X"
                                                        class="w-3.5 h-3.5"
                                                    />
                                                )}
                                                {row.desktop && (
                                                    <span>{row.desktop}</span>
                                                )}
                                            </div>
                                        </li>
                                    ))
                                }
                            </ul>
                        </div>
                        <!-- White Card (ClearTax) -->
                        <div
                            class="hidden group-data-[active-tab=clear]:block bg-[#F4F2F9] rounded-[12px] py-1 border border-[#000000]/16 relative z-[2]"
                        >
                            <ul class="list-none m-0 p-0 flex flex-col">
                                {
                                    rows.map((row) => (
                                        <li class="min-h-[64px] border-b border-[#000000]/10 last:border-0">
                                            <div class="p-3 text-[16px] font-medium flex items-center gap-3 text-black justify-start">
                                                <span
                                                    class="inline-flex items-center justify-center shrink-0"
                                                    set:html={CheckIcon}
                                                />
                                                {row.clear && (
                                                    <span>{row.clear}</span>
                                                )}
                                            </div>
                                        </li>
                                    ))
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function initComparisonTabs() {
        const grid = document.getElementById("comparison-mobile-container");
        const tabBtns = document.querySelectorAll(".cmp-tab-btn");

        if (!grid || !tabBtns.length) return;

        tabBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const tabId = btn.getAttribute("data-tab");
                if (tabId) {
                    tabBtns.forEach((b) => {
                        b.classList.remove("active");
                        b.removeAttribute("data-active");
                    });
                    btn.classList.add("active");
                    btn.setAttribute("data-active", "true");
                    grid.setAttribute("data-active-tab", tabId);
                }
            });
        });
    }

    initComparisonTabs();
    document.addEventListener("astro:after-swap", initComparisonTabs);
</script>
