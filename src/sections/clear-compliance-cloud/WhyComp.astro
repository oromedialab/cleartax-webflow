---
/**
 * USP Section V2 — Tailwind optimized
 * Content/layout updated to match provided design while preserving tilt script hooks.
 */
interface GridCard {
    title: string;
    description: string;
    cardClass: string;
    panelBg: string;
    iconBg: string;
    colSpan: number;
    rowSpan?: number;
    bodyClass?: string;
    textWrapClass?: string;
}

const cards: GridCard[] = [
    {
        title: "GL-Stream data ingestion",
        description:
            "Import raw GL data from SAP, Oracle, Dynamics 365, and other ERPs. Verify it against trial balance before filing begins.",
        cardClass: "col-span-6 max-lg:col-span-12",
        panelBg: "#FDF2ED",
        textWrapClass: "max-w-[95%]",
        iconBg: "rgba(229, 172, 130, 0.2)",
        colSpan: 6,
    },
    {
        title: "TDS filing & FVU generation",
        description:
            "Auto net-off advances, provisions, and reversals. Run 200+ validations and generate FVU files for large-volume deductions.",
        cardClass: "col-span-6 max-lg:col-span-12",
        panelBg: "#EDEBFA",
        textWrapClass: "max-w-[95%]",
        iconBg: "rgba(101, 93, 255, 0.2)",
        colSpan: 6,
    },
    {
        title: "TDS certificate distribution",
        description:
            "Generate, digitally sign, and email Form 16A certificates to deductees in bulk, reducing manual work and vendor follow-ups.",
        cardClass: "col-span-4 max-lg:col-span-12",
        panelBg: "#ECF7ED",
        iconBg: "rgba(51, 136, 120, 0.2)",
        colSpan: 4,
    },
    {
        title: "26AS reconciliation",
        description:
            "Match internal records with Form 26AS using Many:Many, Best-Fit, Cross-FY, and PAN-TAN mapping logic.",
        cardClass: "col-span-4 max-lg:col-span-12",
        panelBg: "#FDF2ED",
        iconBg: "rgba(19, 133, 159, 0.2)",
        colSpan: 4,
    },
    {
        title: "Notice prevention",
        description:
            "Flag short deductions, inactive PANs, exhausted LDC limits, and other risks before filing to avoid future TDS notices.",
        cardClass: "col-span-4 row-span-2 max-lg:col-span-12",
        panelBg: "#EBF4FE",
        iconBg: "rgba(31, 137, 255, 0.2)",
        bodyClass: "mt-auto",
        colSpan: 4,
        rowSpan: 2,
    },
    {
        title: "Expense rationalisation",
        description:
            "AI checks vendor details and expense descriptions to detect section variance, rate mismatch, and missed deductions before filing.",
        cardClass: "col-span-8 max-lg:col-span-12",
        panelBg: "rgba(216, 239, 242, 0.6)",
        textWrapClass: "max-w-[95%]",
        iconBg: "rgba(59, 162, 176, 0.2)",
        colSpan: 8,
    },
];
---

<style is:global>
    .why-grid-container {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        grid-auto-flow: dense;
    }
    @media (max-width: 1024px) {
        .why-grid-container {
            grid-template-columns: 1fr;
        }
        .tilted-card {
            grid-column: span 1 / span 1 !important;
            grid-row: span 1 / span 1 !important;
        }
    }
</style>

<section
    id="why-comp"
    class="bg-gradient-to-r from-[#F3F1F9] to-[#FFFFFF] py-12 lg:py-[100px] w-full"
>
    <div class="max-w-[var(--container-max)] mx-auto px-4 lg:px-6">
        <div class="why-header-split mb-12">
            <h2
                id="why-comp-title"
                class="!lg:text-[44px] !font-semibold text-[#000000] !leading-[1.18] max-w-[450px] !m-0 max-md:text-[32px] max-lg:text-[26px]"
            >
                Everything You Need <br class="md:hidden" /> For
                <span class="text-[#655DFF]">TDS Compliance</span>
            </h2>
            <p
                class="text-[#000000]/80 text-lg max-md:text-base leading-[1.44] max-w-[360px] lg:mt-0 mt-6"
