---
const ctaContent = {
  bgImage:
    "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0811981dbdc952efdf9221_bg.png",
  title: "The government has AI. <br />Now your tax team does too.",
  description:
    "Automated notices. Tightening audits. Zero tolerance for short deductions. CCC Direct Tax gives your team the same data-driven edge — before the next demand lands.",
  buttons: [
    {
      label: "Start free trail",
      href: "#get started",
      variant: "primary",
      class: "bg-[linear-gradient(90deg,_#110072_0%,_#7A5698_100%)]",
    },
    {
      label: "Talk to sales",
      href: "#talk-to-sales",
      variant: "outline",
      class: "btn-gradient-border",
    },
  ],
  globeImage:
    "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0810cc1dbdc952efdf8a15_globe.png",
};
---

<section class="max-md:py-12 md:max-lg:py-16 lg:py-25 bg-offwhite2">
  <div class="mx-auto max-w-[1240px] px-4 w-full">
    <div
      class="rounded-xl p-10 md:max-lg:p-12 lg:p-16 relative w-full overflow-hidden bg-cover bg-center min-h-[400px] flex flex-col justify-center bg-[url('https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0811981dbdc952efdf9221_bg.png')]"
    >
      <div class="flex max-lg:flex-col justify-between gap-y-6">
        <div class="">
          <h2
            class="max-w-129 w-full text-2xl md:max-lg:text-3xl lg:text-4xl font-medium leading-[1.1] font-nohemi inline-block bg-[linear-gradient(99.83deg,_#CC9DFF_0%,_#FFFFFF_44.73%)] bg-clip-text text-transparent"
            set:html={ctaContent.title}
          />
          <p
            class="font-gilroy text-base md:text-lg text-[#FFFFFF]/80 max-w-[460px] w-full mt-4"
          >
            {ctaContent.description}
          </p>
        </div>
        <div
          class="flex flex-wrap gap-6 xl:gap-7 w-fit items-start justify-center"
        >
          {
            ctaContent.buttons.map((btn) => (
              <div class="flex lg:gap-6 gap-3 flex-wrap premium-reveal [transition-delay:500ms] relative z-10">
                <a
                  href={btn.href}
                  class={`lg:py-4 lg:px-10 py-3 sm:w-fit px-10 rounded-full text-white text-sm lg:text-base font-normal inline-flex justify-center items-center gap-2 transition-all duration-250 hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(99,85,216,0.45)] no-underline ${btn.class}`}
                >
                  {btn.variant === "primary" ? (
                    <span class="relative z-10 flex items-center gap-2 text-[#FFFFFF]/80">
                      {btn.label}
                    </span>
                  ) : (
                    btn.label
                  )}
                </a>
              </div>
            ))
          }
        </div>
      </div>
      <div
        class="absolute right-0 bottom-[-3%] max-w-230.5 w-full aspect-586/159 pointer-events-none"
      >
        <img
          src={ctaContent.globeImage}
          alt="globe"
          class="w-full h-full object-contain"
        />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .btn-gradient-border {
    position: relative;
    color: white !important;
  }
  .btn-gradient-border::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    padding: 1.5px;
    background: linear-gradient(90deg, #140373 0%, #765397 100%);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
</style>
