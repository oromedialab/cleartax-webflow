---
/**
 * Comparison Table component showing the difference between ClearTax and Typical Integration.
 */
const comparisonData = [
  {
    moment: "Government Updates Compliance Rules",
    cleartax: "Zero IT Work",
    typical: "IT Re-Engages Or Rewrites Logic"
  },
  {
    moment: "Expanding To A New Country",
    cleartax: "Configuration Only",
    typical: "Re-Integration Or Full Rebuild"
  },
  {
    moment: "Adding Another ClearTax Product",
    cleartax: "Instant",
    typical: "Extra Effort Or Not Possible"
  },
  {
    moment: "Internal IT Approvals Over Time",
    cleartax: "First Install Only",
    typical: "20+ Initially, Recurring Each Quarter"
  },
  {
    moment: "Ongoing ERP Changes After Go-Live",
    cleartax: "Handled By ClearTax",
    typical: "Permanent Burden On Your Team"
  }
];
---

<section class="py-12 lg:py-25 bg-white" id="integration-comparison">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start mb-20">
      <div class="header-left">
        <h2 class="text-[26px]! sm:text-[36px]! lg:text-[44px]! font-semibold! m-0 leading-[1.18] text-black! max-w-[562px] w-full premium-reveal">
          What Changes The Day
          <span class="gradient-text">You Go Live With ClearTax</span>
        </h2>
      </div>
      <div class="header-right flex justify-end lg:pt-4">
        <p class="text-base lg:text-lg text-black/80 leading-relaxed max-w-[455px] premium-reveal [transition-delay:100ms]">
          GL Stream reduces the recurring effort your IT and finance teams spend on ERP changes, reconfiguration, and compliance maintenance.
        </p>
      </div>
    </div>

    <!-- Comparison Table Container -->
    <div class="relative overflow-x-auto lg:overflow-visible py-16">
      <div class="min-w-[900px] lg:min-w-0">
        <!-- Table Body -->
        <div class="comparison-grid relative items-start">
          
          <!-- Column 1: Moments -->
          <div class="flex flex-col">
            <h4 class="text-lg! uppercase! font-medium! text-black! mb-5! px-6 premium-reveal">The Moment That Matters</h4>
            <div class="flex flex-col">
              {comparisonData.map((item, index) => (
                <div class="p-4 flex items-center text-base! text-black! font-medium! border-b border-black/20 premium-reveal" style={`transition-delay: ${400 + index * 50}ms`}>
                  {item.moment}
                </div>
              ))}
            </div>
          </div>

          <!-- Column 2: ClearTax (The Card) -->
          <div class="relative z-30 -mt-6 rounded-xl shadow-[0_48px_100px_-20px_rgba(17,12,34,0.25)]">
             <!-- Floating Card -->
             <div class="bg-white rounded-xl premium-reveal [transition-delay:200ms] overflow-hidden border border-black/[0.03] pointer-events-auto p-5">
                <div class="text-center mb-4">
                   <h4 class="text-xl font-medium text-black">ClearTax <span class="text-[#655DFF]">Seamless</span></h4>
                </div>
                <div class="flex flex-col">
                  {comparisonData.map((item, index) => (
                    <div class="p-4 flex items-center justify-center premium-reveal w-full gradient-border-bottom" style={`transition-delay: ${500 + index * 50}ms`}>
                      <div class="flex items-center gap-4 w-full max-w-[220px]">
                        <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0">
                          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20 9.9339C20 15.4202 15.5228 19.8677 10 19.8677C4.47716 19.8677 0 15.4202 0 9.9339C0 4.44763 4.47716 0.00012207 10 0.00012207C15.5228 0.00012207 20 4.44763 20 9.9339Z" fill="#655DFF"/>
                            <path d="M14.198 7.1111L8.51264 12.7588L5.80615 10.0703" stroke="white" stroke-width="1.66667" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>

                        </div>
                        <span class="text-lg! text-black! font-semibold! whitespace-nowrap!">{item.cleartax}</span>
                      </div>
                    </div>
                  ))}
                </div>
             </div>
          </div>

          <!-- Column 3: Typical -->
          <div class="flex flex-col">
            <div class="flex justify-end mb-5 px-6 premium-reveal">
              <h4 class="text-lg! uppercase! font-medium! text-black! w-full max-w-[280px] text-left">Typical Integration</h4>
            </div>
            <div class="flex flex-col">
              {comparisonData.map((item, index) => (
                <div class="p-4 flex items-center justify-end border-b border-black/20 premium-reveal w-full" style={`transition-delay: ${600 + index * 50}ms`}>
                  <div class="w-full max-w-[280px] text-left text-base! text-black!">
                    {item.typical}
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .comparison-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1.1fr;
  }
  
  .gradient-border-bottom {
    position: relative;
  }
  
  .gradient-border-bottom::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.4px;
    background-image: repeating-linear-gradient(to right, #655DFF 0, #655DFF 4px, transparent 4px, transparent 8px);
    background-repeat: no-repeat;
    mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 20%, rgba(0, 0, 0, 1) 80%, rgba(0, 0, 0, 0) 100%);
    -webkit-mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 20%, rgba(0, 0, 0, 1) 80%, rgba(0, 0, 0, 0) 100%);
  }
  
  .gradient-text {
    background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .premium-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const observerOptions = {
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".premium-reveal").forEach((el) => {
      observer.observe(el);
    });
  })();
</script>
