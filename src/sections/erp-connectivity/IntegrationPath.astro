---
const erpLogos = {
  native: [
    { name: "SAP", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfe3956ddb4d4f844ba3_sap-logo.png" },
    { name: "Microsoft Dynamics", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfe11b9d1549ee39553a_microsoft-dynamics.png" }
  ],
  others: [
    { name: "Shopify", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfe340fdd86811d7431b_shopify-logo.png" },
    { name: "Cegid", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfd6e70cc7ec366c1da1_cegid-logo.png" },
    { name: "Logisense", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdd6a9033ec9a58f781_logisense-logo.png" },
    { name: "Mirnah", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfe33fae32c5e4a5d5b0_mirnah-logo.png" },
    { name: "Oracle Retail", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfe31fa6c75772981d5c_oracle-retail-logo.png" },
    { name: "Infor", src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdc6c0fdc2b920b6ddb_Infor-logo.png" }
  ]
};

const paths = [
  {
    type: "native",
    title: "For SAP or Microsoft Dynamics",
    subtitle: "First workflow built directly on the native cloud apps.",
    bg: "bg-[#655DFF29]",
    logobg: "bg-[#655DFF29]",
    border: "border-[#655DFF]",
    items: [
      "Request a personalised demo in your ERP environment",
      "View the certified listing on SAP Certified Solutions Directory or Microsoft AppSource",
      "Our solution team guides your IT through a single install — that's all they'll ever do",
      "Go live and hand off to ClearTax — compliance is now our responsibility"
    ]
  },
  {
    type: "custom",
    title: "For All Other ERP Environments",
    subtitle: "ClearTax handles the mapping and development for you.",
    bg: "bg-white",
    logobg: "bg-[#F0F0F0]",
    border: "border-black/12",
    items: [
      "ClearTax designs, builds, and maintains the full integration",
      "Share your ERP and geography with our team — we'll scope it within days",
      "Your IT signs off once at the start; we take it from there",
      "Not sure what you have? We'll help you figure out the right path in the first call"
    ]
  }
];
---

<section class="py-12 lg:py-25 bg-[#F9FAFB] overflow-hidden">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Header -->
    <div class="text-center mb-12 premium-reveal">
      <h2 class="text-[26px]! sm:text-[36px]! lg:text-[44px]! font-semibold! leading-[1.18] m-0 text-black! mb-4! max-w-[630px] w-full mx-auto">
        Choose The Integration Path
        <span class="gradient-text">That Fits Your ERP</span>
      </h2>
      <p class="text-base lg:text-lg text-black/80 max-w-2xl mx-auto leading-normal">
        ClearTax helps you connect quickly, get IT approval once, and move to automated compliance without ongoing setup effort.
      </p>
    </div>

    <!-- Comparison Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">
      {paths.map((path, pathIndex) => (
        <div 
          class={`rounded-xl p-4 lg:p-7 border ${path.border} ${path.bg} shadow-sm premium-reveal h-full flex flex-col`}
          style={`transition-delay: ${pathIndex * 200}ms`}
        >
          <!-- Card Header: Logos -->
          <div class={`flex items-center gap-6 mb-7 ${path.logobg} px-6 py-4 rounded-lg`}>
            {path.type === "native" ? (
              erpLogos.native.map(logo => (
                <img src={logo.src} alt={logo.name} class="h-7 w-auto object-contain" />
              ))
            ) : (
              <div class={`flex flex-wrap gap-4 lg:gap-6 ${path.logobg}`}>
                {erpLogos.others.map(logo => (
                  <img src={logo.src} alt={logo.name} class="h-7 w-auto object-contain" />
                ))}
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="flex-1">
            <h3 class={`text-xl! lg:text-[22px]! font-medium! mb-2! ${path.type === "native" ? "text-[#05005C]!" : "text-black!"}`}>{path.title}</h3>
            <p class={`text-base! lg:text-lg!  mb-7 border-b border-black/20 pb-7 ${path.type === "native" ? "text-[#05005CCC]!" : "text-black/80!"}`}>{path.subtitle}</p>

            <div class="space-y-6">
              {path.items.map((item, itemIndex) => (
                <div 
                  class="flex gap-4 premium-reveal"
                  style={`transition-delay: ${pathIndex * 200 + 400 + itemIndex * 100}ms`}
                >
                  <div class="flex items-center justify-center flex-shrink-0">
                    <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M16.1067 8C16.1067 12.4183 12.5011 16 8.05333 16C3.60561 16 0 12.4183 0 8C0 3.58173 3.60561 0 8.05333 0C12.5011 0 16.1067 3.58173 16.1067 8Z" fill="#655DFF"/>
                      <path d="M11.4341 5.72663L6.85552 10.2749L4.6759 8.10975" stroke="white" stroke-width="1.34222" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <p class={`${path.type === "native" ? "text-[#05005CCC]!" : "text-black/80!"} text-base! lg:text-lg! leading-normal!`}>{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style is:global>
    .gradient-text {
        background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
    }
  .premium-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.premium-reveal').forEach(el => observer.observe(el));
</script>
