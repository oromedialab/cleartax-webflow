---
const features = [
  {
    title: "One-time install",
    description: "IT approves once. Automation runs after go-live.",
    icon: "sprout",
    bgColor: "bg-[#33887833]",
    iconBg: "bg-[#33887833]",
    iconColor: "text-[#338878]",
    borderColor: "border-[#338878]"
  },
  {
    title: "Expand globally",
    description: "One connection supports every country.",
    icon: "shield",
    bgColor: "bg-[#DC8F5633]",
    iconBg: "bg-[#DC8F5633]",
    iconColor: "text-[#DC8F56]",
    borderColor: "border-[#DC8F56]"
  },
  {
    title: "We handle updates",
    description: "Rule changes are managed by us, not your ERP.",
    icon: "file-text",
    bgColor: "bg-[#1F89FF33]",
    iconBg: "bg-[#1F89FF33]",
    iconColor: "text-[#1F89FF]",
    borderColor: "border-[#1F89FF]"
  },
  {
    title: "Go live faster",
    description: "AI-assisted mapping helps reduce setup from weeks to days.",
    icon: "bar-chart",
    bgColor: "bg-[#6355D833]",
    iconBg: "bg-[#6355D833]",
    iconColor: "text-[#6355D8]",
    borderColor: "border-[#6355D8]"
  }
];
---

<section class="py-12 lg:py-25 bg-[linear-gradient(180deg,_#F3F1F9_0%,_#FFFFFF_65.36%)] overflow-hidden">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-end mb-16">
      <div class="header-left">
        <h6 class="text-[12px] leading-[1.6] tracking-[0.1em] font-normal text-black/60 uppercase mb-3 block premium-reveal">
          HOW IT WORKS
        </h6>
        <h2 class="text-[26px] sm:text-[36px] lg:text-[44px] font-semibold leading-[1.18] text-black premium-reveal max-w-[332px] w-full">
          Your ERP Stays
          <span class="gradient-text">Untouched.</span>
        </h2>
      </div>
      <div class="header-right flex justify-end lg:pb-2">
        <p class="text-base lg:text-lg text-black/80 leading-relaxed max-w-[455px] premium-reveal [transition-delay:100ms]">
          GL Stream sits between your ERP and ClearTax to read invoice data, transform it for compliance, and submit it to tax authorities – without ongoing IT effort.
        </p>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <div 
          class={`feature-card p-4 min-h-[236px] rounded-xl flex flex-col ${feature.bgColor} transition-all duration-300 hover:shadow-xl premium-reveal`}
          style={`transition-delay: ${200 + index * 100}ms`}
        >
          <div class={`w-12 h-12 ${feature.iconBg} rounded-lg flex items-center justify-center border ${feature.borderColor}`}>
            {feature.icon === 'sprout' && (
              <svg width="23" height="21" viewBox="0 0 23 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13.5631 3.39909C16.2623 0.699951 21.6605 0.699951 21.6605 0.699951C21.6605 0.699951 21.6605 6.09819 18.9614 8.79733C17.0334 10.7253 14.2826 11.0592 12.7919 9.56848C11.3012 8.07779 11.6352 5.32703 13.5631 3.39909Z" stroke="#338878" stroke-width="1.4" stroke-miterlimit="10"/>
                <path d="M17.3773 4.9834L12.842 9.51867C12.3156 10.0451 11.898 10.6701 11.613 11.358C11.3281 12.0459 11.1815 12.7831 11.1815 13.5276V17.6124M7.61789 7.41486C5.31189 5.10887 0.699951 5.10887 0.699951 5.10887C0.699951 5.10887 0.699951 9.72081 3.00594 12.0268C4.65307 13.6739 7.0032 13.9592 8.27675 12.6857C9.55026 11.4121 9.26501 9.06199 7.61789 7.41486Z" stroke="#338878" stroke-width="1.4" stroke-miterlimit="10"/>
                <path d="M4.23145 8.64026L9.75158 14.1604C10.2049 14.6137 10.5644 15.1518 10.8098 15.7441C11.0551 16.3363 11.1813 16.9711 11.1813 17.6122V20.112" stroke="#338878" stroke-width="1.4" stroke-miterlimit="10"/>
                </svg>


            )}
            {feature.icon === 'shield' && (
              <svg width="18" height="22" viewBox="0 0 18 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.80005 0.800049L0.800049 4.80005V10.8C0.800049 15.8 4.30005 19.8 8.80005 20.8C13.3 19.8 16.8 15.8 16.8 10.8V4.80005L8.80005 0.800049Z" stroke="#DC8F56" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5.80005 10.8002L7.80005 12.8002L11.8 8.80017" stroke="#DC8F56" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>


            )}
            {feature.icon === 'file-text' && (
              <svg width="18" height="20" viewBox="0 0 18 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10.8 0.800171H2.80005C2.26962 0.800171 1.76091 1.01088 1.38584 1.38596C1.01076 1.76103 0.800049 2.26974 0.800049 2.80017V16.8002C0.800049 17.3306 1.01076 17.8393 1.38584 18.2144C1.76091 18.5895 2.26962 18.8002 2.80005 18.8002H14.8C15.3305 18.8002 15.8392 18.5895 16.2143 18.2144C16.5893 17.8393 16.8 17.3306 16.8 16.8002V6.80017L10.8 0.800171Z" stroke="#1F89FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.8 0.800049V6.80005H16.8" stroke="#1F89FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4.80054 10.8H12.8005" stroke="#1F89FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4.80054 14.8003H9.80054" stroke="#1F89FF" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

            )}
            {feature.icon === 'bar-chart' && (
              <svg width="23" height="19" viewBox="0 0 23 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.80542 0.805298V17.3053H21.3054" stroke="#6355D8" stroke-width="1.61071" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M7.22192 9.0553H4.47192V14.5553H7.22192V9.0553Z" stroke="#6355D8" stroke-width="1.61071" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12.8052 5.38879H10.0552V14.5555H12.8052V5.38879Z" stroke="#6355D8" stroke-width="1.61071" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18.3889 2.63879H15.6389V14.5555H18.3889V2.63879Z" stroke="#6355D8" stroke-width="1.61071" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

            )}
          </div>
          <div class="flex flex-col mt-auto h-auto">
            <h3 class="text-xl font-medium text-black mb-3">{feature.title}</h3>
            <p class="text-black/80 text-base lg:text-lg leading-normal">
                {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .gradient-text {
    background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .premium-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const observerOptions = {
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".premium-reveal").forEach((el) => {
      observer.observe(el);
    });
  })();
</script>
