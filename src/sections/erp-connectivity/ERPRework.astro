---
const competitors = {
  title: "Competitors",
  subtitle: "Multiple vendors, constant rework",
  points: [
    { text: "Constant updates are needed for future mandates", color: "red" },
    { text: "You will need a different vendor for this", color: "red" }
  ]
};

const cleartax = {
  title: "ClearTax",
  points: [
    "Single pipe from your ERP",
    "Sufficient for everything",
    "Now & the Future"
  ],
  outputs: [
    { label: "E-Invoicing", icon: "📄" },
    { label: "VAT Reporting", icon: "📊" },
    { label: "VAT Recon", icon: "🔍" },
    { label: "GL Recon", icon: "✨" }
  ]
};
---

<section class="py-12 lg:py-24 bg-[#F8F9FF] overflow-hidden">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Section Header -->
    <div class="text-center mb-12 premium-reveal">
      <h2 class="text-[26px]! sm:text-[36px]! lg:text-[44px]! leading-[1.14]! font-semibold! m-0 text-black! mb-4! max-w-[564px] w-full mx-auto">One connector. 
        <span class="gradient-text">No repeated ERP rework.</span></h2>
      <p class="text-base lg:text-lg text-black/80 max-w-[764px] w-full mx-auto">
        Traditional integrations often require ERP-level changes every time a country, format, or rule changes. GL Stream keeps the ERP stable and moves compliance complexity into ClearTax.
      </p>
    </div>

    <div class="max-w-[1090px] w-full aspect-[1090/687] mx-auto">
        <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfda87c0a47c853f05f2_erp-rework.png" alt="">
    </div>
  </div>
</section>

<style is:global>
    .gradient-text {
        background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
    }
  .premium-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* 3D Tube effect helpers */
  .bg-gradient-to-b {
    background-size: 100% 200%;
    animation: flow 4s linear infinite;
  }

  @keyframes flow {
    0% { background-position: 0% 0%; }
    100% { background-position: 0% 100%; }
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.premium-reveal').forEach(el => observer.observe(el));
</script>
