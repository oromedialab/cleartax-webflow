---
const erpLogos = [
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e917bc9a2a6b5bdab_logo-mandate-1.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e4a6c0b488c8e341f_logo-mandate-2.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e7d70b792ffa777c2_logo-mandate-3.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e3d48cec8adaf71dc_logo-mandate-4.png'
];
---
<section class="bg-[#F3F1F9] py-12 lg:py-25 overflow-hidden">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center mb-8 lg:mb-12">
            <h2 class="text-[26px]! sm:text-[36px]! lg:text-[44px]! lg:leading-[1.2]! font-semibold! text-black! mb-4! max-w-[591px] w-full mx-auto">
                From ERP Data To <span class="gradient-text">Compliant E-Invoices</span>
            </h2>
            <p class="text-base! lg:text-lg! text-black/80! max-w-2xl! mx-auto!">
                GL Stream reads your ERP data, sends it securely to ClearTax, and converts it into the required compliance-ready format.
            </p>
        </div>

        <div class="relative max-w-6xl mx-auto min-h-auto lg:min-h-[500px]">
            <div class="flex flex-col lg:flex-row items-center justify-between h-full relative z-10 gap-16 lg:gap-0">
                <!-- ERP Column (Your System) -->
                <div class="relative z-20 w-full lg:max-w-[204px] premium-reveal">
                    <div class="bg-[#EDEAF6] rounded-[12px] border border-[#1B087633] p-6 md:p-7 h-full max-w-[320px] mx-auto lg:mx-0">
                        <h3 class="text-[#1B0876]/80 text-lg text-center mb-7 font-normal">Your System</h3>
                        <div class="your-system-grid border-2 border-dashed border-[#1B087633] rounded-[12px] p-4 md:p-6">
                            {erpLogos.map((logo, i) => (
                                <div class="rounded-[12px] flex items-center justify-center transition-all hover:-translate-y-0.5">
                                    <img src={logo} alt={`ERP Logo ${i + 1}`} class="w-full h-full object-contain" />
                                </div>
                            ))}
                            <div class="rounded-[12px] flex items-center justify-center hover:bg-[#4D45A5]/5 transition-colors">
                                <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5ef8209f69a7534af9_logo-mandate-5.png" alt="More systems" class="w-full h-12 object-contain" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SVG Lines - Hidden on mobile for cleaner vertical stack -->
                <div class="absolute top-1/2 left-1/3 xl:left-1/2 -translate-x-1/2 -translate-y-1/2 aspect-[900/298] w-[87%] hidden lg:block">
                    <svg width="100%" preserveAspectRatio="none" viewBox="0 0 901 299" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M900.213 149.538H520.107" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M0.000244141 149.538H340.107" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M558.247 149.462H501.288M516.288 149.462H559.203C600.348 149.462 633.703 182.817 633.703 223.962C633.703 265.107 667.058 298.462 708.203 298.462H777.288" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M783.288 0.461914H707.247C666.102 0.461914 632.747 33.8167 632.747 74.9619C632.747 116.107 599.392 149.462 558.247 149.462H501.288M559.203 149.462H516.288" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M0.000488281 293.1H92.6458C145.415 293.1 195.692 270.647 230.912 231.35L248.615 211.598C272.569 184.871 306.763 169.6 342.654 169.6" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M0.000732422 222.112H93.8445C139.509 222.112 184.5 211.104 225.006 190.021L238.48 183.009C270.134 166.533 305.294 157.931 340.979 157.931" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M0.000488281 85.6299L96.9561 85.6299C140.713 85.6299 183.953 95.0838 223.717 113.345L231.667 116.995C266.193 132.851 303.737 141.059 341.73 141.059" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                        <path d="M0 14.6406L95.8506 14.6406C146.792 14.6406 195.545 35.351 230.911 72.015L245.177 86.8036C271.427 114.017 307.614 129.389 345.425 129.389" stroke="#493991" stroke-width="0.923954" stroke-dasharray="5.54 5.54"/>
                    </svg>
                </div>

                <!-- Central Hub -->
                <div class="animate-hub-ring w-full max-w-[180px] lg:max-w-[210px] rounded-full flex items-center justify-center z-20 overflow-hidden premium-reveal [transition-delay:200ms]">
                    <img src="/images/erp-connectivity/gl-stream-center.png" alt="ClearTax Global Unified API" class="w-full h-full object-contain" />
                </div>

                <!-- Tax Documents Column -->
                <div class="relative z-20 w-full lg:max-w-[234px] flex flex-row lg:flex-col justify-between min-h-[300px] lg:min-h-[498px] gap-8 lg:gap-0 premium-reveal [transition-delay:300ms]">
                    <div class="lg:-translate-x-12 flex justify-center lg:justify-start">
                        <img src="/images/erp-connectivity/e-invoice-1.png" alt="E-Invoice Top" class="max-w-[123px] w-full h-auto drop-shadow-xl hover:-translate-y-1 transition-transform object-contain" />
                    </div>
                    <div class="lg:translate-x-16 flex justify-center lg:justify-start">
                        <img src="/images/erp-connectivity/e-invoice-2.png" alt="E-Invoice Middle" class="max-w-[123px] w-full h-auto drop-shadow-xl hover:-translate-y-1 transition-transform object-contain" />
                    </div>
                    <div class="lg:-translate-x-12 flex justify-center lg:justify-start">
                        <img src="/images/erp-connectivity/e-invoice-3.png" alt="E-Invoice Bottom" class="max-w-[123px] w-full h-auto drop-shadow-xl hover:-translate-y-1 transition-transform object-contain" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    .animate-pulse-line {
        animation: pulse-line 4s linear infinite;
    }

    @keyframes pulse-line {
        0% { stroke-dashoffset: 1000; }
        100% { stroke-dashoffset: 0; }
    }

    .integration-gradient-left-1 { animation: sweep-mask 4s infinite backwards; animation-delay: 0s; }
    .integration-gradient-left-4 { animation: sweep-mask 4s infinite backwards; animation-delay: 0s; }
    .integration-gradient-left-2 { animation: sweep-mask 4s infinite backwards; animation-delay: 2s; }
    .integration-gradient-left-3 { animation: sweep-mask 4s infinite backwards; animation-delay: 2s; }
    
    /* 5a and 5b use an ultra-slow keyframe (6.4s sweep instead of 2.8s) to feel extremely smooth */
    .integration-gradient-left-5a { animation: sweep-mask-slow 5s infinite backwards; animation-delay: 1.56s; }
    .integration-gradient-left-5b-1 { animation: sweep-mask-slow 6.4s infinite backwards; animation-delay: 6.36s; }
    .integration-gradient-left-5b-2 { animation: sweep-mask-slow 6.4s infinite backwards; animation-delay: 1.16s; }
    .integration-gradient-left-5b-3 { animation: sweep-mask-slow 6.4s infinite backwards; animation-delay: 2.36s; }
    .integration-gradient-left-5b-4 { animation: sweep-mask-slow 6.4s infinite backwards; animation-delay: 3.56s; }
    .integration-gradient-left-5b-5 { animation: sweep-mask-slow 6.4s infinite backwards; animation-delay: 4.76s; }

    @keyframes sweep-mask {
        0% { transform: translateX(-100%); }
        50% { transform: translateX(100%); }
        100% { transform: translateX(100%); }
    }

    @keyframes sweep-mask-slow {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    .animate-hub-ring {
        animation: hub-ring-scale 3.2s ease-in-out infinite;
    }

    @keyframes hub-ring-scale {
        0%, 100% { transform: scale(1); filter: brightness(1); }
        50% { transform: scale(1.05); filter: brightness(1.08); }
    }
    .gradient-text {
        background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
    }
    .your-system-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
        /* Using your variables if you want to keep them for future use: */
        --grid-layout-gap: 20px;
    }
    @media (min-width: 1024px) {
        .your-system-grid {
            gap: 26px;
            --grid-layout-gap: 26px;
        }
    }
    .your-system-grid > div {
        height: 44px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
