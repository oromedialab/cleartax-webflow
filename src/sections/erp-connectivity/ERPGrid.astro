---
/**
 * ERP Integration Grid component
 * Replaced the old list-based grid with a custom layout matching the design reference.
 */
---

<section class="py-12 lg:py-25 bg-white" id="erp-integration">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-end mb-16">
      <div class="header-left">
        <h2 class="text-[26px] sm:text-[36px] lg:text-[44px] font-semibold leading-[1.18] text-black premium-reveal">
          Built For Fast, Low-Effort <br />
          <span class="gradient-text">ERP Integration</span>
        </h2>
      </div>
      <div class="header-right flex justify-end lg:pb-2">
        <p class="text-base lg:text-lg text-black/80 leading-relaxed max-w-[455px] premium-reveal [transition-delay:100ms]">
          GL Stream removes the usual complexity of compliance integrations — from IT dependency to country-wise rework.
        </p>
      </div>
    </div>

    <!-- Integration Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Left 2/3 Area -->
      <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Fast Setup (Green) -->
        <div class=" rounded-2xl bg-[linear-gradient(180deg,_#ECF7ED_0%,_#D4EDD6_100%)] flex flex-col premium-reveal">
            <div class="p-7">
                <h3 class="text-xl font-medium text-black mb-3">Fast, non-disruptive setup</h3>
                <p class="text-black/80 text-base lg:text-lg mb-8 leading-normal">
                  Connect SAP, Microsoft Dynamics, or other ERPs without changing existing workflows.
                </p>
            </div>
          <div class="mt-auto mx-2">
            <img 
              src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdce490ed4439aba75f_integration-image-1.png" 
              alt="Fast Setup" 
              class="w-full h-auto object-contain" 
            />
          </div>
        </div>

        <!-- Compliance Updates (Orange) -->
        <div class="p-7 rounded-2xl bg-[linear-gradient(180deg,_#FBE8DF_0%,_#FDF2ED_100%)] flex flex-col gap-4 premium-reveal [transition-delay:100ms]">
            <div>
            <img 
              src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdcd18cce4c7ac61235_integration-image-2.png" 
              alt="Compliance Updates" 
              class="w-full h-auto object-contain" 
            />
          </div>
          <div class="mt-auto">
              <h3 class="text-xl font-medium text-black mb-3">Compliance updates automatically</h3>
              <p class="text-black/80 text-base lg:text-lg leading-normal">
                ClearTax manages rule changes, so your ERP connection stays intact.
              </p>
          </div>
        </div>

        <!-- Zero Manual Config (Blue) - Span 2 columns in its nested grid -->
        <div class="md:col-span-2 p-7 rounded-2xl bg-[linear-gradient(180deg,_#EBF4FE_0%,_#C5DFFC_100%)] flex flex-col md:flex-row gap-8 items-start premium-reveal [transition-delay:200ms]">
          <div class="flex-1">
            <h3 class="text-xl font-medium text-black mb-3">Zero manual configuration</h3>
            <p class="text-black/80 text-base lg:text-lg leading-normal">
              AI-assisted mapping reduces setup effort and speeds up go-live.
            </p>
          </div>
          <div class="flex-1 w-full mt-4 md:mt-0">
            <img 
              src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdd185353bf7a6a5b77_integration-image-4.png" 
              alt="Zero Manual Config" 
              class="w-full h-auto object-contain" 
            />
          </div>
        </div>
      </div>

      <!-- Right 1/3 Area - Full Height (Purple) -->
      <div class="rounded-2xl bg-[linear-gradient(180deg,_#EDEBFA_0%,_#DEDAF6_100%)] flex flex-col premium-reveal [transition-delay:300ms]">
        <div>
          <img 
            src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a06bfdc3232fa58e481547b_integration-image-3.png" 
            alt="Global Integration" 
            class="w-full h-auto object-contain" 
          />
        </div>
        <div class="mt-auto p-7">
            <h3 class="text-xl font-medium text-black mb-3">One integration, every country</h3>
            <p class="text-black/80 text-base lg:text-lg leading-normal">
              Use one GL Stream setup across ClearTax-supported geographies.
            </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .premium-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const observerOptions = {
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".premium-reveal").forEach((el) => {
      observer.observe(el);
    });
  })();
</script>
