<section class="max-md:pt-12 max-lg:pt-16 lg:pt-25 bg-[#F3F1F9]">
  <div class="max-w-[var(--container-max)] mx-auto px-4">
    <div class="max-w-158.5 w-full mb-12 mx-auto">
      <p class="font-nohemi text-xs! text-[#00000099] text-center mb-3">
        See it in action
      </p>
      <h2
        class="font-nohemi max-md:text-[26px]! md:max-lg:text-4xl! lg:text-[44px]! font-semibold text-[#655DFF] text-center leading-[1.18]"
      >
        <span class="text-black">What VAT assurance looks</span>
        like in practice
      </h2>
      <p
        class="max-md:text-[16px]! md:text-[18px]! font-normal font-gilroy text-black/80 mt-4 text-center"
      >
        Watch how Recon AI catches what your team can't — and closes the gap
        before it becomes a liability.
      </p>
    </div>
  </div>
  <div
    class="max-lg:max-w-[95%] lg:max-w-272.5 w-full aspect-16/9 mx-auto bg-[#171E28] rounded-xl relative overflow-hidden cursor-pointer shadow-[0_24px_80px_rgba(23,30,40,0.25)] group/video"
    data-video-card
    data-video-id="OWYYXUMvzZ0"
  >
    <div class="absolute inset-0 z-10" data-video-placeholder>
      <img class="absolute inset-0 w-full h-full object-cover" src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0add7eee0c59004f7979db_Thumbnail2.png" alt="Video Thumbnail" />
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 bg-[rgba(53,_39,_98,_0.5)] backdrop-blur-[2px] rounded-full flex items-center justify-center transition-transform duration-300 group-hover/video:scale-110 [&>svg]:fill-white [&>svg]:w-7 [&>svg]:h-7">
          <div class="absolute z-10 inset-1.5 rounded-full backdrop-blur-[2px] bg-[rgba(53,_39,_98,_0.8)] "></div>
          <svg class="absolute z-20" width="28" height="28" viewBox="0 0 24 24"><polygon points="8,5 20,12 8,19"></polygon></svg>
      </div>
    </div>
    <div class="absolute inset-0 hidden z-[5] [&_iframe]:absolute [&_iframe]:inset-0 [&_iframe]:w-full [&_iframe]:h-full [&_iframe]:border-0"
      data-video-wrap
    ></div>
  </div>

<script is:inline>
  (function () {
    const card = document.currentScript.previousElementSibling;
    if (!card) return;
    const placeholder = card.querySelector('[data-video-placeholder]');
    const wrap = card.querySelector('[data-video-wrap]');
    const videoId = card.getAttribute('data-video-id');
    if (!card || !placeholder || !wrap) return;

    card.addEventListener('click', function () {
      if (card.classList.contains('playing')) return;
      card.classList.add('playing');

      const iframe = document.createElement('iframe');
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
      iframe.style.cssText = "position:absolute; top:0; left:0; width:100%; height:100%; border:none;";

      iframe.onload = function() {
        placeholder.style.display = 'none';
      };

      wrap.style.display = 'block';
      wrap.appendChild(iframe);

      const origin = (window.location.origin && window.location.origin !== 'null') 
          ? window.location.origin 
          : (window.location.protocol + '//' + window.location.hostname);

      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&enablejsapi=1&origin=${encodeURIComponent(origin)}`;
    });
  })();
</script>
</section>
