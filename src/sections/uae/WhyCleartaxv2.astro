                  <path d="M13.4396 8.36975V13.0364" stroke="#E5AC82" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  <path d="M13.4396 17.7031H13.4523" stroke="#E5AC82" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
