                <path d="M1.02502 1.02502V22.025H27.1159" stroke="#6355D8" stroke-width="2.05" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.19153 11.525H5.69153V18.525H9.19153V11.525Z" stroke="#6355D8" stroke-width="2.05" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16.2977 6.85852H12.7977V18.5252H16.2977V6.85852Z" stroke="#6355D8" stroke-width="2.05" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M23.4041 3.35852H19.9041V18.5252H23.4041V3.35852Z" stroke="#6355D8" stroke-width="2.05" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {index === 2 && (
                <svg width="29" height="26" viewBox="0 0 29 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M17.3961 4.46029C20.8314 1.02502 27.7019 1.02502 27.7019 1.02502C27.7019 1.02502 27.7019 7.89551 24.2666 11.3308C21.8129 13.7845 18.3119 14.2095 16.4146 12.3122C14.5174 10.415 14.9424 6.91403 17.3961 4.46029Z" stroke="#338878" stroke-width="2.05" stroke-miterlimit="10"/>
                  <path d="M22.2508 6.47644L16.4786 12.2486C15.8085 12.9186 15.277 13.7141 14.9144 14.5896C14.5518 15.465 14.3651 16.4033 14.3651 17.3509V22.5498M9.82965 9.57103C6.89475 6.63613 1.025 6.63613 1.025 6.63613C1.025 6.63613 1.025 12.5059 3.9599 15.4408C6.05624 17.5371 9.04732 17.9002 10.6682 16.2793C12.289 14.6584 11.926 11.6674 9.82965 9.57103Z" stroke="#338878" stroke-width="2.05" stroke-miterlimit="10"/>
                  <path d="M5.51983 11.1305L12.5455 18.1561C13.1224 18.733 13.58 19.4179 13.8922 20.1717C14.2045 20.9255 14.3652 21.7334 14.3652 22.5493V25.7309" stroke="#338878" stroke-width="2.05" stroke-miterlimit="10"/>
                </svg>
