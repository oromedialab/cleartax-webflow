---
/**
 * USP Section V2 — Tailwind optimized
 * Content/layout updated to match provided design while preserving tilt script hooks.
 */
interface GridCard {
  title: string;
  description: string;
  cardClass: string;
  panelBgClass: string;
  imgWrapperClass: string;
  bodyClass?: string;
  textWrapClass?: string;
}

const cards: GridCard[] = [
  {
    title: 'Automated error management',
    description:
      'Identify & resolve e-invoicing errors in real time with intuitive alerts, bulk resubmission options & guided correction tools.',
    cardClass: 'col-span-6 max-lg:col-span-12',
    panelBgClass: 'bg-[#FDF2ED]',
    textWrapClass: 'max-w-[95%]',
    imgWrapperClass: 'bg-[#E5AC82]/20',
  },
  {
    title: 'Advanced dashboards & reports',
    description:
      'Leverage AI-driven insights for a complete view of your e-invoicing processes via comprehensive MIS dashboards and customized reports.',
    cardClass: 'col-span-6 max-lg:col-span-12',
    panelBgClass: 'bg-[#EDEBFA]',
    textWrapClass: 'max-w-[95%]',
    imgWrapperClass: 'bg-[#6355D8]/20',
  },
  {
    title: 'Future ready architecture',
    description:
      'New mandates or amendments never require new integrations; simply update, not rebuild.',
    cardClass: 'col-span-4 max-lg:col-span-12',
    panelBgClass: 'bg-[#ECF7ED]',
    imgWrapperClass: 'bg-[#338878]/20',
  },
  {
    title: 'Peppol-ready',
    description:
      "ClearTax follows the Peppol specifications for data exchange, ensuring compliance with the UAE's (CTC) model.",
    cardClass: 'col-span-4 max-lg:col-span-12',
    panelBgClass: 'bg-[#FDF2ED]',
    imgWrapperClass: 'bg-[#E5AC82]/20',
  },
  {
    title: 'End-to-end e-invoicing solution',
    description:
      'A complete solution for issuing, submitting, & receiving e-invoices. It tracks the status of submitted invoices and sends email notifications for e-invoices.',
    cardClass: 'col-span-4 row-span-2 max-lg:col-span-12',
    panelBgClass: 'bg-[#EBF4FE]',
    imgWrapperClass: 'bg-[#1F89FF]/20',
    bodyClass: 'mt-auto',
  },
  {
    title: 'Dedicated customer support',
    description:
      'Our dedicated local support team is available 24/7 to solve any e-invoicing or integration related queries.',
    cardClass: 'col-span-8 max-lg:col-span-12',
    panelBgClass: 'bg-[#EDEBFA]',
    textWrapClass: 'max-w-[95%]',
    imgWrapperClass: 'bg-[#6355D8]/20',
  },
];
---

<section id="usp-v1-shield" class="bg-gradient-to-r from-[#F3F1F9] to-[#FFFFFF] py-20 lg:py-[100px] w-full">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="text-center mb-12">
      <h2 id="usp-title-shield" class="text-[44px]! font-semibold! text-[#000000] leading-[1.18]! m-0! max-lg:text-[32px]!">
       Everything You Need For
        <span class="text-[#655DFF]">UAE E-Invoicing</span>
      </h2>
      <p class="text-[#000000]/80 text-[18px] leading-[1.44] max-w-[780px] mx-auto mt-6">
        Enterprise-grade infrastructure trusted by the world's largest organizations
      </p>
    </div>

    <div class="grid grid-cols-12 gap-6 w-full">
      {cards.map((card, index) => (
        <div class={`${card.cardClass} tilted-card min-h-[300px]`}>
