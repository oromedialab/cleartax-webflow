---
/**
 * UAE Security & Privacy section — hosting card + 3 rows of certifications.
 * Ported from uae-landing-page/index.html:1312-1565.
 */
interface SecCard {
  title: string;
  desc: string;
  icon: string;
  iconStyle: 'plain' | 'badge';
}

const heroCard = {
  title: 'Hosted on AWS Middle East (UAE)',
  desc: 'Multi-AZ hosting with local data residency',
  icon: '<path d="M17.5 19a4.5 4.5 0 1 0-1.9-8.584A7 7 0 1 0 6 16.9"/>',
};

const row1: SecCard[] = [
  {
    title: 'ISO 27001:2022 &amp; ISO 22301:2019',
    desc: 'Certified information security and business continuity',
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
    iconStyle: 'plain',
  },
  {
    title: 'VAPT by Independent Third Party',
    desc: 'Regular security testing and hardening',
    icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
    iconStyle: 'plain',
  },
  {
    title: 'SSL Secured Transit / Motion',
    desc: 'Encrypted data in transit',
    icon: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    iconStyle: 'plain',
  },
];

const row2: SecCard[] = [
  {
    title: 'Encryption at Rest AES 256-bit',
    desc: 'Strong encryption for stored data',
    icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
    iconStyle: 'plain',
  },
  {
    title: 'Role-Based Access Control (RBAC)',
    desc: 'Granular access permissions',
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    iconStyle: 'plain',
  },
];

const row3: SecCard[] = [
  {
    title: 'Authentication Tokens for API Calls',
    desc: 'Secure API access',
    icon: '<path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/>',
    iconStyle: 'badge',
  },
  {
    title: 'SOC 2 Type II Compliant',
    desc: 'Independently audited security controls ensuring the highest standards of data protection and operational excellence.',
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
    iconStyle: 'badge',
  },
  {
    title: 'Privacy and Regulatory Alignment',
    desc: 'Privacy-by-design controls aligned with UAE PDPL principles',
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
    iconStyle: 'badge',
  },
];
---

<section class="sec-section">
  <div class="sec-inner" id="security">
    <div class="sec-header">
      <p class="sec-eyebrow">Security &amp; Privacy</p>
      <h2 class="sec-heading">Your <em>security</em> and <em>privacy</em> are our top priority</h2>
    </div>

    <div class="sec-cards-wrap">
      <article class="sec-hero-card">
        <div class="sec-hero-text">
          <h3 class="sec-hero-title">{heroCard.title}</h3>
          <p class="sec-hero-desc">{heroCard.desc}</p>
        </div>
        <span class="sec-hero-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={heroCard.icon} />
        </span>
      </article>

      <div class="sec-card-row cols-3">
        {row1.map((c) => (
          <article class="sec-card">
            <div class="sec-card-text">
              <h3 class="sec-card-title" set:html={c.title} />
              <p class="sec-card-desc">{c.desc}</p>
            </div>
            <span class={c.iconStyle === 'badge' ? 'sec-icon-badge' : 'sec-card-icon'} aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
            </span>
          </article>
        ))}
      </div>

      <div class="sec-card-row cols-2">
        {row2.map((c) => (
          <article class="sec-card">
            <div class="sec-card-text">
              <h3 class="sec-card-title">{c.title}</h3>
              <p class="sec-card-desc">{c.desc}</p>
            </div>
            <span class={c.iconStyle === 'badge' ? 'sec-icon-badge' : 'sec-card-icon'} aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
            </span>
          </article>
        ))}
      </div>

      <div class="sec-card-row cols-3">
        {row3.map((c) => (
          <article class="sec-card">
            <div class="sec-card-text">
              <h3 class="sec-card-title">{c.title}</h3>
              <p class="sec-card-desc">{c.desc}</p>
            </div>
            <span class={c.iconStyle === 'badge' ? 'sec-icon-badge' : 'sec-card-icon'} aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
            </span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sec-section {
    background: #F7F6FC;
    color: #0F1020;
    box-sizing: border-box;
  }
  .sec-section *,
  .sec-section *::before,
  .sec-section *::after { box-sizing: border-box; }

  .sec-inner { max-width: 1200px; margin: 0 auto; padding: 96px 40px; }
  .sec-header { max-width: 760px; display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }

  .sec-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(99, 85, 216, 0.10);
    border: 1px solid rgba(99, 85, 216, 0.25);
    color: var(--color-purple);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .sec-heading {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0;
    color: #0F1020;
    max-width: 700px;
  }
  .sec-heading em { font-style: normal; color: var(--color-purple); }

  .sec-cards-wrap { margin-top: 48px; display: flex; flex-direction: column; gap: 24px; }
  .sec-card-row { display: grid; gap: 24px; align-items: stretch; }
  .sec-card-row.cols-3 { grid-template-columns: repeat(3, 1fr); }
  .sec-card-row.cols-2 { grid-template-columns: repeat(2, 1fr); }

  .sec-hero-card {
    background: #fff;
    border-radius: 20px;
    padding: 36px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    box-shadow: 0 8px 32px rgba(99, 85, 216, 0.06), 0 2px 8px rgba(99, 85, 216, 0.06);
  }
  .sec-hero-text { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 0; }
  .sec-hero-title { font-size: 26px; font-weight: 700; line-height: 1.25; margin: 0; color: #0F1020; }
  .sec-hero-desc { font-size: 16px; font-weight: 400; line-height: 1.5; color: #5A6070; margin: 0; }
  .sec-hero-icon {
    width: 72px;
    height: 72px;
    border-radius: 36px;
    background: radial-gradient(circle at 30% 30%, rgba(99, 85, 216, 0.2), rgba(99, 85, 216, 0.03));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-purple);
    flex-shrink: 0;
  }
  .sec-hero-icon svg { width: 40px; height: 40px; }

  .sec-card {
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    box-shadow: 0 4px 24px rgba(99, 85, 216, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .sec-card:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(99, 85, 216, 0.12); }
  .sec-card-text { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; }
  .sec-card-title { font-size: 18px; font-weight: 700; line-height: 1.3; margin: 0; color: #0F1020; }
  .sec-card-desc { font-size: 14px; font-weight: 400; line-height: 1.5; color: #5A6070; margin: 0; }
  .sec-card-icon { width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; color: var(--color-purple); flex-shrink: 0; }
  .sec-card-icon svg { width: 40px; height: 40px; }
  .sec-icon-badge {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #EEECFB;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-purple);
    flex-shrink: 0;
  }
  .sec-icon-badge svg { width: 24px; height: 24px; }

  @media (max-width: 1024px) {
    .sec-inner { padding: 80px 40px; }
    .sec-card-row.cols-3 { grid-template-columns: repeat(2, 1fr); }
    .sec-heading { font-size: 36px; }
  }
  @media (max-width: 768px) {
    .sec-inner { padding: 64px 16px; }
    .sec-header { gap: 12px; }
    .sec-eyebrow { font-size: 12px; letter-spacing: 2px; }
    .sec-heading { font-size: 28px; line-height: 1.2; letter-spacing: -0.3px; }
    .sec-cards-wrap { margin-top: 24px; gap: 16px; }
    .sec-card-row { gap: 16px; }
    .sec-card-row.cols-3, .sec-card-row.cols-2 { grid-template-columns: 1fr; }
    .sec-hero-card { padding: 24px; border-radius: 16px; }
    .sec-hero-title { font-size: 16px; }
    .sec-hero-desc { font-size: 13px; }
    .sec-hero-icon { width: 56px; height: 56px; }
    .sec-hero-icon svg { width: 30px; height: 30px; }
    .sec-card { padding: 20px; border-radius: 14px; gap: 12px; }
    .sec-card-title { font-size: 15px; }
    .sec-card-desc { font-size: 13px; }
    .sec-card-icon { width: 32px; height: 32px; }
    .sec-card-icon svg { width: 32px; height: 32px; }
    .sec-icon-badge { width: 40px; height: 40px; border-radius: 10px; }
    .sec-icon-badge svg { width: 20px; height: 20px; }
  }
</style>
