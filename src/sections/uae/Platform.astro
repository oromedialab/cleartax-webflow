---
/**
 * UAE platform / Scale-Security-Reliability accordion + Performance Hub.
 * Ported from uae-landing-page/index.html:1166-1307.
 */
interface AccItem {
  id: string;
  icon: string;
  title: string;
  body: string;
  features: string[];
}

const accItems: AccItem[] = [
  {
    id: 'scale',
    icon: '⚡',
    title: 'Scale — Handle Any Volume',
    body: 'Our cloud-native architecture handles peak loads of 1M+ invoices per hour with auto-scaling infrastructure. Whether you process 100 or 10 million invoices annually, ClearTax scales with you.',
    features: ['1M+ invoices/hr', 'Auto-scaling', 'Multi-entity support', 'Bulk processing'],
  },
  {
    id: 'security',
    icon: '🛡️',
    title: 'Security — Enterprise-Grade Protection',
    body: 'ISO 27001 certified with SOC 2 Type II compliance. UAE data residency ensures your invoice data never leaves the country, meeting TDRA and FTA requirements.',
    features: ['ISO 27001', 'SOC 2 Type II', 'AES-256 encryption', 'UAE residency'],
  },
  {
    id: 'reliability',
    icon: '🔄',
    title: 'Reliability — 99.9% Uptime SLA',
    body: 'Contractual 99.9% uptime SLA backed by multi-region active-active deployment across UAE data centres. Automatic failover and 24x7 NOC team.',
    features: ['99.9% SLA', 'Multi-region', 'Auto-failover', '24x7 NOC'],
  },
  {
    id: 'compliance',
    icon: '📋',
    title: 'Compliance — Always Up-to-Date',
    body: 'FTA regulatory updates are automatically reflected in the platform — no manual updates required. Our compliance team monitors FTA announcements 24/7.',
    features: ['Auto-updates', 'FTA certified', 'Zero-downtime', 'Alerts'],
  },
];

const stats = [
  { val: '250M', sup: '+', label: 'Invoices processed' },
  { val: '99.9', sup: '%', label: 'Uptime achieved' },
  { val: '<1', sup: 's', label: 'Avg. submission time' },
  { val: '5000', sup: '+', label: 'Enterprise clients' },
];

const trustLogos = [
  { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69e0c09f3a4c77f59ef94ec9_fta%20(1).png', alt: 'FTA', title: 'FTA Approved' },
  { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de3489d33a3b65b80679b3_PEPPOL.svg', alt: 'PEPPOL', title: 'Peppol' },
  { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de348a727b4af4ae07f283_AICPA.svg', alt: 'SOC 2', title: 'SOC 2 Compliant' },
  { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de34899c0f1c6735b19fc1_SSL.svg', alt: 'SSL', title: 'SSL Secure' },
];
---

<section class="ssr-section" id="platform">
  <div class="section-inner">
    <div class="section-eyebrow" style="color:#A89FF0">Enterprise Ready</div>
    <h2 class="section-h2">Built for scale, <em style="color:#8B7EE8">security &amp; reliability</em></h2>
    <p class="section-sub">ClearTax's infrastructure is purpose-built for enterprise-grade compliance — from single entities to multi-city conglomerates.</p>

    <div class="ssr-grid">
      <div class="ssr-accordion" data-acc-root>
        {accItems.map((item, i) => (
          <div class:list={['acc-item', i === 0 && 'open']} data-acc-item>
            <div class="acc-header" data-acc-trigger>
              <div class="acc-icon">{item.icon}</div>
              <h4>{item.title}</h4>
              <div class="acc-chevron">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </div>
            </div>
            <div class="acc-body">
              <p>{item.body}</p>
              <div class="acc-features">
                {item.features.map((f) => <span class="acc-feature-tag">{f}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="ssr-visual">
        <div class="ssr-visual-card">
          <div class="ssr-visual-head">Platform Performance</div>
          <div class="ssr-stat-grid">
            {stats.map((s) => (
              <div class="ssr-stat-item">
                <div class="ssr-stat-val">{s.val}<sup>{s.sup}</sup></div>
                <div class="ssr-stat-label">{s.label}</div>
              </div>
            ))}
          </div>

          <div style="margin-top:28px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.07)">
            <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;margin-bottom:14px">Compliance &amp; Certifications</div>
            <div class="trust-logos-grid">
              {trustLogos.map((l) => (
                <div class="trust-logo-card" title={l.title}>
                  <img src={l.src} alt={l.alt} class="trust-logo-img" loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .ssr-section { background: var(--color-dark); padding: 100px 0; }
  .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(99, 85, 216, 0.10);
    border: 1px solid rgba(99, 85, 216, 0.25);
    color: var(--color-purple);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .section-h2 {
    font-size: clamp(30px, 3.5vw, 46px);
    font-weight: 900;
    color: var(--color-white);
    letter-spacing: -1.2px;
    line-height: 1.18;
    margin-bottom: 16px;
  }
  .section-h2 em { font-style: normal; }
  .section-sub { font-size: 17px; color: rgba(255, 255, 255, 0.5); line-height: 1.72; max-width: 100%; margin: 0; }

  .ssr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; margin-top: 60px; }
  .ssr-accordion { display: flex; flex-direction: column; gap: 8px; }
  .acc-item { border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; overflow: hidden; transition: border-color 0.3s; }
  .acc-item.open { border-color: rgba(99, 85, 216, 0.4); }
  .acc-header { display: flex; align-items: center; gap: 16px; padding: 20px 24px; cursor: pointer; background: rgba(255, 255, 255, 0.02); transition: background 0.2s; }
  .acc-item.open .acc-header { background: rgba(99, 85, 216, 0.08); }
  .acc-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(99, 85, 216, 0.15); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .acc-header h4 { flex: 1; font-size: 15.5px; font-weight: 700; color: var(--color-white); margin: 0; }
  .acc-chevron { width: 16px; height: 16px; transition: transform 0.3s; color: rgba(255, 255, 255, 0.4); }
  .acc-item.open .acc-chevron { transform: rotate(180deg); color: var(--color-purple-light); }

  .acc-body { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; padding: 0 24px; }
  .acc-item.open .acc-body { max-height: 400px; padding: 0 24px 20px; }
  .acc-body p { font-size: 14px; color: rgba(255, 255, 255, 0.55); line-height: 1.75; margin-bottom: 16px; }

  .acc-features { display: flex; flex-wrap: wrap; gap: 8px; }
  .acc-feature-tag { background: rgba(99, 85, 216, 0.10); border: 1px solid rgba(99, 85, 216, 0.25); color: var(--color-purple-light); font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 100px; }

  .ssr-visual { position: sticky; top: 120px; }
  .ssr-visual-card { background: var(--color-dark-2); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 24px; padding: 32px; box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4); }
  .ssr-visual-head { font-size: 11px; font-weight: 700; color: rgba(255, 255, 255, 0.3); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1.2px; }

  .ssr-stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .ssr-stat-item { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 14px; padding: 18px 16px; }
  .ssr-stat-val { font-size: 28px; font-weight: 900; color: var(--color-white); line-height: 1; }
  .ssr-stat-val sup { font-size: 14px; margin-left: 2px; color: var(--color-purple-light); }
  .ssr-stat-label { font-size: 11.5px; color: rgba(255, 255, 255, 0.4); margin-top: 6px; line-height: 1.4; }

  .trust-logos-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 20px; }
  .trust-logo-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; padding: 12px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; height: 84px; }
  .trust-logo-card:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(139, 127, 232, 0.4); transform: translateY(-2px); }
  .trust-logo-img { max-height: 100%; object-fit: contain; height: 50px; max-width: 135px; }

  @media (max-width: 1024px) {
    .ssr-section { padding: 80px 0; }
    .ssr-grid { grid-template-columns: 1fr; gap: 40px; }
    .ssr-visual { position: static; }
  }
  @media (max-width: 480px) {
    .ssr-stat-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function () {
    const root = document.currentScript.previousElementSibling.querySelector('[data-acc-root]') || document.currentScript.previousElementSibling.previousElementSibling?.querySelector('[data-acc-root]');
    if (!root) return;
    const items = root.querySelectorAll('[data-acc-item]');
    items.forEach((item) => {
      const trigger = item.querySelector('[data-acc-trigger]');
      if (!trigger) return;
      trigger.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        items.forEach((other) => other.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
  })();
</script>
