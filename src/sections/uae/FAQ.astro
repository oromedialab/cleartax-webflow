---
/**
 * UAE FAQ accordion — CSS ported from archive/uae-landing-page/index.html:1822-2015.
 * Animated height transitions with `transitionend` to settle on `auto` so
 * the open panel handles content reflow on viewport resize.
 */
interface FaqItem {
  q: string;
  /** Plain string OR array of paragraphs / lists. */
  a:
    | string
    | Array<
        { kind: "p"; html: string } | { kind: "ul" | "ol"; items: string[] }
      >;
}

const items: FaqItem[] = [
  {
    q: "What is e-invoicing in the UAE?",
    a: "E-invoicing in the UAE refers to the electronic generation, submission, and storage of invoices in a standardized digital format. This process supports the UAE's move towards a fully digitized tax system.",
  },
  {
    q: "What are the advantages of using ClearTax for e-invoicing in the UAE?",
    a: [
      {
        kind: "p",
        html: "ClearTax offers a seamless, end-to-end e-invoicing solution tailored to meet UAE's regulatory requirements. Key advantages include:",
      },
      {
        kind: "ul",
        items: [
          "Easy integration with ERP/POS systems.",
          "Peppol-compliant invoicing capabilities.",
          "Automated error handling and real-time compliance checks.",
          "Advanced dashboards and insightful reporting tools.",
          "24/7 dedicated support for technical and compliance queries.",
        ],
      },
    ],
  },
  {
    q: "When is e-invoicing being implemented, and what are the phases for UAE?",
    a: [
      {
        kind: "p",
        html: "E-invoicing in the UAE is set to become mandatory by <strong>July 2026</strong>. The phased implementation includes:",
      },
      {
        kind: "ul",
        items: [
          "<strong>Q4 2024</strong>: Accreditation of service providers begins.",
          "<strong>Q2 2025</strong>: Legislative updates for e-invoicing are introduced.",
          "<strong>Q2 2026</strong>: Phase 1 of e-invoicing reporting goes live.",
        ],
      },
    ],
  },
  {
    q: "What are the benefits of using e-invoicing software?",
    a: [
      {
        kind: "ol",
        items: [
          "Faster invoice processing and reduced errors.",
          "Enhanced compliance with real-time data transmission.",
          "Improved transparency and efficiency in financial operations.",
          "Cost savings by eliminating manual processes and paper invoices.",
          "Simplified VAT reporting and reconciliation.",
        ],
      },
    ],
  },
  {
    q: "What are the key features of e-invoicing software?",
    a: [
      { kind: "p", html: "Effective e-invoicing software includes:" },
      {
        kind: "ol",
        items: [
          "Seamless integration with existing business systems.",
          "Real-time compliance checks and data validation.",
          "Compatibility with structured formats like XML and Peppol standards.",
          "Advanced reporting and error management tools.",
          "Secure data storage and archival capabilities.",
        ],
      },
    ],
  },
  {
    q: "What are the penalties for non-compliance with e-invoicing regulations?",
    a: [
      {
        kind: "p",
        html: "Non-compliance with e-invoicing regulations may result in:",
      },
      {
        kind: "ol",
        items: [
          "Fines imposed by the Federal Tax Authority (FTA).",
          "Rejection of invoices, affecting cash flow and business operations.",
          "Legal liabilities for repeated violations.",
        ],
      },
    ],
  },
  {
    q: "What is the role of accredited service providers (ASPs) in e-invoicing?",
    a: "ASPs are intermediaries approved by the FTA to facilitate the generation, validation, and submission of e-invoices. They ensure compliance by converting invoices into the required Peppol specified format and transmitting them to the FTA and receivers through secure networks.",
  },
  {
    q: "How does ClearTax's e-invoicing software meet compliance requirements?",
    a: [
      {
        kind: "p",
        html: "ClearTax ensures 100% compliance with FTA e-invoicing mandates through:",
      },
      {
        kind: "ol",
        items: [
          "Peppol-based integration for seamless data exchange.",
          "Real-time data validation and error correction.",
          "Automatic updates to incorporate regulatory changes.",
          "Secure archival of invoices in compliance with FTA guidelines.",
        ],
      },
    ],
  },
  {
    q: "Can businesses that are not registered for VAT be considered part of B2B e-invoicing transactions?",
    a: "No, VAT-registered businesses are the primary participants in B2B e-invoicing transactions. Non-VAT-registered businesses do not fall under the scope of mandatory e-invoicing requirements.",
  },
  {
    q: "Can ClearTax integrate with custom ERP systems?",
    a: "Yes, ClearTax offers flexible APIs that integrate seamlessly with any ERP, including custom systems, ensuring smooth implementation without disrupting operations.",
  },
  {
    q: "Can ClearTax handle bulk invoice processing?",
    a: "Absolutely. ClearTax's software is highly scalable, capable of processing up to 15,000 e-invoices per minute, ensuring smooth operations even during high-volume transactions.",
  },
];
---

<section
  class="faq-section box-border bg-[#FFFFFF] py-16 font-['Manrope'] text-[#0F1020] sm:py-24"
  id="faq"
>
  <div class="faq-container mx-auto max-w-[1200px] px-4 sm:px-6">
    <div class="faq-header mb-8 max-w-[720px] mx-auto text-center sm:mb-12">
      <h2
        class="faq-heading mb-4 lg:text-[44px] sm:text-[32px] font-semibold leading-[1.18] tracking-[-1.2px] text-[#0F1020]"
      >
        Frequently asked <em class="not-italic text-[#655DFF]">questions</em>
      </h2>
      <p
        class="faq-sub max-w-[540px] mx-auto text-lg leading-[1.44] text-black/80"
      >
        Everything you need to know about UAE e-invoicing and ClearTax.
      </p>
    </div>

    <div class="faq-list flex flex-col gap-3" data-faq-root>
      {
        items.map((it, i) => (
          <div
            class={`faq-item group overflow-hidden rounded-[14px] border border-[rgba(15,16,32,0.08)] bg-white transition-[border-color,box-shadow] duration-300 ease-in-out [box-sizing:border-box] [&.faq-open]:border-[rgba(99,85,216,0.35)] [&.faq-open]:shadow-[0_6px_24px_-12px_rgba(99,85,216,0.25)] ${i >= 5 ? "hidden hidden-faq" : ""}`}
          >
            <button
              class="faq-trigger flex w-full appearance-none items-center justify-between gap-4 border-0 bg-transparent px-[18px] py-[18px] text-left text-[15.5px] font-bold leading-[1.4] text-[#0F1020] [box-sizing:border-box] cursor-pointer focus-visible:rounded-[14px] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[#6355D8] sm:px-6 sm:py-[22px] sm:text-[17px]"
              type="button"
              aria-expanded="false"
            >
              <span class="faq-question min-w-0 flex-1 text-lg leading-[1.32] break-words text-[#0F172A] text-left">
                {it.q}
              </span>
              <span
                class="faq-icon flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[rgba(99,85,216,0.1)] text-[#6355D8] transition-[transform,background,color] duration-300 ease-in-out group-[.faq-open]:rotate-45 group-[.faq-open]:bg-[#6355D8] group-[.faq-open]:text-white"
                aria-hidden="true"
              >
                <svg class="h-[14px] w-[14px]" viewBox="0 0 14 14" fill="none">
                  <path
                    d="M7 1v12M1 7h12"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </button>
            <div class="faq-panel h-0 overflow-hidden transition-[height] duration-[320ms] [transition-timing-function:cubic-bezier(.4,0,.2,1)]">
              <div class="faq-answer px-[18px] pb-[18px] text-[14.5px] leading-[1.7] text-[#5A6070] sm:px-6 sm:pb-[22px] sm:text-[15.5px] [&_li]:mb-1.5 [&_ol]:m-0 [&_ol]:pl-5 [&_p:last-child]:mb-0 [&_p]:mb-2.5 [&_p]:mt-0 [&_strong]:text-[#0F1020] [&_ul]:m-0 [&_ul]:pl-5">
                {typeof it.a === "string" ? (
                  <p>{it.a}</p>
                ) : (
                  it.a.map((block) =>
                    block.kind === "p" ? (
                      <p set:html={block.html} />
                    ) : block.kind === "ul" ? (
                      <ul>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ul>
                    ) : (
                      <ol>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ol>
                    ),
                  )
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      items.length > 5 && (
        <div
          class="mt-6 mx-auto flex items-center justify-center"
          id="faq-load-more-container"
        >
          <button
            id="faq-load-more-btn"
            class="inline-flex h-10 items-center gap-2 justify-center border-gradient-[#110072]/50 rounded-3xl bg-white px-10 py-4 text-base font-bold leading-[1.4] text-[#1C0976] outline-offset-[-2px] transition-all duration-300 ease-in-out hover:scale-105 active:scale-95"
          >
            Load More
            <span class="flex items-center justify-center">
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M8 3V12M8 12L12 8M8 12L4 8"
                  stroke="#1C0976"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </button>
        </div>
      )
    }
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-faq-root]");
    if (!root) return;
    const items = root.querySelectorAll(".faq-item");

    const loadMoreBtn = document.getElementById("faq-load-more-btn");
    const loadMoreContainer = document.getElementById(
      "faq-load-more-container",
    );
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", function () {
        const hiddenItems = root.querySelectorAll(".hidden-faq");
        hiddenItems.forEach(function (item) {
          item.classList.remove("hidden", "hidden-faq");
        });
        if (loadMoreContainer) {
          loadMoreContainer.style.display = "none";
        }
      });
    }
    items.forEach(function (item) {
      const trigger = item.querySelector(".faq-trigger");
      const panel = item.querySelector(".faq-panel");
      if (!trigger || !panel) return;

      trigger.addEventListener("click", function () {
        const isOpen = item.classList.contains("faq-open");
        if (isOpen) {
          panel.style.height = panel.scrollHeight + "px";
          requestAnimationFrame(function () {
            panel.style.height = "0px";
          });
          item.classList.remove("faq-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          panel.style.height = panel.scrollHeight + "px";
          item.classList.add("faq-open");
          trigger.setAttribute("aria-expanded", "true");
          panel.addEventListener("transitionend", function handler(e) {
            if (e.propertyName !== "height") return;
            panel.removeEventListener("transitionend", handler);
            if (item.classList.contains("faq-open"))
              panel.style.height = "auto";
          });
        }
      });

      window.addEventListener("resize", function () {
        if (item.classList.contains("faq-open")) panel.style.height = "auto";
      });
    });
  })();
</script>
