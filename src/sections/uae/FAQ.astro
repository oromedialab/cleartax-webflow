---
/**
 * UAE FAQ accordion — ported from uae-landing-page/index.html:1819-2305.
 * Animated height transitions with `transitionend` to settle on `auto` so
 * the open panel handles content reflow on viewport resize.
 */
interface FaqItem {
  q: string;
  /** Plain string OR array of paragraphs / lists. */
  a:
    | string
    | Array<
        | { kind: 'p'; html: string }
        | { kind: 'ul' | 'ol'; items: string[] }
      >;
}

const items: FaqItem[] = [
  {
    q: 'What is e-invoicing in the UAE?',
    a: "E-invoicing in the UAE refers to the electronic generation, submission, and storage of invoices in a standardized digital format. This process supports the UAE's move towards a fully digitized tax system.",
  },
  {
    q: 'What are the advantages of using ClearTax for e-invoicing in the UAE?',
    a: [
      { kind: 'p', html: "ClearTax offers a seamless, end-to-end e-invoicing solution tailored to meet UAE's regulatory requirements. Key advantages include:" },
      {
        kind: 'ul',
        items: [
          'Easy integration with ERP/POS systems.',
          'Peppol-compliant invoicing capabilities.',
          'Automated error handling and real-time compliance checks.',
          'Advanced dashboards and insightful reporting tools.',
          '24/7 dedicated support for technical and compliance queries.',
        ],
      },
    ],
  },
  {
    q: 'When is e-invoicing being implemented, and what are the phases for UAE?',
    a: [
      { kind: 'p', html: 'E-invoicing in the UAE is set to become mandatory by <strong>July 2026</strong>. The phased implementation includes:' },
      {
        kind: 'ul',
        items: [
          '<strong>Q4 2024</strong>: Accreditation of service providers begins.',
          '<strong>Q2 2025</strong>: Legislative updates for e-invoicing are introduced.',
          '<strong>Q2 2026</strong>: Phase 1 of e-invoicing reporting goes live.',
        ],
      },
    ],
  },
  {
    q: 'What are the benefits of using e-invoicing software?',
    a: [
      {
        kind: 'ol',
        items: [
          'Faster invoice processing and reduced errors.',
          'Enhanced compliance with real-time data transmission.',
          'Improved transparency and efficiency in financial operations.',
          'Cost savings by eliminating manual processes and paper invoices.',
          'Simplified VAT reporting and reconciliation.',
        ],
      },
    ],
  },
  {
    q: 'What are the key features of e-invoicing software?',
    a: [
      { kind: 'p', html: 'Effective e-invoicing software includes:' },
      {
        kind: 'ol',
        items: [
          'Seamless integration with existing business systems.',
          'Real-time compliance checks and data validation.',
          'Compatibility with structured formats like XML and Peppol standards.',
          'Advanced reporting and error management tools.',
          'Secure data storage and archival capabilities.',
        ],
      },
    ],
  },
  {
    q: 'What are the penalties for non-compliance with e-invoicing regulations?',
    a: [
      { kind: 'p', html: 'Non-compliance with e-invoicing regulations may result in:' },
      {
        kind: 'ol',
        items: [
          'Fines imposed by the Federal Tax Authority (FTA).',
          'Rejection of invoices, affecting cash flow and business operations.',
          'Legal liabilities for repeated violations.',
        ],
      },
    ],
  },
  {
    q: 'What is the role of accredited service providers (ASPs) in e-invoicing?',
    a: 'ASPs are intermediaries approved by the FTA to facilitate the generation, validation, and submission of e-invoices. They ensure compliance by converting invoices into the required Peppol specified format and transmitting them to the FTA and receivers through secure networks.',
  },
  {
    q: "How does ClearTax's e-invoicing software meet compliance requirements?",
    a: [
      { kind: 'p', html: 'ClearTax ensures 100% compliance with FTA e-invoicing mandates through:' },
      {
        kind: 'ol',
        items: [
          'Peppol-based integration for seamless data exchange.',
          'Real-time data validation and error correction.',
          'Automatic updates to incorporate regulatory changes.',
          'Secure archival of invoices in compliance with FTA guidelines.',
        ],
      },
    ],
  },
  {
    q: 'Can businesses that are not registered for VAT be considered part of B2B e-invoicing transactions?',
    a: 'No, VAT-registered businesses are the primary participants in B2B e-invoicing transactions. Non-VAT-registered businesses do not fall under the scope of mandatory e-invoicing requirements.',
  },
  {
    q: 'Can ClearTax integrate with custom ERP systems?',
    a: 'Yes, ClearTax offers flexible APIs that integrate seamlessly with any ERP, including custom systems, ensuring smooth implementation without disrupting operations.',
  },
  {
    q: 'Can ClearTax handle bulk invoice processing?',
    a: "Absolutely. ClearTax's software is highly scalable, capable of processing up to 15,000 e-invoices per minute, ensuring smooth operations even during high-volume transactions.",
  },
];
---

<section class="tw:bg-[#F7F6FC] tw:py-24 tw:text-[#0F1020] tw:box-border" id="faq">
  <div class="tw:max-w-[1200px] tw:mx-auto tw:px-6">
    <div class="tw:max-w-[720px] tw:mb-12">
      <div class="tw:inline-flex tw:items-center tw:bg-[rgba(99,85,216,0.10)] tw:border tw:border-[rgba(99,85,216,0.25)] tw:text-[#6355D8] tw:text-[12px] tw:font-bold tw:px-3.5 tw:py-1.5 tw:rounded-full tw:tracking-wider tw:uppercase tw:mb-4">
        FAQ
      </div>
      <h2 class="tw:text-[clamp(30px,3.5vw,46px)] tw:font-black tw:text-[#0F172A] tw:tracking-[-1.2px] tw:leading-[1.18] tw:mb-4">
        Frequently asked <em class="tw:not-italic tw:text-[#6355D8]">questions</em>
      </h2>
      <p class="tw:text-[17px] tw:text-[#64748B] tw:leading-[1.72] tw:max-w-[540px] tw:m-0">
        Everything you need to know about UAE e-invoicing and ClearTax.
      </p>
    </div>

    <div class="tw:flex tw:flex-col tw:gap-3" data-faq-root>
      {items.map((it) => (
        <div class="faq-item group tw:bg-white tw:border tw:border-[rgba(15,16,32,0.08)] tw:rounded-[14px] tw:overflow-hidden tw:transition-all tw:duration-250 [&.faq-open]:tw:border-[rgba(99,85,216,0.35)] [&.faq-open]:tw:shadow-[0_6px_24px_-12px_rgba(99,85,216,0.25)]">
          <button class="faq-trigger tw:flex tw:items-center tw:justify-between tw:gap-4 tw:w-full tw:p-[22px_24px] tw:cursor-pointer tw:text-[17px] tw:font-bold tw:text-[#0F172A] tw:leading-[1.4] tw:transition-all tw:focus-visible:outline-2 tw:focus-visible:outline-[#6355D8] tw:focus-visible:outline-offset-[-2px] tw:focus-visible:rounded-[14px]" type="button" aria-expanded="false">
            <span class="faq-question tw:flex-1 tw:min-w-0 tw:text-left tw:break-words">{it.q}</span>
            <span class="faq-icon tw:shrink-0 tw:w-7 tw:h-7 tw:rounded-full tw:bg-[rgba(99,85,216,0.10)] tw:text-[#6355D8] tw:flex tw:items-center tw:justify-center tw:transition-all tw:duration-300 group-[.faq-open]:tw:rotate-45 group-[.faq-open]:tw:bg-[#6355D8] group-[.faq-open]:tw:text-white" aria-hidden="true">
              <svg viewBox="0 0 14 14" class="tw:w-3.5 tw:h-3.5" fill="none">
                <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            </span>
          </button>
          <div class="faq-panel tw:h-0 tw:overflow-hidden tw:transition-[height] tw:duration-320 tw:ease-[cubic-bezier(0.4,0,0.2,1)]">
            <div class="faq-answer tw:px-6 tw:pb-[22px] tw:text-[15.5px] tw:leading-[1.7] tw:text-[#64748B]">
              {typeof it.a === 'string' ? (
                <p class="tw:m-0 tw:mb-2.5 tw:last:mb-0">{it.a}</p>
              ) : (
                it.a.map((block) =>
                  block.kind === 'p' ? (
                    <p class="tw:m-0 tw:mb-2.5 tw:last:mb-0" set:html={block.html} />
                  ) : block.kind === 'ul' ? (
                    <ul class="tw:m-0 tw:pl-5">{block.items.map((li) => <li class="tw:mb-1.5 tw:last:mb-0" set:html={li} />)}</ul>
                  ) : (
                    <ol class="tw:m-0 tw:pl-5">{block.items.map((li) => <li class="tw:mb-1.5 tw:last:mb-0" set:html={li} />)}</ol>
                  ),
                )
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const items = root.querySelectorAll('.faq-item');
    items.forEach(function (item) {
      const trigger = item.querySelector('.faq-trigger');
      const panel = item.querySelector('.faq-panel');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', function () {
        const isOpen = item.classList.contains('faq-open');
        if (isOpen) {
          panel.style.height = panel.scrollHeight + 'px';
          requestAnimationFrame(function () { panel.style.height = '0px'; });
          item.classList.remove('faq-open');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          panel.style.height = panel.scrollHeight + 'px';
          item.classList.add('faq-open');
          trigger.setAttribute('aria-expanded', 'true');
          panel.addEventListener('transitionend', function handler(e) {
            if (e.propertyName !== 'height') return;
            panel.removeEventListener('transitionend', handler);
            if (item.classList.contains('faq-open')) panel.style.height = 'auto';
          });
        }
      });

      window.addEventListener('resize', function () {
        if (item.classList.contains('faq-open')) panel.style.height = 'auto';
      });
    });
  })();
</script>
