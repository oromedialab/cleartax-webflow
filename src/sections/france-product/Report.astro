---
interface Row {
  transactionType: string;
  whatToReport: string;
  frequency: string;
  deadline: string;
}

const rows: Row[] = [
  {
    transactionType: "B2C Transactions",
    whatToReport: "Aggregated Data - Not Invoice Level",
    frequency: "Every 10 Days",
    deadline: "Day 20, Day 30 Of Month; Day 10 Following Month",
  },
  {
    transactionType: "B2B Exports",
    whatToReport: "Invoice & Line Item Level Data",
    frequency: "Every 10 Days",
    deadline: "Day 20, Day 30 Of Month; Day 10 Following Month",
  },
  {
    transactionType: "Payment Reporting",
    whatToReport: "Monthly Data Across All Three Categories",
    frequency: "Monthly",
    deadline: "Before 10th Of The Following Month",
  },
];

const CheckIcon = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect width="20" height="19.8676" rx="9.93378" fill="#F92B2E"/>
<path d="M10.1555 12.5332C9.51735 12.5332 9 12.0159 9 11.3777V7.55551V4.98764C9 4.44218 9.44218 4 9.98764 4H10.3234C10.8689 4 11.3111 4.44218 11.3111 4.98764V7.55551V11.3777C11.3111 12.0159 10.7937 12.5332 10.1555 12.5332Z" fill="white"/>
<path d="M10.9721 15.6611C10.7461 15.8871 10.474 16 10.1555 16C9.83712 16 9.56493 15.8871 9.33896 15.6611C9.11299 15.4351 9 15.1629 9 14.8445C9 14.5261 9.10785 14.2539 9.32355 14.0279C9.54952 13.802 9.82685 13.689 10.1555 13.689C10.474 13.689 10.7461 13.802 10.9721 14.0279C11.1981 14.2539 11.3111 14.5261 11.3111 14.8445C11.3111 15.1629 11.1981 15.4351 10.9721 15.6611Z" fill="white"/>
</svg>
`;
---

<section class="bg-[#F3F1F9] py-12 lg:py-25">
  <div id="Reports" class="lg:container px-4 lg:px-6 mx-auto">
    <div class="max-w-182 mx-auto text-center mb-12">
      <h2
        class="text-3xl md:text-[40px] lg:text-[44px] font-semibold mx-auto leading-1.18 text-[#030203] max-w-149.5"
      >
        What To Report,<span class="text-[#655DFF]"> And When</span>
      </h2>
      <p class="text-black/80 text-base mt-4 md:text-lg font-normal">
        E-Reporting covers cross-border B2B and B2C transactions not in scope
        for domestic e-invoicing. Frequencies and deadlines vary by VAT regime
        and transaction type.
      </p>
    </div>
    <!-- Desktop  -->
    <div class="hidden lg:block">
      <div class="grid grid-cols-[1.1fr_3.2fr] items-start gap-0">
        <!-- Column 1 -->
        <div class="flex flex-col min-w-0">
          <h3
            class="text-lg font-medium leading-[1.3] text-black mb-7.5 flex flex-col justify-start gap-1"
          >
            TRANSACTION TYPE
          </h3>
          <ul class="list-none m-0 p-0 flex flex-col">
            {
              rows.map((row) => (
                <li class="text-[16px] min-h-25 leading-[1.4] text-black flex items-center border-b border-black/16 last:border-0 font-normal pb-12.5 pt-7">
                  {row.transactionType}
                </li>
              ))
            }
          </ul>
        </div>
        <!-- second colunm -->
        <div class="flex flex-col min-w-0">
          <div class="grid grid-cols-[2fr_1.2fr] items-start gap-0">
            <div class="grid grid-cols-2 gap-8 px-8">
              <h3
                class="text-lg font-medium leading-[1.3] text-black mb-7 flex flex-col justify-start gap-1"
              >
                WHAT TO REPORT
              </h3>
              <h3
                class="text-lg text-center font-medium leading-[1.3] text-black mb-7 flex flex-col justify-start gap-1"
              >
                FREQUENCY
              </h3>
            </div>
            <h3
              class="text-lg text-center font-medium leading-[1.3] text-black mb-7 flex flex-col justify-start gap-1"
            >
              DEADLINE
            </h3>
          </div>

          <div
            class="bg-[#F4F2F9] mix-blend-multiply shadow-[inset_0px_4px_8px_0px_#00000014] rounded-xl border border-[#00000029] relative z-[1] lg:shadow-[inset_0_4px_8px_rgba(0,0,0,0.08)] box-shadow-[0px_2px_6px_rgba(0,0,0,0.08)] grid grid-cols-[2fr_1.2fr] items-stretch gap-0 py-[2px] pr-[2px]"
          >
            <ul class="list-none m-0 p-0 flex flex-col">
              {
                rows.map((row) => (
                  <li class="grid grid-cols-2 border-b border-[#000000]/10 last:border-0 pl-8 min-h-25 ">
                    <div class="pt-6.5 pb-6.5 max-w-44.5 flex items-center gap-[10px] text-base font-normal leading-[1.5] text-black/80">
                      {row.whatToReport && <span>{row.whatToReport}</span>}
                    </div>
                    <div class="pt-6.5 pb-6.5  flex  justify-center text-base leading-[1.4] text-black/80 font-normal">
                      {row.frequency && <span>{row.frequency}</span>}
                    </div>
                  </li>
                ))
              }
            </ul>

            <div
              class="bg-white rounded-[10px] shadow-[0_24px_60px_rgba(15,17,49,0.08),0_4px_14px_rgba(15,17,49,0.04)] relative z-[2] overflow-hidden"
            >
              <ul class="list-none m-0 p-0 flex flex-col">
                {
                  rows.map((row, index) => (
                    <li class="border-b border-black/16 last:border-0">
                      <div
                        class={`pl-5 pr-4.5 ${index === 0 ? "pt-[18px] pb-7" : "py-7"} min-h-25 flex gap-2 text-black text-base font-medium leading-[1.4]`}
                      >
                        <span
                          class="inline-flex items-start justify-center shrink-0 mt-1 "
                          set:html={CheckIcon}
                        />
                        {row.deadline && <span>{row.deadline}</span>}
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile View (Hidden on desktop) -->
    <div class="lg:hidden" id="rpt-mobile-container">
      <!-- Tab Buttons -->
      <div class="mb-6 overflow-x-auto scrollbar-none px-4 flex justify-start sm:justify-center w-full">
        <div
          class="flex gap-1 p-1 rounded-full border border-black/[0.08] w-max flex-nowrap"
        >
          <button
            class="rpt-tab-btn py-2 px-4 rounded-full text-base whitespace-nowrap font-semibold text-black/40 cursor-pointer transition-all duration-300 border-none bg-transparent"
            data-panel="rpt-panel-0">What To Report</button
          >
          <button
            class="rpt-tab-btn py-2 px-4 rounded-full text-base whitespace-nowrap font-semibold text-black/40 cursor-pointer transition-all duration-300 border-none bg-transparent"
            data-panel="rpt-panel-1">Frequency</button
          >
          <button
            class="rpt-tab-btn py-2 px-4 rounded-full text-base whitespace-nowrap font-semibold text-black/40 cursor-pointer transition-all duration-300 border-none bg-transparent rpt-tab-active"
            data-panel="rpt-panel-2">Deadline</button
          >
        </div>
      </div>

      <!-- Grid: Transaction Type (fixed) + Panel (switches) -->
      <div class="grid grid-cols-[1.4fr_2.1fr] bg-[#F4F2F9] -mx-4 px-4 py-7 gap-0">
        <!-- Column 1: Transaction Type (always visible) -->
        <div class="flex flex-col min-w-0">
          <h3
            class="text-base font-medium mb-3 min-h-[40px] flex items-center px-2"
          >
            Transaction Type
          </h3>
          <ul class="list-none m-0 p-0 flex flex-col">
            {
              rows.map((row) => (
                <li class="p-3 text-[14px] min-h-[64px] flex items-center border-b border-black/5 last:border-0 font-medium text-black/80 pr-1">
                  <p>{row.transactionType}</p>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Column 2: Switchable panels -->
        <div class="flex flex-col min-w-0 relative">
          <!-- Panel 0: What To Report -->
          <div id="rpt-panel-0" class="rpt-panel hidden flex-col">
            <h3
              class="text-base font-medium mb-3 min-h-[40px] flex items-center px-2 text-center justify-center"
            >
              What To Report
            </h3>
            <div class="bg-white rounded-[12px] border border-black/16 flex-1">
              <ul class="list-none m-0 p-0 flex flex-col">
                {
                  rows.map((row) => (
                    <li class="min-h-[64px] border-b border-black/16 last:border-0 flex items-center">
                      <div class="p-3 text-[13px] gap-2 text-black/80">
                        {row.whatToReport && <span>{row.whatToReport}</span>}
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- Panel 1: Frequency -->
          <div id="rpt-panel-1" class="rpt-panel hidden flex-col">
            <h3
              class="text-base font-medium mb-3 min-h-[40px] flex items-center px-2 text-center justify-center"
            >
              Frequency
            </h3>
            <div class="bg-white rounded-[12px] border border-black/16 flex-1">
              <ul class="list-none m-0 p-0 flex flex-col">
                {
                  rows.map((row) => (
                    <li class="min-h-[64px] border-b flex items-center border-black/16 last:border-0">
                      <div class="p-3 text-[14px]  gap-2 text-black/80">
                        {row.frequency && <span>{row.frequency}</span>}
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- Panel 2: Deadline (default active) -->
          <div id="rpt-panel-2" class="rpt-panel flex flex-col">
            <h3
              class="text-base font-medium mb-3 min-h-[40px] flex items-center px-2 text-center justify-center"
            >
              Deadline
            </h3>
            <div
              class="bg-[#F4F2F9] rounded-[12px] border border-black/16 flex-1"
            >
              <ul class="list-none m-0 p-0 flex flex-col">
                {
                  rows.map((row) => (
                    <li class="min-h-[64px] border-b border-black/10 last:border-0 flex items-center">
                      <div class="text-[13px] font-medium flex items-center gap-2 text-black">
                        <span
                          class="inline-flex items-center pl-2 justify-center shrink-0 mt-0.5"
                          set:html={CheckIcon}
                        />
                        {row.deadline && <span class="mt-1">{row.deadline}</span>}
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
   <p class="text-sm md:text-base text-black/80 mt-4 md:mt-5 lg:mt-7">Note : All e-reporting must follow DGFIP-opproved XML/JSON structured schemas. ClearTax automates all transformations, scheduling, and submissions your team sees a status dashboard, not row XML.</p>
  </div>
</section>

<style is:global>
  .rpt-tab-active {
    background-color: rgba(17, 0, 114, 0.12);
    color: #110072;
  }
  .rpt-panel.hidden {
    display: none !important;
  }
  .rpt-panel:not(.hidden) {
    display: flex;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline>
  (function () {
    function initRptTabs() {
      var container = document.getElementById("rpt-mobile-container");
      if (!container) return;

      var tabs = container.querySelectorAll(".rpt-tab-btn");
      var panels = container.querySelectorAll(".rpt-panel");

      tabs.forEach(function (tab) {
        if (tab.getAttribute("data-rpt-init")) return;
        tab.setAttribute("data-rpt-init", "1");

        tab.addEventListener("click", function () {
          var targetId = tab.getAttribute("data-panel");

          // Update tab active state
          tabs.forEach(function (t) {
            t.classList.remove("rpt-tab-active");
          });
          tab.classList.add("rpt-tab-active");

          // Show matching panel, hide others
          panels.forEach(function (p) {
            if (p.id === targetId) {
              p.classList.remove("hidden");
            } else {
              p.classList.add("hidden");
            }
          });
        });
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initRptTabs);
    } else {
      initRptTabs();
    }
    document.addEventListener("astro:page-load", initRptTabs);
  })();
</script>
