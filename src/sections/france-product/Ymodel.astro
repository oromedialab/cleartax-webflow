---
/**
 * USP Section V2 — Y-Model layout matching design reference.
 * Custom grid structure and inline Y-Model flow diagram.
 */
---

<section
  id="y-model"
  class="bg-[#FFFFFF] py-12 lg:py-[100px] w-full"
>
  <div class="max-w-[1280px] mx-auto px-4 lg:px-6">
    <div class="text-center mb-12">
      <h2
        id="usp-title-shield"
        class="lg:text-[44px]! font-semibold! text-[#000000] leading-[1.18]! m-0! max-md:text-[32px] max-lg:text-[26px]"
      >
        The Y-Model,
        <span class="text-[#655DFF]">demystified</span>
      </h2>
      <p
        class="text-[#000000]/80 text-lg font-normal max-md:text-base leading-[1.44] max-w-[780px] mx-auto mt-6"
      >
        France uses a decentralised CTC exchange model. Invoices flow via certified PAs — direct supplier-to-buyer exchange is not permitted by DGFiP.
      </p>
    </div>

    <div class="grid grid-cols-12 gap-7 w-full items-stretch">
      <!-- Left Column: Spans 8 cols on desktop -->
      <div class="col-span-8 max-lg:col-span-12 flex flex-col gap-7">
        
        <!-- Card 1: Y-Model Diagram Card -->
        <div class="tilted-card flex-1 min-h-[360px] flex flex-col">
          <div class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-6 lg:p-8 flex flex-col h-full relative overflow-hidden justify-between">
            <!-- Diagram Heading -->
            <div class="w-full flex justify-center sm:justify-end items-start">
              <div class="text-end">
                <h4 class="text-lg lg:text-[20px] font-normal text-black m-0">
                  Decentralised CTC Y-Model
                </h4>
              </div>
            </div>
            
            <!-- Image placeholder -->
            <div class="mt-6 flex-grow flex items-center justify-center w-full">
              <img
                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a228ed09946cf95f753c30e_ppf.png"
                alt="Decentralised CTC Y-Model Diagram"
                class="w-full h-auto max-w-full object-contain"
              />
            </div>
          </div>
        </div>

        <!-- Bottom Row: DGFiP-approved PA & EN16931 formats -->
        <div class="grid grid-cols-2 gap-7 max-md:grid-cols-1">
          <!-- Card 2: DGFiP-approved PA -->
          <div class="tilted-card min-h-[252px] flex flex-col">
            <div class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] p-7 flex flex-col h-full justify-between">
              <div class="tilted-card-img-wrapper mb-8 flex h-14 w-14 items-center justify-center rounded-[12px] bg-[#33887833]">
