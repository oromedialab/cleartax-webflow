<section
  id="y-model"
  class="bg-[#FFFFFF] py-12 lg:py-[100px] w-full"
>
  <div class="max-w-[1280px] mx-auto px-4 lg:px-6">
    <div class="text-center mb-12">
      <h2
        id="usp-title-shield"
        class="lg:text-[44px]! font-semibold! text-[#000000] leading-[1.18]! m-0! max-md:text-[32px] max-lg:text-[26px]"
      >
        The Y-Model,
        <span class="text-[#655DFF]">Demystified</span>
      </h2>
      <p
        class="text-[#000000]/80 text-lg font-normal max-md:text-base leading-[1.44] max-w-[780px] mx-auto mt-6"
      >
        France uses a decentralised CTC exchange model. Invoices flow via certified PAs — direct supplier-to-buyer exchange is not permitted by DGFiP.
      </p>
    </div>

    <div class="grid grid-cols-12 gap-7 w-full items-stretch">
      <!-- Left Column: Spans 8 cols on desktop -->
