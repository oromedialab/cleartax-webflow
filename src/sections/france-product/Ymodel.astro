            <div class="w-full flex justify-center sm:justify-end items-start">
              <div class="text-end">
                <h4 class="text-lg lg:text-[20px] font-normal text-black m-0">
                  Decentralised CTC Y-Model
                </h4>
              </div>
            </div>
            
