/**
 * Germany Hero section — modern Astro component
 * Matches reference layout and screenshot with hero-bg.png as background,
 * floating avatar badge, pill badge, trust strip, and glassmorphic HubSpot booking form.
 */
---

<section class="hero-section relative min-h-[780px] flex items-center pt-28 pb-20 md:pt-30 md:pb-24 lg:pt-40 lg:pb-28" id="hero">
  <!-- Sunset Skyline Background with dark to soft fade overlays -->
  <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat" style="background-image: url('https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a226d2334511041fc26d6bf_hero-bg.png');"></div>

  <div class="relative z-10 mx-auto lg:container w-full px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <!-- Hero Left Column -->
      <div class="hero-left-content flex flex-col items-start">
        
        <!-- Badge Capsule -->
        <h5 class="inline-flex items-center gap-1.5 bg-[linear-gradient(90deg,_rgba(144,_68,_169,_0.2)_0%,_rgba(184,_126,_200,_0.2)_100%)] text-[#8841A0] leading-[1] text-xs font-medium px-3 py-2 rounded-full mb-5">
          France e-Invoicing Mandate — September 2026
        </h5>
        
        <!-- Headline -->
        <h1 class="text-[36px] lg:text-[44px] xl:text-[56px] font-medium leading-[1.14] mb-6 bg-clip-text text-transparent" style="background-image: linear-gradient(180deg, #AA50C8 0%, #030203 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          Comply with France's E-Invoicing mandate before it's urgent.
        </h1>
        
        <!-- Description -->
        <p class="text-base sm:text-lg text-[#432984] leading-normal mb-10">
            ClearTax is listed on DGFiP's official PA registry and live in the French ecosystem. One platform, zero rebuilds — ready for September 2026 and every mandate that follows.
        </p>
         
