---
export interface Props {
    //
}

const steps = [
    {
        dateLine1: "S1",
        dateLine2: "2025",
        desc: "Central directory API opened for certified PA integration testing",
        active: true,
        highlight: false,
        lineSolid: true
    },
    {
        dateLine1: "OCT",
        dateLine2: "2025",
        desc: "PPF qualification testing opened for invoice flows 1, 6, 10",
        active: true,
        highlight: false,
        lineSolid: true
    },
    {
        dateLine1: "FEB",
        dateLine2: "2026",
        desc: "Voluntary pilot launched for early e-invoicing via certified PAs",
        active: true,
        highlight: false,
        lineSolid: true
    },
    {
        dateLine1: "SEP",
        dateLine2: "2026",
        desc: "Mandatory reception for all; €50M+ issuance/e-reporting begins",
        active: true,
        highlight: true,
        lineSolid: false
    },
    {
        dateLine1: "SEP",
        dateLine2: "2027",
        desc: "Full mandate extends to SMEs, micro-enterprises, & remaining businesses",
        active: false,
        highlight: false,
        lineSolid: false
    }
];
---

<section class="py-20 lg:py-25 bg-gradient-to-t from-[#F3F1F9] to-[#FFFFFF] overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-4 lg:px-6">
        <div class="text-center premium-reveal">
            <h2 class="text-3xl md:text-[40px] lg:text-[44px] font-semibold tracking-tight text-[#030203]">
                France's Reform Is On Track. <span class="text-[#655DFF]">Are you?</span>
            </h2>
            <p class="text-center font-normal max-w-200 mx-auto text-black/80 mt-3 lg:mt-4 text-base lg:text-lg">
                The DGFiP mandate rolls out in phases. Large enterprises hit mandatory compliance in September 2026. Implementation takes 8–10 weeks — the window is closing.
            </p>
        </div>

        <div class="flex flex-col gap-12 lg:grid lg:grid-cols-5 lg:gap-6 xl:gap-8 mt-12 lg:mt-24 relative z-10 max-w-[400px] lg:max-w-none mx-auto premium-reveal [transition-delay:200ms]">
            {steps.map((step, index) => (
                <div class="relative flex flex-row lg:flex-col w-[370px] lg:w-auto items-start lg:items-center group">
                    <div class="relative shrink-0 flex justify-center w-[96px]">
                        <div class={`w-[96px] h-[96px] rounded-full flex flex-col items-center justify-center text-white transition-all duration-300 group-hover:-translate-y-1 ${
                            step.highlight 
                                ? 'bg-[#6B5CE7] ring-[6px] ring-[#6B5CE7]/20 glow-pulse scale-105' 
                                : step.active 
                                    ? 'bg-[#6B5CE7] shadow-[0_0_20px_rgba(101,93,255,0.2)]' 
                                    : 'bg-[#A198EE] text-white/80'
                        }`}>
                            <span class="text-base font-semibold tracking-wide">{step.dateLine1}</span>
                            <span class="text-base font-semibold mt-0.5">{step.dateLine2}</span>
                        </div>
                    </div>
                    
                    <div class="ml-6 lg:ml-0 lg:mt-10 flex-1 lg:text-center pt-2 lg:pt-0">
                        <div class={`text-lg max-w-[250px] mt-1.5 leading-[1.5] text-wrap lg:mx-auto ${
                            step.highlight 
                                ? 'font-medium text-black text-lg' 
                                : step.active 
                                    ? 'font-normal text-black/56' 
                                    : 'font-normal text-black/56'
                        }`}>
                            {step.desc}
                        </div>
                    </div>
 
                    {index < steps.length - 1 && (
                        <>
                            <!-- Desktop Line -->
                            <div 
                                class={`hidden lg:block absolute top-[48px] left-1/2 w-full -z-10 ${step.lineSolid ? 'h-[2px] bg-[#655DFF]' : 'dashed-line-horizontal'}`}
                            ></div>
                            
                            <!-- Mobile Line -->
                            <div class={`lg:hidden absolute top-[96px] h-17 left-[48px] -translate-x-1/2 -bottom-12 -z-10 ${step.lineSolid ? 'w-[2px] bg-[#655DFF]' : 'dashed-line-vertical'}`}></div>
                        </>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>

<style is:global>
    .dashed-line-horizontal {
        height: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(90deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .dashed-line-vertical {
        width: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(0deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .glow-pulse {
        animation: pulse-glow 2s infinite ease-in-out;
    }
    @keyframes pulse-glow {
        0% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0.6);
        }
        70% {
            box-shadow: 0 0 0 12px rgba(107, 92, 231, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0);
        }
    }
</style>
