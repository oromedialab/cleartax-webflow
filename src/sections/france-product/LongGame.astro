        </div>
      </div>
            
            <!-- VAT Assurance (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-5 pb-0 pr-0 gap-8 md:gap-0 flex max-sm:flex-col overflow-hidden relative h-full"
                >
                    <div
                        class="flex flex-col justify-start relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4 w-full"
                        >
                            Enterprise-Scale Performance
                        </h3>
                        <p
                            class="text-base max-w-192 font-normal leading-normal text-black/80 m-0"
                        >
                        Processes 100M+ invoices per month globally with 99.88% uptime for enterprises that cannot afford compliance downtime.
                        </p>
                    </div>
                    <div
                        class="flex justify-end items-end order-1 lg:order-2 ml-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a27d65b63fbebd86ce1609f_platform-advantage-5-2.png"
                            alt="VAT Assurance"
                            class="w-full h-auto object-contain origin-top-right flex justify-center items-end pt-3"
                            loading="lazy"
                            decoding="async"
                        />
