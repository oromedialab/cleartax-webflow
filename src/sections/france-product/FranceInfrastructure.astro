---
/**
 * Infrastructure Tab Switcher Component
 */
const tabs = [
  {
    id: "at-scale",
    label: "At Scale",
    image: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a05563018464102613a7afe_compliance.png",
