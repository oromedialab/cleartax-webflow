---
export interface Props {
  stats?: Array<{
    value: string;
    label: string;
    bg: string;
  }>;
}

const features = [
  {
    title: "Disaster Recovery",
    description:
      "Instant failover across local providers keeps operations running without single-vendor dependency.",
    bg: "bg-[#ECF7ED]",
    iconBg: "bg-[#338878]/16",
    icon: `<svg width="27" height="32" viewBox="0 0 27 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M25.6486 8.72128C25.6341 8.39308 25.6246 8.06469 25.6201 7.73621C25.6018 6.50237 24.6311 5.49542 23.399 5.42654C19.6308 5.21609 16.6837 3.96267 14.1945 1.53633C13.7779 1.15456 13.1532 1.15456 12.7366 1.53633C10.2474 3.96267 7.30037 5.21609 3.53213 5.42654C2.30004 5.49542 1.32931 6.50237 1.31099 7.73621C1.30655 8.06469 1.29704 8.39308 1.28248 8.72128C1.144 15.9928 0.93639 25.9588 13.0313 30.1763C13.0892 30.1964 13.1484 30.2125 13.2086 30.2245L13.2092 30.2246C13.3785 30.2585 13.5527 30.2585 13.722 30.2246C13.7823 30.2125 13.8422 30.1963 13.9004 30.176C25.9602 25.9585 25.7871 16.0273 25.6486 8.72128Z" stroke="#338878" stroke-width="2.5" stroke-miterlimit="10"/><path d="M14.9662 16.2526C15.97 15.7157 16.653 14.6573 16.653 13.4393C16.653 11.6787 15.2257 10.2513 13.4649 10.2513C11.7041 10.2513 10.2767 11.6787 10.2767 13.4393C10.2767 14.6643 10.9675 15.7278 11.9808 16.2617" stroke="#338878" stroke-width="2.5" stroke-miterlimit="10" stroke-linecap="round"/><path d="M14.9759 16.2706L14.9513 19.688C14.9513 20.5157 14.2803 21.1866 13.4527 21.1866C12.625 21.1866 11.954 20.5157 11.954 19.688L11.9787 16.266" stroke="#338878" stroke-width="2.5" stroke-miterlimit="10" stroke-linecap="round"/></svg>`,
  },
  {
    title: "Data Sovereignty",
    description:
      "Data is processed and stored within your designated region to meet local compliance requirements.",
