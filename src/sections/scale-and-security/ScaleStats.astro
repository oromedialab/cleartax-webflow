---

<div
  class="scale-ss relative overflow-hidden lg:py-25 py-12 bg-linear-to-br from-[#F3F1F9] to-[#FFFFFFF] bg-cover bg-center md:bg-right lg:bg-center bg-no-repeat"
>
  <div class="mx-auto max-w-[1280px] px-4 lg:px-6 flex flex-col items-center">
    <div class="text-center">
      <h2
        class="text-[26px]! sm:text-[36px]! lg:text-[44px]! m-0 font-semibold! text-black leading-[1.18] mb-4 text-balance max-w-[732px] w-full mx-auto blur-reveal"
      >
        Sovereign infrastructure.
        <span class="text-[#655DFF]"> Zero single points of failure. </span>
      </h2>
      <p
        class="lg:text-lg! text-base! font-normal text-[#000000]/80 leading-[1.4] mb-12 max-w-[750px] w-full mx-auto premium-reveal [transition-delay:150ms]"
    >
        Deploy across AWS, OCI, or GCP based on each country’s regulatory,
        performance, and data residency needs.
    </p>
    </div>
    <div class="tw-grid lg:grid-cols-3 md:grid-cols-2 gap-6 w-full">
      {
        features.map((item, index) => (
          <div
            class={`relative lg:p-8 p-5 rounded-[24px] overflow-hidden transition-all duration-300 hover:-translate-y-1 ${item.bg} premium-reveal`}
            style={`transition-delay: ${index * 150}ms`}
          >
            <div
              class={`w-14 h-14 rounded-xl flex items-center justify-center mb-10 ${item.iconBg}`}
            >
              <Fragment set:html={item.icon} />
            </div>

            <div class="relative z-10">
              <h3 class="text-[22px] leading-[1.36] font-medium text-black mb-4 tracking-tight">
                {item.title}
              </h3>
              <p class="text-base leading-[1.5] text-black/80 font-normal">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
