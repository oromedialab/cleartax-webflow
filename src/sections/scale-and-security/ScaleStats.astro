    icon: '<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M26.25 25.3571C26.25 25.8503 25.8503 26.25 25.3571 26.25H2.14286C1.64975 26.25 1.25 25.8503 1.25 25.3571V2.14286C1.25 1.64975 1.64975 1.25 2.14286 1.25H25.3571C25.8503 1.25 26.25 1.64975 26.25 2.14286V25.3571Z" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M1.25 9.58337H26.25" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M1.25 17.9166H26.25" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M3.58594 13.75H5.1432" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M6.70044 13.75H8.2577" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M15.3074 13.75H23.9142" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M3.58594 5.4165H5.1432" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M6.70044 5.4165H8.2577" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M15.3074 5.4165H23.9142" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M3.58594 22.0833H5.1432" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M6.70044 22.0833H8.2577" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/><path d="M15.3074 22.0833H23.9142" stroke="#1F89FF" stroke-width="2.5" stroke-miterlimit="10"/></svg>',
  },
