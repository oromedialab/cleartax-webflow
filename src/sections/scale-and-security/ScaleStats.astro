---
/**
 * Scale Stats Section
 */
const stats = [
  { value: "500M+", label: "Invoices Processed Annually", color: "from-blue-500 to-cyan-400" },
  { value: "99.99%", label: "Uptime SLA Guaranteed", color: "from-green-500 to-emerald-400" },
  { value: "10ms", label: "Average API Latency", color: "from-purple-500 to-indigo-400" },
  { value: "5000+", label: "Enterprise Customers", color: "from-orange-500 to-amber-400" },
];
---

<section class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <div class="lg:w-1/2">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 leading-tight mb-6 blur-reveal">
          Infrastructure built for the <span class="text-blue-600">world's largest</span> tax operations.
        </h2>
        <p class="text-lg text-gray-600 mb-8 premium-reveal">
          Our cloud-native platform automatically scales to handle peak volumes without breaking a sweat. 
          Whether it's the end of the quarter or a nationwide tax deadline, we've got you covered.
        </p>
        <ul class="space-y-4 mb-10">
          {['Auto-scaling architecture', 'High-availability multi-region clusters', 'Real-time monitoring and alerts'].map(item => (
            <li class="flex items-center gap-3 text-gray-700 font-medium premium-reveal">
              <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
      
      <div class="lg:w-1/2 grid grid-cols-1 sm:grid-cols-2 gap-6">
        {stats.map((stat, idx) => (
          <div class="p-8 rounded-3xl border border-gray-100 bg-gray-50/50 hover:bg-white hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 group premium-reveal" style={`transition-delay: ${idx * 100}ms`}>
            <div class={`text-4xl md:text-5xl font-bold mb-2 bg-gradient-to-r ${stat.color} bg-clip-text text-transparent`}>
              {stat.value}
            </div>
            <div class="text-gray-500 font-medium tracking-wide">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
