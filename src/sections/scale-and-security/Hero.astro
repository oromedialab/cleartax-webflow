---
/**
 * Scale and Security Hero Section
 */
---

<section class="relative overflow-hidden bg-[#0F0F10] py-20 lg:py-32">
  <!-- Background Accents -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none opacity-20">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-600 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple-600 blur-[120px] rounded-full"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8 blur-reveal">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-white/70 text-sm font-medium tracking-wide uppercase">Enterprise Grade Infrastructure</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-8 clip-reveal">
        Scale with <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Confidence</span>, 
        Secure by Design.
      </h1>
      
      <p class="text-lg md:text-xl text-white/60 leading-relaxed mb-12 max-w-2xl mx-auto premium-reveal [transition-delay:200ms]">
        Experience the most robust e-invoicing platform designed for global enterprises. 
        Unmatched throughput, military-grade security, and 99.99% uptime.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 premium-reveal [transition-delay:400ms]">
        <a href="#contact" class="px-8 py-4 bg-white text-black font-semibold rounded-full hover:bg-gray-100 transition-all duration-300 w-full sm:w-auto text-center">
          Request Enterprise Demo
        </a>
        <a href="#security" class="px-8 py-4 bg-white/5 text-white font-semibold rounded-full border border-white/10 hover:bg-white/10 transition-all duration-300 w-full sm:w-auto text-center">
          Security Whitepaper
        </a>
      </div>
    </div>
  </div>

  <!-- Decorative Grid -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
</section>

<style is:global>
  .clip-reveal {
    clip-path: inset(100% 0 0 0);
    transition: clip-path 1.2s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .clip-reveal.is-visible {
    clip-path: inset(0 0 0 0);
  }
  
  .blur-reveal {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .blur-reveal.is-visible {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  .premium-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
