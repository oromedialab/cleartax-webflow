---
/**
 * Security Features Section
 */
const features = [
  {
    title: "SOC 2 Type II",
    desc: "Rigorous annual auditing for security, availability, and confidentiality.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`
  },
  {
    title: "ISO 27001",
    desc: "International standard for information security management systems.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>`
  },
  {
    title: "AES-256 Encryption",
    desc: "Data is encrypted at rest and in transit using military-grade standards.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09a13.916 13.916 0 002.103-4.411C5.696 12.467 5.056 9.812 5.056 7V5a1 1 0 011-1h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    title: "Data Residency",
    desc: "Local data residency options to comply with regional regulations.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2 2 2 0 012 2v.625M15.345 3.147A11.39 11.39 0 0112 3c-5.854 0-10.71 4.408-11.317 10.147L1.5 13"></path></svg>`
  }
];
---

<section id="security" class="py-24 bg-gray-950 text-white relative">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 blur-reveal">
        Enterprise-grade <span class="text-purple-400">Security</span>
      </h2>
      <p class="text-lg text-white/60 premium-reveal">
        We prioritize your data security with multi-layered protection and continuous monitoring. 
        Trusted by the world's most security-conscious organizations.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((f, idx) => (
        <div class="p-8 rounded-2xl bg-white/5 border border-white/10 hover:border-purple-500/50 hover:bg-white/10 transition-all duration-500 premium-reveal" style={`transition-delay: ${idx * 100}ms`}>
          <div class="w-16 h-16 rounded-xl bg-purple-500/20 flex items-center justify-center text-purple-400 mb-6 group-hover:scale-110 transition-transform">
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="text-xl font-bold mb-4">{f.title}</h3>
          <p class="text-white/50 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-20 p-10 rounded-3xl bg-gradient-to-br from-blue-900/40 to-purple-900/40 border border-white/10 backdrop-blur-xl flex flex-col md:flex-row items-center justify-between gap-8 premium-reveal">
      <div>
        <h4 class="text-2xl font-bold mb-2">Ready to secure your tax operations?</h4>
        <p class="text-white/60">Download our comprehensive security architecture whitepaper.</p>
      </div>
      <a href="#" class="px-8 py-4 bg-white text-black font-semibold rounded-full hover:bg-gray-100 transition-all">
        Download Whitepaper
      </a>
    </div>
  </div>
</section>
