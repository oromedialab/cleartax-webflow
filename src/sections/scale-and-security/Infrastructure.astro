---

<div class="infrastructure-section relative bg-[#FCFCFD] py-12 lg:py-25 overflow-hidden border-t border-[#E5E5E5]">
  <div class="mx-auto max-w-[1280px] px-4 md:px-6">
    <div class="text-center mb-16">
      <h2 class="text-[26px] lg:text-[44px] font-semibold text-black leading-[1.1] mb-4 blur-reveal">
        Infrastructure That <span class="text-[#655DFF]">Grows With You</span>
      </h2>
      <p class="text-base lg:text-lg text-black/60 max-w-[750px] mx-auto premium-reveal [transition-delay:100ms]">
        From the first return to millions of invoices across every jurisdiction — our platform handles it without blinking.
      </p>
    </div>

    <!-- Tab Bar -->
    <div class="flex justify-center mb-7 overflow-x-auto pb-2 hide-scrollbar">
      <div class="inline-flex bg-white border w-full justify-evenly border-[#E5E5E5] rounded-full p-1.5 gap-1">
        {tabs.map((tab, index) => (
          <button
            class={`flex items-center w-full justify-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 infra-tab-btn ${index === 0 ? 'active-tab text-black' : 'text-black/40'}`}
            data-tab={tab.id}
            data-active-bg={
              index === 0 ? 'bg-[#E5AB82]/20' : 
              index === 1 ? 'bg-[#338878]/20' : 
              index === 2 ? 'bg-[#13859F]/20' : 
              index === 3 ? 'bg-[#9878AF]/20' :
              'bg-[#655DFF]/20'
            }
            style={index === 0 ? `background-color: ${['rgba(229, 171, 130, 0.2)', 'rgba(51, 136, 120, 0.2)', 'rgba(19, 133, 159, 0.2)', 'rgba(152, 120, 175, 0.2)', 'rgba(101, 93, 255, 0.2)'][index]}` : ''}
          >
            <span class="icon-wrapper opacity-60 transition-all duration-300" set:html={tab.icon}></span>
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Content Area -->
    <div class="relative bg-white border border-[#E5E5E5] rounded-[32px] p-6 lg:p-10 min-h-[440px] grid overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.02)]">
      {tabs.map((tab, index) => (
        <div 
          class={`infra-tab-content grid grid-cols-1 sm:grid-cols-2 gap-12 lg:gap-20 items-center transition-all duration-500 [grid-area:1/1] ${index === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-[0.98] pointer-events-none z-0'}`}
          id={`content-${tab.id}`}
        >
          <!-- Left: Text -->
          <div>
            <h3 class="text-[24px] md:text-[32px] font-semibold text-black leading-[1.2] mb-6">
              {tab.title}
            </h3>
            <p class="text-base lg:text-lg text-black/70 leading-relaxed mb-10">
              {tab.description}
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-8">
              {tab.points.map((point) => (
                <div class="flex items-center gap-2 group">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[#D97D54] group-hover:scale-110 transition-transform">
                   <span set:html={point.cardIcon}></span>
                  </div>
                  <span class="text-base font-medium text-black/80">{point.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Right: Visual Area -->
          <div class="relative group">
            <div class="aspect-[4/3] rounded-3xl bg-[#FAF1ED] border border-[#F5E6DE] flex items-center justify-center overflow-hidden">
               {tab.image ? (
                  <img 
                    src={tab.image} 
                    alt={tab.label}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
               ) : null}
               
               
            </div>
            
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const initTabs = () => {
      const section = document.querySelector('.infrastructure-section');
      if (!section) return;

      const btns = section.querySelectorAll('.infra-tab-btn');
      const contents = section.querySelectorAll('.infra-tab-content');
      let isTransitioning = false;

      // Function to switch tabs
      const switchTab = (targetId) => {
        if (isTransitioning) return;
        
        const targetContent = section.querySelector(`#content-${targetId}`);
        const activeContent = section.querySelector('.infra-tab-content:not(.hidden)');
        
        if (targetContent === activeContent) return;
        isTransitioning = true;

        // 1. Update Buttons
        btns.forEach(btn => {
          if (btn.getAttribute('data-tab') === targetId) {
            btn.classList.add('active-tab');
            btn.classList.remove('text-black/40');
            
            // Apply dynamic background
            const bgClass = btn.getAttribute('data-active-bg');
            if (bgClass) {
              // Remove all bg classes from other buttons
              btns.forEach(b => {
                const allBgClasses = [
                  'bg-[#E5AB82]/20', 'bg-[#338878]/20', 'bg-[#13859F]/20', 
                  'bg-[#9878AF]/20', 'bg-[#655DFF]/20'
                ];
                b.classList.remove(...allBgClasses);
              });
              btn.classList.add(bgClass);
            }
            
            // Reset styles
            btn.style.removeProperty('background-color');
            
            // Update icons
            const iconWrapper = btn.querySelector('.icon-wrapper');
            if (iconWrapper) {
              iconWrapper.style.filter = 'grayscale(0)';
              iconWrapper.style.opacity = '1';
            }
          } else {
            btn.classList.remove('active-tab');
            btn.classList.add('text-black/40');
            
            // Reset styles
            const allBgClasses = [
              'bg-[#E5AB82]/20', 'bg-[#338878]/20', 'bg-[#13859F]/20', 
              'bg-[#9878AF]/20', 'bg-[#655DFF]/20'
            ];
            btn.classList.remove(...allBgClasses);
            btn.style.removeProperty('background-color');
            
            // Reset icons
            const iconWrapper = btn.querySelector('.icon-wrapper');
            if (iconWrapper) {
              iconWrapper.style.filter = 'grayscale(1)';
              iconWrapper.style.opacity = '0.4';
            }
          }
        });

        // 2. Transition Content
        contents.forEach(content => {
          if (content.id === `content-${targetId}`) {
            content.classList.remove('opacity-0', 'scale-[0.98]', 'pointer-events-none', 'z-0');
            content.classList.add('opacity-100', 'scale-100', 'z-10');
          } else {
            content.classList.add('opacity-0', 'scale-[0.98]', 'pointer-events-none', 'z-0');
            content.classList.remove('opacity-100', 'scale-100', 'z-10');
          }
        });
        
        setTimeout(() => {
          isTransitioning = false;
        }, 500);
      };

      // Add click listeners
      btns.forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.getAttribute('data-tab')));
      });
    };

    // Initialize on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }
  })();
</script>

