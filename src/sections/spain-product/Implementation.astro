<div class="infrastructure-section relative bg-[#FFFFFF] py-12 lg:py-25 overflow-hidden [&_button]:font-[inherit]">
  <div class="mx-auto max-w-[1280px] w-full px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-[26px] md:text-[36px] lg:text-[44px] max-w-[560px] mx-auto font-semibold! text-black leading-[1.18] mb-4 blur-reveal m-0">
       Built for tax compliance.  <span class=" text-[#655DFF]">Not retrofitted for it.</span>
      </h2>
      <p class="text-base lg:text-lg text-[#000000]/80 max-w-[676px] leading-1.4 mx-auto premium-reveal [transition-delay:100ms]">
        Most e-invoicing tools are EDI platforms or ERP add-ons with compliance bolted on. ClearTax was built from day one for tax and it shows.
      </p>
    </div>

    <!-- Tab Bar Desktop Only -->
    <div class="!hidden lg:!flex justify-center mb-7 overflow-x-auto pb-2 [scrollbar-width:_none] [-ms-overflow-style:_none] [&::-webkit-scrollbar]:hidden">
      <div class="inline-flex border w-full justify-evenly items-center border-[#000000]/12 rounded-full p-2">
        {tabs.map((tab, index) => (
          <button
            class={`flex items-center w-full justify-center gap-2 px-6 py-3 rounded-full text-base font-medium transition-all duration-300 infra-tab-btn cursor-pointer border-none bg-transparent outline-none ${index === 0 ? 'active-tab shadow-[0_4px_12px_rgba(0,0,0,0.05)]' : 'text-black/40'}`}
            style={index === 0 ? `color: ${['#BA6F3B', '#338878', '#13859f', '#8059ba', '#655DFF', '#BA6F3B'][index]};` : ''}
            data-index={index}
            data-tab={tab.id}
          >
            <img class="icon-wrapper opacity-60 transition-all duration-300 w-5 h-[17px] object-contain" src={tab.icon} alt="" loading="lazy" decoding="async" />
           <span class="leading-none mt-auto ">
                {tab.label}
           </span>
          
          </button>
        ))}
      </div>
    </div>


    <div class="!hidden lg:!block infra-swiper swiper relative bg-white border border-[#000000]/12 rounded-[12px] overflow-hidden w-full h-auto">
      <div class="swiper-wrapper">
        {tabs.map((tab) => (
          <div class="swiper-slide !h-auto p-5 min-h-[440px] flex items-center">
            <div 
              class="infra-tab-content grid grid-cols-1 sm:grid-cols-2 gap-12 lg:gap-20 items-center w-full"
              id={`content-${tab.id}`}
            >
              <!-- Left: Text -->
              <div class="p-4">
                <h3 class="text-[24px] md:text-[36px] max-w-124 font-semibold text-black leading-[1.2] mb-6 m-0">
                  {tab.title}
                </h3>
                <p class="text-base lg:text-lg text-black/80 max-w-149 leading-relaxed mb-10">
                  {tab.description}
                </p>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-8">
                  {tab.points.map((point) => (
                   <div class="flex items-center gap-3">
                      <div class="max-w-5 max-h-[17px] flex items-center justify-center">
                         <img
                          src={point.cardIcon}
                          class="max-w-5 max-h-[17px] object-cover "
                           alt=""
                           loading="lazy"
                           decoding="async"
                         />
                      </div>

                        <span class="text-base max-lg:text-lg xl:text-lg font-normal text-black leading-none whitespace-nowrap">
                             {point.label}
                        </span>
                </div>
                  ))}
                </div>
              </div>

              <!-- Right: Visual Area -->
              <div class="relative group w-full h-full aspect-[4/3] rounded-[12px] overflow-hidden">
                {tab.id === 'erp-native' && (
                  <div class="w-full h-full relative overflow-hidden bg-gradient-to-r from-[#E5AB82] to-[#E09C6B] flex items-center justify-center select-none erp-native-visual-container">
                    
                    <div class="absolute inset-0 max-w-[223px] top-[45%] -left-1 h-[48px] erp-base-image-wrapper">
                    <img src={tab.image} alt={tab.label} class="w-full h-full object-cover erp-base-image" loading="lazy" decoding="async" />
                    </div>
                    <div class="absolute right-[32%] top-0 h-auto w-[238px] erp-svg-wrapper">
                    <svg viewBox="0 0 229 400" fill="none" xmlns="http://www.w3.org/2000/svg">
