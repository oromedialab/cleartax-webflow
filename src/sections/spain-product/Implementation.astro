    <!-- Mobile Accordion -->
    <div class="!flex lg:!hidden flex-col gap-4">
      {tabs.map((tab, index) => (
        <div 
          class={`infra-acc-item border border-[#000000]/12 rounded-[12px] bg-white transition-all duration-500 overflow-hidden ${index === 0 ? 'acc-active shadow-sm' : ''}`}
          style={index === 0 ? `background-color: ${['rgba(229, 171, 130, 0.1)', 'rgba(51, 136, 120, 0.1)', 'rgba(19, 133, 159, 0.1)', 'rgba(152, 120, 175, 0.1)', 'rgba(101, 93, 255, 0.1)'][index]}` : ''}
        >
          <button 
            class="infra-acc-trigger w-full flex items-center justify-between p-5 text-left border-none bg-transparent outline-none cursor-pointer"
            data-index={index}
          >
            <div class="flex items-center gap-3 pointer-events-none">
              <img src={tab.icon} class={`icon-wrapper transition-all duration-300 w-5 h-[17px] object-contain ${index === 0 ? 'opacity-100' : 'opacity-40 grayscale'}`} alt="" loading="lazy" decoding="async" />
              <span class={`text-base font-semibold transition-colors duration-300 ${index === 0 ? '' : 'text-black/60'}`} style={index === 0 ? `color: ${['#BA6F3B', '#338878', '#13859f', '#8059ba', '#655DFF'][index]};` : ''}>{tab.label}</span>
            </div>
            <svg class={`acc-chevron w-5 h-5 transition-transform duration-500 pointer-events-none ${index === 0 ? 'rotate-180' : ''}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          
          <div 
            class="infra-acc-content transition-all duration-500 ease-in-out overflow-hidden"
            style={index === 0 ? 'max-height: 2000px; opacity: 1;' : 'max-height: 0px; opacity: 0;'}
          >
            <div class="px-5 pb-6">
              <h3 class="text-[20px] font-semibold text-black leading-[1.2] mb-4 m-0">{tab.title}</h3>
              <p class="text-sm text-black/70 leading-relaxed mb-6">{tab.description}</p>
              
              <div class="grid grid-cols-1 sm:grid sm:grid-cols-2 gap-4 mb-8">
                {tab.points.map((point) => (
                  <div class="flex items-center gap-3">
                    <div class="w-5 h-5 rounded-lg flex items-center justify-center text-[#D97D54] bg-black/5">
                     <img src={point.cardIcon} class="w-full h-full object-contain" alt="" loading="lazy" decoding="async" />
                    </div>
                    <span class="text-sm font-normal text-black/80 leading-none mt-auto">{point.label}</span>
                  </div>
                ))}
              </div>

              <div class="aspect-[4/3] rounded-2xl bg-[#FAF1ED] max-w-150 border border-[#F5E6DE] flex items-center justify-center overflow-hidden relative w-full h-full">
                {tab.id === 'erp-native' && (
