---
/**
 * Spain Mandate At A Glance section
 * Matches the reference layout with two rows of timeline cards and precise solid/dashed progress lines.
 */

const row1 = [
    {
        month: "OCT",
        year: "2026",
        date: "1 OCT 2026 · EXPECTED",
        desc: "Draft Ministerial Order enters force – Crea y Crece phase-in clock starts",
    },
    {
        month: "JAN",
        year: "2027",
        date: "1 JAN 2027",
        desc: "Verifactu mandatory for all CIT (corporate income tax) taxpayers",
    },
    {
        month: "JUL",
        year: "2027",
        date: "1 JUL 2027",
        desc: "Verifactu mandatory for self-employed (autónomos) and all IRPF taxpayers",
    },
];

const row2 = [
    {
        month: "AUG",
        year: "2027",
        date: "BY AUG 2027",
        desc: "AEAT public e-invoicing platform goes live (at least 2 months before Phase 1)",
    },
    {
        month: "OCT",
        year: "2027",
        date: "PHASE 1 · 1 OCT 2027",
        desc: "Structured e-invoicing + lifecycle reporting mandatory for businesses with turnover >€8M",
    },
    {
        month: "OCT",
        year: "2028",
        date: "PHASE 2 · 1 OCT 2028",
        desc: "Universal issuance. All businesses and professionals obligated",
    },
];

const allSteps = [...row1, ...row2];
---

<section class="py-20 lg:py-28 bg-[#F3F1F9] overflow-hidden" id="spain-mandate">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-8">
        <!-- Top header row -->
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-12">
            <div class="max-w-xl">
                <h2 class="text-4xl lg:text-[44px] font-semibold text-black leading-tight m-0 font-gilroy">
                    Spain Mandate At <span class="text-[#655DFF]">A Glance</span>
                </h2>
            </div>
            <p class="max-w-md text-base lg:text-lg text-black/80 font-normal m-0 lg:text-right">
                Dates per draft Ministerial Order (17 Apr 2026); subject to final BOE publication.
            </p>
        </div>

        <!-- Desktop Layout -->
        <div class="hidden lg:flex flex-col gap-24 relative">
            <!-- Row 1 -->
            <div class="grid grid-cols-3 gap-x-13 relative">
                {
                    row1.map((step, idx) => (
                        <div class="group relative flex flex-col items-start">
                            <!-- Line Segments -->
                            {idx === 0 && (
                                <div 
                                    class="absolute left-[54px] -right-20 h-[2px] bg-[#6B5CE7] top-[54px] z-0 animate-draw-x"
                                    style="animation-delay: 0.1s"
                                />
                            )}
                            {idx === 1 && (
                                <>
                                    <div 
                                        class="absolute left-[54px] -right-20 top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 0.5s"
                                    />
                                </>
                            )}
                            {idx === 2 && (
                                <>
                                    <div 
                                        class="absolute left-[-87px] w-[94px] top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 0.65s"
                                    />
                                    <div 
                                        class="absolute left-[54px] w-[100vw] top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 0.9s"
                                    />
                                </>
                            )}

                            <!-- Circle -->
                            <div 
                                class="w-[108px] h-[108px] border-[6px] border-transparent bg-clip-padding bg-[#5F56E8] rounded-full flex flex-col items-center justify-center text-white relative z-10 shadow-lg shadow-[#5F56E8]/15 transform transition-all duration-300 select-none glow-pulse"
                                style={`animation-delay: ${idx * 0.4}s`}
                            >
                                <span class="text-base font-semibold uppercase opacity-90 leading-none mb-0.5">{step.month}</span>
                                <span class="text-base font-semibold leading-none">{step.year}</span>
                            </div>

                            <!-- Text Content -->
                            <div class="mt-10 transform transition-all duration-300">
                                <div class="text-[#4D3BE2] text-base font-normal tracking-[1.5px] uppercase mb-3">
                                    {step.date}
                                </div>
                                <p class="text-black text-lg font-normal max-w-[384px] leading-relaxed">
                                    {step.desc}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-3 gap-x-13 relative">
                {
                    row2.map((step, idx) => (
                        <div class="group relative flex flex-col items-start">
                            <!-- Line Segments -->
                            {idx === 0 && (
                                <>
                                    <div 
                                        class="absolute -left-[100vw] right-[calc(100%-54px)] h-[2px] top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 0.9s"
                                    />
                                    <div 
                                        class="absolute left-[54px] -right-20 top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 1.3s"
                                    />
                                </>
                            )}
                            {idx === 1 && (
                                <>
                                    <div 
                                        class="absolute left-0 w-[54px] top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 1.45s"
                                    />
                                    <div 
                                        class="absolute left-[54px] -right-20 top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 1.7s"
                                    />
                                </>
                            )}
                            {idx === 2 && (
                                <>
                                    <div 
                                        class="absolute left-0 w-[54px] top-[54px] z-0 dashed-line-horizontal animate-draw-x"
                                        style="animation-delay: 1.85s"
                                    />
                                    
                                </>
                            )}

                            <!-- Circle -->
                            <div 
                                class="w-[108px] h-[108px] border-[6px] border-transparent bg-clip-padding bg-[#5F56E8] rounded-full flex flex-col items-center justify-center text-white relative z-10 shadow-lg shadow-[#5F56E8]/15 transform transition-all duration-300 select-none glow-pulse"
                                style={`animation-delay: ${(idx + 3) * 0.4}s`}
                            >
                                <span class="text-base font-semibold uppercase opacity-90 leading-none mb-0.5">{step.month}</span>
                                <span class="text-base font-semibold leading-none">{step.year}</span>
                            </div>

                            <!-- Text Content -->
                            <div class="mt-8 transform transition-all duration-300">
                                <div class="text-[#4D3BE2] text-base font-normal tracking-[1.5px] uppercase mb-3">
                                    {step.date}
                                </div>
                                <p class="text-black text-lg font-normal max-w-[384px] leading-relaxed">
                                    {step.desc}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- Mobile Layout -->
        <div class="block lg:hidden flex flex-col gap-10">
            {
                allSteps.map((step, idx) => (
                    <div class="group flex gap-6 relative">
                        <!-- Vertical line connection -->
                        {idx < allSteps.length - 1 && (
                            idx === 0 ? (
                                <div 
                                    class="absolute top-[42px] bottom-[-40px] left-[42px] -translate-x-1/2 w-[2px] bg-[#6B5CE7] z-0 animate-draw-y" 
                                    style={`animation-delay: ${(idx * 0.4) + 0.2}s`}
                                />
                            ) : (
                                <div 
                                    class="absolute top-[42px] bottom-[-40px] left-[42px] -translate-x-1/2 z-0 dashed-line-vertical animate-draw-y" 
                                    style={`animation-delay: ${(idx * 0.4) + 0.2}s`}
                                />
                            )
                        )}

                        <!-- Circle -->
                        <div 
                            class="w-[84px] h-[84px] border-[4px] border-transparent bg-clip-padding bg-[#5F56E8] rounded-full shrink-0 flex flex-col items-center justify-center text-white relative z-10 shadow-md shadow-[#5F56E8]/15 select-none glow-pulse"
                            style={`animation-delay: ${idx * 0.4}s`}
                        >
                            <span class="text-xs font-semibold tracking-wider uppercase opacity-90 leading-none mb-0.5">{step.month}</span>
                            <span class="text-xs font-semibold tracking-wider leading-none">{step.year}</span>
                        </div>

                        <!-- Content -->
                        <div class="flex flex-col justify-center py-1">
                            <div class="text-[#4D3BE2] text-sm font-normal tracking-[1.5px] uppercase mb-1.5">
                                {step.date}
                            </div>
                            <p class="text-black text-base font-normal leading-relaxed m-0">
                                {step.desc}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style is:global>
    .dashed-line-horizontal {
        height: 2px;
        --clr-border: #6B5CE7;
        background-image: repeating-linear-gradient(90deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .dashed-line-vertical {
        width: 2px;
        --clr-border: #6B5CE7;
        background-image: repeating-linear-gradient(0deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .glow-pulse {
        animation: pulse-glow 2.8s infinite ease-in-out;
    }
    .animate-draw-x {
        clip-path: inset(0 100% 0 0);
        animation: drawX 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    .animate-draw-y {
        clip-path: inset(0 0 100% 0);
        animation: drawY 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    @keyframes drawX {
        to {
            clip-path: inset(0 0 0 0);
        }
    }
    @keyframes drawY {
        to {
            clip-path: inset(0 0 0 0);
        }
    }
    @keyframes pulse-glow {
        0% {
            border-color: rgba(227, 223, 255, 0);
            box-shadow: 0 0 0 0 rgba(227, 223, 255, 0), 0 10px 25px -5px rgba(95, 86, 232, 0.1);
        }
        25% {
            border-color: rgba(227, 223, 255, 1);
            box-shadow: 0 0 0 0 rgba(227, 223, 255, 0.8), 0 10px 25px -5px rgba(95, 86, 232, 0.1);
        }
        70% {
            border-color: rgba(227, 223, 255, 0);
            box-shadow: 0 0 0 18px rgba(227, 223, 255, 0), 0 10px 25px -5px rgba(95, 86, 232, 0.1);
        }
        100% {
            border-color: rgba(227, 223, 255, 0);
            box-shadow: 0 0 0 0 rgba(227, 223, 255, 0), 0 10px 25px -5px rgba(95, 86, 232, 0.1);
        }
    }
</style>
