---
/**
 * Spain FAQ Accordion Component
 */
interface FaqItem {
  q: string;
  a: string;
}

const items: FaqItem[] = [
  {
    q: "Does ClearTax e-Invoicing support Spain's Verifactu and the Crea y Crece B2B mandate?",
    a: "Yes. ClearTax supports Spain's evolving e-Invoicing requirements, including Verifactu and the Crea y Crece B2B mandate. As regulations evolve, ClearTax updates the platform to help businesses stay compliant without changing their existing invoicing process.",
  },
  {
    q: "Which e-Invoice formats does ClearTax support for Spain?",
    a: "ClearTax supports UBL (the mandatory B2B format under RD 238/2026), Facturae (B2G via FACe, and accepted during the B2B transition), and other formats including EDIFACT and Peppol BIS where applicable. The platform handles format conversion and validation, so businesses do not have to manually manage multiple invoice standards.",
  },
  {
    q: "Does ClearTax integrate with SAP, Microsoft Dynamics and other ERPs?",
    a: "Yes. ClearTax integrates with SAP, Microsoft Dynamics, Oracle, NetSuite and other ERP systems through standard connectors and the ClearTax API. This allows businesses to automate e-Invoicing without replacing their existing ERP.",
  },
  {
    q: "What happens if Spain's e-Invoicing regulations change or deadlines shift again?",
    a: "Regulatory changes are expected as Spain rolls out its e-Invoicing framework. ClearTax continuously updates the platform to reflect new technical requirements, helping businesses stay compliant without rebuilding their integrations.",
  },
  {
    q: "Can ClearTax handle e-Invoicing for multi-entity or cross-border B2B operations involving Spain?",
    a: "Yes. ClearTax is a global e-Invoicing platform supporting businesses operating across multiple entities and countries. It applies Spain's compliance requirements while helping standardise e-Invoicing across different jurisdictions.",
  },
  {
    q: "What are the advantages of using ClearTax for e-Invoicing in Spain?",
    a: "ClearTax is an e-invoicing solution provider that goes beyond compliance. It offers a single API for multiple jurisdictions, country-specific configurations with pre-built workflows, a unified dashboard for complete visibility, and an in-house team of tax experts to help you navigate changing regulations with confidence. Instead of managing multiple tools, businesses can handle Spain's e-Invoicing requirements through a single solution.",
  },
  {
    q: "How does ClearTax support an in-house e-Invoicing setup without outsourcing our IT?",
    a: "You can integrate ClearTax with your existing ERP systems using APIs while keeping your IT infrastructure in-house. ClearTax manages the compliance layer, allowing internal teams to stay in control of their integrations.",
  },
  {
    q: "Can ClearTax work with Spain's public e-Invoicing platform (SPFE) or AEAT systems, and what does it offer in addition?",
    a: "Yes. ClearTax is designed to work with Spain's public e-Invoicing ecosystem where required. Beyond regulatory connectivity, it offers a single API for multiple jurisdictions, country-specific workflows, a unified dashboard for end-to-end visibility, and expert guidance to help businesses stay compliant as regulations evolve.",
  },
  {
    q: "Is ClearTax an authorised or certified e-Invoicing software provider for Verifactu?",
    a: "Spain does not currently certify Verifactu software providers. Instead, software must meet the technical requirements set by the regulations. ClearTax is built to align with these requirements and is continuously updated as regulations evolve. Businesses operating across Europe can use the same platform to manage multiple e-invoicing mandates, backed by enterprise integrations and an in-house team of tax experts.",
  },
  {
    q: "Does ClearTax support e-invoicing compliance across Spain and multiple European countries?",
    a: "Yes. ClearTax runs one platform across 50+ countries, covering Spain alongside France, Germany, Belgium and Poland.",
  },
];
---

<section
  class="faq-section box-border bg-[#FFFFFF] py-12 font-['Manrope'] text-[#0F1020] sm:py-20"
  id="faq"
>
  <div class="faq-container mx-auto max-w-[1200px] px-4 sm:px-6">
    <div class="faq-header mb-8 max-w-[720px] mx-auto text-center sm:mb-12">
      <h2
        class="faq-heading mb-4 m-0 lg:text-[44px] sm:text-[32px] text-[26px] font-semibold leading-[1.18] tracking-[-1.2px] text-black"
      >
        Frequently Asked <em class="not-italic text-[#655DFF]">Questions</em>
      </h2>
      <p
        class="faq-sub max-w-147 mx-auto lg:text-lg text-base leading-[1.44] text-black/80"
      >
        Everything you need to know about Spain e-invoicing and ClearTax.
      </p>
    </div>

    <div class="faq-list flex flex-col gap-5" data-faq-root>
      {
        items.map((it, i) => (
          <div
            class={`faq-item group overflow-hidden rounded-[8px] border border-[rgba(15,16,32,0.08)] bg-white transition-[border-color,box-shadow] duration-300 ease-in-out [box-sizing:border-box] ${i === 0 ? "faq-open" : ""} ${i >= 5 ? "hidden hidden-faq" : ""}`}
            style={`transition-delay: ${200 + i * 50}ms`}
          >
            <button
              class="faq-trigger flex w-full appearance-none items-center justify-between gap-4 border-0 bg-transparent px-[18px] py-[18px] text-left text-[15.5px] leading-[1.4] text-[#0F1020] [box-sizing:border-box] cursor-pointer focus-visible:rounded-[14px] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[#0057FF] sm:px-6 sm:py-[22px] sm:text-[17px]"
              type="button"
              aria-expanded={i === 0 ? "true" : "false"}
            >
              <h4 class="faq-question min-w-0 flex-1 font-medium text-[18px] sm:text-[20px] leading-[1.32] break-words text-[#0F172A] text-left m-0">
                {it.q}
              </h4>
              <span
                class="faq-icon flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[rgba(0,87,255,0.1)] text-[#0057FF] transition-[transform,background,color] duration-300 ease-in-out group-[.faq-open]:rotate-45 group-[.faq-open]:bg-[#0057FF1A] group-[.faq-open]:text-white"
                aria-hidden="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 14 14"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M6.69995 0.700195V12.7002M0.699951 6.7002H12.7"
                    stroke="#6355D8"
                    stroke-width="1.4"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </button>
            <div
              class={`faq-panel overflow-hidden transition-[height] duration-[320ms] [transition-timing-function:cubic-bezier(.4,0,.2,1)] ${i === 0 ? "" : "h-0"}`}
              style={i === 0 ? "height: auto;" : undefined}
            >
              <div class="faq-answer px-[18px] pb-[18px] leading-[1.7] text-[#5A6070] sm:px-6 sm:pb-[22px] text-[16px]">
                <p class="m-0" set:html={it.a} />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      items.length > 5 && (
        <div
          class="mt-12 mx-auto flex items-center justify-center"
          id="faq-load-more-container"
        >
          <button
            id="faq-load-more-btn"
            class="inline-flex items-center gap-2 justify-center rounded-full border border-[#110072] bg-white px-10 py-4 text-base font-medium font-['gilroy'] leading-[1.4] text-[#1C0976] outline-offset-[-2px] transition-all duration-300 ease-in-out hover:scale-105 active:scale-95 cursor-pointer"
          >
            Load More
            <span class="flex items-center justify-center">
              <svg
                width="10"
                height="11"
                viewBox="0 0 10 11"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M4.79999 0.799805V9.7998M0.799988 5.7998L4.79999 9.7998L8.79999 5.7998"
                  stroke="#1C0976"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </button>
        </div>
      )
    }
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-faq-root]");
    if (!root) return;
    const items = root.querySelectorAll(".faq-item");

    const loadMoreBtn = document.getElementById("faq-load-more-btn");
    const loadMoreContainer = document.getElementById(
      "faq-load-more-container",
    );
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", function () {
        const hiddenItems = root.querySelectorAll(".hidden-faq");
        hiddenItems.forEach(function (item) {
          item.classList.remove("hidden", "hidden-faq");
        });
        if (loadMoreContainer) {
          loadMoreContainer.style.display = "none";
        }
      });
    }
    items.forEach(function (item) {
      const trigger = item.querySelector(".faq-trigger");
      const panel = item.querySelector(".faq-panel");
      if (!trigger || !panel) return;

      trigger.addEventListener("click", function () {
        const isOpen = item.classList.contains("faq-open");
        if (isOpen) {
          panel.style.height = panel.scrollHeight + "px";
          requestAnimationFrame(function () {
            panel.style.height = "0px";
          });
          item.classList.remove("faq-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          panel.style.height = panel.scrollHeight + "px";
          item.classList.add("faq-open");
          trigger.setAttribute("aria-expanded", "true");
          panel.addEventListener("transitionend", function handler(e) {
            if (e.propertyName !== "height") return;
            panel.removeEventListener("transitionend", handler);
            if (item.classList.contains("faq-open"))
              panel.style.height = "auto";
          });
        }
      });

      window.addEventListener("resize", function () {
        if (item.classList.contains("faq-open")) panel.style.height = "auto";
      });
    });
  })();
</script>
