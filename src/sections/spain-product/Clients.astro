<section class="py-20 lg:py-25 bg-[#F3F1F9]">
    <div class="max-w-[1280px] mx-auto px-4 md:px-6">
        <div class="text-center mb-12">
            <h2
                class="text-[26px] md:text-[36px] lg:text-[44px] max-w-189 mx-auto font-semibold text-[#000000] leading-[1.18] m-0"
            >
                100+ Clients In The EU.
                <span class="block text-[#655DFF]"
                    >5,000+ Enterprises Worldwide.</span
                >
            </h2>
            <p
                class="text-base md:text-[18px] text-[#000000]/80 mt-4 max-w-170 mx-auto leading-[1.5]"
            >
                From global conglomerates to EU-headquartered enterprises,
                finance teams trust ClearTax to keep them compliant — across
                every mandate, in every market.
            </p>
        </div>

        <!-- Row 1: 4 Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3 mb-3">
            {
                items.slice(0, 4).map((item) => (
                    <div class="group relative overflow-hidden bg-[#E7E2F3] h-[180px] rounded-[16px] flex flex-col justify-center items-center transition-all duration-300">
                        <!-- Background SVG (opacity 0, reveals on hover) -->
                        <div class="absolute inset-0 z-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <Fragment set:html={item.bgSvg} />
                        </div>

                        <!-- Card Content Wrapper -->
                        <div class="relative z-10 w-full h-full flex flex-col items-center justify-center">
                            <!-- Logo container (shrinks and moves up on hover) -->
                            <div class="w-19 h-19 md:w-22 md:h-22 flex justify-center items-center transition-all duration-300 ease-out transform group-hover:scale-100 group-hover:-translate-y-3">
                                <img
                                    src={item.img}
                                    alt={item.title}
                                    class="max-w-full max-h-full object-contain"
                                />
                            </div>

                            <!-- Text Title (slides up from below and fades in on hover) -->
                            <div class="absolute bottom-4 left-0 right-0 transition-all duration-300 ease-out transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 text-center px-2 pointer-events-none">
                                <h3 class="text-base font-normal text-black leading-[1.44] m-0">
                                    {item.title}
                                </h3>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Row 2: 3 Cards Centered Flex -->
        <div class="flex flex-wrap justify-center gap-3">
            {
                items.slice(4).map((item) => (
                    <div class="group relative overflow-hidden bg-[#EBE9F5] min-h-[180px] w-full sm:w-[calc(50%-6px)] md:w-[calc(25%-9px)] rounded-[16px] flex flex-col justify-center items-center px-4 transition-all duration-300 hover:bg-[#E2DFF0]">
                        <!-- Background SVG (opacity 0, reveals on hover) -->
                        <div class="absolute inset-0 z-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <Fragment set:html={item.bgSvg} />
                        </div>

                        <!-- Card Content Wrapper -->
                        <div class="relative z-10 w-full h-full flex flex-col items-center justify-center">
                            <!-- Logo container (shrinks and moves up on hover) -->
                            <div class="w-19 h-19 md:w-22 md:h-22 flex justify-center items-center transition-all duration-300 ease-out transform group-hover:scale-100 group-hover:-translate-y-3">
                                <img
                                    src={item.img}
                                    alt={item.title}
                                    class="max-w-full max-h-full object-contain"
                                />
                            </div>

                            <!-- Text Title (slides up from below and fades in on hover) -->
                            <div class="absolute bottom-4 left-0 right-0 transition-all duration-300 ease-out transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 text-center px-2 pointer-events-none">
                                <h3 class="text-base font-normal text-black leading-[1.44] m-0">
                                    {item.title}
                                </h3>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
