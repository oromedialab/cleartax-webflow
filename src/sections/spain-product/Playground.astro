---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="playground-section" class="bg-[#FFFFFF] py-12 lg:py-25 w-full">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center">
            <h2
                id="oman-title-shield"
                class="text-[26px]! sm:text-[32px]! lg:text-[44px]! font-semibold! max-w-168 mx-auto! text-black leading-[1.18]! m-0! premium-reveal"
            >
                What Spain Requires and <span
                    class="text-[#655DFF] inline-block">How</span
                >
                <span class="text-[#655DFF] block">ClearTax Delivers It</span>
            </h2>
        </div>

        <div class="grid grid-cols-12 gap-7 mt-12 w-full">
            <!-- Built for Your Busiest Day (6 columns) -->
            <div
                id="card-verifactu"
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[330px] lg:min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 pb-0 pt-0 px-0 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="flex justify-center items-center w-full max-w-[587px] max-lg:max-w-[610px] max-sm:max-w-[430px] mx-auto tilted-card-img-wrapper relative text-center"
                    >
                        <!-- Step 1: Base State (determines relative aspect ratio) -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a61eafa8e5a4f85a2fb05c2_Mask%20group%20(1).png"
                            alt="Verifactu Step 1"
                            class="w-full h-auto object-contain relative z-10 pg-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 2: Ripple Wave State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a61dcd389cce83ffbb04a17_verifactu-flow-1.png"
                            alt="Verifactu Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 3: Multiple Ripples State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a61dcde7c9ee09714189366_verifactu-flow-2.png"
                            alt="Verifactu Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 4: Full Final Illustration State (Layered) -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755dd784ea9056f310ffe_Mask%20group.png"
                            alt="Verifactu Step 4 - Layer 1"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-4-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a61dbd27cc8aa123ea87ccd_verifactu-1-5.png"
                            alt="Verifactu Step 4 - Layer 2"
                            class="absolute w-[25%]! pg-step-4-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755b8b5473a538781e8d6_E2.png"
                            alt="Verifactu Step 4 - Layer 3"
                            class="absolute w-[33%]! pg-step-4-3 pointer-events-none left-[14%]! sm:left-[14%]! lg:left-[14%]!"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755b3f6c63980f8ee3da1_E1.png"
                            alt="Verifactu Step 4 - Layer 4"
                            class="absolute w-[33%]! pg-step-4-4 pointer-events-none right-[14%]! sm:right-[14%]! lg:right-[14%]!"
                            loading="lazy"
                            decoding="async"
                        />
                        <div
                            class="absolute -bottom-5 left-0 right-0 h-15! sm:h-30! md:h-30! lg:h-48! z-15 pointer-events-none"
                            style="background: linear-gradient(to top, #FDF2ED 30%, rgba(253, 242, 237, 0) 100%);"
                        >
                        </div>
                    </div>
                    <div class="mt-auto p-5 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Verifactu
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0"
                        >
                            ClearTax creates tamper-proof invoice records with
                            QR codes and reports them to AEAT in near real time.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Connects to Everything (6 columns) -->
            <div
                id="card-lifecycle"
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[330px] lg:min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] flex flex-col justify-start overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Lifecycle
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            ClearTax tracks acceptance, rejection, and payment
                            status, then flags missing updates before they
                            become audit risks.
                        </p>
                    </div>
                    <div
                        class="absolute -bottom-3 sm:-bottom-5 left-1/2 -translate-x-1/2 w-full max-w-[650px] max-lg:max-w-[750px] max-sm:max-w-[400px] flex justify-between tilted-card-img-wrapper"
                    >
                        <!-- Static Pills Container (Positioned above 3 card slots) -->
                        <div
                            class="absolute -top-6 sm:-top-8 lg:-top-17 left-0 right-0 z-30 flex items-center justify-center pointer-events-none px-1"
                        >
                            <div
                                class="w-[38%] opacity-[40%] relative -left-[8%] lg:-left-[9%] flex justify-end items-center pr-1"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f0abf67e5fd6ac3d25f68_animate-pad-1.png"
                                    alt="Format Step 1"
                                    class="h-6 sm:h-8 lg:h-10 object-contain object-right pointer-events-none card2-pill-left"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div
                                class="w-[49%] flex justify-center items-center z-10 relative"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a62158af581926fb02aec62_pill-effect.png"
                                    alt="Format Step Base"
                                    class="w-full h-auto object-contain pointer-events-none max-w-[280px] card2-pill-base"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f0cf803c1c5b4f18c4807_animate-pad-3.png"
                                    alt="Format Step 2"
                                    class="w-full h-auto object-contain absolute inset-0 m-auto pointer-events-none max-w-[280px] card2-pill-content-2 z-10"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f0abf67e5fd6ac3d25f68_animate-pad-1.png"
                                    alt="Format Step 1"
                                    class="w-full h-auto object-contain absolute inset-0 m-auto pointer-events-none max-w-[280px] card2-pill-content-1 z-10 opacity-0"
                                    loading="lazy"
                                    decoding="async"
                                />
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f0ac4aefaccb62cc4fa5e_animate-pad-2.png"
                                    alt="Format Step 3"
                                    class="w-full h-auto object-contain absolute inset-0 m-auto pointer-events-none max-w-[280px] card2-pill-content-3 z-10 opacity-0"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                            <div
                                class="w-[38%] opacity-[40%] relative -right-[8%] lg:-right-[9%] flex justify-start items-center pl-1"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f0ac4aefaccb62cc4fa5e_animate-pad-2.png"
                                    alt="Format Step 3"
                                    class="h-6 sm:h-8 lg:h-10 object-contain object-left pointer-events-none card2-pill-right"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>
                        </div>

                        <!-- Card 1 (Left) - Animates -->
                        <div
                            class="relative w-[34%] aspect-[223/140] card2-item-left"
                        >
                            <!-- Card 2 Step 6: Background 3 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 3"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <!-- Card 2 (Center) - Animates -->
                        <div
                            class="relative w-[38%] aspect-[223/140] card2-item-center"
                        >
                            <!-- Card 2 Step 5: Background 2 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 2"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <!-- Card 3 (Right) - Animates -->
                        <div
                            class="relative w-[34%] aspect-[223/140] card2-item-right"
                        >
                            <!-- Card 2 Step 4: Background 1 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 1"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Always-On e-Invoicing (5 columns) -->
            <div
                id="card-interoperability"
                class="col-span-12 md:col-span-6 lg:col-span-5 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] flex flex-col justify-end overflow-hidden relative h-full pt-5"
                >
                    <div
                        class="absolute top-3 right-4 left-4 sm:left-[45%] md:left-[1%] xl:left-4 bottom-28 tilted-card-img-wrapper select-none pointer-events-none"
                    >
                        <!-- Left Block: Gear -->
                        <div
                            class="absolute -left-4 top-1/2 -translate-y-1/2 z-10 w-[24%] card3-gear-wrapper"
                        >
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59cc1af451b1e790ae6898_step-3-1-img.png"
                                alt="Validation Step 1"
                                class="w-full h-auto object-contain card3-gear"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <!-- Middle SVG: Lines -->
                        <div
                            class="absolute left-[20%] right-[38%] top-1/2 -translate-y-1/2 h-full z-5 card3-svg-wrapper"
                        >
                            <svg
                                viewBox="0 0 184 176"
                                class="w-full h-full"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <defs>
                                    <!-- Masks to reveal the dashed lines progressively -->
                                    <mask
                                        id="card3-mask-left"
                                        maskUnits="userSpaceOnUse"
                                    >
                                        <path
                                            d="M 0 88 L 93.6775 88"
                                            stroke="#ffffff"
                                            stroke-width="6"
                                            fill="none"
                                            class="card3-line-left"></path>
                                    </mask>
                                    <mask
                                        id="card3-mask-mid"
                                        maskUnits="userSpaceOnUse"
                                    >
                                        <path
                                            d="M 93.6775 88 L 142.677 88"
                                            stroke="#ffffff"
                                            stroke-width="6"
                                            fill="none"
                                            class="card3-line-mid"></path>
                                    </mask>
                                    <mask
                                        id="card3-mask-top"
                                        maskUnits="userSpaceOnUse"
                                    >
                                        <path
                                            d="M78.6775 88C103.843 88 125.673 70.6188 131.311 46.0931L132.38 41.445C137.821 17.7748 158.89 1 183.177 1"
                                            stroke="#ffffff"
                                            stroke-width="6"
                                            fill="none"
                                            class="card3-line-top"></path>
                                    </mask>
                                    <mask
                                        id="card3-mask-bottom"
                                        maskUnits="userSpaceOnUse"
                                    >
                                        <path
                                            d="M78.6775 88 C102.965 88 124.034 104.775 129.475 128.445 L130.544 133.093 C136.182 157.619 158.012 175 183.177 175"
                                            stroke="#ffffff"
                                            stroke-width="6"
                                            fill="none"
                                            class="card3-line-bottom"></path>
                                    </mask>
                                </defs>

                                <!-- Dashed paths with masks applied -->
                                <path
                                    d="M 0 88 L 93.6775 88"
                                    stroke="#36943F"
                                    stroke-opacity="0.8"
                                    stroke-width="2"
                                    stroke-dasharray="8 12"
                                    fill="none"
                                    mask="url(#card3-mask-left)"></path>
                                <path
                                    d="M 93.6775 88 L 142.677 88"
                                    stroke="#36943F"
                                    stroke-opacity="0.8"
                                    stroke-width="2"
                                    stroke-dasharray="8 12"
                                    fill="none"
                                    mask="url(#card3-mask-mid)"></path>
                                <path
                                    d="M78.6775 88C103.843 88 125.673 70.6188 131.311 46.0931L132.38 41.445C137.821 17.7748 158.89 1 183.177 1"
                                    stroke="#36943F"
                                    stroke-opacity="0.8"
                                    stroke-width="2"
                                    stroke-dasharray="8 12"
                                    fill="none"
                                    mask="url(#card3-mask-top)"></path>
                                <path
                                    d="M78.6775 88 C102.965 88 124.034 104.775 129.475 128.445 L130.544 133.093 C136.182 157.619 158.012 175 183.177 175"
                                    stroke="#36943F"
                                    stroke-opacity="0.8"
                                    stroke-width="2"
                                    stroke-dasharray="8 12"
                                    fill="none"
                                    mask="url(#card3-mask-bottom)"></path>

                                <!-- Branch dot and outline -->
                                <circle
                                    cx="93.6775"
                                    cy="88"
                                    r="7"
                                    fill="#ECF7ED"
                                    class="card3-dot"></circle>
                                <circle
                                    cx="93.6775"
                                    cy="88"
                                    r="8"
                                    stroke="#36943F"
                                    stroke-opacity="0.8"
                                    stroke-width="2"
                                    class="card3-dot-outline"></circle>
                            </svg>
                        </div>

                        <!-- Right Column: Pills -->
                        <div
                            class="absolute -right-4 top-1/2 -translate-y-1/2 z-10 w-[50%] h-[80%] md:h-[75%] lg:h-[100%] flex flex-col items-end justify-between card3-pills-wrapper"
                        >
                            <!-- Top Pill: Buyer Platform -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59cc23fa2000f3611707d3_step-3-2-img.png"
                                alt="Validation Step 2"
                                class="w-[195px] lg:w-[220px] max-w-full h-auto object-contain card3-pill-top"
                                loading="lazy"
                                decoding="async"
                            />
                            <!-- Middle Pill: Private Platform -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59cc2c347973fc673933a7_step-3-3-img.png"
                                alt="Validation Step 3"
                                class="w-[234px] lg:w-[260px] max-w-full h-auto object-contain card3-pill-mid"
                                loading="lazy"
                                decoding="async"
                            />
                            <!-- Bottom Pill: AEAT Public Solution -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59cc357d65684b41ba624a_step-3-4-img.png"
                                alt="Validation Step 4"
                                class="w-[195px] lg:w-[220px] max-w-full h-auto object-contain card3-pill-bottom"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    </div>
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Interoperability
                        </h3>
                        <p
                            class="text-balance font-normal max-w-116 leading-normal text-black/80 m-0"
                        >
                            ClearTax connects private platforms with each other
                            and AEAT’s public solution, including automated
                            retrieval flows.
                        </p>
                    </div>
                </div>
            </div>

            <!-- VAT Assurance (7 columns) -->
            <div
                id="card-format"
                class="col-span-12 md:col-span-6 lg:col-span-7 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#E8F5F7] rounded-[16px] p-5 pt-0 flex flex-col overflow-hidden relative h-full"
                >
                    <div
                        class="relative w-full min-h-[200px] max-w-[305px] top-6 sm:top-7 lg:ml-auto max-lg:mx-auto my-auto tilted-card-img-wrapper"
                    >
                        <!-- Card 4 Step 1: Base State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5a23a6ab84249470760fa0_step-left.png"
                            alt="Archival Step 1"
                            class="absolute -left-3 top-1/2 -translate-y-1/2 w-[194px] z-10 -rotate-[12deg] card4-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 4 Step 2: Mid State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5a239da9799c0b265e272b_step-center.png"
                            alt="Archival Step 2"
                            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[230px] z-20 card4-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 4 Step 3: Final State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5a23b014109da7a7686c64_step-right.png"
                            alt="Archival Step 3"
                            class="absolute -right-2 top-1/2 -translate-y-1/2 w-[194px] z-10 rotate-[12deg] card4-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <!-- Bottom blur gradient to match design reference -->
                        <div
                            class="absolute -bottom-6 left-0 right-0 h-20 bg-gradient-to-t from-[#E8F5F7] via-[#E8F5F7]/54 to-transparent z-30 pointer-events-none"
                        >
                        </div>
                    </div>
                    <div
                        class="flex flex-col justify-start order-2 relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4 w-full"
                        >
                            Format
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0 w-full"
                        >
                            ClearTax converts ERP invoice data into UBL,
                            Facturae, CII, or EDIFACT without changing your data
                            model.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Zero Downtime (7 columns) -->
            <div
                id="card-applicability"
                class="col-span-7 max-lg:col-span-12 tilted-card !min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] max-w-[748px] flex flex-col justify-start overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Applicability
                        </h3>
                        <p
                            class="text-base font-normal max-w-[350px] leading-normal text-black/80 m-0"
                        >
                            ClearTax helps route the right transactions: Spanish
                            domestic B2B in scope, B2C and B2G excluded.
                        </p>
                    </div>
                    <div
                        class="absolute inset-0 w-full h-full tilted-card-img-wrapper pointer-events-none"
                    >
                        <!-- Container to scale all graphic elements proportionally on mobile/tablet -->
                        <div
                            class="absolute right-0 bottom-0 w-[748px] h-full card5-graphic-container pointer-events-none"
                        >
                            <!-- B2B Bubble -->
                            <div
                                class="absolute top-[29%] right-[38%] w-[80px] z-10"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a6071ef074fa9d47841f8ba_b2b.png"
                                    alt="B2B Bubble"
                                    class="w-full h-auto object-contain card5-step-1 pointer-events-none"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>

                            <!-- B2G Bubble -->
                            <div
                                class="absolute left-[33%] top-[45%] w-[80px] z-10"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a606c75e2e6e9dfdbcd11bb_b2g.png"
                                    alt="B2G Bubble"
                                    class="w-full h-auto object-contain card5-step-2 pointer-events-none"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>

                            <!-- B2C Bubble -->
                            <div
                                class="absolute bottom-[7%] right-[39%] w-[80px] z-10"
                            >
                                <img
                                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a606c71cf41f8691e10f4e0_b2c.png"
                                    alt="B2C Bubble"
                                    class="w-full h-auto object-contain card5-step-3 pointer-events-none"
                                    loading="lazy"
                                    decoding="async"
                                />
                            </div>

                            <!-- Cleartax Circle -->
                            <div
                                class="absolute right-[6%] top-[66%] -translate-y-1/2 w-[140px] z-20"
                            >
                                <img
