<script
    src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    is:inline></script>

<script is:inline>
    (function () {
        let initialized = false;
        const section = document.getElementById("playground-section");

        let card1Timeline = null;
        let card2Timeline = null;

        function initCard1Animation() {
            const cardEl = document.getElementById("card-verifactu");
            if (!cardEl) return;

            const step1 = cardEl.querySelector(".pg-step-1");
            const step2 = cardEl.querySelector(".pg-step-2");
            const step3 = cardEl.querySelector(".pg-step-3");
            const step4_1 = cardEl.querySelector(".pg-step-4-1");
            const step4_2 = cardEl.querySelector(".pg-step-4-2");
            const step4_3 = cardEl.querySelector(".pg-step-4-3");
            const step4_4 = cardEl.querySelector(".pg-step-4-4");

            if (
                !step1 ||
                !step2 ||
                !step3 ||
                !step4_1 ||
                !step4_2 ||
                !step4_3 ||
                !step4_4
            )
                return;

            cardEl.addEventListener("mouseenter", () => {
                runAnim();
            });

            function runAnim() {
                if (card1Timeline) {
                    card1Timeline.kill();
                }

                gsap.set(step1, { opacity: 1, scale: 1 });
                gsap.set([step2, step3, step4_1, step4_2], {
                    opacity: 0,
                    scale: 0.97,
                });

                // Initialize step-4-3 and step-4-4 to start exactly centered behind the step-4-2 circle
                gsap.set(step4_3, {
                    xPercent: 100,
                    yPercent: 20,
                    opacity: 0,
                    transformOrigin: "center center",
                });
                gsap.set(step4_4, {
                    xPercent: -100,
                    yPercent: 20,
                    opacity: 0,
                    transformOrigin: "center center",
                });

                card1Timeline = gsap.timeline();

                card1Timeline
                    // Step 1 to Step 2
                    .to(
                        step1,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        1.0,
                    )
                    .to(
                        step2,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        1.0,
                    )

                    // Step 2 to Step 3
                    .to(
                        step2,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        2.0,
                    )
                    .to(
                        step3,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        2.0,
                    )

                    // Step 3 to Step 4
                    .to(
                        step3,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )
                    .to(
                        step4_1,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )
                    .to(
                        step4_2,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )

                    // Smooth spring slide out from behind circle (longer duration, smoother ease)
                    .to(
                        step4_3,
                        {
                            xPercent: 0,
                            yPercent: 0,
                            scale: 1,
                            opacity: 1,
                            duration: 1.2,
                            ease: "back.out(1.2)",
                        },
                        3.1,
                    )
                    .to(
                        step4_4,
                        {
                            xPercent: 0,
                            yPercent: 0,
                            scale: 1,
                            opacity: 1,
                            duration: 1.2,
                            ease: "back.out(1.2)",
                        },
                        3.25,
                    );
            }

            window.playCard1GSAP = runAnim;
        }

        function initCard2Animation() {
            const cardEl = document.getElementById("card-lifecycle");
            if (!cardEl) return;

            const itemLeft = cardEl.querySelector(".card2-item-left");
            const itemCenter = cardEl.querySelector(".card2-item-center");
            const itemRight = cardEl.querySelector(".card2-item-right");

            if (!itemLeft || !itemCenter || !itemRight) return;

            const bgLeft = itemLeft.querySelectorAll("img")[0];
            const bgCenter = itemCenter.querySelectorAll("img")[0];
            const bgRight = itemRight.querySelectorAll("img")[0];

            if (!bgLeft || !bgCenter || !bgRight) return;

            // Entrance animation (runs once when scrolled into view)
            gsap.fromTo(
                itemLeft,
                { opacity: 0, xPercent: 10, scale: 0.8, rotation: 0 },
                {
                    opacity: 0.15,
                    xPercent: -10,
                    scale: 0.8,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                },
            );
            gsap.fromTo(
                bgLeft,
                { rotation: 15 },
                { rotation: 15, duration: 0.6 },
            );

            gsap.fromTo(
                itemCenter,
                { opacity: 0, xPercent: 10, scale: 0.8, rotation: 0 },
                {
                    opacity: 1,
                    xPercent: 0,
                    scale: 1,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                    delay: 0.2,
                },
            );
            gsap.fromTo(
                bgCenter,
                { rotation: 0 },
                { rotation: 0, duration: 0.6, delay: 0.2 },
            );

            gsap.fromTo(
                itemRight,
                { opacity: 0, xPercent: 20, scale: 0.8, rotation: 0 },
                {
                    opacity: 0.15,
                    xPercent: 10,
                    scale: 0.8,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                    delay: 0.4,
                },
            );
            gsap.fromTo(
                bgRight,
                { rotation: -15 },
                { rotation: -15, duration: 0.6, delay: 0.4 },
            );

            // Hover trigger loop
            cardEl.addEventListener("mouseenter", () => {
                runLifecycleLoop();
            });

            function runLifecycleLoop() {
                if (card2Timeline) {
                    card2Timeline.kill();
                }

                // Reset to initial State 1 (Center active)
                gsap.set(itemLeft, {
                    xPercent: -10,
                    scale: 0.8,
                    rotation: 0,
                    opacity: 0.15,
                    zIndex: 10,
                });
                gsap.set(bgLeft, { rotation: 15 });

                gsap.set(itemCenter, {
                    xPercent: 0,
                    scale: 1,
                    rotation: 0,
                    opacity: 1,
                    zIndex: 20,
                });
                gsap.set(bgCenter, { rotation: 0 });

                gsap.set(itemRight, {
                    xPercent: 10,
                    scale: 0.8,
                    rotation: 0,
                    opacity: 0.15,
                    zIndex: 10,
                });
                gsap.set(bgRight, { rotation: -15 });

                card2Timeline = gsap.timeline();

                card2Timeline
                    // Transition 1: Right card to center, Left card to right (behind), Center card to left
                    // Hold State 1 for 1.2s before shuffling
                    // 1. Left card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemLeft,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        1.2,
                    )
                    .set(itemLeft, { xPercent: 221.8, zIndex: 5 }, 1.5)
                    .to(
                        itemLeft,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        1.6,
                    )
                    .to(
                        bgLeft,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        1.6,
                    )

                    // 2. Center card moves Center -> Left (visible slide)
                    .to(
                        itemCenter,
                        {
                            xPercent: -99.5,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        1.2,
                    )
                    .to(
                        bgCenter,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        1.2,
                    )
                    .set(itemCenter, { zIndex: 10 }, 1.2)

                    // 3. Right card moves Right -> Center (visible slide)
                    .set(itemRight, { zIndex: 20 }, 1.2)
                    .to(
                        itemRight,
                        {
                            xPercent: -105.9,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        1.2,
                    )
                    .to(
                        bgRight,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        1.2,
                    )

                    // Transition 2: Left card to center, Center card to right (behind), Right card to left
                    // Hold State 2 for 1.2s before shuffling
                    // 1. Center card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemCenter,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        3.2,
                    )
                    .set(itemCenter, { xPercent: 99.5, zIndex: 5 }, 3.5)
                    .to(
                        itemCenter,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        3.6,
                    )
                    .to(
                        bgCenter,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        3.6,
                    )

                    // 2. Right card moves Center -> Left (visible slide)
                    .to(
                        itemRight,
                        {
                            xPercent: -221.8,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        3.2,
                    )
                    .to(
                        bgRight,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        3.2,
                    )
                    .set(itemRight, { zIndex: 10 }, 3.2)

                    // 3. Left card moves Right -> Center (visible slide)
                    .set(itemLeft, { zIndex: 20 }, 3.2)
                    .to(
                        itemLeft,
                        {
                            xPercent: 105.9,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        3.2,
                    )
                    .to(
                        bgLeft,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        3.2,
                    )

                    // Transition 3: Reset back to initial State 1 (Right card moves Left -> Right behind)
                    // Hold State 3 for 1.2s before shuffling
                    // 1. Right card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemRight,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        5.2,
                    )
                    .set(itemRight, { xPercent: 10, zIndex: 5 }, 5.5)
                    .to(
                        itemRight,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        5.6,
                    )
                    .to(
                        bgRight,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        5.6,
                    )

                    // 2. Left card moves Center -> Left (visible slide)
                    .to(
                        itemLeft,
                        {
                            xPercent: -10,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        5.2,
                    )
                    .to(
                        bgLeft,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        5.2,
                    )
                    .set(itemLeft, { zIndex: 10 }, 5.2)

                    // 3. Center card moves Right -> Center (visible slide)
                    .set(itemCenter, { zIndex: 20 }, 5.2)
                    .to(
                        itemCenter,
                        {
                            xPercent: 0,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        5.2,
                    )
                    .to(
                        bgCenter,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        5.2,
                    );
            }
        }

        let card3Timeline = null;

        function runCard3Animation() {
            const cardEl = document.getElementById("card-interoperability");
            if (!cardEl) return;

            const gear = cardEl.querySelector(".card3-gear-wrapper");
            const lineLeft = cardEl.querySelector(".card3-line-left");
            const dot = cardEl.querySelector(".card3-dot");
            const dotOutline = cardEl.querySelector(".card3-dot-outline");
            const lineMid = cardEl.querySelector(".card3-line-mid");
            const lineTop = cardEl.querySelector(".card3-line-top");
            const lineBottom = cardEl.querySelector(".card3-line-bottom");
            const pillTop = cardEl.querySelector(".card3-pill-top");
            const pillMid = cardEl.querySelector(".card3-pill-mid");
            const pillBottom = cardEl.querySelector(".card3-pill-bottom");

            if (card3Timeline) {
                card3Timeline.kill();
            }

            // Set initial states
            gsap.set(gear, { opacity: 0, scale: 0.5, x: -20 });
            gsap.set([dot, dotOutline], {
                scale: 0,
                opacity: 0,
                transformOrigin: "center center",
            });
            gsap.set([pillTop, pillMid, pillBottom], { opacity: 0, x: 20 });

            // Prepare SVG paths for stroke animation
            const preparePath = (path) => {
                if (!path) return;
                const length = path.getTotalLength();
                gsap.set(path, {
                    strokeDasharray: length,
                    strokeDashoffset: length,
                    opacity: 1,
                });
            };

            preparePath(lineLeft);
            preparePath(lineMid);
            preparePath(lineTop);
            preparePath(lineBottom);

            card3Timeline = gsap.timeline();

            card3Timeline
                // 1. Gear animates in
                .to(gear, {
                    opacity: 1,
                    scale: 1,
                    x: 0,
                    duration: 0.6,
                    ease: "back.out(1.7)",
                })
                // 2. Horizontal line starts drawing
                .to(
                    lineLeft,
                    {
                        strokeDashoffset: 0,
                        duration: 0.8,
                        ease: "power1.inOut",
                    },
                    "-=0.2",
                )
                // 3. Dot and outline scale up as the line passes through (around 65% mark)
                .to(
                    [dot, dotOutline],
                    {
                        scale: 1,
                        opacity: 1,
                        duration: 0.3,
                        ease: "back.out(2)",
                        stagger: 0.05,
                    },
                    "-=0.45",
                )
                // 4. Branching top, middle, and bottom curves start drawing as the dot scales up
                .to(
                    [lineTop, lineMid, lineBottom],
                    {
                        strokeDashoffset: 0,
                        duration: 0.7,
                        ease: "power1.inOut",
                        stagger: 0.05,
                    },
                    "-=0.2",
                )
                // 5. Middle pill fades in when the horizontal line reaches it
                .to(
                    pillMid,
                    {
                        opacity: 1,
                        x: 0,
                        duration: 0.4,
                        ease: "power2.out",
                    },
                    "-=0.5",
                )
                // 6. Top and bottom pills fade in when their curves reach them
                .to(
                    [pillTop, pillBottom],
                    {
                        opacity: 1,
                        x: 0,
                        duration: 0.4,
                        ease: "power2.out",
                        stagger: 0.1,
                    },
                    "-=0.3",
                );
        }

        function initCard3Animation() {
            const cardEl = document.getElementById("card-interoperability");
            if (!cardEl) return;

            cardEl.addEventListener("mouseenter", () => {
                runCard3Animation();
            });
        }

        let card4Timeline = null;

        function runCard4Animation() {
            const cardEl = document.getElementById("card-format");
            if (!cardEl) return;

            const stepLeft = cardEl.querySelector(".card4-step-1");
            const stepCenter = cardEl.querySelector(".card4-step-2");
            const stepRight = cardEl.querySelector(".card4-step-3");

            if (card4Timeline) {
                card4Timeline.kill();
            }

            // Set initial states: center hidden, left and right hidden and shifted behind it
            gsap.set(stepCenter, {
                opacity: 0,
                scale: 0.8,
                y: 20,
                transformOrigin: "center center",
            });
            gsap.set(stepLeft, {
                opacity: 0,
                x: 50,
                scale: 0.9,
                transformOrigin: "center center",
            });
            gsap.set(stepRight, {
                opacity: 0,
                x: -50,
                scale: 0.9,
                transformOrigin: "center center",
            });

            card4Timeline = gsap.timeline();

            card4Timeline
                // 1. Center card fades in and slides/scales up
                .to(stepCenter, {
                    opacity: 1,
                    scale: 1,
                    y: 0,
                    duration: 0.6,
                    ease: "back.out(1.4)",
                })
                // 2. Left and right cards slide/fan out from behind the center card together
                .to(
                    [stepLeft, stepRight],
                    {
                        opacity: 1,
                        x: 0,
                        scale: 1,
                        duration: 0.7,
                        ease: "power2.out",
                        stagger: 0.05,
                    },
                    "-=0.25",
                );
        }

        function initCard4Animation() {
            const cardEl = document.getElementById("card-format");
            if (!cardEl) return;

            cardEl.addEventListener("mouseenter", () => {
                runCard4Animation();
            });
        }

        function initTiltedCards() {
            if (initialized) return;
            initialized = true;

            // Initialize GSAP animations
            initCard1Animation();
            initCard2Animation();
            initCard3Animation();
            initCard4Animation();
            runCard3Animation();
            runCard4Animation();
        }

        if (section) {
            section.addEventListener("mouseenter", initTiltedCards, {
                once: true,
            });
            section.addEventListener("touchstart", initTiltedCards, {
                once: true,
            });
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                initTiltedCards();
                                section.classList.add("animate-start");
                            } else {
                                section.classList.remove("animate-start");
                            }
                        });
                    },
                    { rootMargin: "100px" },
                );
                obs.observe(section);
            } else {
                initTiltedCards();
                section.classList.add("animate-start");
            }
        }
    })();
</script>
