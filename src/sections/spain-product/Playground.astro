<script
    src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    is:inline></script>

<script is:inline>
    (function () {
        let initialized = false;
        const section = document.getElementById("playground-section");

        let card1Timeline = null;
        let card2Timeline = null;

        function initCard1Animation() {
            const cardEl = document.getElementById("card-verifactu");
            if (!cardEl) return;

            const step1 = cardEl.querySelector(".pg-step-1");
            const step2 = cardEl.querySelector(".pg-step-2");
            const step3 = cardEl.querySelector(".pg-step-3");
            const step4_1 = cardEl.querySelector(".pg-step-4-1");
            const step4_2 = cardEl.querySelector(".pg-step-4-2");
            const step4_3 = cardEl.querySelector(".pg-step-4-3");
            const step4_4 = cardEl.querySelector(".pg-step-4-4");

            if (
                !step1 ||
                !step2 ||
                !step3 ||
                !step4_1 ||
                !step4_2 ||
                !step4_3 ||
                !step4_4
            )
                return;

            cardEl.addEventListener("mouseenter", () => {
                runAnim();
            });

            function runAnim() {
                if (card1Timeline) {
                    card1Timeline.kill();
                }

                gsap.set(step1, { opacity: 1, scale: 1 });
                gsap.set([step2, step3, step4_1, step4_2], {
                    opacity: 0,
                    scale: 0.97,
                });

                // Initialize step-4-3 and step-4-4 to start exactly centered behind the step-4-2 circle
                gsap.set(step4_3, {
                    xPercent: 100,
                    yPercent: 20,
                    opacity: 0,
                    transformOrigin: "center center",
                });
                gsap.set(step4_4, {
                    xPercent: -100,
                    yPercent: 20,
                    opacity: 0,
                    transformOrigin: "center center",
                });

                card1Timeline = gsap.timeline();

                card1Timeline
                    // Step 1 to Step 2
                    .to(
                        step1,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        1.0,
                    )
                    .to(
                        step2,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        1.0,
                    )

                    // Step 2 to Step 3
                    .to(
                        step2,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        2.0,
                    )
                    .to(
                        step3,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        2.0,
                    )

                    // Step 3 to Step 4
                    .to(
                        step3,
                        {
                            opacity: 0,
                            scale: 0.97,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )
                    .to(
                        step4_1,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )
                    .to(
                        step4_2,
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.inOut",
                        },
                        3.0,
                    )

                    // Smooth spring slide out from behind circle (longer duration, smoother ease)
                    .to(
                        step4_3,
                        {
                            xPercent: 0,
                            yPercent: 0,
                            scale: 1,
                            opacity: 1,
                            duration: 1.2,
                            ease: "back.out(1.2)",
                        },
                        3.1,
                    )
                    .to(
                        step4_4,
                        {
                            xPercent: 0,
                            yPercent: 0,
                            scale: 1,
                            opacity: 1,
                            duration: 1.2,
                            ease: "back.out(1.2)",
                        },
                        3.25,
                    );
            }

            window.playCard1GSAP = runAnim;
        }

        function initCard2Animation() {
            const cardEl = document.getElementById("card-lifecycle");
            if (!cardEl) return;

            const itemLeft = cardEl.querySelector(".card2-item-left");
            const itemCenter = cardEl.querySelector(".card2-item-center");
            const itemRight = cardEl.querySelector(".card2-item-right");

            if (!itemLeft || !itemCenter || !itemRight) return;

            const bgLeft = itemLeft.querySelectorAll("img")[0];
            const bgCenter = itemCenter.querySelectorAll("img")[0];
            const bgRight = itemRight.querySelectorAll("img")[0];

            if (!bgLeft || !bgCenter || !bgRight) return;

            // Entrance animation (runs once when scrolled into view)
            gsap.fromTo(
                itemLeft,
                { opacity: 0, xPercent: 10, scale: 0.8, rotation: 0 },
                {
                    opacity: 0.15,
                    xPercent: -10,
                    scale: 0.8,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                },
            );
            gsap.fromTo(
                bgLeft,
                { rotation: 15 },
                { rotation: 15, duration: 0.6 },
            );

            gsap.fromTo(
                itemCenter,
                { opacity: 0, xPercent: 10, scale: 0.8, rotation: 0 },
                {
                    opacity: 1,
                    xPercent: 0,
                    scale: 1,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                    delay: 0.2,
                },
            );
            gsap.fromTo(
                bgCenter,
                { rotation: 0 },
                { rotation: 0, duration: 0.6, delay: 0.2 },
            );

            gsap.fromTo(
                itemRight,
                { opacity: 0, xPercent: 20, scale: 0.8, rotation: 0 },
                {
                    opacity: 0.15,
                    xPercent: 10,
                    scale: 0.8,
                    rotation: 0,
                    duration: 0.6,
                    ease: "power2.out",
                    delay: 0.4,
                },
            );
            gsap.fromTo(
                bgRight,
                { rotation: -15 },
                { rotation: -15, duration: 0.6, delay: 0.4 },
            );

            // Hover trigger loop
            cardEl.addEventListener("mouseenter", () => {
                runLifecycleLoop();
            });

            function runLifecycleLoop() {
                if (card2Timeline) {
                    card2Timeline.kill();
                }

                // Reset to initial State 1 (Center active)
                gsap.set(itemLeft, {
                    xPercent: -10,
                    scale: 0.8,
                    rotation: 0,
                    opacity: 0.15,
                    zIndex: 10,
                });
                gsap.set(bgLeft, { rotation: 15 });

                gsap.set(itemCenter, {
                    xPercent: 0,
                    scale: 1,
                    rotation: 0,
                    opacity: 1,
                    zIndex: 20,
                });
                gsap.set(bgCenter, { rotation: 0 });

                gsap.set(itemRight, {
                    xPercent: 10,
                    scale: 0.8,
                    rotation: 0,
                    opacity: 0.15,
                    zIndex: 10,
                });
                gsap.set(bgRight, { rotation: -15 });

                card2Timeline = gsap.timeline();

                card2Timeline
                    // Transition 1: Right card to center, Left card to right (behind), Center card to left
                    // Hold State 1 for 1.2s before shuffling
                    // 1. Left card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemLeft,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        1.2,
                    )
                    .set(itemLeft, { xPercent: 221.8, zIndex: 5 }, 1.5)
                    .to(
                        itemLeft,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        1.6,
                    )
                    .to(
                        bgLeft,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        1.6,
                    )

                    // 2. Center card moves Center -> Left (visible slide)
                    .to(
                        itemCenter,
                        {
                            xPercent: -99.5,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        1.2,
                    )
                    .to(
                        bgCenter,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        1.2,
                    )
                    .set(itemCenter, { zIndex: 10 }, 1.2)

                    // 3. Right card moves Right -> Center (visible slide)
                    .set(itemRight, { zIndex: 20 }, 1.2)
                    .to(
                        itemRight,
                        {
                            xPercent: -105.9,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        1.2,
                    )
                    .to(
                        bgRight,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        1.2,
                    )

                    // Transition 2: Left card to center, Center card to right (behind), Right card to left
                    // Hold State 2 for 1.2s before shuffling
                    // 1. Center card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemCenter,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        3.2,
                    )
                    .set(itemCenter, { xPercent: 99.5, zIndex: 5 }, 3.5)
                    .to(
                        itemCenter,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        3.6,
                    )
                    .to(
                        bgCenter,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        3.6,
                    )

                    // 2. Right card moves Center -> Left (visible slide)
                    .to(
                        itemRight,
                        {
                            xPercent: -221.8,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        3.2,
                    )
                    .to(
                        bgRight,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        3.2,
                    )
                    .set(itemRight, { zIndex: 10 }, 3.2)

                    // 3. Left card moves Right -> Center (visible slide)
                    .set(itemLeft, { zIndex: 20 }, 3.2)
                    .to(
                        itemLeft,
                        {
                            xPercent: 105.9,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        3.2,
                    )
                    .to(
                        bgLeft,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        3.2,
                    )

                    // Transition 3: Reset back to initial State 1 (Right card moves Left -> Right behind)
                    // Hold State 3 for 1.2s before shuffling
                    // 1. Right card moves Left -> Right (fades out, moves behind, fades in)
                    .to(
                        itemRight,
                        {
                            opacity: 0,
                            scale: 0.5,
                            rotation: 0,
                            duration: 0.3,
                            ease: "power2.in",
                        },
                        5.2,
                    )
                    .set(itemRight, { xPercent: 10, zIndex: 5 }, 5.5)
                    .to(
                        itemRight,
                        {
                            opacity: 0.15,
                            scale: 0.8,
                            rotation: 0,
                            duration: 0.4,
                            ease: "power2.out",
                        },
                        5.6,
                    )
                    .to(
                        bgRight,
                        { rotation: -15, duration: 0.4, ease: "power2.out" },
                        5.6,
                    )

                    // 2. Left card moves Center -> Left (visible slide)
                    .to(
                        itemLeft,
                        {
                            xPercent: -10,
                            scale: 0.8,
                            rotation: 0,
                            opacity: 0.15,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        5.2,
                    )
                    .to(
                        bgLeft,
                        { rotation: 15, duration: 0.8, ease: "power2.inOut" },
                        5.2,
                    )
                    .set(itemLeft, { zIndex: 10 }, 5.2)

                    // 3. Center card moves Right -> Center (visible slide)
                    .set(itemCenter, { zIndex: 20 }, 5.2)
                    .to(
                        itemCenter,
                        {
                            xPercent: 0,
                            scale: 1,
                            rotation: 0,
                            opacity: 1,
                            duration: 0.8,
                            ease: "power2.inOut",
                        },
                        5.2,
                    )
                    .to(
                        bgCenter,
                        { rotation: 0, duration: 0.8, ease: "power2.inOut" },
                        5.2,
                    );
            }
        }

        function initTiltedCards() {
            if (initialized) return;
            initialized = true;

            // Initialize GSAP animations
            initCard1Animation();
            initCard2Animation();
        }

        if (section) {
            section.addEventListener("mouseenter", initTiltedCards, {
                once: true,
            });
            section.addEventListener("touchstart", initTiltedCards, {
                once: true,
            });
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                initTiltedCards();
                                section.classList.add("animate-start");
                            } else {
                                section.classList.remove("animate-start");
                            }
                        });
                    },
                    { rootMargin: "100px" },
                );
                obs.observe(section);
            } else {
                initTiltedCards();
                section.classList.add("animate-start");
            }
        }
    })();
</script>
