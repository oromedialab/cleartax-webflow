---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="playground-section" class="bg-[#FFFFFF] py-12 lg:py-25 w-full">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center">
            <h2
                id="oman-title-shield"
                class="text-[26px]! sm:text-[32px]! lg:text-[44px]! font-semibold! max-w-168 mx-auto! text-black leading-[1.18]! m-0! premium-reveal"
            >
                What Spain Requires and <span
                    class="text-[#655DFF] inline-block">How</span
                >
                <span class="text-[#655DFF] block">ClearTax Delivers It</span>
            </h2>
        </div>

        <div class="grid grid-cols-12 gap-7 mt-12 w-full">
            <!-- Built for Your Busiest Day (6 columns) -->
            <div
                id="card-verifactu"
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[420px] lg:min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 pt-0 px-0 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="flex justify-center items-end -mb-8 max-w-[626px] max-lg:max-w-[480px] max-sm:max-w-[340px] w-full mx-auto tilted-card-img-wrapper relative"
                    >
                        <!-- Step 1: Base State (determines relative aspect ratio) -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55df305eb97a02386aed4c_playground-1-1.png"
                            alt="Verifactu Step 1"
                            class="w-full h-auto object-contain relative z-10 pg-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 2: Ripple Wave State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55df36ddd768b1d266f57c_playground-1-2.png"
                            alt="Verifactu Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 3: Multiple Ripples State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55df3a4d3261b2a7e54089_playground-1-3.png"
                            alt="Verifactu Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Step 4: Full Final Illustration State (Layered) -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755dd784ea9056f310ffe_Mask%20group.png"
                            alt="Verifactu Step 4 - Layer 1"
                            class="w-full h-full object-contain absolute inset-0 z-10 pg-step-4-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a58ab1a1f3db0e0f42f2cab_step-4-2.png"
                            alt="Verifactu Step 4 - Layer 2"
                            class="absolute w-[25%]! pg-step-4-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755b8b5473a538781e8d6_E2.png"
                            alt="Verifactu Step 4 - Layer 3"
                            class="absolute w-[33%]! pg-step-4-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5755b3f6c63980f8ee3da1_E1.png"
                            alt="Verifactu Step 4 - Layer 4"
                            class="absolute w-[33%]! pg-step-4-4 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                        <div
                            class="absolute bottom-0 left-0 right-0 h-24 lg:h-40 z-15 pointer-events-none"
                            style="background: linear-gradient(to top, #FDF2ED 15%, rgba(253, 242, 237, 0) 100%);"
                        >
                        </div>
                    </div>
                    <div class="mt-auto p-5 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Verifactu
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0"
                        >
                            ClearTax creates tamper-proof invoice records with
                            QR codes and reports them to AEAT in near real time.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Connects to Everything (6 columns) -->
            <div
                id="card-lifecycle"
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[420px] lg:min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] flex flex-col justify-start overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Lifecycle
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            ClearTax tracks acceptance, rejection, and payment
                            status, then flags missing updates before they
                            become audit risks.
                        </p>
                    </div>
                    <div
                        class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-full max-w-[650px] max-lg:max-w-[480px] max-sm:max-w-[340px] flex justify-between tilted-card-img-wrapper"
                    >
                        <!-- Card 1 (Left) - Animates -->
                        <div
                            class="relative w-[34%] aspect-[223/140] card2-item-left"
                        >
                            <!-- Card 2 Step 4: Background 1 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 1"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                            <!-- Card 2 Step 1: Base State Pill -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59c4e875110820e1be7b69_scratch-pad.png"
                                alt="Format Step 1"
                                class="w-auto h-auto absolute -top-12 left-1/2 -translate-x-1/2 z-20 pointer-events-none max-w-[280px]"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <!-- Card 2 (Center) - Animates -->
                        <div
                            class="relative w-[38%] aspect-[223/140] card2-item-center"
                        >
                            <!-- Card 2 Step 5: Background 2 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 2"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                            <!-- Card 2 Step 2: Mid State Pill -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5783face5c3718370ee2cc_card-2-step-2.png"
                                alt="Format Step 2"
                                class="w-auto h-auto absolute -top-12 left-1/2 -translate-x-1/2 z-20 pointer-events-none max-w-[280px]"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>

                        <!-- Card 3 (Right) - Animates -->
                        <div
                            class="relative w-[34%] aspect-[223/140] card2-item-right"
                        >
                            <!-- Card 2 Step 6: Background 3 -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5784103c4773fa008e5e14_card-2-step-5.png"
                                alt="Format Background 3"
                                class="w-full h-full object-contain absolute inset-0 z-10 pointer-events-none"
                                loading="lazy"
                                decoding="async"
                            />
                            <!-- Card 2 Step 3: Final State Pill -->
                            <img
                                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a59c41f09dab641e62ef84e_scratch-pad-2.png"
                                alt="Format Step 3"
                                class="w-auto h-auto absolute -top-12 left-1/2 -translate-x-1/2 z-20 pointer-events-none max-w-[280px]"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Always-On e-Invoicing (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] flex flex-col justify-end overflow-hidden relative h-full pt-5"
                >
                    <div
                        class="absolute top-0 right-0 flex max-w-[504px] w-full tilted-card-img-wrapper"
                    >
                        <!-- Card 3 Step 1: Base State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f19f1e871c89e5f543bd_playground-3-1.png"
                            alt="Validation Step 1"
                            class="w-full h-auto object-contain relative z-10 card3-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 3 Step 2: Mid State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f1a3a65421650514ff2d_playground-3-2.png"
                            alt="Validation Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 card3-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 3 Step 3: Final State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f1a847d891cd37954e26_playground-3-3.png"
                            alt="Validation Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 card3-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Interoperability
                        </h3>
                        <p
                            class="text-balance font-normal max-w-116 leading-normal text-black/80 m-0"
                        >
                            ClearTax connects private platforms with each other
                            and AEAT’s public solution, including automated
                            retrieval flows.
                        </p>
                    </div>
                </div>
            </div>

            <!-- VAT Assurance (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#E8F5F7] rounded-[16px] p-5 pt-0 flex flex-col overflow-hidden relative h-full"
                >
                    <div
                        class="max-w-[406px] w-full flex items-start justify-end order-1 ml-auto my-auto tilted-card-img-wrapper relative"
                    >
                        <!-- Card 4 Step 1: Base State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f5095b2d80ef446cae1c_playground-4-1.png"
                            alt="Archival Step 1"
                            class="w-full h-auto object-contain relative z-10 card4-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 4 Step 2: Mid State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f5103f35cc5a575ec839_playground-4-2.png"
                            alt="Archival Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 card4-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 4 Step 3: Final State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a55f5144d3261b2a7f37063_playground-4-3.png"
                            alt="Archival Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 card4-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div
                        class="flex flex-col justify-start order-2 relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4 w-full"
                        >
                            Format
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0 w-full"
                        >
                            ClearTax converts ERP invoice data into UBL,
                            Facturae, CII, or EDIFACT without changing your data
                            model.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Zero Downtime (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card !min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] max-w-[748px] flex flex-col justify-start overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Applicability
                        </h3>
                        <p
                            class="text-base font-normal max-w-132 leading-normal text-black/80 m-0"
                        >
                            ClearTax identifies the right route: Spanish B2B in
                            scope, B2C excluded, and B2G handled through FACe.
                        </p>
                    </div>
                    <div
                        class="absolute bottom-0 right-0 flex max-w-[600px] w-full tilted-card-img-wrapper"
                    >
                        <!-- Card 5 Step 1: Base State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a560f1787b599eaa5dc6326_animate-1.png"
                            alt="Scope Step 1"
                            class="w-full h-auto object-contain relative z-10 card5-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 5 Step 2 -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a560f1cf7949c164ae866ca_animate-2.png"
                            alt="Scope Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 card5-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 5 Step 3 -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5610d187b599eaa5ddb6ce_animate-3.png"
                            alt="Scope Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 card5-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 5 Step 4: Final State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5610d639762bc1b5fa33e7_animate-4.png"
                            alt="Scope Step 4"
                            class="w-full h-full object-contain absolute inset-0 z-10 card5-step-4 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Enterprise AI Security (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] p-5 flex flex-col justify-start overflow-hidden relative h-full"
                >
                    <div class="mb-8 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            True Copy
                        </h3>
                        <p
                            class="text-base font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            ClearTax sends a faithful UBL copy to AEAT at the
                            same time the invoice reaches the buyer.
                        </p>
                    </div>
                    <div
                        class="absolute bottom-0 left-1/2 -translate-x-1/2 flex max-w-[478px] w-full tilted-card-img-wrapper"
                    >
                        <!-- Card 6 Step 1: Base State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5612abe746efe70a546b44_playground-6-1.png"
                            alt="Security Step 1"
                            class="w-full h-auto object-contain relative z-10 card6-step-1 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 6 Step 2 -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5612b18d3f605647ae9116_playground-6-2.png"
                            alt="Security Step 2"
                            class="w-full h-full object-contain absolute inset-0 z-10 card6-step-2 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 6 Step 3 -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5612b827a368670803bc49_playground-6-3.png"
                            alt="Security Step 3"
                            class="w-full h-full object-contain absolute inset-0 z-10 card6-step-3 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />

                        <!-- Card 6 Step 4: Final State -->
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5612bee746efe70a54756c_playground-6-4.png"
                            alt="Security Step 4"
                            class="w-full h-full object-contain absolute inset-0 z-10 card6-step-4 pointer-events-none"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Tilted Card Styles */
    .tilted-card {
        perspective: 1000px;
        z-index: 1;
    }
    .tilted-card-inner {
        transform-style: preserve-3d;
        will-change: transform;
        transition:
            transform 0.1s ease-out,
            box-shadow 0.3s ease; /* Fallback */
    }
    .tilted-card-img-wrapper {
        transform: translateZ(20px);
        transform-style: preserve-3d;
        backface-visibility: hidden;
    }
    .tilted-card-img-wrapper img:not(.absolute) {
        transform: translateZ(10px);
    }
    /* Layered Card Cross-fade Animations */
    .pg-step-1 {
        opacity: 0;
    }
    .pg-step-2 {
        opacity: 0;
    }
    .pg-step-3 {
        opacity: 0;
    }
    .pg-step-4-1,
    .pg-step-4-2,
    .pg-step-4-3,
    .pg-step-4-4 {
        opacity: 1;
    }
    .pg-step-4-1 {
        width: 100%;
        height: 100%;
        left: 0;
        top: 0;
        object-fit: contain;
    }
    .pg-step-4-2 {
        width: 32%;
        height: auto;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -55%);
        object-fit: contain;
        z-index: 13;
    }
    .pg-step-4-3 {
        width: 38%;
        height: auto;
        left: 12%;
        top: 14%;
        object-fit: contain;
        z-index: 11;
    }
    .pg-step-4-4 {
        width: 38%;
        height: auto;
        right: 12%;
        top: 14%;
        object-fit: contain;
        z-index: 12;
    }
    .card2-item-left,
    .card2-item-center,
    .card2-item-right {
        opacity: 1;
        will-change: transform, opacity;
    }
    .card3-step-1 {
        opacity: 1;
    }
    .card3-step-2 {
        opacity: 0;
    }
    .card3-step-3 {
        opacity: 0;
    }
    .card4-step-1 {
        opacity: 1;
    }
    .card4-step-2 {
        opacity: 0;
    }
    .card4-step-3 {
        opacity: 0;
    }
    .card5-step-1 {
        opacity: 1;
    }
    .card5-step-2 {
        opacity: 0;
    }
    .card5-step-3 {
        opacity: 0;
    }
    .card5-step-4 {
        opacity: 0;
    }
    .card6-step-1 {
        opacity: 1;
    }
    .card6-step-2 {
        opacity: 0;
    }
    .card6-step-3 {
        opacity: 0;
    }
    .card6-step-4 {
        opacity: 0;
    }

    #playground-section.animate-start .card3-step-1 {
        animation: card3-step1-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card3-step-2 {
        animation: card3-step2-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card3-step-3 {
        animation: card3-step3-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card4-step-1 {
        animation: card4-step1-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card4-step-2 {
        animation: card4-step2-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card4-step-3 {
        animation: card4-step3-fade 1.8s forwards ease-in-out;
    }
    #playground-section.animate-start .card5-step-1 {
        animation: card5-step1-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card5-step-2 {
        animation: card5-step2-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card5-step-3 {
        animation: card5-step3-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card5-step-4 {
        animation: card5-step4-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card6-step-1 {
        animation: card6-step1-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card6-step-2 {
        animation: card6-step2-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card6-step-3 {
        animation: card6-step3-fade 2.4s forwards ease-in-out;
    }
    #playground-section.animate-start .card6-step-4 {
        animation: card6-step4-fade 2.4s forwards ease-in-out;
    }

    /* Hover card: Restart and replay sequence from beginning (desktop pointer only) */
    @media (hover: hover) {
        /* Card 2 has static side-by-side entrance layout, no hover step loop needed */
        #playground-section.animate-start .tilted-card:hover .card3-step-1 {
            animation: card3-step1-hover-fade 1.8s forwards ease-in-out;
        }
        #playground-section.animate-start .tilted-card:hover .card3-step-2 {
            animation: card3-step2-hover-fade 1.8s forwards ease-in-out;
        }
