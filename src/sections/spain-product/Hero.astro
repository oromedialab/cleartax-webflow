---
/**
 * Spain Hero section — modern Astro component
 * Matches reference layout and screenshot with hero-bg.png as background,
 * floating avatar badge, pill badge, trust strip, and glassmorphic HubSpot booking form.
 */
const checklistItems = [
    {
        label: "Exchange structured B2B invoices under Crea y Crece",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a54e46699a728deb66bc8f3_checklist-1.png",
    },
    {
        label: "Stay compliant with Verifactu-certified billing system requirements",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a54e46cd54e6bcacb56f9c5_checklist-2.png",
    },
    {
        label: "Connect directly to AEAT from your existing ERP",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a54e47126b0bb512b112a89_checklist-3.png",
    },
];
---

<section
    class="hero-section relative min-h-[700px] overflow-hidden flex items-center pt-28 pb-12 md:pt-30 md:pb-16 lg:pt-35 lg:pb-25"
    id="hero"
>
    <!-- Sunset Skyline Background with dark to soft fade overlays -->
    <div
        class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
        style="background-image: url('https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a587b3d11e28adacbd08ef7_Hero-bg.png');"
    >
    </div>
    <div
        class="absolute inset-0 z-0 bg-gradient-to-b from-white/85 via-white/50 to-transparent hidden max-[630px]:block pointer-events-none"
    >
    </div>

    <!-- Video absolutely positioned relative to the section -->
    <div
        class="hidden lg:flex lg:absolute -right-4 lg:top-1/2 lg:-translate-y-1/2 items-center justify-end w-full inset-0 premium-reveal [transition-delay:500ms]"
    >
        <video
            src="https://npenclnkidsfdleqtsho.supabase.co/storage/v1/object/public/Cleartax%20Assets/Glass_Anim_CT010000-0150.webm"
            autoplay
            loop
            muted
            playsinline
            class="w-full max-w-full h-auto object-contain opacity-90"
        >
        </video>
    </div>

    <div class="relative z-10 mx-auto lg:container w-full px-4 lg:px-8">
        <div
            class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.9fr] 2xl:grid-cols-2 gap-12 lg:gap-8 items-start"
        >
            <!-- Hero Left Column -->
            <div class="hero-left-content flex flex-col items-start">
                <!-- Headline -->
                <h2
                    class="text-[36px] lg:text-[44px] xl:text-[56px] font-medium leading-[1.15] max-w-168 mb-4 m-0 bg-clip-text text-transparent"
                    style="background-image: linear-gradient(180deg, #AA50C8 0%, #030203 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
                >
                    Two Different E-Invoicing Mandates. No Room for Compliance
                    Gaps.
                </h2>

                <!-- Description -->
                <p
                    class="text-base sm:text-lg text-[#110813]/80 max-w-134 leading-[1.44] mb-8 sm:mb-10"
                >
                    ClearTax helps you manage Verifactu and Crea y Crece
                    end-to-end, connecting your existing ERP directly with AEAT.
                </p>

                <!-- Trust Badges Strip -->
                <ul
                    class="list-none p-0 mb-14 sm:mt-0 grid grid-cols-1 gap-x-9 gap-y-6"
                >
                    {
                        checklistItems.map((item, index) => (
                            <li
                                class="inline-flex items-center leading-snug gap-3 transition-all cursor-pointer premium-reveal"
                                style={`transition-delay: ${200 + index * 100}ms`}
                            >
                                <div class="shrink-0 flex items-center justify-center w-6 h-6">
                                    <img
                                        src={item.icon}
                                        alt=""
                                        class="w-full h-full object-contain"
                                    />
                                </div>
                                <span class="text-base lg:text-lg leading-[1.44] font-normal text-[#432984]">
                                    {item.label}
                                </span>
                            </li>
                        ))
                    }
                </ul>

                <!-- Call to Action button -->
                <a
                    href="javascript:void(0)"
                    onclick="scrollToPlayground(event)"
                    class="inline-flex items-center justify-center px-14 py-2 md:py-4 font-gilroy rounded-full font-normal text-white transition-all duration-300 hover:-translate-y-1 text-base cursor-pointer bg-[linear-gradient(90deg,_#110072_0%,_#7A5698_100%)] border border-white/20"
                    style="outline: none;"
                >
                    Explore platform
                </a>
            </div>

            <!-- Empty column placeholder on desktop to reserve space in grid layout so text does not overlap -->
            <div class="hidden lg:block pointer-events-none"></div>
        </div>

    </div>
</section>

<script is:inline>
    window.scrollToPlayground = (e) => {
        if (e) e.preventDefault();
        const el = document.getElementById("playground");
        if (el) el.scrollIntoView({ behavior: "smooth" });
    };
</script>
