---



<section class="hero-section relative min-h-[700px] overflow-hidden flex items-center pt-28 pb-12 md:pt-30 md:pb-16 lg:pt-35 lg:pb-25" id="hero">
  <!-- Sunset Skyline Background with dark to soft fade overlays -->
  <div class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat" style="background-image: url('https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1d17a650966f1b3103a1e2_Hero-img.png');"></div>
<div class="absolute inset-0 z-0 bg-gradient-to-b from-white/85 via-white/50 to-transparent hidden max-[630px]:block pointer-events-none"></div>

  <div class="relative z-10 mx-auto lg:container w-full px-4 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.9fr] 2xl:grid-cols-2 gap-12 lg:gap-8 items-start">
      
      <!-- Hero Left Column -->
      <div class="hero-left-content flex flex-col items-start">
        <!-- Badge Capsule -->
        <h1 class="inline-flex items-center gap-1.5 bg-[linear-gradient(90deg,_rgba(144,_68,_169,_0.2)_0%,_rgba(184,_126,_200,_0.2)_100%)] text-[#8841A0] leading-[1] text-xs font-normal px-3 py-2 rounded-full mb-4">
          Best E-invoicing Software in Oman
        </h1>
        <!-- Headline -->
        <h2 class="text-[36px] lg:text-[44px] xl:text-[52px] font-medium leading-[1.15] max-w-134 mb-4 m-0 bg-clip-text text-transparent" style="background-image: linear-gradient(180deg, #AA50C8 0%, #030203 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
         If your supplier isn't Fawtara-ready, your VAT input claim isn't either.
        </h2>
        
        <!-- Description -->
        <p class="text-base sm:text-lg text-[#110813]/80 max-w-134 leading-[1.44] mb-8 sm:mb-10">
          Every e-invoicing supplier will say they support Fawtara. But ClearTax is already OTA Accredited.
        </p>
         
        
        <!-- Trust Badges Strip -->
        <ul class="list-none p-0 mb-14 sm:mt-0 grid grid-cols-1 sm:grid-cols-2 gap-x-9 gap-y-6">
          {
                    checklistItems.map((item, index) => (
                        <li
                            class="inline-flex items-center leading-snug gap-3 transition-all cursor-pointer premium-reveal"
                            style={`transition-delay: ${200 + index * 100}ms`}
                        >
                            <div class="shrink-0 flex items-center justify-center w-6 h-6">
                                <img src={item.icon} alt="" class="w-full h-full object-contain" />
                            </div>
                            <span class="text-base lg:text-lg leading-[1.44] font-normal text-[#432984]">
                                {item.label}
                            </span>
                        </li>
                    ))
                }
            </ul>
            
            <!-- Call to Action button -->
            <a 
            href="javascript:void(0)"
            onclick="scrollToPlayground(event)"
            class="inline-flex items-center justify-center px-14 py-2 md:py-4 font-gilroy rounded-full font-normal text-white transition-all duration-300 hover:-translate-y-1 text-base cursor-pointer bg-[linear-gradient(90deg,_#110072_0%,_#7A5698_100%)] border border-white/20"
            style="outline: none;"
            >
            Explore platform
          </a>
        </div>
    
        <div class="relative premium-reveal [transition-delay:500ms] w-full">
        <!-- Desktop Background Image -->
            <div
                class="hidden xl:block absolute -z-10 top-1/3 left-1/4 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
            >
                <img
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a460449cea6ca713d88d19f_hero-graphic-img.png"
                    alt=""
                    class="min-w-[411px] min-h-[589px] object-cover opacity-80"
                />
            </div>
        <!-- Responsive Background Image -->
            <div
                class="block lg:hidden absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
            >
                <img
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a460449cea6ca713d88d19f_hero-graphic-img.png"
                    alt=""
                    class="min-w-[329px] min-h-[471px] object-cover opacity-80"
                />
            </div>
       <!-- Hero Right Column: Lead Form Card -->
      <aside id="hero-form" class="hero-form bg-white/80 backdrop-blur-xl text-[#111827] rounded-xl p-6 2xl:p-8 [box-shadow:_-1px_1px_22px_0px_#00000029] border border-white/60 w-full max-w-[600px] scroll-mt-28">
        <h3 class="text-[22px] font-medium text-black mb-3 leading-[1.36] m-0">Book a Demo</h3>
        <p class="text-base text-black/80 mb-4">Get a personalized walkthrough of our Philippine e-invoicing solution.</p>

        <!-- HubSpot Form Mount Container -->
        <div id="hero-hubspot-form" class="hs-form-wrap-light">
          <!-- Form Skeleton Loader -->
          <div id="form-skeleton" class="form-skeleton">
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div>
              <div class="skeleton-label shimmer" style="width: 100px;"></div>
              <div class="skeleton-input shimmer"></div>
            </div>
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div class="skeleton-button shimmer"></div>
          </div>
        </div>
        
        <p class="text-sm text-black/80 text-center mt-4">No spam. Just a 30-min call with our Philippine specialists.</p>
      </aside>
        </div>
    </div>
  </div>
</section>

<script is:inline>
  // HubSpot form embed with URL parameters auto-prefill
  (() => {
    let initialized = false;
    
    const initForm = () => {
      if (initialized) return;
      if (window.hbspt && window.hbspt.forms) {
        initialized = true;
        window.hbspt.forms.create({
          portalId: "245744706",
          formId: "51af6b81-aa59-4bd2-b499-ff081e27324d",
          region: "na2",
          target: "#hero-hubspot-form",
          onFormReady: function($form) {
            // Remove the skeleton loader
            const skeleton = document.getElementById("form-skeleton");
            if (skeleton) {
              skeleton.remove();
            }

            const formEl = ($form && $form[0]) ? $form[0] : $form;
            if (formEl && formEl.querySelector) {
              const urlParams = new URLSearchParams(window.location.search);
              const utms = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
              utms.forEach(utm => {
                const value = urlParams.get(utm);
                if (value) {
                  const input = formEl.querySelector('input[name="' + utm + '"]');
                  if (input) {
                    input.value = value;
                  }
                }
              });
            }
          }
        });
      }
    };

    window.scrollToPlayground = (e) => {
      if (e) e.preventDefault();
      const el = document.getElementById('playground');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    };

    const checkAndInit = () => {
      if (window.hbspt && window.hbspt.forms) {
        initForm();
      } else {
        // Look for HubSpot script and attach load listener
        const script = document.querySelector('script[src*="hsforms.net"]');
        if (script) {
          script.addEventListener('load', initForm);
        }
        // Also poll as a robust fallback
        let pollCount = 0;
        const interval = setInterval(() => {
          pollCount++;
          if (window.hbspt && window.hbspt.forms) {
            clearInterval(interval);
            initForm();
          } else if (pollCount > 100) { // Stop polling after 10 seconds
            clearInterval(interval);
          }
        }, 100);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", checkAndInit);
    } else {
      checkAndInit();
    }
  })();
</script>

<style is:global>
