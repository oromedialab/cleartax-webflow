    }
  }
  .skeleton-label {
    height: 14px;
    width: 80px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .skeleton-input {
    height: 44px;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    width: 100%;
  }
  .skeleton-button {
    height: 46px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.25) 0%, rgba(49, 46, 129, 0.25) 100%);
    border-radius: 30px;
    width: 100%;
    margin-top: 8px;
  }
  
  /* Shimmer Animation */
  .shimmer {
    position: relative;
    overflow: hidden;
  }
  .shimmer::after {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    transform: translateX(-100%);
    background-image: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.6) 20%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 255, 255, 0) 100%
    );
    animation: shimmer-anim 1.6s infinite;
    content: '';
  }
  @keyframes shimmer-anim {
    100% {
      transform: translateX(100%);
    }
  }
</style>