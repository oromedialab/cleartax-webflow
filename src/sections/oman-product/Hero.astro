 */
const checklistItems = [
    {
        label: "OTA Accredited",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a47492734b2f4a738dcfda4_hero-svg-1.png",
    },
    {
        label: "Direct ERP-to-Fawtara",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a4749278d5edcd911530daf_hero-svg-2.png",
    },
    {
        label: "Real-Time Transmission",
        icon: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a4753454e601d56b67a4e50_hero-svg-3.png",
    },
    {
        label: "Fully Peppol-Ready",
