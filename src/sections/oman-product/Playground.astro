---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="playground" class="bg-[#FFFFFF] py-12 lg:py-25 w-full">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center">
            <h2
                id="oman-title-shield"
                class="text-[26px]! sm:text-[32px]! lg:text-[44px]! font-semibold! max-w-227 mx-auto! text-black leading-[1.18]! m-0! premium-reveal"
            >
                What Oman's Fawtara mandate requires <span class="text-[#655DFF]"
                    >And what ClearTax covers</span
                >
            </h2>
            <p
                id="oman-subtitle-shield"
                class="lg:text-lg! text-base! font-normal! text-black/80! mt-4! max-w-227 mx-auto premium-reveal [transition-delay:150ms]"
            >
                Oman uses a Peppol-based 5-corner model, also called a decentralised continuous transaction control & exchange model. The OTA became an official Peppol Authority in January 2026. ClearTax handles every requirement out of the box.
            </p>
        </div>

        <div class="grid grid-cols-12 gap-7 mt-12 w-full">
            <!-- Built for Your Busiest Day (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 pt-0 px-0 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="flex justify-center items-end -mb-8 max-w-[626px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a46258f76d14c75838ed347_playground-1.png"
                            alt="Speedometer"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="mt-auto p-5 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Transmission
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0"
                        >
                            B2B invoices transmit in real time, while B2C transactions have a 24-hour window. ClearTax automates both flows.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Connects to Everything (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Format
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            Invoices must use XML (UBL 2.1) or PDF/A-3 and follow OTA’s PINT OM specification for Peppol interoperability.
                        </p>
                    </div>
                    <div
                        class="flex max-w-[412px] ml-auto w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a462597a2a554599fa776f6_playground-2.png"
                            alt="Connectors"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Always-On e-Invoicing (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] flex flex-col justify-end overflow-hidden relative h-full pt-5"
                >
                    <div
                        class="absolute top-0 right-0 flex max-w-[504px] w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a46259d07b10c48c6f6a1f5_playground-3.png"
                            alt="Always-On"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Validation
                        </h3>
                        <p
                            class="text-balance font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            ClearTax checks XSD structure, business rules, and code lists before invoices reach the Fawtara network.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Zero Downtime (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card !min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] max-w-[748px] flex flex-col justify-end overflow-hidden relative h-full pt-5"
                >
                <div
                    class="absolute top-0 right-0 flex max-w-[550px] w-full tilted-card-img-wrapper"
                >
                    <img
                        src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a4625a3d1e5f2f75a445894_playground-4.png"
                        alt="Zero Downtime"
                        class="w-full h-auto object-contain"
                        loading="lazy"
                        decoding="async"
                    />
                </div>
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Scope
                        </h3>
                        <p
                            class="text-base font-normal max-w-132 leading-normal text-black/80 m-0"
                        >
                            B2B, B2G, and B2C obligations apply simultaneously within each rollout phase, all covered through one ClearTax deployment.
                        </p>
                    </div>
                </div>
            </div>

            <!-- VAT Assurance (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-5 gap-8 flex flex-col lg:flex-row overflow-hidden relative h-full"
                >
                    <div
                        class="flex flex-col justify-start order-2 lg:order-1 relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4 w-full"
                        >
                            Archival
                        </h3>
                        <p
                            class="text-base max-w-64 font-normal leading-normal text-black/80 m-0 w-full"
                        >
                            Invoices must be securely retained for at least 10 years. ClearTax stores them in a structured, immutable, audit-ready format.
                        </p>
                    </div>
                    <div
                        class="max-w-[406px] w-full flex items-start justify-end order-1 lg:order-2 ml-auto my-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a46481ffd30baed73fa0e98_playground-5.png"
                            alt="VAT Assurance"
                            class="w-full h-auto object-contain origin-top-right flex justify-center items-end pt-3"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Enterprise AI Security (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[360px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="mb-8 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Security
                        </h3>
                        <p
                            class="text-base font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            ISO 27001:2022, SOC 2, AES-256 encryption, SSL, role-based access, and Oman-aligned data residency controls.
                        </p>
                    </div>
                    <div
                        class="mt-auto flex justify-center items-end pt-4 max-w-[430px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a4de76ad4029f18ac886a33_grid-5.png"
                            alt="Security"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Tilted Card Styles */
    .tilted-card {
        perspective: 1000px;
        z-index: 1;
    }
    .tilted-card-inner {
        transform-style: preserve-3d;
        will-change: transform;
        transition:
            transform 0.1s ease-out,
            box-shadow 0.3s ease; /* Fallback */
    }
    .tilted-card-img-wrapper {
        transform: translateZ(20px);
        transform-style: preserve-3d;
        backface-visibility: hidden;
    }
    .tilted-card-img-wrapper img {
        transform: translateZ(10px);
    }

    /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
    #usp-title-shield {
        font-size: 44px !important;
        line-height: 1.18 !important;
        font-weight: 600 !important;
        color: black !important;
        text-align: center !important;
        margin: 0 !important;
    }
    #usp-subtitle-shield {
        font-size: 18px !important;
        font-weight: 500 !important;
        color: black !important;
        opacity: 0.8 !important;
        text-align: center !important;
        margin-top: 16px !important;
    }
    @media (max-width: 1024px) {
        #usp-title-shield {
            font-size: 32px !important;
        }
    }
    @media (max-width: 640px) {
        #usp-title-shield {
            font-size: 26px !important;
        }
        #usp-subtitle-shield {
            font-size: 16px !important;
        }
    }
</style>

<script is:inline>
    (function () {
        let initialized = false;
        const section = document.getElementById("playground");

        function initTiltedCards() {
            if (initialized) return;
            initialized = true;

            const cards = document.querySelectorAll(".tilted-card");
            cards.forEach((card) => {
                const inner = card.querySelector(".tilted-card-inner");
                if (!inner) return;

                const rotateAmplitude = 12;
                const scaleOnHover = 1.02;

                let targetRotateX = 0,
                    targetRotateY = 0,
                    targetScale = 1;
                let currentRotateX = 0,
                    currentRotateY = 0,
                    currentScale = 1;
                let rafId = null;

                function update() {
                    currentRotateX += (targetRotateX - currentRotateX) * 0.1;
                    currentRotateY += (targetRotateY - currentRotateY) * 0.1;
                    currentScale += (targetScale - currentScale) * 0.1;
                    inner.style.transform = `rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) scale(${currentScale})`;
                    if (
                        Math.abs(targetRotateX - currentRotateX) > 0.01 ||
                        Math.abs(targetRotateY - currentRotateY) > 0.01 ||
                        Math.abs(targetScale - currentScale) > 0.001
                    ) {
                        rafId = requestAnimationFrame(update);
                    } else {
                        rafId = null;
                    }
                }

                card.addEventListener("mousemove", (e) => {
                    const rect = card.getBoundingClientRect();
                    const offsetX = e.clientX - rect.left - rect.width / 2;
                    const offsetY = e.clientY - rect.top - rect.height / 2;
                    targetRotateX =
                        (offsetY / (rect.height / 2)) * -rotateAmplitude;
                    targetRotateY =
                        (offsetX / (rect.width / 2)) * rotateAmplitude;
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseenter", () => {
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseleave", () => {
                    targetRotateX = 0;
                    targetRotateY = 0;
                    targetScale = 1;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });
            });
        }

        if (section) {
            section.addEventListener("mouseenter", initTiltedCards, {
                once: true,
            });
            section.addEventListener("touchstart", initTiltedCards, {
                once: true,
            });
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        if (entries[0].isIntersecting) {
                            initTiltedCards();
                            obs.disconnect();
                        }
                    },
                    { rootMargin: "100px" },
                );
                obs.observe(section);
            } else {
                initTiltedCards();
            }
        }
    })();
</script>
