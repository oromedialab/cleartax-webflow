---
export interface Props {
    //
}

const steps = [
    {
        dateLine1: "AUG",
        dateLine2: "2026",
        phaseLine1: "PHASE 1 · TOP 100",
        phaseLine2: "TAXPAYERS",
        phaseColor: "text-[#4D3BE2]",
        descColor: "text-[#000000]/80",
        desc: "Largest VAT-registered companies go live with B2B, B2G, and B2C in scope.",
        desc2: "ClearTax : OTA pre-approved and live from day one.",
        highlight: true,
        active: true,
        lineSolid: true
    },
    {
        dateLine1: "FEB",
        dateLine2: "2027",
        phaseLine1: "PHASE 2 · LARGE",
        phaseLine2: "TAXPAYERS",
        phaseColor: "text-[#4D3BE2]",
        descColor: "text-[#000000]/80",
        desc: "All large VAT-registered taxpayers go live based on OTA revenue thresholds.",
        desc2: "ClearTax : Same integration with no new IT project.",
        highlight: true,
        active: true,
        lineSolid: true
    },
    {
        dateLine1: "AUG",
        dateLine2: "2027",
        phaseLine1: "PHASE 3 · ALL VAT",
        phaseLine2: "BUSINESSES",
        phaseColor: "text-[#4D3BE2]",
        descColor: "text-[#000000]/80",
        desc: "All remaining VAT-registered businesses, including SMEs, must comply. No exemptions.",
        desc2: "ClearTax : Same platform with updated configuration.",
        highlight: false,
        active: false,
        lineSolid: false
    },
    {
        dateLine1: "AUG",
        dateLine2: "2028",
        phaseLine1: "PHASE 1 · GOVERNMENT",
        phaseLine2: "ENTITIES",
        phaseColor: "text-[#4D3BE2]",
        descColor: "text-[#000000]/80",
        desc: "Government entities go live with mandatory B2G invoicing through Fawtara.",
        desc2: "ClearTax : Already planned on the product roadmap.",
        active: false,
        lineSolid: false
    }
];
---

<section class="py-15 lg:py-20 bg-gradient-to-b from-[#F3F1F9] to-[#F3F1F9] overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-4 lg:px-6">
        <div class="flex w-full justify-between lg:items-end gap-12 max-lg:flex-col">
      <!-- left side  -->
      <div class="w-full lg:max-w-161">
        <div class='w-full'>
        <h2
          class="mt-5 text-[26px] sm:text-[36px] lg:text-[44px] max-w-161 font-semibold leading-[1.18] text-black m-0"
        >
          August 2026 is Phase 1. The mandate <span class="text-[#655DFF]">doesn't stop there.</span>
        </h2>
       </div>
      </div>
      <!-- right side -->
      <div class="w-full lg:max-w-[408px]">
        <p class="text-base lg:text-lg max-w-161 mt-4 text-black/80">Fawtara is a four-phase programme running to 2028. ClearTax is already built for every phase — so you integrate once and stay compliant as the scope expands.</p>
      </div>
    </div>

        <div class="flex flex-col gap-6 lg:grid lg:grid-cols-4 lg:gap-8 sm:gap-16 mt-12 mb-9 relative z-10 max-w-[400px] lg:max-w-none mx-auto premium-reveal [transition-delay:200ms]">
            {steps.map((step, index) => (
                <div class={`relative flex flex-row lg:flex-col max-w-[370px] lg:w-auto items-start lg:items-start group ${index === 1 || index === 2 ? 'lg:translate-x-7' : ''}`}>
                    <div class="relative shrink-0 flex justify-center w-[96px]">
                        <div class={`w-[96px] h-[96px] rounded-full flex flex-col items-center font-semibold justify-center text-white transition-all duration-300 group-hover:-translate-y-1 ${
                            step.highlight 
                                ? 'bg-[#6B5CE7] ring-[6px] ring-[#6B5CE7]/20 glow-pulse scale-105' 
                                : step.active 
                                    ? 'bg-[#6B5CE7] shadow-[0_0_20px_rgba(101,93,255,0.2)]' 
                                    : 'bg-[#A198EE] text-white/80'
                        }`}>
                            <span>{step.dateLine1}</span>
                            <span>{step.dateLine2}</span>
                        </div>
                    </div>
                    
                    <div class="ml-6 lg:ml-0 lg:mt-7 flex-1 pt-2 lg:pt-0 text-left">
                        <div class={`text-[16px] tracking-[1.5px] uppercase font-normal ${step.phaseColor}`}>
                            <div>{step.phaseLine1}</div>
                            <div>{step.phaseLine2}</div>
                        </div>
                        <div class={`text-lg font-normal mt-3 leading-[1.4] text-wrap ${step.descColor} ${index === 1 ? 'max-w-[240px]' : 'max-w-[258px]'}`}>
                            {step.desc}
                        </div>
                        {step.desc2 && (
                            <div class={`text-lg font-normal mt-2 leading-[1.4] text-wrap ${step.descColor} ${index === 1 ? 'max-w-[240px]' : 'max-w-[258px]'}`}>
                                <span class="font-medium text-black">{step.desc2.split(':')[0]} : </span>{step.desc2.split(':')[1]}
                            </div>
                        )}
                    </div>
 
                    {index < steps.length - 1 && (
                        <>
                            <!-- Desktop Line -->
                            <div 
                                class={`hidden lg:block absolute top-[48px] left-[75px] w-70 -z-10 ${step.lineSolid ? 'h-[2px] bg-[#655DFF]' : 'dashed-line-horizontal'}`}
                                style={
                                    index === 0 
                                        ? "width: calc(75% + 160px);" 
                                        : index === 2 
                                            ? "width: calc(100% - -25px);" 
                                            : undefined
                                }
                            ></div>
                            
                            <!-- Mobile Line -->
                            <div class={`lg:hidden absolute top-[96px] h-50 left-[48px] -translate-x-1/2 -bottom-12 -z-10 ${step.lineSolid ? 'w-[2px] bg-[#655DFF]' : 'dashed-line-vertical'}`}></div>
                        </>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>

<style is:global>
    .dashed-line-horizontal {
        height: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(90deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .dashed-line-vertical {
        width: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(0deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .glow-pulse {
        animation: pulse-glow 2s infinite ease-in-out;
    }
    @keyframes pulse-glow {
        0% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0.6);
        }
        70% {
            box-shadow: 0 0 0 12px rgba(107, 92, 231, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0);
        }
    }
</style>
