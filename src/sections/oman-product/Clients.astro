---
const items = [
    {
        title: "BIR EIS Compliance",
        description: "100% compliant with BIR EIS under RR No. 011-2025.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a44e648916bf40cbc2b5a_logo-1.png",
    },
    {
        title: "Peppol Access Point",
        description: "for compliant e-invoicing exchange.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a44f0e2e7d26264cc5505_logo-2.png",
    },
    {
        title: "ISO 27001:2022",
        description: "Certified information security management.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a44f85ca6a21f4da3745c_logo-3.png",
    },
    {
        title: "SOC 2 Type II",
        description: "Independently audited security and availability.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a45006078291fafc211bc_logo-4.png",
    },
    {
        title: "ZATCA Accreditation",
        description: "Accredited by ZATCA across global mandates.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a4506a290eecaf4b52d7f_logo-5.png",
    },
    {
        title: "FTA Accreditation",
        description: "Accredited by FTA across global mandates.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a450de2e7d26264cc6391_logo-6.png",
    },
    {
        title: "Peppol BIS 3.0",
        description: "Fully Peppol BIS 3.0 compliant.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a44f0e2e7d26264cc5505_logo-2.png",
    },
    {
        title: "LHDN / MDEC",
        description: "Accredited by LHDN & MDEC across global.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a45142ddb95c0e2b13be3_logo-7.png",
    },
    {
        title: "NIC Accreditation",
        description: "Accredited by NIC across global mandates.",
        img: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a454aa7dddb1dc84e5bc4_logo-8.png",
    }
];
---

<section class="py-20 lg:py-25 bg-[#FFFFFF]">
  <div class="max-w-[1280px] mx-auto px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-[26px] md:text-[36px] lg:text-[44px] max-w-154 mx-auto font-semibold text-[#000000] leading-[1.18] m-0">
        5,000+ Enterprise Clients.
        <span class="text-[#655DFF]">50+ Countries. One Platform.</span>
      </h2>
      <p class="text-base md:text-[18px] text-[#000000]/80 mt-4 max-w-170 mx-auto leading-[1.5]">
        From global conglomerates to EU-headquartered enterprises, finance teams trust ClearTax to keep them compliant, across every mandate, in every market.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
      {items.map((item) => (
        <div class="flex items-center gap-5">
          <!-- Circle with empty div for the user to add the image -->
          <div class="w-20 h-20 md:w-[120px] md:h-[120px] shrink-0 rounded-full bg-[#E7E2F34D] border-2 border-[#DAD4EC] flex items-center justify-center">
            <div class="w-12 h-12 md:w-18 md:h-18 flex justify-center items-center">
               <img src={item.img} alt={item.title} />
            </div>
          </div>
          
          <div>
            <h3 class="text-[18px] font-medium text-[#000000] mb-2 leading-[1.44] m-0">
              {item.title}
            </h3>
            <p class="text-lg text-[#000000] font-normal leading-[1.44] max-w-[215px]">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
