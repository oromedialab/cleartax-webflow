---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img
            src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfa05ecb34c38b5b8b5f54_cleartax-logo-light.png"
            alt="ClearTax"
            height="28"
            style="filter: brightness(0) invert(1);"
            loading="lazy"
            decoding="async"
          />
        </a>
        <div class="footer-social">
          <p class="footer-social-label">Follow us on</p>
          <div class="footer-social-icons">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  class="footer-social-icon"
                  aria-label={s.label}
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    set:html={s.icon}
                  />
                </a>
              ))
            }
          </div>
        </div>
      </div>

      {
        columns.map((col) => (
          <div class="footer-col">
            <h4 class="footer-col-title" set:html={col.title} />
            <ul class="footer-links">
              {col.items.map((it) => (
                <li>
                  <a href={it.href}>{it.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <div class="footer-bottom-left">
          <div class="footer-legal-links">
            <a href="https://www.cleartax.com/s/legal" class="footer-legal-link">Legal</a>
            <a href="https://www.cleartax.com/meta/privacy" class="footer-legal-link">Privacy Policy</a>
          </div>
          <p class="footer-address">P.O. Box 112, P.C. 122, Muscat, Muscat Governorate, Sultanate of Oman</p>
          <p class="footer-copyright">
            Cleartax is a product by Defmacro Software Pvt. Ltd.
          </p>
        </div>
        <div class="footer-bottom-right">
          <div class="footer-trust-logos">
            <img alt="ISO Certified" decoding="async" loading="lazy" src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69fb0ff41b9a63ce3e1f50d9_iso.png" />
            <img alt="SOC Certified" decoding="async" loading="lazy" src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69fad934822abf67d7c25954_soc.png" />
            <img alt="SSL Secured" decoding="async" loading="lazy" src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/6a154210439a661bb4313f68_ssll.png" />
            <img alt="GDPR Compliant" decoding="async" loading="lazy" src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a153c9e423a6b967412239c_gdpr.png" />
          </div>
          <p class="footer-badges-text">
            Your data security and privacy matter most to us.
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background: var(--color-dark);
    padding: 72px 0 0;
  }
  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 220px repeat(4, 1fr);
    gap: 40px;
    text-align: left;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .footer-logo img {
    height: 28px;
  }
  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-social-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
    margin: 0;
  }
  .footer-social-icons {
    display: flex;
    gap: 12px;
  }
  .footer-social-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-white);
    transition: background var(--transition-fast);
  }
  .footer-social-icon:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .footer-query {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer-query-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
    margin: 0;
  }
  .footer-query-link {
    font-size: 14px;
    color: var(--color-gray-400);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }
  .footer-query-link:hover {
    color: var(--color-white);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer-col-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
  }
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-links a {
    font-size: 14px;
    color: var(--color-gray-400);
    transition: color var(--transition-fast);
  }
  .footer-links a:hover {
    color: var(--color-white);
  }

  .footer-bottom {
    margin-top: 56px;
    padding: 32px 0 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }
  .footer-bottom-left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
  }
  .footer-legal-links {
    display: flex;
    gap: 24px;
  }
  .footer-legal-link {
    font-size: 14px;
    color: var(--color-gray-400);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-legal-link:hover {
    color: var(--color-white);
  }
  .footer-bottom-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    text-align: right;
  }
  .footer-trust-logos {
    display: flex !important;
    align-items: center !important;
    gap: 10px;
  }
  .footer-trust-logos img {
    height: 40px;
    width: auto;
  }
  .footer-badges-text {
    font-size: 14px;
    color: var(--color-gray-400);
    margin: 16px 0 0;
  }
  .footer-address {
    font-size: 13px;
    color: var(--color-gray-500);
    margin: 0;
  }
  .footer-copyright {
    font-size: 13px;
    color: var(--color-gray-500);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-bottom-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }
    .footer-bottom-right {
      align-items: flex-start;
      text-align: left;
      margin-top: 16px;
    }
  }

  @media (max-width: 1080px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px 32px;
    }
    .footer-brand {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: start;
      gap: 48px;
      flex-wrap: wrap;
    }
  }
  @media (max-width: 640px) {
    .footer {
      padding: 48px 0 0;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px 24px;
    }
    .footer-brand {
      flex-direction: column;
      gap: 24px;
    }
    .footer-bottom {
      margin-top: 40px;
    }
  }
</style>
