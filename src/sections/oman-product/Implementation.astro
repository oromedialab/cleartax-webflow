---
export interface Props {
    //
}

const steps = [
    {
        dateLine1: "FEB-MAY",
        dateLine2: "2026",
        phase: "PILOT",
        desc: "OTA sandbox, ASP certification and integration testing",
        active: true,
        highlight: false,
        lineSolid: true
    },
    {
        dateLine1: "AUG",
        dateLine2: "2026",
        phase: "PHASE 1",
        desc: "Top 100 taxpayers begin mandatory E-invoicing",
        active: true,
        highlight: true,
        lineSolid: false
    },
    {
        dateLine1: "FEB",
        dateLine2: "2027",
        phase: "PHASE 2",
        desc: "Mandate expands to qualifying large taxpayers",
        active: false,
        highlight: false,
        lineSolid: false
    },
    {
        dateLine1: "AUG",
        dateLine2: "2027",
        phase: "PHASE 3",
        desc: "All VAT-registered businesses, including SMEs",
        active: false,
        highlight: false,
        lineSolid: false
    },
    {
        dateLine1: "AUG",
        dateLine2: "2028",
        phase: "PHASE 4",
        desc: "Government entities adopt Fawtara-compliant B2G invoicing",
        active: false,
        highlight: false,
        lineSolid: false
    }
];
---

<section class="py-20 lg:py-15 lg:pt-15 bg-gradient-to-t from-[#F3F1F9] to-[#FFFFFF] overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-4 lg:px-6">
        <div class="text-center premium-reveal">
            <h2 class="text-3xl md:text-[40px] lg:text-[44px] font-semibold mx-auto m-0 text-[#030203]">
                Oman Fawtara Implementation <span class="text-[#655DFF]">Timeline</span>
            </h2>
        </div>

        <div class="flex flex-col gap-12 lg:grid lg:grid-cols-5 lg:gap-6 xl:gap-20 mt-12 mb-12 relative z-10 max-w-[400px] lg:max-w-none mx-auto premium-reveal [transition-delay:200ms]">
            {steps.map((step, index) => (
                <div class="relative flex flex-row lg:flex-col max-w-[370px] lg:w-auto items-start lg:items-center group">
                    <div class="relative shrink-0 flex justify-center w-[120px]">
                        <div class={`w-[120px] h-[120px] rounded-full flex flex-col items-center justify-center text-white transition-all duration-300 group-hover:-translate-y-1 ${
                            step.highlight
                                ? 'bg-[#6B5CE7] ring-[6px] ring-[#6B5CE7]/20 glow-pulse scale-105' 
                                : step.active 
                                    ? 'bg-[#6B5CE7] shadow-[0_0_20px_rgba(101,93,255,0.2)]' 
                                    : 'bg-[#A198EE] text-white/80'
                        }`}>
                            <span class="text-base font-semibold tracking-wide">{step.dateLine1}</span>
                            <span class="text-base font-semibold mt-0.5">{step.dateLine2}</span>
                        </div>
                    </div>
                    
                    <div class="ml-6 lg:ml-0 lg:mt-7 flex-1 lg:text-center pt-2 lg:pt-0">
                        <div 
                            class="text-base uppercase mb-2 font-normal tracking-[1.5px] text-[#4D3BE2] leading-none" 
                        >
                            {step.phase}
                        </div>
                        <div class={`text-lg max-w-[200px] leading-[1.5] text-wrap lg:mx-auto ${
                            step.highlight 
                                ? 'font-normal text-black text-lg'
                                : step.active 
                                    ? 'font-normal text-black' 
                                    : 'font-normal text-black/56'
                        }`}>
                            {step.desc}
                        </div>
                    </div>
 
                    {index < steps.length - 1 && (
                        <>
                            <!-- Desktop Line -->
                            <div 
                                class={`hidden lg:block absolute top-[60px] left-1/2 w-[220px] -z-10 ${step.lineSolid ? 'h-[2px] bg-[#655DFF]' : 'dashed-line-horizontal'}`}
                            ></div>
                            
                            <!-- Mobile Line -->
                            <div class={`lg:hidden absolute top-[120px] h-17 left-[60px] -translate-x-1/2 -bottom-12 -z-10 ${step.lineSolid ? 'w-[2px] bg-[#655DFF]' : 'dashed-line-vertical'}`}></div>
                        </>
                    )}
                </div>
            ))}
        </div>

        <!-- Bottom Scale Section -->
         <div class="w-full">
            <div class="flex items-center gap-5 mb-8 premium-reveal [transition-delay:200ms]">
        <div class="h-[1px] flex-1 bg-gradient-to-r from-black/10 via-black to-black/10"></div>
      </div>
      <div class="relative w-full">
        <!-- Scale Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-4 md:gap-0 text-center premium-reveal [transition-delay:250ms]">
          
          <!-- Scale 1 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-[#16075F] leading-[1.36] mb-3 m-0">
              250M+
            </h3>
            <span class="text-sm sm:text-base text-black font-normal leading-normal">
              Invoices processed
            </span>
          </div>

          <!-- Scale 2 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/50 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-[#16075F] leading-[1.36] mb-3 m-0">
              99.9%
            </h3>
            <span class="text-sm sm:text-base text-black font-normal leading-normal">
                Uptime achieved
            </span>
          </div>

          <!-- Scale 3 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/50 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-[#16075F] leading-[1.36] mb-3 m-0">
              &lt;1s
            </h3>
            <span class="text-sm sm:text-base text-black font-normal leading-normal">
                Avg. submission time
            </span>
          </div>

          <!-- Scale 4 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/50 pt-4 md:pt-0">
            <h3 class="text-[22px] font-medium text-[#16075F] leading-[1.36] mb-3 m-0">
              5000+
            </h3>
            <span class="text-sm sm:text-base text-black font-normal leading-normal">
              Enterprise clients 
            </span>
          </div>

        </div>

        <!-- Mobile Segmented Plus Dividers -->
        <!-- Top Vertical Divider Line -->
        <div class="absolute md:hidden left-1/2 -translate-x-1/2 bottom-[calc(50%+16px)] h-16 w-[1px] bg-black/28"></div>
        <!-- Bottom Vertical Divider Line -->
        <div class="absolute md:hidden left-1/2 -translate-x-1/2 top-[calc(50%+16px)] h-16 w-[1px] bg-black/28"></div>
        <!-- Left Horizontal Divider Line -->
        <div class="absolute md:hidden top-1/2 -translate-y-1/2 left-1/4 -translate-x-1/2 w-16 h-[1px] bg-black/28"></div>
        <!-- Right Horizontal Divider Line -->
        <div class="absolute md:hidden top-1/2 -translate-y-1/2 left-3/4 -translate-x-1/2 w-16 h-[1px] bg-black/28"></div>
      </div>
         </div>
    </div>
</section>

<style is:global>
    .dashed-line-horizontal {
        height: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(90deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .dashed-line-vertical {
        width: 2px;
        --clr-border: #A198EE;
        background-image: repeating-linear-gradient(0deg, var(--clr-border), var(--clr-border) 10px, transparent 10px, transparent 20px);
    }
    .glow-pulse {
        animation: pulse-glow 2s infinite ease-in-out;
    }
    @keyframes pulse-glow {
        0% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0.6);
        }
        70% {
            box-shadow: 0 0 0 12px rgba(107, 92, 231, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0);
        }
    }
</style>
