---
/**
 * Germany FAQ accordion — adapted from UAE standard page styling and structure.
 * Features 6 Germany B2B & ViDA enterprise questions with support for paragraph, list,
 * and mixed content blocks. Uses native javascript height transition animations that remain resize-safe.
 */
interface FaqItem {
  q: string;
  /** Plain string OR array of paragraphs / lists. */
  a:
    | string
    | Array<
        { kind: "p"; html: string } | { kind: "ul" | "ol"; items: string[] }
      >;
}

const items: FaqItem[] = [
  {
    q: "Which software is best for e-invoicing in Oman?",
    a: "ClearTax is a pre-approved Service Provider under Oman's Fawtara e-invoicing framework. It operates as both Corner 2 (Seller ASP) and Corner 3 (Buyer ASP). With 5,000+ enterprise customers globally and 500+ GCC businesses already live, it is built specifically for the Fawtara mandate, not retrofitted.",
  },
  {
    q: "How do I choose e-invoicing software for my business in Oman?",
    a: [
      {
        kind: "p",
        html: "When choosing e-invoicing software, transmission alone is not enough. Omani enterprises must check for "
      },
      {
        kind: "ul",
        items: [
          "OTA-approved SP status",
          "Native Fawtara/PEPPOL compatibility",
          "Pre-built connectors to their ERP (SAP, Oracle, Dynamics, or custom ERPs)",
          "End-to-end tax coverage, including invoice generation, OTA submission, 10-year archival, and VAT return reconciliation."
        ]
      }
    ]
  },
  {
    q: "What are the advantages of using e-invoicing software?",
    a: [
      {
        kind: "p",
        html: "An efficient e-invoicing solution in Oman:"
      },
      {
        kind: "ul",
        items: [
          "Helps businesses stay compliant with OTA's Fawtara mandate",
          "Native Fawtara/PEPPOL compatibilityEliminates manual errors through automated OTA Business Rules validation",
          "Speeds up VAT return preparation with invoice data flowing directly into reconciliation",
          "Protects buyer input tax claims with QR-code verifiable invoices",
          "Maintains 10-year audit-ready archival without manual effort"
        ]
      }
    ]
  },
  {
    q: "How does e-invoicing software integrate with my ERP or accounting system?",
    a: "ClearTax connects via pre-built connectors for SAP, Oracle, Microsoft Dynamics, and 30+ other systems. Your invoice data is extracted automatically, validated against OTA's Data Dictionary, submitted to the Fawtara network, and reconciled, with responses written back to your ERP. No manual exports needed.",
  },
  {
    q: "What are the compliance risks of not using e-invoicing software?",
    a: "Under Oman's Fawtara rules, enterprises with high volumes of invoices can’t depend on manual processes. E-Invoicing software such as ClearTax can help you smoothly comply with Oman e-invoicing requirements at scale. Further, e-invoicing non-compliance risks include VAT Law penalties, rejected buyer input tax claims, OTA audit exposure from mismatched VAT return data, and operational disruption once your mandate phase kicks in.",
  },
  {
    q: "How long does it take to implement e-invoicing software?",
    a: [
      {
        kind: "p",
        html: "It depends on ERP readiness, the number of legal entities, and invoice volumes. ClearTax’s AI-driven autonomous integration agent runs a full system analysis for faster onboarding, backed by:"
      },
      {
        kind: "ul",
        items: [
          "On-demand functional consultants",
          "Multi-stakeholder program management",
          "360-degree hyper-care support",
          "Proactive CSM engagement"
        ]
      },
      {
        kind: "p",
        html: "With Phase 1 mandatory compliance from August 2026, businesses in scope should start now."
      },
    ]
  }
  
];
---

<section
  class="faq-section box-border bg-gradient-to-t from-[#FFFFFF] to-[#F3F1F9] py-12 font-['Manrope'] text-[#0F1020] sm:py-20"
  id="faq"
>
  <div class="faq-container mx-auto max-w-[1200px] px-4 sm:px-6">
    <div class="faq-header mb-8 max-w-[720px] mx-auto text-center sm:mb-12">
      <h2
        class="faq-heading mb-4 m-0 lg:text-[44px] sm:text-[32px] text-[26px] font-semibold leading-[1.18] tracking-[-1.2px] text-black"
      >
        Frequently Asked <em class="not-italic text-[#655DFF]">Questions</em>
      </h2>
      <p
        class="faq-sub max-w-147 mx-auto lg:text-lg text-base leading-[1.44] text-black/80"
      >
        Everything you need to know about Oman-product and ClearTax.
      </p>
    </div>

    <div class="faq-list flex flex-col gap-5" data-faq-root>
      {
        items.map((it, i) => (
          <div
            class={`faq-item group overflow-hidden rounded-[8px] border border-[rgba(15,16,32,0.08)] bg-white transition-[border-color,box-shadow] duration-300 ease-in-out [box-sizing:border-box] ${i === 0 ? "faq-open" : ""} ${i >= 5 ? "hidden hidden-faq" : ""}`}
            style={`transition-delay: ${200 + (i * 50)}ms`}
          >
            <button
              class="faq-trigger flex w-full appearance-none items-center justify-between gap-4 border-0 bg-transparent px-[18px] py-[18px] text-left text-[15.5px] leading-[1.4] text-[#0F1020] [box-sizing:border-box] cursor-pointer focus-visible:rounded-[14px] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[#0057FF] sm:px-6 sm:py-[22px] sm:text-[17px]"
              type="button"
              aria-expanded={i === 0 ? "true" : "false"}
            >
              <h4 class="faq-question min-w-0 flex-1 font-medium text-[18px] sm:text-[20px] leading-[1.32] break-words text-[#0F172A] text-left m-0">
                {it.q}
              </h4>
              <span
                class="faq-icon flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[rgba(0,87,255,0.1)] text-[#0057FF] transition-[transform,background,color] duration-300 ease-in-out group-[.faq-open]:rotate-45 group-[.faq-open]:bg-[#0057FF1A] group-[.faq-open]:text-white"
                aria-hidden="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 14 14"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M6.69995 0.700195V12.7002M0.699951 6.7002H12.7"
                    stroke="#6355D8"
                    stroke-width="1.4"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </button>
            <div 
              class={`faq-panel overflow-hidden transition-[height] duration-[320ms] [transition-timing-function:cubic-bezier(.4,0,.2,1)] ${i === 0 ? "" : "h-0"}`}
              style={i === 0 ? "height: auto;" : undefined}
            >
              <div class="faq-answer px-[18px] pb-[18px leading-[1.7] text-[#5A6070] sm:px-6 sm:pb-[22px] text-[16px] [&_li]:mb-1.5 [&_ol]:m-0 [&_ol]:pl-5 [&_p:last-child]:mb-0 [&_p]:mb-2.5 [&_p]:mt-0 [&_strong]:text-[#0F1020] [&_ul]:m-0 [&_ul]:pl-5">
                {typeof it.a === "string" ? (
                  <p set:html={it.a} />
                ) : (
                  it.a.map((block) =>
                    block.kind === "p" ? (
                      <p set:html={block.html} />
                    ) : block.kind === "ul" ? (
                      <ul>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ul>
                    ) : (
                      <ol>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ol>
                    ),
                  )
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      items.length > 5 && (
        <div
          class="mt-12 mx-auto flex items-center justify-center"
          id="faq-load-more-container"
        >
          <button
            id="faq-load-more-btn"
            class="inline-flex items-center gap-2 justify-center rounded-full border border-[#110072] bg-white px-10 py-4 text-base font-medium font-['gilroy'] leading-[1.4] text-[#1C0976] outline-offset-[-2px] transition-all duration-300 ease-in-out hover:scale-105 active:scale-95 cursor-pointer"
          >
            Load More
            <span class="flex items-center justify-center">
              <svg
                width="10"
                height="11"
                viewBox="0 0 10 11"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M4.79999 0.799805V9.7998M0.799988 5.7998L4.79999 9.7998L8.79999 5.7998"
                  stroke="#1C0976"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </button>
        </div>
      )
    }
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-faq-root]");
    if (!root) return;
    const items = root.querySelectorAll(".faq-item");

    const loadMoreBtn = document.getElementById("faq-load-more-btn");
    const loadMoreContainer = document.getElementById(
      "faq-load-more-container",
    );
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", function () {
        const hiddenItems = root.querySelectorAll(".hidden-faq");
        hiddenItems.forEach(function (item) {
          item.classList.remove("hidden", "hidden-faq");
        });
        if (loadMoreContainer) {
          loadMoreContainer.style.display = "none";
        }
      });
    }
    items.forEach(function (item) {
      const trigger = item.querySelector(".faq-trigger");
      const panel = item.querySelector(".faq-panel");
      if (!trigger || !panel) return;

      trigger.addEventListener("click", function () {
        const isOpen = item.classList.contains("faq-open");
        if (isOpen) {
          panel.style.height = panel.scrollHeight + "px";
          requestAnimationFrame(function () {
            panel.style.height = "0px";
          });
          item.classList.remove("faq-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          panel.style.height = panel.scrollHeight + "px";
          item.classList.add("faq-open");
          trigger.setAttribute("aria-expanded", "true");
          panel.addEventListener("transitionend", function handler(e) {
            if (e.propertyName !== "height") return;
            panel.removeEventListener("transitionend", handler);
            if (item.classList.contains("faq-open"))
              panel.style.height = "auto";
          });
        }
      });

      window.addEventListener("resize", function () {
        if (item.classList.contains("faq-open")) panel.style.height = "auto";
      });
    });
  })();
</script>
