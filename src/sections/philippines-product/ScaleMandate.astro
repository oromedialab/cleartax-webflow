      { label: "Easy mandate updates" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f12d7fd289d1a0063b5f2_tab-2-1.png'},
      { label: "Ready for Phase 2 expansion" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f12d75b81f97f68524ccb_tab-2-2.png'},
      { label: "No new IT project" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f12d7c1fb264e32f401bc_tab-2-3.png'}
