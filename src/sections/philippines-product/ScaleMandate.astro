    image: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ed386937d8f2e58a0c01a_invoices.png",
    title: "Keep invoices flowing",
    description: "ClearTax validates every invoice before transmission, catching schema errors, missing fields, duplicates, and abnormal values before they become BIR failures.",
    points: [
        { label: "Pre-transmission invoice checks" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ecd71733d064b0dda81b5_tabs-9.png' },
        { label: "Duplicate detection",cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ecd8159409661d8ef13f0_tabs-10.png' },
        { label: "Correction before submission" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f12d716179111be9438e3_tab-3-3.png' },
        { label: "Schema and field validation" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a5f144f0cd97e3f6612b1ed_tab-3-4.png'}
