---
/**
 * ERP Integration Grid component
 * Replaced the old list-based grid with a custom layout matching the design reference.
 */
---

<section class="py-12 lg:py-25 bg-white" id="grid-risk">
  <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
    <!-- Header -->
      <div class="text-center mb-12">
      <h2 class="text-[26px] md:text-[36px] lg:text-[44px] max-w-186 mx-auto m-0 font-semibold text-[#000000] leading-[1.18]">
        The Wrong Platform Doesn't Just
        <span class="text-black">Slow You Down.</span>
        <span class="text-[#655DFF]"> It Puts You At Risk.</span>
      </h2>
      <p class="text-base md:text-[18px] text-[#000000]/80 mt-4 max-w-213 mx-auto leading-[1.5]">
        A lot of vendors will tell you they support Philippines EIS compliance. Very few have the global depth, the local track record, and the technical infrastructure to back that up. Here's why it matters.
      </p>
    </div>

    <!-- Integration Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-[1.5fr_1fr] lg:grid-cols-[minmax(0,749px)_minmax(0,504px)] justify-center gap-6 w-full">
      <!-- Left 2/3 Area -->
      <div class="w-full grid grid-cols-1 gap-6">
        <!-- Zero Manual Config (Blue) - Span 2 columns in its nested grid -->
        <div class="p-7 pb-0 rounded-2xl bg-[#FDF2ED] flex flex-col gap-8 items-start premium-reveal [transition-delay:200ms]">
          <div class="relative z-10">
            <h3 class="text-xl font-medium text-black mb-3 m-0">Built for Tax From Day One</h3>
            <p class="text-black/80 text-base lg:text-lg leading-normal">
                ClearTax is not an ERP add-on. Tax compliance is the product, with schema and BIR changes handled at platform level.
            </p>
          </div>
          <div class="mt-auto p-2 sm:pb-0 flex justify-center items-end w-full">
            <img 
              src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a53782f5940af5dbe4e05_grid-1.png" 
              alt="Zero Manual Config" 
              class="w-full h-auto object-contain" 
            />
          </div>
        </div>
        <!-- Zero Manual Config (Blue) - Span 2 columns in its nested grid -->
        <div class="p-7 rounded-2xl bg-[#EDEBFA] flex flex-col gap-8 items-start premium-reveal [transition-delay:200ms]">
            <div class="w-full mt-auto flex justify-end items-end max-w-[420px] ml-auto">
              <img 
                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a537e047ddfae929fb39f_grid-2.png" 
                alt="Zero Manual Config" 
                class="w-full h-auto object-contain" 
              />
            </div>
          <div class="relative z-10">
            <h3 class="text-xl font-medium text-black mb-3 m-0">A Team, Not Just a Tool</h3>
            <p class="text-black/80 text-base max-w-153 lg:text-lg leading-normal">
                5,000+ enterprise deployments, 1,000+ engineers and compliance specialists, plus Philippines support for BIR, EIS, and mandate changes.
            </p>
          </div>
        </div>

      </div>

      <!-- Right 1/3 Area - Full Height (Purple) -->
      <div class="w-full rounded-2xl bg-[#ECF7ED] flex flex-col premium-reveal [transition-delay:300ms]">
        <div class="sm:pt-12 lg:pt-0">
          <img 
            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a61d6ee89cce83ffbabe266_grid-3-new.png" 
            alt="Global Integration" 
            class="w-full h-auto object-contain" 
          />
        </div>
        <div class="mt-auto p-7">
            <h3 class="text-xl font-medium text-black mb-3 m-0">Global Depth, Local Accountability</h3>
            <p class="text-black/80 text-base lg:text-lg leading-normal">
                ClearTax has navigated mandates across India, Saudi Arabia, Malaysia, France, UAE, and 50+ countries, bringing proven experience to the Philippines.
            </p>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6">
        <!-- Fast Setup (Green) -->
        <div class="rounded-2xl bg-[#D8EFF2] flex flex-col h-auto lg:h-[360px] relative overflow-hidden premium-reveal">
            <div class="absolute top-0 left-0 right-0 w-full flex justify-center lg:justify-end pt-4 sm:pt-0">
                <img 
                src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a538b0cbd7018a1afea4b_grid-4.png" 
                alt="Fast Setup" 
                class="w-full max-w-[622px] h-auto object-contain" 
                />
            </div>
            <div class="mt-auto p-7 pt-40 lg:pt-7 relative z-10">
                <h3 class="text-xl font-medium text-black mb-3 m-0">Don’t Be the Test Case</h3>
                <p class="text-black/80 text-base lg:text-lg mb-0 leading-normal">
                    Markets like India, France, and Saudi Arabia saw post-launch failures with lightweight tools. ClearTax is built to avoid that.
                </p>
            </div>
        </div>

        <!-- Compliance Updates (Orange) -->
        <div class="rounded-2xl bg-[#E8F5F7] flex flex-col h-auto lg:h-[360px] premium-reveal [transition-delay:100ms] overflow-hidden">
            <div class=" p-7">
                <h3 class="text-xl font-medium text-black mb-3 m-0">Certifications That Matter</h3>
                <p class="text-black/80 text-base lg:text-lg leading-normal">
                  ISO 27001:2022, SOC 2 Type II, VAPT, Open Peppol, and accreditations across ZATCA, FTA, LHDN, MDEC, and NIC.
                </p>
            </div>
          <div class="p-7 sm:p-10 mt-auto flex justify-center">
            <img 
              src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a3a5393cae202e9c6ee58a2_grid-5.png" 
              alt="Compliance Updates" 
              class="w-full h-auto object-contain max-h-[160px] lg:max-h-[180px]" 
            />
          </div>
        </div>
    </div>
  </div>
</section>

<style is:global>
  .gradient-text {
    background: linear-gradient(135deg, #8B7EE8 0%, #6355D8 50%, #4338CA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .premium-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .premium-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const observerOptions = {
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".premium-reveal").forEach((el) => {
      observer.observe(el);
    });
  })();
</script>
