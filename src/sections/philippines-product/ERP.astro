---
/**
 * Germany Integrations Section
 * Features a 2-column layout with vertical scrolling marquees for ERP integrations
 * and integration depth metrics at the bottom.
 */

const column1 = [
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f7cad6f6fd7b478e44c_integration-1-1.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f84e361d6eb8117cbb9_integration-1-2.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f8a33514a2e01c192e0_integration-1-3.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f912ac4a9b3c879d61b_integration-1-4.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f9733514a2e01c19e2a_integration-1-5.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200f9d308c748146ef0231_integration-1-6.png"
];

const column2 = [
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fa76f1afdd0cc773d4b_integration-2-1.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fad79840a91b69c1de4_integration-2-2.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fb484008cc263d0d3e1_integration-2-3.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fb9c6faf39b64f56fc8_integration-2-4.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fbf095a454286fb9cc5_integration-2-5.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fc5ad6f6fd7b4790c84_integration-2-6.png"
];

const column3 = [
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fcdc57357009e017c93_integration-3-1.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fd416d18f06026f82e9_integration-3-2.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fda4d01fc7ccd3759a4_integration-3-3.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fe2fd5c9cb811ce305b_integration-3-4.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200fea7614509d2bdd0d5e_integration-3-5.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a200ff1c6faf39b64f5939f_integration-3-6.png"
];

const doubledC1 = [...column1, ...column1];
const doubledC2 = [...column2, ...column2];
const doubledC3 = [...column3, ...column3];
---

<section id="integrations" class="bg-[#F3F1F9] pb-16 lg:pb-25 overflow-hidden w-full relative">
  <div class="lg:container mx-auto px-4 md:px-6">
    <!-- Two Column Grid for Intro and Marquee -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-center mb-5">
      
      <!-- Left Column: Copy -->
      <div class="lg:col-span-6 flex flex-col justify-center max-md:pb-0 py-16 lg:py-25 lg:max-w-[520px] w-full">
        <h2 class="text-[26px] sm:text-[32px] lg:text-[44px] font-semibold text-black leading-[1.15] m-0 mb-4 premium-reveal">
          1,600+ successful integrations <span class="text-black block">completed.</span> <span class="text-[#6D65FF]">Ready for any ERP complexity.</span>
        </h2>
        <p class="text-base sm:text-lg text-black/80 leading-normal m-0 premium-reveal [transition-delay:150ms]">
            SAP R3, SAP HANA, SAP Business One, Oracle E-Business Suite, Oracle Fusion, Oracle NetSuite, Microsoft Dynamics 365, Microsoft NAV, Xero, QuickBooks, local Philippine CAS platforms, and 100+ others — all integrated.
        </p>
      </div>

      <!-- Right Column: Vertical Marquees -->
      <div class="lg:col-span-6 relative h-[440px] w-full max-w-[530px] mx-auto overflow-hidden bg-transparent">
        <!-- Fading/Blur Overlays -->
        <div class="absolute top-0 left-0 right-0 h-[100px] bg-gradient-to-b from-[#F3F1F9] via-[#F3F1F9]/80 to-transparent pointer-events-none z-20"></div>
        <div class="absolute bottom-0 left-0 right-0 h-[100px] bg-gradient-to-t from-[#F3F1F9] via-[#F3F1F9]/80 to-transparent pointer-events-none z-20"></div>

        <!-- Marquees Flex Grid -->
        <div class="grid grid-cols-3 gap-6 sm:gap-10 h-full px-2">
          
          <!-- Column 1 (Scroll Up) -->
          <div class="flex flex-col h-full overflow-hidden group">
            <div class="flex flex-col gap-7 py-2 animate-[scroll-up_25s_linear_infinite] group-hover:[animation-play-state:paused]">
              {doubledC1.map((src) => (
                <div class="max-w-[148px] w-full h-[44px] shrink-0 rounded-lg flex items-center justify-center shadow-[2px_4px_12px_0px_#0000000F] border border-black/[0.01] transition-transform duration-200 hover:scale-105">
                  <img src={src} alt="ERP Partner Logo" class="max-w-full max-h-full object-contain scale-105" loading="lazy" />
                </div>
              ))}
            </div>
          </div>

          <!-- Column 2 (Scroll Down) -->
          <div class="flex flex-col h-full overflow-hidden group">
            <div class="flex flex-col gap-7 py-2 animate-[scroll-down_30s_linear_infinite] group-hover:[animation-play-state:paused]">
              {doubledC2.map((src) => (
                <div class="max-w-[148px] w-full h-[44px] shrink-0 rounded-lg flex items-center justify-center shadow-[2px_4px_12px_0px_#0000000F] border border-black/[0.01] transition-transform duration-200 hover:scale-105">
                  <img src={src} alt="ERP Partner Logo" class="max-w-full max-h-full object-contain scale-105" loading="lazy" />
                </div>
              ))}
            </div>
          </div>

          <!-- Column 3 (Scroll Up) -->
          <div class="flex flex-col h-full overflow-hidden group">
            <div class="flex flex-col gap-7 py-2 animate-[scroll-up_28s_linear_infinite] group-hover:[animation-play-state:paused]">
              {doubledC3.map((src) => (
                <div class="max-w-[148px] w-full h-[44px] shrink-0 rounded-lg flex items-center justify-center shadow-[2px_4px_12px_0px_#0000000F] border border-black/[0.01] transition-transform duration-200 hover:scale-105">
                  <img src={src} alt="ERP Partner Logo" class="max-w-full max-h-full object-contain scale-105" loading="lazy" />
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>

    </div>

    <!-- Bottom Stats Depth Section -->
    <div class="w-full">
      <!-- Title + Line Divider -->
      <div class="flex items-center gap-5 mb-8 premium-reveal [transition-delay:200ms]">
        <span class="text-sm tracking-[1.5px] text-black/68 uppercase whitespace-nowrap leading-normal">
          Integration Depth
        </span>
        <div class="h-[1px] flex-1 bg-black/28"></div>
      </div>

      <div class="relative w-full">
        <!-- Stats Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-4 md:gap-0 text-center premium-reveal [transition-delay:250ms]">
          
          <!-- Stat 1 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-black/80 leading-[1.36] mb-3 m-0">
              100+
            </h3>
            <span class="text-sm sm:text-base text-black/68 font-normal leading-normal">
              ERP & source systems
            </span>
          </div>

          <!-- Stat 2 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/28 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-black/80 leading-[1.36] mb-3 m-0">
              4000+
            </h3>
            <span class="text-sm sm:text-base text-black/68 font-normal leading-normal">
                Source devices connected
            </span>
          </div>

          <!-- Stat 3 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/28 py-4 md:py-0">
            <h3 class="text-[22px] font-medium text-black/80 leading-[1.36] mb-3 m-0">
              9-10
            </h3>
            <span class="text-sm sm:text-base text-black/68 font-normal leading-normal">
              weeks Typical go-live
            </span>
          </div>

          <!-- Stat 4 -->
          <div class="flex flex-col items-center px-2 sm:px-4 md:px-8 md:border-l border-black/28 pt-4 md:pt-0">
            <h3 class="text-[22px] font-medium text-black/80 leading-[1.36] mb-3 m-0">
              0
            </h3>
            <span class="text-sm sm:text-base text-black/68 font-normal leading-normal">
              No new IT project 
            </span>
          </div>

        </div>

        <!-- Mobile Segmented Plus Dividers -->
        <!-- Top Vertical Divider Line -->
        <div class="absolute md:hidden left-1/2 -translate-x-1/2 bottom-[calc(50%+16px)] h-16 w-[1px] bg-black/28"></div>
        <!-- Bottom Vertical Divider Line -->
        <div class="absolute md:hidden left-1/2 -translate-x-1/2 top-[calc(50%+16px)] h-16 w-[1px] bg-black/28"></div>
        <!-- Left Horizontal Divider Line -->
        <div class="absolute md:hidden top-1/2 -translate-y-1/2 left-1/4 -translate-x-1/2 w-16 h-[1px] bg-black/28"></div>
        <!-- Right Horizontal Divider Line -->
        <div class="absolute md:hidden top-1/2 -translate-y-1/2 left-3/4 -translate-x-1/2 w-16 h-[1px] bg-black/28"></div>
      </div>

      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Vertical scrolling animations */
  @keyframes scroll-up {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes scroll-down {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }
</style>
