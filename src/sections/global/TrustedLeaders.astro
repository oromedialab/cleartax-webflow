---
/**
 * Trusted-leaders testimonials carousel — Swiper-based.
 * Ported from global-e-invoicing-mandate-page/index.html:3803-3949.
 * Swiper loads from jsDelivr CDN; the embed has to be self-contained so we
 * inject the CDN link + script tags once per section mount.
 */
interface Testimonial {
  logoSrc: string;
  logoClass: 'tl-logo1' | 'tl-logo2' | 'tl-logo3' | 'tl-logo5';
  quote: string;
  initials: string;
  name: string;
  role: string;
}

const testimonials: Testimonial[] = [
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df4949e511b373dbb99294_leaders-brand-1.png',
    logoClass: 'tl-logo1',
    quote: 'ClearTax has transformed the way we handle GST compliance. Real-time creation of e-Invoices and e-Way bills plays a significant role in providing us with critical insight into our business.',
    initials: 'P',
    name: 'Pratush Kumar',
    role: 'DGM-IT, JK Tyre (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df494a80821e2087576b23_leaders-brand-2.png',
    logoClass: 'tl-logo2',
    quote: 'ClearTax is simplifying e-Invoicing. They enabled us to implement the e-Invoicing system in time and handled all our business complexities with ease. Thank you for the effort and good job!',
    initials: 'R',
    name: 'Raj Kiran',
    role: 'Head, Taxation & Retail Finance, Puma (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df494a067e75f8309b363b_leaders-brand-3.png',
    logoClass: 'tl-logo3',
    quote: 'We appreciate ClearTax for successfully completing the complex ZATCA E-Invoicing Phase II Integration project. Their platform enabled seamless management of multiple business units. Kudos to the team for their timely delivery.',
    initials: 'P',
    name: 'Pratush Kumar',
    role: 'DGM-IT, JK Tyre (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de2f46ea62c039f7e81c4d_gamuda-land.png',
    logoClass: 'tl-logo3',
    quote: 'Collaborating with ClearTax was an exceptional experience. They streamlined the entire process, even under tight deadlines, for our diverse ERP systems.',
    initials: 'V',
    name: 'V Bharathy',
    role: 'Manager, Finance Applications, Gamuda Land',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69df166cc8fd06a5b99629c5_salam-removebg-preview.png',
    logoClass: 'tl-logo5',
    quote: "Salam's search for a reliable partner ended with ClearTax. Their tailored solutions ensured a smooth transition for all 8 of our systems in just 3 months.",
    initials: 'A',
    name: 'Arslan Choudhary',
    role: 'Director of Enterprise Enablement, Salam Telco',
  },
];

const cardColors = ['#F6E0C5', '#D8EFF2', '#DEDAF6'];
const shuffledColors = [...cardColors].sort(() => Math.random() - 0.5);
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="tl-section">
  <div class="wf-container">
    <div class="tl-header">
      <h2 class="tl-title">Trusted by industry leaders across the world</h2>
      <div class="navigation-controls">
        <button class="tl-swipper-left" aria-label="Previous">
          <svg width="7" height="14" viewBox="0 0 9 16" fill="none"><path d="M8 15L1 8L8 1" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <button class="tl-swipper-right" aria-label="Next">
          <svg width="7" height="14" viewBox="0 0 9 16" fill="none"><path d="M8 15L1 8L8 1" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
      </div>
    </div>
  </div>
  <div class="tl-swiper-bleed-wrapper">
    <div class="tl-swiper">
      <div class="swiper-wrapper tl-swiper-wrapper">
        {testimonials.map((t, i) => {
          const cardColor = shuffledColors[i % shuffledColors.length];
          return (
            <div class="swiper-slide tl-swiper-slide">
              <div class="tl-card" style={`background-color: ${cardColor}`}>
                <img class={t.logoClass} src={t.logoSrc} alt="" />
                <p class="tl-card-text">{t.quote}</p>
                <div class="tl-user">
                  <div class="tl-user-img">{t.initials}</div>
                  <div>
                    <div class="tl-user-wrapper">
                      <p>{t.name}</p>
                    </div>
                    <p class="tl-user-location">{t.role}</p>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .tl-section { padding: 100px 0; overflow-x: hidden; }
  .wf-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .tl-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; }
  .tl-title { max-width: 581px; width: 100%; font-size: 44px; font-weight: 600; line-height: 1.18; color: #000; margin: 0; text-wrap: balance; }

  .tl-swiper-bleed-wrapper { margin-left: 80px; }
  .tl-swiper { overflow: visible !important; margin: 0; }
  .tl-swiper-slide { width: fit-content !important; }

  .tl-card { max-width: 630px; width: 100%; padding: 28px; border-radius: 20px; display: flex; flex-direction: column; height: 375px; }
  .tl-logo1 { width: 198px; object-fit: contain; aspect-ratio: 198/44; margin-bottom: 28px; }
  .tl-logo2 { width: 88px; aspect-ratio: 88/44; object-fit: contain; margin-bottom: 28px; }
  .tl-logo3 { width: 260px; aspect-ratio: 260/30; object-fit: cover; margin-bottom: 28px; }
  .tl-logo5 { width: 140px; aspect-ratio: 140/44; object-fit: cover; margin-bottom: 28px; }
  .tl-card-text { font-size: 20px; line-height: 1.5; margin-bottom: 16px; color: #343A40; }
  .tl-user { display: flex; gap: 12px; align-items: center; margin-top: auto; }
  .tl-user-img { width: 44px; height: 44px; display: flex; justify-content: center; align-items: center; border-radius: 100%; background-color: #3025A0; color: #fff; font-weight: 700; }
  .tl-user-wrapper { max-width: 167px; display: flex; align-items: center; gap: 8px; }
  .tl-user-wrapper p { margin: 0; font-weight: 700; font-size: 16px; color: #171E28; }
  .tl-user-location { color: #6C757D; font-size: 14px; margin-top: 2px; margin-bottom: 0; }

  .navigation-controls { display: flex; gap: 12px; }
  .tl-swipper-left,
  .tl-swipper-right { width: 48px; height: 48px; border-radius: 100%; cursor: pointer; display: flex; align-items: center; justify-content: center; border: none; background-color: #2D0A4E; }
  .tl-swipper-right svg { transform: rotate(180deg); }
  .tl-swipper-left:hover,
  .tl-swipper-right:hover { opacity: 0.8; }

  @media (min-width: 1024px) and (max-width: 1280px) {
    .tl-swiper-bleed-wrapper { margin-left: 40px; }
  }
  @media (max-width: 1024px) {
    .tl-section { padding: 60px 0 80px; }
    .tl-title { font-size: 36px; }
    .tl-header { margin-bottom: 40px; }
    .tl-swiper-bleed-wrapper { margin-left: 24px; }
    .tl-card { padding: 24px; height: 330px; }
    .tl-swipper-left, .tl-swipper-right { width: 42px; height: 42px; }
  }
  @media (max-width: 640px) {
    .tl-section { padding: 40px 0 50px; }
    .tl-title { font-size: 28px; }
    .tl-swiper-bleed-wrapper { margin-left: 16px; }
    .tl-header { flex-direction: column; align-items: flex-start; gap: 24px; margin-bottom: 32px; }
    .tl-card { padding: 16px; border-radius: 14px; height: 270px; }
    .tl-card-text { font-size: 14px; }
    .tl-swipper-left, .tl-swipper-right { width: 32px; height: 32px; }
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script is:inline>
  (function () {
    function boot() {
      if (typeof Swiper === 'undefined') { setTimeout(boot, 50); return; }
      new Swiper('.tl-swiper', {
        loop: true,
        navigation: { nextEl: '.tl-swipper-right', prevEl: '.tl-swipper-left' },
        slidesPerView: 1,
        spaceBetween: 10,
        breakpoints: {
          768: { slidesPerView: 'auto', spaceBetween: 16 },
          1024: { slidesPerView: 2.2, spaceBetween: 20 },
        },
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else boot();
  })();
</script>
