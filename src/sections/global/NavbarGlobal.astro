---
/**
 * Global-page navbar — standard horizontal bar with dropdown menus + a country picker.
 * Ported from global-e-invoicing-mandate-page/index.html:32-776.
 *
 * Distinct from the UAE page's floating-pill Navbar — different visual language
 * (white bar, scroll shadow, multi-column country dropdown) so it lives as its
 * own component under sections/global rather than in _shared.
 */
export interface NavLink {
  label: string;
  href?: string;
  dropdown?: { label: string; href: string }[];
}
export interface CountryOption {
  name: string;
  flag: string;
  href: string;
  lang?: string;
}

const links: NavLink[] = [
  {
    label: 'E-Invoicing Platform',
    dropdown: [
      { label: 'Global e-invoicing', href: 'https://www.cleartax.com/electronic-invoicing' },
      { label: 'AI Reconciliation', href: 'https://cleartax.in/gst' },
      { label: 'Integration', href: 'https://cleartax.in/supply-chain-automation-solution' },
      { label: 'Scale & Security', href: 'https://cleartax.in/supply-chain-automation-solution' },
    ],
  },
  {
    label: 'Resources',
    dropdown: [
      { label: 'Blogs', href: 'https://www.cleartax.com/electronic-invoicing#country-select' },
      { label: 'Case Studies', href: 'https://www.cleartax.com/case-studies' },
      { label: 'Press Releases', href: 'https://www.clear.in/s/press?forceCacheReload=1' },
    ],
  },
  { label: 'Contact Us', href: 'https://www.cleartax.com/contact-us' },
  { label: 'Partners', href: 'https://www.cleartax.com/partners' },
];

const countries: CountryOption[] = [
  { name: 'INDIA', flag: '🇮🇳', href: 'https://www.clear.in/' },
  { name: 'MALAYSIA', flag: '🇲🇾', href: 'https://www.cleartax.com/my/en' },
  { name: 'USA', flag: '🇺🇸', href: 'https://www.clear.tech/' },
  { name: 'POLAND', flag: '🇵🇱', href: 'https://www.cleartax.com/pl/en', lang: 'English | Polish' },
  { name: 'SAUDI ARABIA', flag: '🇸🇦', href: 'https://www.cleartax.com/sa', lang: 'English | العربية' },
  { name: 'OMAN', flag: '🇴🇲', href: 'https://www.cleartax.com/om' },
  { name: 'FRANCE', flag: '🇫🇷', href: 'https://www.cleartax.com/fr/en', lang: 'English | French' },
  { name: 'BAHRAIN', flag: '🇧🇭', href: 'https://www.cleartax.com/bh' },
  { name: 'SPAIN', flag: '🇪🇸', href: 'https://www.cleartax.com/es/en' },
  { name: 'UAE', flag: '🇦🇪', href: 'https://www.cleartax.com/ae' },
  { name: 'SINGAPORE', flag: '🇸🇬', href: 'https://www.cleartax.com/sg/e-invoicing-software' },
  { name: 'GERMANY', flag: '🇩🇪', href: 'https://www.cleartax.com/de/en' },
  { name: 'BELGIUM', flag: '🇧🇪', href: 'https://www.cleartax.com/be/en' },
];
---

<header class="navbar" data-nav-root>
  <div class="navbar-container">
    <a href="/" class="navbar-logo">
      <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg" alt="ClearTax" />
    </a>

    <nav class="navbar-menu" data-nav-menu>
      <ul class="navbar-links">
        {links.map((l) => (
          <li class:list={['navbar-item', l.dropdown && 'has-dropdown']}>
            {l.dropdown ? (
              <>
                <button class="navbar-link" type="button" data-nav-trigger>
                  {l.label}
                  <svg class="navbar-dropdown_icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </button>
                <div class="dropdown-list">
                  {l.dropdown.map((d) => <a href={d.href} class="dropdown-link">{d.label}</a>)}
                </div>
              </>
            ) : (
              <a href={l.href} class="navbar-link">{l.label}</a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="navbar-actions">
      <div class="country-selector" data-country-selector>
        <button class="country-btn" type="button" data-country-btn>
          <span class="global-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </span>
          <span class="country-name" data-country-current>Global</span>
          <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="country-dropdown">
          <div class="country-dropdown-inner">
            <div class="country-grid">
              {countries.map((c) => (
                <a href={c.href} class="country-option" data-country={c.name} data-flag={c.flag}>
                  <span class="country-flag">{c.flag}</span>
                  <div class="country-option-info">
                    <span class="country-option-name">{c.name}</span>
                    {c.lang && <span class="country-option-lang">{c.lang}</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a href="#contact" class="navbar-cta bg-gradient-to-r from-[#110072] to-[#7A5698]">
        Request a demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>

      <button class="mobile-toggle" data-mobile-toggle aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="navbar-spacer"></div>

<style is:global>
  .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: var(--color-white); border-bottom: 1px solid var(--color-gray-200); transition: box-shadow var(--transition-base); }
  .navbar.scrolled { box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08); }
  .navbar-container { max-width: 1328px; margin: 0 auto; padding: 0 24px; height: var(--navbar-height); display: flex; align-items: center; justify-content: space-between; gap: 32px; }
  .navbar-logo { flex-shrink: 0; display: flex; align-items: center; color: var(--color-dark); }
  .navbar-logo img { height: 28px; width: auto; }
  .navbar-menu { flex: 1; display: flex; justify-content: center; }
  .navbar-links { display: flex; align-items: center; list-style: none; gap: 4px; margin: 0; padding: 0; }
  .navbar-item { position: relative; }
  .navbar-link { display: flex; align-items: center; gap: 5px; padding: 8px 16px; font-size: 14px; font-weight: 500; color: var(--color-gray-600); border-radius: 8px; transition: all var(--transition-fast); white-space: nowrap; text-decoration: none; background: none; border: none; cursor: pointer; font-family: inherit; }
  .navbar-link:hover { color: var(--color-dark); background: var(--color-gray-50); }
  .navbar-item.active .navbar-link { color: var(--color-blue); background: rgba(21, 114, 237, 0.06); }
  .dropdown-arrow { transition: transform var(--transition-fast); flex-shrink: 0; }
  .navbar-item.active .dropdown-arrow { transform: rotate(180deg); }
  .navbar-actions { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .navbar-cta { display: inline-flex; align-items: center; gap: 6px; padding: 10px 24px; font-size: 14px; font-weight: 500; color: var(--color-white); background: linear-gradient(90deg, #110072 0%, #7A5698 100%); border-radius: 50px; transition: all var(--transition-fast); white-space: nowrap; text-decoration: none; transform: transition 0.3s ease-in-out ; }
  .navbar-cta:hover { transform: translateY(-1px);}
  .navbar-cta:hover svg { transform: translateX(3px);
   }
  .navbar-spacer { height: var(--navbar-height); }

  .dropdown-list { position: absolute; top: 100%; left: 50%; transform: translateX(-50%) translateY(10px); background: #fff; border-radius: 12px; box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12); padding: 8px 0; min-width: 180px; opacity: 0; visibility: hidden; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1); z-index: 1001; margin-top: 10px; }
  .navbar-item:hover .dropdown-list,
  .navbar-item.active .dropdown-list { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .dropdown-link { display: block; padding: 10px 20px; font-size: 14px; font-weight: 500; color: #171E28; transition: all 0.2s ease; text-decoration: none; }
  .dropdown-link:hover { background: #F4F6F9; color: #5E46E5; }
  .navbar-dropdown_icon { transition: transform var(--transition-fast); }
  .navbar-item.active .navbar-dropdown_icon { transform: rotate(180deg); }

  .country-selector { position: relative; }
  .country-btn { display: flex; align-items: center; gap: 8px; padding: 8px 12px; border-radius: 8px; transition: background var(--transition-fast); background: none; border: none; cursor: pointer; font-family: inherit; color: var(--color-dark); font-weight: 600; font-size: 14px; }
  .country-btn:hover { background: var(--color-gray-50); }
  .global-icon { color: #5E46E5; display: flex; align-items: center; justify-content: center; }
  .country-dropdown { position: absolute; top: 100%; right: 0; width: 380px; background: transparent; padding-top: 10px; opacity: 0; visibility: hidden; pointer-events: none; transition: all var(--transition-base); z-index: 1001; }
  .country-dropdown-inner { background: var(--color-white); border-radius: 16px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04); padding: 20px 24px; }

  @media (min-width: 1025px) {
    .country-selector:hover .country-dropdown { opacity: 1; visibility: visible; pointer-events: auto; }
    .country-selector:hover .dropdown-arrow { transform: rotate(180deg); }
  }
  .country-selector.active .country-dropdown { opacity: 1; visibility: visible; pointer-events: auto; }

  .country-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
  .country-option { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; transition: background var(--transition-fast); text-decoration: none; color: inherit; }
  .country-option:hover { background: var(--color-gray-50); }
  .country-flag { font-size: 18px; flex-shrink: 0; width: 24px; text-align: center; }
  .country-option-info { display: flex; flex-direction: column; }
  .country-option-name { display: block; font-size: 14px; font-weight: 600; color: var(--color-dark); text-transform: uppercase; letter-spacing: 0.2px; }
  .country-option-lang { display: block; font-size: 11px; color: var(--color-gray-400); margin-top: 1px; }

  .mobile-toggle { display: none; flex-direction: column; gap: 5px; width: 32px; height: 32px; justify-content: center; align-items: center; z-index: 1100; background: none; border: none; cursor: pointer; }
  .mobile-toggle span { width: 24px; height: 2px; background: var(--color-dark); border-radius: 2px; transition: all var(--transition-base); }

  @media (max-width: 1024px) {
    .mobile-toggle { display: flex; }
    .navbar-menu { position: fixed; top: var(--navbar-height); left: 0; right: 0; bottom: 0; background: var(--color-white); flex-direction: column; justify-content: flex-start; padding: 40px 24px; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); overflow-y: auto; z-index: 1050; display: block; }
    .navbar-menu.open { transform: translateX(0); }
    .navbar-links { flex-direction: column; align-items: stretch; width: 100%; gap: 8px; }
    .navbar-item.has-dropdown .dropdown-list { position: static; transform: none; min-width: auto; opacity: 1; visibility: visible; display: none; box-shadow: none; background: var(--color-gray-50); margin-top: 8px; }
    .navbar-item.has-dropdown.active .dropdown-list { display: block; }
    .navbar-actions { gap: 12px; }
    .navbar-cta { display: none; }
    .mobile-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .mobile-toggle.active span:nth-child(2) { opacity: 0; }
    .mobile-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .country-dropdown { width: 100%; position: static; transform: none; box-shadow: none; display: none; padding: 0; background: var(--color-gray-50); border-radius: 12px; margin-top: 8px; }
    .country-selector.active .country-dropdown { display: block; }
    .country-dropdown-inner { background: transparent; box-shadow: none; padding: 12px; }
    .country-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function () {
    const navbar = document.querySelector('[data-nav-root]');
    if (!navbar) return;
    const menu = navbar.querySelector('[data-nav-menu]');
    const mobileToggle = navbar.querySelector('[data-mobile-toggle]');
    const dropdownItems = navbar.querySelectorAll('.navbar-item.has-dropdown');
    const countrySelector = navbar.querySelector('[data-country-selector]');

    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 10);
    });

    dropdownItems.forEach((item) => {
      const btn = item.querySelector('[data-nav-trigger]');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) {
          e.preventDefault();
          const isActive = item.classList.contains('active');
          dropdownItems.forEach((i) => i.classList.remove('active'));
          item.classList.toggle('active', !isActive);
        }
      });
    });

    if (countrySelector) {
      const countryBtn = countrySelector.querySelector('[data-country-btn]');
      const currentLabel = countrySelector.querySelector('[data-country-current]');
      const globeIcon = countryBtn?.querySelector('.global-icon');
      const options = countrySelector.querySelectorAll('.country-option');

      countryBtn?.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) {
          e.stopPropagation();
          countrySelector.classList.toggle('active');
        }
      });

      options.forEach((option) => {
        option.addEventListener('click', (e) => {
          e.preventDefault();
          const flag = option.getAttribute('data-flag');
          const name = option.getAttribute('data-country');
          if (globeIcon) globeIcon.innerHTML = `<span class="country-flag">${flag}</span>`;
          if (currentLabel) currentLabel.textContent = name;
          countrySelector.classList.remove('active');
        });
      });
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.navbar-item.has-dropdown')) {
        dropdownItems.forEach((item) => item.classList.remove('active'));
      }
      if (countrySelector && !e.target.closest('[data-country-selector]')) {
        countrySelector.classList.remove('active');
      }
    });

    mobileToggle?.addEventListener('click', () => {
      menu?.classList.toggle('open');
      mobileToggle.classList.toggle('active');
      document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownItems.forEach((item) => item.classList.remove('active'));
        countrySelector?.classList.remove('active');
        menu?.classList.remove('open');
        mobileToggle?.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  })();
</script>
