---

<section class="se-section">
  <div class="wf-container">
    <div>
      <h2 class="se-heading">Enterprise-grade protection for your <span class="break">data and operations.</span></h2>
      <div class="se-content">
        {cards.map((c) => (
          <div class="se-card">
            <div class="se-img">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none" set:html={c.icon} />
            </div>
            <div>
              <h3 set:html={c.title} />
              <p set:html={c.desc} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .se-section { background-color: #171e28; padding: 100px 0; }
  .wf-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .se-heading { text-align: left; font-size: 44px; color: white; margin: 0 0 48px; font-weight: 600; line-height: 1.18; }
  .break { display: block; color: var(--color-purple); }

  .se-content { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 28px; }
  .se-card { display: flex; gap: 20px; padding: 28px; background-color: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 8px; width: 100%; height: 100%; box-sizing: border-box; }
  .se-img img { width: 40px; height: 40px; }
  .se-card h3 { color: white; font-size: 20px; font-weight: 500; line-height: 1.6; margin: 0; }
  .se-card p { font-size: 16px; color: #6c757d; font-weight: 400; line-height: 1.5; padding-top: 8px; margin: 0; }

  @media (max-width: 1250px) {
    .se-content { grid-template-columns: repeat(2, minmax(0, 1fr)); margin: auto; }
  }
  @media (max-width: 1024px) {
    .se-content { grid-template-columns: repeat(2, minmax(0, 1fr)); padding-bottom: 40px; }
    .break { display: inline; }
    .se-heading { font-size: 32px; }
  }
  @media (max-width: 640px) {
    .se-content { grid-template-columns: 1fr; margin: 32px 0 0; }
    .break { display: inline; }
    .se-card { padding: 20px; gap: 16px; }
  }
</style>
