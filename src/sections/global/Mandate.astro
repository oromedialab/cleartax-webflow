---
const mandates = [
    { name: 'UAE', status: 'Live 2027', flag: 'uae' },
    { name: 'KSA', status: 'Live', flag: 'ksa' }, // Placeholder for KSA
    { name: 'France', status: 'Live 2026', flag: 'france' },
    { name: 'Germany', status: 'Live 2027', flag: 'germany' },
    { name: 'Malaysia', status: 'Live', flag: 'malaysia' },
    { name: 'Oman', status: 'Live 2026', flag: 'oman' },
    { name: 'Poland', status: 'Live 2026', flag: 'poland' },
    { name: 'Croatia', status: 'Live', flag: 'croatia' },
];
---
<section class="bg-[#F3F1F9] py-20 lg:py-25 overflow-hidden">
    <div class="container mx-auto px-4">
        <div class="text-center mb-8 lg:mb-12">
            <h2 class="text-3xl lg:text-5xl font-bold text-black mb-4">
                One API. Every Mandate.
            </h2>
            <p class="text-base lg:text-lg text-black max-w-3xl mx-auto">
                One API. Country mandates sit on top of it as configuration, not separate builds. When a new country goes live, you switch it on. Your integration doesn't change.
            </p>
        </div>

        <div class="relative max-w-7xl mx-auto min-h-[500px]">
            <div class="flex flex-col lg:flex-row items-center justify-between h-full relative z-10 gap-12 lg:gap-0">
                <!-- ERP Column (Your System) -->
                <div class="relative z-20 w-full lg:max-w-[204px]">
                    <div class="bg-[#EDEAF6] rounded-[12px] border border-[#1B087633] p-4 md:p-7 h-full">
                        <h3 class="text-[#1B0876]/80 text-lg text-center mb-7 font-normal">Your System</h3>
                        <div class="your-system-grid border-2 border-dashed border-[#1B087633] rounded-[12px] p-4 md:p-6">
                            {[1, 2, 3, 4].map((i) => (
                                <div class="rounded-[12px] flex items-center justify-center transition-all hover:-translate-y-0.5">
                                    <img src={`/images/logo-mandate-${i}.png`} alt={`ERP Logo ${i}`} class="w-full h-full object-contain" />
                                </div>
                            ))}
                            <div class="rounded-[12px] flex items-center justify-center hover:bg-[#4D45A5]/5 transition-colors">
                                <img src="/images/logo-mandate-5.png" alt="More systems" class="w-full h-full object-contain" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="absolute top-1/4 translate-x-1/2 aspect-373/301 w-1/4 z-10">
                    <svg width="100%" preserveAspectRatio="none" viewBox="0 0 374 303" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 0.5L103.74 0.500006C158.874 0.50001 211.639 22.9149 249.917 62.5966L265.356 78.6022C293.767 108.056 332.932 124.693 373.855 124.693" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke" />
                        <path d="M0 301.878L100.27 301.878C157.383 301.878 211.798 277.576 249.916 235.046L269.077 213.668C295.002 184.741 332.011 168.213 370.855 168.213" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                        <path d="M0 225.047H101.568C150.99 225.047 199.685 213.134 243.525 190.315L258.107 182.725C292.367 164.894 330.42 155.584 369.042 155.583" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                        <path d="M0 77.3321L104.936 77.332C152.294 77.332 199.092 87.5641 242.129 107.328L250.734 111.279C288.101 128.439 328.735 137.324 369.855 137.324" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                    </svg>
                </div>

                <!-- Central Hub -->
                <div class="max-w-[210px] w-full rounded-full flex items-center justify-center z-20 overflow-hidden">
                    <img src="/images/global-unified-api.png" alt="ClearTax Global Unified API" class="w-full h-full object-contain" />
                </div>

                <div class="absolute top-[46%] w-full">
                    <svg width="100%" preserveAspectRatio="none" viewBox="0 0 704 1" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M703.729 0.5H0" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                    </svg>
                </div>

                <!-- Tax Authorities Column -->
                <div class="relative z-10 w-full lg:max-w-[378px]">
                    <div class="bg-[#EDEAF6] rounded-[12px] border border-[#1B087633] p-5 shadow-sm">
                        <h3 class="text-[#1B0876]/80 text-lg font-normal mb-7">Tax Authorities</h3>
                        <div class="live-flag-grid mb-4">
                            {mandates.map((m) => (
                                <div class="bg-[#E0DBF080] rounded-[8px] py-2 px-5 flex max-sm:flex-col items-start gap-3 hover:shadow-md transition-all hover:-translate-y-0.5 border border-black/8">
                                    <div class="w-6 h-6 rounded-full flex-shrink-0 overflow-hidden mt-1">
                                        <img src={`/images/tax-live-${m.flag}.png`} alt={m.name} class="w-full h-full object-cover" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-lg text-black">{m.name}</span>
                                        <span class="text-base text-black/80">{m.status}</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                        <div class="border-2 border-dashed border-[#1B087633] rounded-[16px] py-4 text-center">
                            <span class="text-[#4D45A5] font-bold text-sm">50+ Countries & Growing</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .animate-pulse-line {
        animation: pulse-line 4s linear infinite;
    }

    @keyframes pulse-line {
        0% { stroke-dashoffset: 1000; }
        100% { stroke-dashoffset: 0; }
    }
</style>
