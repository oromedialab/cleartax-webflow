---
const erpLogos = [
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e917bc9a2a6b5bdab_logo-mandate-1.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e4a6c0b488c8e341f_logo-mandate-2.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e7d70b792ffa777c2_logo-mandate-3.png',
    'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5e3d48cec8adaf71dc_logo-mandate-4.png'
];

const mandates = [
    { name: 'UAE', status: 'Live 2027', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5dc761d4d31839b3d0_tax-live-uae.png' },
    { name: 'KSA', status: 'Live', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5d917bc9a2a6b5bd4e_tax-live-ksa.png' },
    { name: 'France', status: 'Live 2026', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5d567d2e2d1613e721_tax-live-france.png' },
    { name: 'Germany', status: 'Live 2027', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5dc8e9320a2037eb0d_tax-live-germany.png' },
    { name: 'Malaysia', status: 'Live', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5dd6a34ed2f49f885a_tax-live-malaysia.png' },
    { name: 'Oman', status: 'Live 2026', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5ddfac4df487891014_tax-live-oman.png' },
    { name: 'Poland', status: 'Live 2026', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5d22a81ad28a27d8ac_tax-live-poland.png' },
    { name: 'Croatia', status: 'Live', flagUrl: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5dc05fbaba634a0995_tax-live-croatia.png' },
];
---
<section class="bg-[#F3F1F9] py-20 lg:py-25 overflow-hidden">
    <div class="wf-container mx-auto px-4">
        <div class="text-center mb-8 lg:mb-12">
            <h2 class="text-[28px]! sm:text-[36px]! lg:text-[44px]! lg:leading-[1.2]! font-semibold! text-black! mb-4!">
                One API. Every Mandate.
            </h2>
            <p class="text-base! lg:text-lg! text-black! max-w-3xl! mx-auto!">
                One API. Country mandates sit on top of it as configuration, not separate builds. When a new country goes live, you switch it on. Your integration doesn't change.
            </p>
        </div>

        <div class="relative max-w-7xl mx-auto min-h-[500px]">
            <div class="flex flex-col lg:flex-row items-center justify-between h-full relative z-10 gap-30 sm:gap-40 lg:gap-0">
                <!-- ERP Column (Your System) -->
                <div class="relative z-20 w-full lg:max-w-[204px]">
                    <div class="bg-[#EDEAF6] rounded-[12px] border border-[#1B087633] p-4 md:p-7 h-full">
                        <h3 class="text-[#1B0876]!/80! text-lg! text-center! mb-7! font-normal!">Your System</h3>
                        <div class="your-system-grid border-2 border-dashed border-[#1B087633] rounded-[12px] p-4 md:p-6">
                            {erpLogos.map((logo, i) => (
                                <div class="rounded-[12px] flex items-center justify-center transition-all hover:-translate-y-0.5">
                                    <img src={logo} alt={`ERP Logo ${i + 1}`} class="w-full h-full object-contain" />
                                </div>
                            ))}
                            <div class="rounded-[12px] flex items-center justify-center hover:bg-[#4D45A5]/5 transition-colors max-sm:col-span-2">
                                <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5ef8209f69a7534af9_logo-mandate-5.png" alt="More systems" class="w-full h-12 object-contain" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="absolute top-[22%] lg:top-1/4 max-sm:left-[17%] max-lg:left-1/4 lg:translate-x-1/2 aspect-373/301 w-[64%] sm:w-1/2 lg:w-1/4 max-lg:rotate-90">
                    <svg width="100%" preserveAspectRatio="none" viewBox="0 0 374 303" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 0.5L103.74 0.500006C158.874 0.50001 211.639 22.9149 249.917 62.5966L265.356 78.6022C293.767 108.056 332.932 124.693 373.855 124.693" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke" />
                        <path d="M0 301.878L100.27 301.878C157.383 301.878 211.798 277.576 249.916 235.046L269.077 213.668C295.002 184.741 332.011 168.213 370.855 168.213" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                        <path d="M0 225.047H101.568C150.99 225.047 199.685 213.134 243.525 190.315L258.107 182.725C292.367 164.894 330.42 155.584 369.042 155.583" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                        <path d="M0 77.3321L104.936 77.332C152.294 77.332 199.092 87.5641 242.129 107.328L250.734 111.279C288.101 128.439 328.735 137.324 369.855 137.324" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                    </svg>
                </div>
                <div class="absolute flex top-1/2 w-[200%] md:w-full max-lg:rotate-90">
                    <svg width="100%" preserveAspectRatio="none" viewBox="0 0 704 1" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M703.729 0.5H0" stroke="#493991" stroke-dasharray="6 6" vector-effect="non-scaling-stroke"/>
                    </svg>
                </div>

                <!-- Central Hub -->
                <div class="max-w-[210px] w-full rounded-full flex items-center justify-center z-20 overflow-hidden">
                    <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c5ec8b9705daa98868e_global-unified-api.png" alt="ClearTax Global Unified API" class="w-full h-full object-contain" />
                </div>

                <!-- Tax Authorities Column -->
                <div class="relative z-10 w-full lg:max-w-[378px]">
                    <div class="bg-[#EDEAF6] rounded-[12px] border border-[#1B087633] p-5 shadow-sm">
                        <h3 class="text-[#1B0876]/80! text-lg! font-normal! mb-7!">Tax Authorities</h3>
                        <div class="live-flag-grid mb-4">
                            {mandates.map((m) => (
                                <div class="bg-[#E0DBF080]! rounded-[8px]! py-2! px-5! flex max-sm:flex-col! items-start! gap-3! hover:shadow-md! transition-all! hover:-translate-y-0.5! border border-black/8!">
                                    <div class="w-6! h-6! rounded-full! flex-shrink-0! overflow-hidden! mt-1!">
                                        <img src={m.flagUrl} alt={m.name} class="w-full! h-full! object-cover!" />
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-lg text-black">{m.name}</span>
                                        <span class="text-base text-[#000000CC]">{m.status}</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                        <div class="border-2 border-dashed border-[#1B087633] rounded-[16px] py-4 text-center">
                            <span class="text-[#4D45A5] font-bold text-sm">50+ Countries & Growing</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    .animate-pulse-line {
        animation: pulse-line 4s linear infinite;
    }

    @keyframes pulse-line {
        0% { stroke-dashoffset: 1000; }
        100% { stroke-dashoffset: 0; }
    }
</style>
