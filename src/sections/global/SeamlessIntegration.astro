            </div>
            <div class="flex-1 flex flex-col items-start gap-0">
              {
                supportSteps.map((step, i) => (
                  <>
                    <div class="flex items-start gap-16 sm:gap-6">
                      <div
                        class="w-11 h-11 rounded-[12px] flex items-center justify-center shrink-0 shadow-[0_4px_12px_rgba(0,0,0,0.1)]"
                        style={`background:${step.color}`}
                      >
                        <svg
                          viewBox="0 0 16 16"
                          fill="none"
                          height="16"
                          width="16"
                          class="w-5 h-5"
                        >
                          <circle
                            cx="8"
                            cy="8"
                            r="3"
                            fill="white"
                            opacity="0.4"
                          />
                        </svg>
                      </div>
                      <div class="pt-1">
                        <div class="text-[17px] font-semibold text-black mb-[3px]">
                          {step.title}
                        </div>
                        <p class="text-[13px] font-medium text-black/50 m-0 leading-[1.45]">
                          {step.desc}
                        </p>
                      </div>
                    </div>
                    {i < supportSteps.length - 1 && (
                      <div class="w-[2.5px] h-5 bg-gradient-to-b from-black/0.15 to-black/0.06 ml-[21px] rounded-[2px]" />
                    )}
                  </>
