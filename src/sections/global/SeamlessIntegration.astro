<style is:global>
  @keyframes ssrFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const items = root.querySelectorAll("[data-ssr]");
    const graphics = root.querySelectorAll("[data-ssr-graphic]");
    items.forEach((item) => {
      // The header is the first child of the item (the div containing the label and chevron)
      const header = item.firstElementChild;
      header?.addEventListener("click", () => {
        const key = item.getAttribute("data-ssr");
        if (item.classList.contains("active")) return;
        items.forEach((i) => i.classList.remove("active"));
        graphics.forEach((g) => g.classList.remove("active"));
        item.classList.add("active");
        root
          .querySelector(`[data-ssr-graphic="${key}"]`)
          ?.classList.add("active");
      });
    });
  })();
</script>
