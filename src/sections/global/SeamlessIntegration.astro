          >
            <h3 class="text-[15px] font-medium text-black/50 leading-[1.5] m-0">
              Military-grade security to protect your global financial data
            </h3>
          </div>
        </div>
        <div
          class="group relative border-b border-black/10 first:border-t before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[3px] before:bg-[var(--color-purple)] before:rounded-r-[3px] before:scale-y-0 before:transition-transform before:duration-300 before:ease flex flex-col [&.active]:before:scale-y-100"
          data-ssr="support"
        >
          <div
            class="flex items-center justify-between p-[20px_16px_20px_20px] cursor-pointer transition-colors duration-200 hover:bg-black/4"
          >
            <span
              class="text-[18px] font-bold text-black/45 transition-[color,font-size] duration-300 group-[.active]:text-black group-[.active]:text-[20px] group-[.active]:font-bold"
              >Service and Support</span
            >
            <svg
              viewBox="0 0 22 22"
              fill="none"
              height="22"
              width="22"
              class="text-[#a5a5a5] transition-[transform,color] duration-300 shrink-0 group-[.active]:rotate-180"
              ><path
                d="M7 9l4 4 4-4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div
            class="max-h-0 overflow-hidden transition-[max-height,padding] duration-400 px-5 group-[.active]:max-h-[120px] group-[.active]:pb-5"
          >
            <h3 class="text-[15px] font-medium text-black/50 leading-[1.5] m-0">
              Committed to Your Success
            </h3>
          </div>
        </div>
      </div>

      <div class="relative flex items-stretch min-h-full">
        <div
          class="hidden animate-[ssrFadeIn_0.4s_ease] w-full [&.active]:flex [&.active]:items-stretch active"
          data-ssr-graphic="compliance"
        >
          <div class="flex flex-col gap-[14px] w-full">
            <div class="grid gap-[14px] grid-cols-3 sm:grid-cols-3">
              {
                complianceCardsRow1.map((c) => (
                  <div class="bg-[var(--color-white)] rounded-[12px] p-4 flex flex-col transition-[transform,box-shadow] duration-200 border border-black/12 hover:-translate-y-[3px] hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
                    <div class="flex gap-4 flex-wrap items-center min-h-[34px] mb-[36px] sm:gap-3">
                      {c.flags.map((f) => (
                        <img src={f} alt="" class="w-10 h-auto" />
                      ))}
                    </div>
                    <div class="flex flex-col h-full justify-end">
                      <div class="text-[18px] font-semibold mb-2 text-[var(--color-dark)]">
                        {c.name}
                      </div>
                      <p class="text-[16px] text-[var(--color-gray-500)] leading-[1.45] m-0">
                        {c.desc}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="grid gap-[14px] grid-cols-4 sm:grid-cols-4">
              {
                complianceCardsRow2.map((c) => (
                  <div class="bg-[var(--color-white)] rounded-[12px] p-4 flex flex-col transition-[transform,box-shadow] duration-200 border border-black/12 hover:-translate-y-[3px] hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
                    <div class="flex gap-4 flex-wrap items-center min-h-[34px] mb-[36px] sm:gap-3">
                      <img src={c.flag} alt="" class="w-10 h-auto" />
                    </div>
                    <div class="flex flex-col h-full justify-end">
                      <div class="text-[18px] font-semibold mb-2 text-[var(--color-dark)]">
                        {c.name}
                      </div>
                      <p class="text-[16px] text-[var(--color-gray-500)] leading-[1.45] m-0">
                        {c.desc}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div
          class="hidden animate-[ssrFadeIn_0.4s_ease] w-full [&.active]:flex [&.active]:items-stretch"
          data-ssr-graphic="integrations"
        >
          <div
            class="flex gap-0 items-stretch w-full bg-[#e8f0fe] rounded-[20px] p-[28px_24px] min-h-full sm:flex-row"
          >
            <div class="flex flex-col gap-[10px] w-[170px] shrink-0">
              <div
                class="bg-gradient-to-br from-[#2563eb] to-[#7c3aed] rounded-[16px] p-[20px_16px] flex flex-col items-center justify-center text-center gap-1 flex-1"
              >
                <span class="text-[36px] font-semibold text-white leading-[1.1]"
                  >2,000+</span
                >
                <span
                  class="text-[12px] font-semibold text-white/80 leading-[1.4]"
                  >Successful<br />Integrations</span
                >
              </div>
              <div
                class="bg-gradient-to-br from-[#2563eb] to-[#7c3aed] rounded-[16px] p-[20px_16px] flex flex-col items-center justify-center text-center gap-1 flex-1"
              >
                <span class="text-[36px] font-semibold text-white leading-[1.1]"
                  >100+</span
                >
                <span
                  class="text-[12px] font-semibold text-white/80 leading-[1.4]"
                  >Integration engineers</span
                >
              </div>
              <div
                class="bg-gradient-to-br from-[#2563eb] to-[#7c3aed] rounded-[16px] p-[16px_14px] flex flex-col items-center justify-center text-center gap-[6px] flex-1"
              >
                <svg viewBox="0 0 32 32" fill="none" height="32" width="32">
                  <circle
                    cx="16"
                    cy="16"
                    r="5"
                    stroke="white"
                    stroke-width="1.5"></circle>
                  <circle cx="16" cy="4" r="2.5" fill="white" opacity="0.7"
                  ></circle>
                  <circle cx="16" cy="28" r="2.5" fill="white" opacity="0.7"
                  ></circle>
                  <circle cx="4" cy="16" r="2.5" fill="white" opacity="0.7"
                  ></circle>
                  <circle cx="28" cy="16" r="2.5" fill="white" opacity="0.7"
                  ></circle>
                  <line
                    stroke="white"
                    stroke-width="1.2"
                    x1="16"
                    x2="16"
                    y1="6.5"
                    y2="11"></line>
                  <line
                    stroke="white"
                    stroke-width="1.2"
                    x1="16"
                    x2="16"
                    y1="21"
                    y2="25.5"></line>
                  <line
                    stroke="white"
                    stroke-width="1.2"
                    x1="6.5"
                    x2="11"
                    y1="16"
                    y2="16"></line>
                  <line
                    stroke="white"
                    stroke-width="1.2"
                    x1="21"
                    x2="25.5"
                    y1="16"
                    y2="16"></line>
                </svg>
                <span class="text-[14px] font-bold text-white leading-[1.3]"
                  >Integrate Multiple Systems</span
                >
                <span
                  class="text-[10px] font-medium text-white/65 leading-[1.4]"
                  >EPRs, POS, Handheld systems, all are supported</span
                >
              </div>
            </div>
            <div
              class="w-0 border-l-2 border-dashed border-black/12 mx-5 shrink-0 self-stretch sm:hidden"
            >
            </div>
            <div class="flex-1 flex flex-col justify-center min-w-0 p-6">
              <div class="text-[14px] leading-[1.6] text-black/60 m-0">
                <p>
                  SAP · Oracle · Microsoft Dynamics · Shopify · Toshiba · and
                  40+ more ERPs / POS systems supported
                </p>
              </div>
            </div>
          </div>
        </div>

        <div
          class="hidden animate-[ssrFadeIn_0.4s_ease] w-full [&.active]:flex [&.active]:items-stretch"
          data-ssr-graphic="security"
        >
          <div class="flex flex-col w-full">
            <div class="grid sm:grid-cols-1 gap-4 lg:grid-cols-3 w-full">
