                securityCards.map((card, index) => (
                  <div
                    class="bg-[var(--color-white)] rounded-[12px] p-5 flex items-start gap-4 transition-[transform,box-shadow] duration-200 border border-black/12 hover:-translate-y-[3px] hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]"
                    style={`background:${card.bg}`}
                  >
                    <div
                      class="flex items-center justify-center shrink-0 [&_svg]:w-10 [&_svg]:h-10"
