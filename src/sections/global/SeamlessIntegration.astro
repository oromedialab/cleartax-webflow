---
/**
 * Seamless integrations / compliance / support accordion.
 * Ported from global-e-invoicing-mandate-page/index.html:3076-3467.
 * Accordion selects one of three panels (compliance / integrations / support).
 */

const complianceCardsRow1 = [
  {
    name: 'Peppol',
    desc: 'Pan-European e-invoicing & procurement network',
    flags: [
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae53935abc459cd8030_Europion-union.svg',
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae53703cec9637d073a_Germany.svg',
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae5e8372214ac10693f_France.svg',
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae6fd1811f749f8f048_Italy.svg',
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae546a953797671325a_Netherlands.svg',
      'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae57fbbff808d68a9a6_Belgium.svg',
    ],
  },
  {
    name: 'FTA',
    desc: 'UAE Federal Tax Authority compliance',
    flags: ['https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae5d0963b18e351a106_United_Arab_Emirates.svg'],
  },
  {
    name: 'ZATCA',
    desc: 'Saudi e-invoicing mandate (Fatoorah)',
    flags: ['https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae5b436fb7dd54c2a00_saudi-flag.svg'],
  },
];

const complianceCardsRow2 = [
  { name: 'DGFiP', desc: 'French tax administration', flag: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae5e8372214ac10693f_France.svg' },
  { name: 'FPS Finance', desc: 'Belgian fiscal services', flag: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae57fbbff808d68a9a6_Belgium.svg' },
  { name: 'NIC', desc: 'National Informatics Centre', flag: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae6cf6ea42dd96209b7_India.svg' },
  { name: 'LHDN', desc: 'Malaysian tax authority', flag: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df8ae6be3c33a3ce43be9d_Malaysia.svg' },
];

const supportSteps = [
  { color: '#6c5ce7', title: 'Onboarding Managers', desc: 'Dedicated onboarding team ensures smooth setup' },
  { color: '#1572ed', title: 'Training', desc: 'Comprehensive training programs for your team' },
  { color: '#27ae60', title: 'Dedicated KAMs', desc: 'Key Account Managers for personalized service' },
  { color: '#f39c12', title: 'Feature Requests', desc: 'We build what you need, when you need it' },
  { color: '#e74c3c', title: 'Onsite Visits', desc: 'In-person support and consultation at your office' },
];
---

<section class="ssr-section">
  <div class="wf-container">
    <div class="ssr-header">
      <h2 class="ssr-heading">Seamless integrations, compliance &amp; dependable support</h2>
    </div>
    <div class="ssr-layout">
      <div class="ssr-accordion" data-ssr-root>
        <div class="ssr-item active" data-ssr="compliance">
          <div class="ssr-item-header">
            <span class="ssr-item-name">Compliance</span>
            <svg viewBox="0 0 22 22" fill="none" height="22" width="22" class="ssr-chevron"><path d="M7 9l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </div>
          <div class="ssr-item-body"><h3 class="ssr-item-headline">Powering Global e-Invoicing Alongside Regulators</h3></div>
        </div>
        <div class="ssr-item" data-ssr="integrations">
          <div class="ssr-item-header">
            <span class="ssr-item-name">Integrations</span>
            <svg viewBox="0 0 22 22" fill="none" height="22" width="22" class="ssr-chevron"><path d="M7 9l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </div>
          <div class="ssr-item-body"><h3 class="ssr-item-headline">Deep integrations means minimal to no changes in your daily workflow</h3></div>
        </div>
        <div class="ssr-item" data-ssr="support">
          <div class="ssr-item-header">
            <span class="ssr-item-name">Service and Support</span>
            <svg viewBox="0 0 22 22" fill="none" height="22" width="22" class="ssr-chevron"><path d="M7 9l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </div>
          <div class="ssr-item-body"><h3 class="ssr-item-headline">Committed to Your Success</h3></div>
        </div>
      </div>

      <div class="ssr-display">
        <div class="ssr-graphic active" data-ssr-graphic="compliance">
          <div class="ssr-comp">
            <div class="ssr-comp-row ssr-comp-row-3">
              {complianceCardsRow1.map((c) => (
                <div class="ssr-comp-card">
                  <div class="ssr-comp-flags">
                    {c.flags.map((f) => <img src={f} alt="" />)}
                  </div>
                  <div class="ssr-comp-content">
                    <div class="ssr-comp-name">{c.name}</div>
                    <p class="ssr-comp-desc">{c.desc}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="ssr-comp-row ssr-comp-row-4">
              {complianceCardsRow2.map((c) => (
                <div class="ssr-comp-card">
                  <div class="ssr-comp-flags"><img src={c.flag} alt="" /></div>
                  <div class="ssr-comp-content">
                    <div class="ssr-comp-name">{c.name}</div>
                    <p class="ssr-comp-desc">{c.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="ssr-graphic" data-ssr-graphic="integrations">
          <div class="ssr-int">
            <div class="ssr-int-left">
              <div class="ssr-int-stat">
                <span class="ssr-int-stat-num">2,000+</span>
                <span class="ssr-int-stat-label">Successful<br/>Integrations</span>
              </div>
              <div class="ssr-int-stat">
                <span class="ssr-int-stat-num">100+</span>
                <span class="ssr-int-stat-label">Integration engineers</span>
              </div>
              <div class="ssr-int-stat ssr-int-stat-multi">
                <svg viewBox="0 0 32 32" fill="none" height="32" width="32">
                  <circle cx="16" cy="16" r="5" stroke="white" stroke-width="1.5"></circle>
                  <circle cx="16" cy="4" r="2.5" fill="white" opacity="0.7"></circle>
                  <circle cx="16" cy="28" r="2.5" fill="white" opacity="0.7"></circle>
                  <circle cx="4" cy="16" r="2.5" fill="white" opacity="0.7"></circle>
                  <circle cx="28" cy="16" r="2.5" fill="white" opacity="0.7"></circle>
                  <line stroke="white" stroke-width="1.2" x1="16" x2="16" y1="6.5" y2="11"></line>
                  <line stroke="white" stroke-width="1.2" x1="16" x2="16" y1="21" y2="25.5"></line>
                  <line stroke="white" stroke-width="1.2" x1="6.5" x2="11" y1="16" y2="16"></line>
                  <line stroke="white" stroke-width="1.2" x1="21" x2="25.5" y1="16" y2="16"></line>
                </svg>
                <span class="ssr-int-stat-title">Integrate Multiple Systems</span>
                <span class="ssr-int-stat-sub">EPRs, POS, Handheld systems, all are supported</span>
              </div>
            </div>
            <div class="ssr-int-divider"></div>
            <div class="ssr-int-right">
              <div class="ssr-int-placeholder">
                <p>SAP · Oracle · Microsoft Dynamics · Shopify · Toshiba · and 40+ more ERPs / POS systems supported</p>
              </div>
            </div>
          </div>
        </div>

        <div class="ssr-graphic" data-ssr-graphic="support">
          <div class="ssr-sup">
            <div class="ssr-sup-left">
              <div class="ssr-sup-big">360°</div>
              <div class="ssr-sup-word">support</div>
              <p class="ssr-sup-desc">End-to-end assistance from onboarding to ongoing optimization for your business</p>
            </div>
            <div class="ssr-sup-timeline">
              {supportSteps.map((step, i) => (
                <>
                  <div class="ssr-sup-step">
                    <div class="ssr-sup-dot" style={`background:${step.color}`}>
                      <svg viewBox="0 0 16 16" fill="none" height="16" width="16">
                        <circle cx="8" cy="8" r="3" fill="white" opacity="0.4"></circle>
                      </svg>
                    </div>
                    <div class="ssr-sup-step-content">
                      <div class="ssr-sup-step-title">{step.title}</div>
                      <p>{step.desc}</p>
                    </div>
                  </div>
                  {i < supportSteps.length - 1 && <div class="ssr-sup-line"></div>}
                </>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .ssr-section { background: var(--color-gray-50); padding: 100px 0; }
  .wf-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .ssr-header { text-align: left; margin-bottom: 64px; }
  .ssr-heading { font-size: 44px; font-weight: 600; color: #000; line-height: 1.15; margin-bottom: 52px; letter-spacing: -.02em; text-wrap: balance; max-width: 732px; width: 100%; }

  .ssr-layout { display: grid; grid-template-columns: 340px 1fr; gap: 24px; align-items: start; }
  .ssr-accordion { display: flex; flex-direction: column; }
  .ssr-item { border-bottom: 1px solid rgba(0, 0, 0, .1); position: relative; }
  .ssr-item:first-child { border-top: 1px solid rgba(0, 0, 0, .1); }
  .ssr-item::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--color-purple); border-radius: 0 3px 3px 0; transform: scaleY(0); transition: transform .3s ease; }
  .ssr-item.active::before { transform: scaleY(1); }
  .ssr-item-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 16px 20px 20px; cursor: pointer; transition: background .2s ease; }
  .ssr-item-header:hover { background: rgba(0, 0, 0, .04); }
  .ssr-item-name { font-size: 18px; font-weight: 700; color: rgba(0, 0, 0, .45); transition: color .3s ease, font-size .3s ease; }
  .ssr-item.active .ssr-item-name { color: #000; font-size: 20px; }
  .ssr-chevron { color: #a5a5a5; transition: transform .3s ease, color .3s ease; flex-shrink: 0; }
  .ssr-item.active .ssr-chevron { transform: rotate(180deg); }
  .ssr-item-body { max-height: 0; overflow: hidden; transition: max-height .4s ease, padding .4s ease; padding: 0 20px; }
  .ssr-item.active .ssr-item-body { max-height: 120px; padding: 0 20px 20px; }
  .ssr-item-headline { font-size: 15px; font-weight: 500; color: rgba(0, 0, 0, .5); line-height: 1.5; margin: 0; }

  .ssr-display { position: relative; display: flex; align-items: stretch; }
  .ssr-graphic { display: none; animation: ssrFadeIn .4s ease; width: 100%; }
  .ssr-graphic.active { display: flex; align-items: stretch; }
  @keyframes ssrFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .ssr-comp { display: flex; flex-direction: column; gap: 14px; width: 100%; }
  .ssr-comp-row { display: grid; gap: 14px; }
  .ssr-comp-row-3 { grid-template-columns: repeat(3, 1fr); }
  .ssr-comp-row-4 { grid-template-columns: repeat(4, 1fr); }
  .ssr-comp-content { display: flex; flex-direction: column; height: 100%; justify-content: flex-end; }
  .ssr-comp-card { background: var(--color-white); border-radius: 12px; padding: 16px; display: flex; flex-direction: column; transition: transform .2s ease, box-shadow .2s ease; border: 1px solid rgba(0, 0, 0, .12); }
  .ssr-comp-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0, 0, 0, .06); }
  .ssr-comp-flags { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; min-height: 34px; margin-bottom: 36px; }
  .ssr-comp-flags img { width: 24px; height: auto; }
  .ssr-comp-row-4 .ssr-comp-flags { gap: 12px; }
  .ssr-comp-name { font-size: 18px; font-weight: 600; margin-bottom: 8px; color: var(--color-dark); }
  .ssr-comp-desc { font-size: 16px; color: var(--color-gray-500); line-height: 1.45; margin: 0; }

  .ssr-int { display: flex; gap: 0; align-items: stretch; width: 100%; background: #e8f0fe; border-radius: 20px; padding: 28px 24px; min-height: 100%; }
  .ssr-int-left { display: flex; flex-direction: column; gap: 10px; width: 170px; flex-shrink: 0; }
  .ssr-int-stat { background: linear-gradient(145deg, #2563eb 0, #7c3aed 100%); border-radius: 16px; padding: 20px 16px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 4px; flex: 1; }
  .ssr-int-stat-num { font-size: 36px; font-weight: 600; color: #fff; line-height: 1.1; }
  .ssr-int-stat-label { font-size: 12px; font-weight: 600; color: rgba(255, 255, 255, .8); line-height: 1.4; }
  .ssr-int-stat-multi { gap: 6px; padding: 16px 14px; }
  .ssr-int-stat-title { font-size: 14px; font-weight: 700; color: #fff; line-height: 1.3; }
  .ssr-int-stat-sub { font-size: 10px; font-weight: 500; color: rgba(255, 255, 255, .65); line-height: 1.4; }
  .ssr-int-divider { width: 0; border-left: 2px dashed rgba(0, 0, 0, .12); margin: 0 20px; flex-shrink: 0; align-self: stretch; }
  .ssr-int-right { flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; padding: 24px; }
  .ssr-int-placeholder p { font-size: 14px; line-height: 1.6; color: rgba(0, 0, 0, 0.6); margin: 0; }

  .ssr-sup { display: flex; gap: 24px; align-items: center; width: 100%; }
  .ssr-sup-left { width: 240px; flex-shrink: 0; }
  .ssr-sup-big { font-size: 80px; font-weight: 600; color: #000; line-height: 1; letter-spacing: -.04em; }
  .ssr-sup-word { font-size: 34px; font-weight: 700; color: rgba(0, 0, 0, .5); margin-top: -4px; }
  .ssr-sup-desc { font-size: 14px; font-weight: 500; color: rgba(0, 0, 0, .4); line-height: 1.55; margin: 16px 0 0; }
  .ssr-sup-timeline { flex: 1; display: flex; flex-direction: column; align-items: flex-start; gap: 0; }
  .ssr-sup-step { display: flex; align-items: flex-start; gap: 16px; }
  .ssr-sup-dot { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 12px rgba(0, 0, 0, .1); }
  .ssr-sup-dot svg { width: 20px; height: 20px; }
  .ssr-sup-step-content { padding-top: 4px; }
  .ssr-sup-step-title { font-size: 17px; font-weight: 600; color: #000; margin-bottom: 3px; }
  .ssr-sup-step-content p { font-size: 13px; font-weight: 500; color: rgba(0, 0, 0, .5); margin: 0; line-height: 1.45; }
  .ssr-sup-line { width: 2.5px; height: 20px; background: linear-gradient(to bottom, rgba(0, 0, 0, .15), rgba(0, 0, 0, .06)); margin-left: 21px; border-radius: 2px; }

  @media (max-width: 1024px) {
    .ssr-heading { font-size: 36px; }
    .ssr-layout { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .ssr-section { padding: 72px 0 80px; }
    .ssr-heading { font-size: 28px; }
    .ssr-header { margin-bottom: 40px; }
    .ssr-comp-row-3, .ssr-comp-row-4 { grid-template-columns: 1fr; }
    .ssr-int { flex-direction: column; }
    .ssr-sup { flex-direction: column; gap: 24px; }
    .ssr-sup-left { width: 100%; }
    .ssr-sup-big { font-size: 48px; }
  }
</style>

<script is:inline>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const items = root.querySelectorAll('[data-ssr]');
    const graphics = root.querySelectorAll('[data-ssr-graphic]');
    items.forEach((item) => {
      item.querySelector('.ssr-item-header')?.addEventListener('click', () => {
        const key = item.getAttribute('data-ssr');
        if (item.classList.contains('active')) return;
        items.forEach((i) => i.classList.remove('active'));
        graphics.forEach((g) => g.classList.remove('active'));
        item.classList.add('active');
        root.querySelector(`[data-ssr-graphic="${key}"]`)?.classList.add('active');
      });
    });
  })();
</script>
