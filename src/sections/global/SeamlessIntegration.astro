              }
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-[48px] flex gap-2 items-center justify-center">
      <button
        class="flex items-center gap-2 p-[14px_40px] bg-gradient-to-r from-[#110072] to-[#7a5698] text-white rounded-[60px] text-[16px] font-medium leading-[1.5] border-none outline-none"
        >Learn more <span class="inline-flex">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 8H13M13 8L9 4M13 8L9 12"
              stroke="white"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span></button
      >
    </div>
  </div>
</section>

<style is:global>
  @keyframes ssrFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const items = root.querySelectorAll("[data-ssr]");
    const graphics = root.querySelectorAll("[data-ssr-graphic]");
    items.forEach((item) => {
      // The header is the first child of the item (the div containing the label and chevron)
      const header = item.firstElementChild;
      header?.addEventListener("click", () => {
        const key = item.getAttribute("data-ssr");
        if (item.classList.contains("active")) return;
        items.forEach((i) => i.classList.remove("active"));
        graphics.forEach((g) => g.classList.remove("active"));
        item.classList.add("active");
        root
          .querySelector(`[data-ssr-graphic="${key}"]`)
          ?.classList.add("active");
      });
    });
  })();
</script>
