---

<section
  class="bg-[var(--color-gray-50)] py-[100px] lg:py-[72px] sm:py-[72px] sm:pb-[80px]"
>
  <div class="max-w-[var(--container-max)] mx-auto px-6 w-full">
    <div class="text-center">
      <h2
        class="text-[28px] sm:text-[36px] lg:text-[44px] font-semibold text-black leading-[1.15] mb-12 tracking-[-0.02em] text-balance max-w-[732px] w-full mx-auto"
      >
        Seamless integrations, compliance &amp; dependable support
      </h2>
    </div>
    <div
      class="grid sm:grid-cols-[340px_1fr] gap-6 items-start lg:grid-cols-0 lg:gap-8"
    >
      <div class="flex flex-col" data-ssr-root>
        <div
          class="group relative border-b border-black/10 first:border-t before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[3px] before:bg-[var(--color-purple)] before:rounded-r-[3px] before:scale-y-0 before:transition-transform before:duration-300 before:ease flex flex-col [&.active]:before:scale-y-100 active"
          data-ssr="compliance"
        >
          <div
            class="flex items-center justify-between p-[20px_16px_20px_20px] cursor-pointer transition-colors duration-200 hover:bg-black/4"
          >
            <span
              class="text-[18px] font-bold text-black/45 transition-[color,font-size] duration-300 group-[.active]:text-black group-[.active]:text-[20px] group-[.active]:font-bold"
              >Compliance</span
            >
            <svg
              viewBox="0 0 22 22"
              fill="none"
              height="22"
              width="22"
              class="text-[#a5a5a5] transition-[transform,color] duration-300 shrink-0 group-[.active]:rotate-180"
              ><path
                d="M7 9l4 4 4-4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div
            class="max-h-0 overflow-hidden transition-[max-height,padding] duration-400 px-5 group-[.active]:max-h-[120px] group-[.active]:pb-5"
          >
            <h3 class="text-[15px] font-medium text-black/50 leading-[1.5] m-0">
              Powering Global e-Invoicing Alongside Regulators
            </h3>
          </div>
        </div>
        <div
          class="group relative border-b border-black/10 first:border-t before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[3px] before:bg-[var(--color-purple)] before:rounded-r-[3px] before:scale-y-0 before:transition-transform before:duration-300 before:ease flex flex-col [&.active]:before:scale-y-100"
          data-ssr="integrations"
        >
          <div
            class="flex items-center justify-between p-[20px_16px_20px_20px] cursor-pointer transition-colors duration-200 hover:bg-black/4"
          >
            <span
              class="text-[18px] font-bold text-black/45 transition-[color,font-size] duration-300 group-[.active]:text-black group-[.active]:text-[20px] group-[.active]:font-bold"
              >Integrations</span
            >
            <svg
              viewBox="0 0 22 22"
              fill="none"
              height="22"
              width="22"
              class="text-[#a5a5a5] transition-[transform,color] duration-300 shrink-0 group-[.active]:rotate-180"
              ><path
                d="M7 9l4 4 4-4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div
            class="max-h-0 overflow-hidden transition-[max-height,padding] duration-400 px-5 group-[.active]:max-h-[120px] group-[.active]:pb-5"
          >
            <h3 class="text-[15px] font-medium text-black/50 leading-[1.5] m-0">
              Deep integrations means minimal to no changes in your daily
              workflow
            </h3>
          </div>
        </div>
        <div
          class="group relative border-b border-black/10 first:border-t before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-[3px] before:bg-[var(--color-purple)] before:rounded-r-[3px] before:scale-y-0 before:transition-transform before:duration-300 before:ease flex flex-col [&.active]:before:scale-y-100"
          data-ssr="security"
        >
          <div
            class="flex items-center justify-between p-[20px_16px_20px_20px] cursor-pointer transition-colors duration-200 hover:bg-black/4"
          >
            <span
              class="text-[18px] font-bold text-black/45 transition-[color,font-size] duration-300 group-[.active]:text-black group-[.active]:text-[20px] group-[.active]:font-bold"
