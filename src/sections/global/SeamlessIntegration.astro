                  src="/images/global/integrations/mandate-logos.png"
                  alt=""
                  class="w-full h-full min-h-[131px] md:min-h-0 object-cover"
                />
              </div>
            </div>
            <div
              class="px-8 py-7 grid grid-cols-1 md:grid-cols-3 gap-6 bg-[#FDFDFB]"
            >
              <div>
                <div
                  class="text-[18px] font-semibold leading-[1.44] text-black"
