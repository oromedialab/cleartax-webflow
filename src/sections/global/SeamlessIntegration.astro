                      <p class="text-[14px] text-[var(--color-gray-500)] leading-[1.45] m-0">
                        {card.desc}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div
          class="hidden animate-[ssrFadeIn_0.4s_ease] w-full [&.active]:flex [&.active]:items-stretch"
          data-ssr-graphic="support"
        >
          <div class="flex gap-[24px] items-center w-full lg:gap-6 sm:flex-row">
            <div class="w-[240px] shrink-0 sm:w-auto">
              <div
                class="text-[80px] font-semibold text-black leading-none tracking-[-0.04em] sm:text-[48px]"
