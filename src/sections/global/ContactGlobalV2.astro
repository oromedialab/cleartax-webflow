---
/**
 * ContactGlobalV2.astro — Tailwind v4 port.
 * Matches the single-column layout and styling of Version 1.
 */
export interface Props {
  recaptchaSiteKey?: string;
  sheetName?: string;
  originCountry?: string;
  formType?: string;
  leadType?: string;
}

const {
  recaptchaSiteKey = '6Lc5ZG0mAAAAAGwClrZwtcyttcUMYDUPxg4MM4p3',
  sheetName = 'uaeRAD',
  originCountry = 'UAE',
  formType = 'GCC-contact-sales-form',
  leadType = 'GCC',
} = Astro.props as Props;
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@25.2.1/build/css/intlTelInput.css" />
<script is:inline src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>

<section id="contact" 
  class="bg-[linear-gradient(180deg,#FFFFFF_0%,#EDEAF6_100%)] py-25 overflow-hidden w-full max-lg:py-20 max-sm:py-16"
  data-recaptcha-key={recaptchaSiteKey}
  data-sheet-name={sheetName}
  data-origin-country={originCountry}
  data-form-type={formType}
  data-lead-type={leadType}>
  <div class="max-w-[var(--container-max)] mx-auto px-6">
    <div class="flex flex-row justify-between gap-6 max-lg:flex-col">
      <div class="flex flex-col gap-4 flex-1">
        <h2 class="v2-contact-title text-[44px] font-semibold leading-[1.2] text-black m-0 max-lg:text-[32px]">Simplify compliance<br />with ClearTax</h2>
        <p class="text-base lg:text-lg leading-[1.6] text-black m-0 mb-6 max-w-[450px]">Discover how ClearTax helps you manage invoicing, filings, and reporting with ease.</p>
        
        <!-- Premium Stats Grid -->
        <div class="grid grid-cols-2 gap-4 mt-8 w-full">
          <!-- 5000+ Enterprises -->
          <div class="p-4 flex flex-col items-start">
            <div class="w-10 h-10 flex items-center justify-center mb-7">
              <svg width="42" height="39" viewBox="0 0 42 39" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M37.0797 20.8457L39.1829 22.9489C40.1988 23.9648 40.1988 25.6119 39.1829 26.6278C38.1671 27.6437 36.52 27.6437 35.5041 26.6278L32.8899 24.0137" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M32.89 24.0127L37.3436 28.4663C38.3594 29.4821 38.3594 31.1292 37.3436 32.1452C36.3277 33.161 34.6806 33.161 33.6647 32.1452L29.2111 27.6916" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M29.2111 27.6924L31.8252 30.3065C32.8411 31.3224 32.8411 32.9695 31.8252 33.9854C30.8094 35.0013 29.1623 35.0013 28.1463 33.9854L25.5322 31.3713" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M25.5322 31.3716L26.92 32.7594C27.9359 33.7753 27.9359 35.4223 26.92 36.4383C25.9042 37.4541 24.2571 37.4541 23.2412 36.4383L21.0854 34.2825M20.6524 4.85754L20.2663 4.47145C15.9046 0.109777 8.83293 0.109777 4.47125 4.47145C0.109579 8.83312 0.109579 15.9048 4.47125 20.2665L5.0769 20.8721" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M5.61404 20.3352L2.9999 22.9493C1.98404 23.9652 1.98404 25.6123 2.9999 26.6282C4.01577 27.6441 5.66285 27.6441 6.6788 26.6282L9.29293 24.0141C10.3088 22.9982 10.3088 21.3511 9.29293 20.3352C8.27706 19.3193 6.62998 19.3193 5.61404 20.3352Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.29293 24.0134L4.83935 28.4669C3.82349 29.4828 3.82349 31.1299 4.83935 32.1458C5.85521 33.1617 7.5023 33.1617 8.51824 32.1458L12.9718 27.6923C13.9877 26.6764 13.9877 25.0293 12.9718 24.0134C11.9559 22.9975 10.3088 22.9975 9.29293 24.0134Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12.9718 27.6921L10.3577 30.3062C9.34182 31.3221 9.34182 32.9692 10.3577 33.9851C11.3735 35.001 13.0206 35.001 14.0366 33.9851L16.6507 31.371C17.6666 30.3551 17.6666 28.708 16.6507 27.6921C15.6348 26.6762 13.9877 26.6762 12.9718 27.6921Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16.6506 31.3708L15.2628 32.7587C14.2469 33.7745 14.2469 35.4216 15.2628 36.4376C16.2787 37.4534 17.9257 37.4534 18.9417 36.4376L20.3295 35.0497C21.3454 34.0339 21.3454 32.3868 20.3295 31.3708C19.3137 30.3549 17.6666 30.3549 16.6506 31.3708Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13.1968 13.1388L13.9351 13.8771C15.5591 15.5011 18.1922 15.5011 19.8163 13.8771L21.2848 12.4086C23.3166 10.3768 26.6108 10.3768 28.6425 12.4086L37.0798 20.8459L37.4659 20.4598C41.8276 16.0981 41.8276 9.02648 37.4659 4.66481C33.1042 0.303136 26.0326 0.303136 21.671 4.66481L13.1968 13.1388Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
            </svg>
            </div>
            <h3 class="text-xl font-semibold text-black mb-2 leading-normal">5,000+</h3>
            <p class="text-base text-black/80 m-0 leading-normal text-balance max-w-[162px] w-full">Businesses trust ClearTax worldwide</p>
          </div>

          <!-- 50+ Countries -->
          <div class="p-4 flex flex-col items-start">
            <div class="w-9 h-9 flex items-center justify-center mb-7">
              <svg width="39" height="39" viewBox="0 0 39 39" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M37.1999 19.1997C37.1999 29.1409 29.1411 37.1997 19.2 37.1997C9.25884 37.1997 1.20001 29.1409 1.20001 19.1997C1.20001 9.25861 9.25884 1.19978 19.2 1.19978C29.1411 1.19978 37.1999 9.25861 37.1999 19.1997Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M28.9474 19.1997C28.9474 29.1409 24.5833 37.1997 19.2 37.1997C13.8166 37.1997 9.45258 29.1409 9.45258 19.1997C9.45258 9.25861 13.8166 1.19978 19.2 1.19978C24.5833 1.19978 28.9474 9.25861 28.9474 19.1997Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M19.2 1.19978V37.1997" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M32.9156 7.54291C29.6139 9.64442 24.6944 10.9775 19.2 10.9775C13.7055 10.9775 8.78606 9.64442 5.48438 7.54283" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M5.48438 30.8569C8.78606 28.7553 13.7055 27.4222 19.2 27.4222C24.6944 27.4222 29.6139 28.7553 32.9156 30.8569" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>

            </div>
            <h3 class="text-xl font-semibold text-black mb-2 leading-normal">50+</h3>
            <p class="text-base text-black/80 m-0 leading-normal text-balance max-w-[162px] w-full">Countries supported for global compliance</p>
          </div>

          <!-- 1B+ Transactions -->
          <div class="p-4 flex flex-col items-start">
            <div class="w-9 h-9 flex items-center justify-center mb-7">
              <svg width="39" height="39" viewBox="0 0 39 39" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M34.4542 1.75618V9.3833H26.8271" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M15.1898 1.64056C16.4804 1.3521 17.8225 1.19994 19.2 1.19994C25.5672 1.19994 31.175 4.45077 34.4544 9.3833" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M36.757 15.1789C37.047 16.4727 37.2 17.8182 37.2 19.1996C37.2 25.5693 33.9465 31.1791 29.0107 34.458" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M23.2117 36.7588C21.9207 37.0475 20.5781 37.1997 19.2 37.1997C12.834 37.1997 7.22702 33.9501 3.94736 29.0191" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M1.64359 23.2236C1.35315 21.9289 1.2 20.5824 1.2 19.2C1.2 12.8299 4.45395 7.21965 9.3903 3.94091" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M1.76646 3.94564H9.39358V11.5728" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M29.008 26.827V34.4541H36.6351" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M3.94576 36.6475V29.0203H11.5729" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M13.6237 20.1996L16.6748 23.2505L22.7765 17.1488L24.7266 15.1987" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
            </svg>
            </div>
            <h3 class="text-xl font-semibold text-black mb-2 leading-normal">1B+</h3>
            <p class="text-base text-black/80 m-0 leading-normal max-w-[162px] w-full">E-invoices processed annually</p>
          </div>

          <!-- 500B+ Revenue -->
          <div class="p-4 flex flex-col items-start">
            <div class="w-9 h-9 flex items-center justify-center mb-7">
              <svg width="41" height="39" viewBox="0 0 41 39" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10.9294 26.0635H9.44426C4.90992 26.0635 1.20001 22.3536 1.20001 17.8192C1.20001 13.2849 4.90992 9.57498 9.44426 9.57498H9.75746C10.7799 4.78932 15.0317 1.20024 20.1225 1.20024C25.2133 1.20024 29.4651 4.78932 30.4876 9.57498H30.8008C35.3351 9.57498 39.045 13.2849 39.045 17.8192C39.045 22.3536 35.3349 26.0635 30.8008 26.0635H29.5234" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M20.1225 37.2002C15.5267 36.6065 11.9568 32.6788 11.9568 27.9477V20.2196L20.1225 17.335L28.2883 20.2196V27.9477C28.2883 32.6787 24.7184 36.6065 20.1225 37.2002Z" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
                <path d="M16.2458 27.3236L18.9508 30.0156L24.0003 24.9905" stroke="#655DFF" stroke-width="2.4" stroke-miterlimit="10" stroke-linejoin="round"/>
            </svg>

            </div>
            <h3 class="text-xl font-semibold text-black mb-2 leading-normal">$500B+</h3>
            <p class="text-base text-black/80 m-0 leading-normal max-w-[162px] w-full">B2B invoices digitized annually</p>
          </div>
        </div>
      </div>

      <div class="basis-[560px] max-lg:basis-auto max-lg:w-full">
        <form id="contact-form-v2" class="bg-white p-12 rounded-[12px] shadow-[0_8px_40px_rgba(0,0,0,0.06)] border border-[#EDEAF6] flex flex-col gap-4 max-sm:p-6" data-lead-form>
            <div>
                <h3 class="text-xl lg:text-[22px] font-medium leading-[1.36] text-black m-0 mb-3">Book A Demo</h3>
                <p class="text-base text-black/80 mb-4">Our specialists will walk you through the platform and build your compliance roadmap.</p>
            </div>
          
          <!-- Name Field -->
          <div class="flex flex-col gap-2">
            <label class="text-base text-black/80" for="cfg-name">Name*</label>
            <input type="text" id="cfg-name" data-field="name" placeholder="e.g. John Doe" class="p-[10px_12px] border border-[#E5E7EB] rounded-lg text-base outline-none focus:border-[var(--color-blue)] bg-[#F9FAFB] transition-colors" required />
          </div>

          <!-- Phone Field -->
          <div class="flex flex-col gap-2">
            <label class="text-base text-black/80" for="cfg-phone">Phone Number*</label>
            <input type="tel" id="cfg-phone" data-field="phone" class="w-full p-[10px_12px] border border-[#E5E7EB] rounded-lg text-base outline-none focus:border-[var(--color-blue)] bg-[#F9FAFB] transition-colors" required />
          </div>

          <!-- Two Fields Row -->
          <div class="flex max-sm:flex-col gap-4">
            <!-- Email Field -->
            <div class="flex flex-col gap-2 flex-1">
              <label class="text-base text-black/80" for="cfg-email">Company Email*</label>
              <input type="email" id="cfg-email" data-field="email" placeholder="e.g. john@company.com" class="p-[10px_12px] border border-[#E5E7EB] rounded-lg text-base outline-none focus:border-[var(--color-blue)] bg-[#F9FAFB] transition-colors" required />
            </div>

          <!-- Company Field -->
          <div class="flex flex-col gap-2 flex-1">
            <label class="text-base text-black/80" for="cfg-company">Company Name*</label>
            <input type="text" id="cfg-company" data-field="company" placeholder="e.g. Acme Corp" class="p-[10px_12px] border border-[#E5E7EB] rounded-lg text-base outline-none focus:border-[var(--color-blue)] bg-[#F9FAFB] transition-colors" required />
          </div>
          </div>

          <!-- Consent -->
          <label class="flex items-start gap-4 cursor-pointer mt-2">
            <input type="checkbox" id="cfg-consent" class="w-4 h-4 mt-1 shrink-0 accent-[var(--color-blue)]" required />
            <span class="text-sm text-black/80 leading-[1.5]">
              I agree to ClearTax's <a href="https://www.clear.in/meta/privacy" target="_blank" rel="noopener" class="text-[#200D78]">Privacy Policy</a> and <a href="https://www.clear.in/meta/terms" target="_blank" rel="noopener" class="text-[#200D78]">Terms of Service</a>. I consent to receiving communications about ClearTax products and e-invoicing updates.
            </span>
          </label>

          <button type="submit" class="v2-contact-btn w-full p-[10px_40px] text-base font-semibold text-white bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)] border-none rounded-full cursor-pointer transition-all duration-250 ease-in-out mt-1 font-inherit hover:-translate-y-[1px] max-lg:text-sm" data-submit>Get in touch</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .v2-contact-title {
    font-size: 44px !important;
    font-weight: 600 !important;
    line-height: 1.2 !important;
    color: #000000 !important;
    margin: 0 !important;
  }
  @media (max-width: 1024px) {
    .v2-contact-title { font-size: 32px !important; }
  }

  .v2-contact-btn {
    width: 100% !important;
    padding: 10px 40px !important;
    font-size: 16px !important;
    font-weight: 500 !important;
    color: #ffffff !important;
    background: linear-gradient(90deg, #110072 0%, #7A5698 100%) !important;
    border: none !important;
    cursor: pointer !important;
    transition: all 250ms ease !important;
    margin-top: 4px !important;
    font-family: inherit !important;
  }
  .v2-contact-btn:hover { transform: translateY(-1px) !important; }


  .iti { width: 100%; }

  /* ITI Search Bar & Dropdown styling */
  .iti__country-list {
    border-radius: 12px !important;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    border: 1px solid #E5E7EB !important;
    padding: 8px 0 !important;
    max-width: 300px !important;
  }
  .iti__search-input {
    margin: 8px !important;
    padding: 10px 12px !important;
    border-radius: 8px !important;
    border: 1px solid #E5E7EB !important;
    width: calc(100% - 16px) !important;
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@25.2.1/build/js/intlTelInput.min.js"></script>
<script is:inline>
  (function () {
    const section = document.querySelector('#contact');
    const form = section?.querySelector('[data-lead-form]');
    const phoneInput = form?.querySelector('[data-field="phone"]');
    if (!form || !phoneInput) return;

    let iti;
    function initIti() {
      if (typeof window.intlTelInput === 'undefined') { setTimeout(initIti, 50); return; }
      iti = window.intlTelInput(phoneInput, {
        utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@25.2.1/build/js/utils.js',
        initialCountry: 'us',
        separateDialCode: true,
        countrySearch: true,
        preferredCountries: ['ae', 'sa', 'in', 'us', 'uk'],
        autoPlaceholder: 'aggressive',
      });
    }
    initIti();

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const btn = form.querySelector('[data-submit]');
      const originalText = btn.innerText;
      btn.disabled = true;
      btn.innerText = 'Sending...';

      const recaptchaKey = section.getAttribute('data-recaptcha-key');
      const sheetName = section.getAttribute('data-sheet-name');
      const originCountry = section.getAttribute('data-origin-country');
      const formType = section.getAttribute('data-form-type');
      const leadType = section.getAttribute('data-lead-type');

      function readField(name) {
        const el = form.querySelector(`[data-field="${name}"]`);
        return el ? el.value : '';
      }

      function submit(token) {
        const countryData = iti ? iti.getSelectedCountryData() : { dialCode: '' };
        const payload = {
          lead_platforms: { google_sheet: { sheet_name: sheetName }, pardot: true, salesforce: true },
          extra_payload: { origin_country: originCountry },
          lead_data: {
            name: readField('name'),
            phone_number: iti ? iti.getNumber() : readField('phone'),
            email: readField('email'),
            company_name: readField('company'),
            ISD: `+${countryData.dialCode}`,
            form_type: formType,
            lead_type: leadType,
            lead_source_url: window.location.href,
            whatsapp_consent: false,
          },
        };

        fetch(`https://www.cleartax.com/f/common-lead/lead/?captcha_token=${token}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then((response) => {
            if (response.status === 201 || response.ok) {
                form.reset();
                if (iti) iti.setCountry('us');
            } else {
              throw new Error('Failed to submit');
            }
          })
          .catch((err) => {
            console.error(err);
          })
          .finally(() => {
            btn.disabled = false;
            btn.innerText = originalText;
          });
      }

      if (typeof grecaptcha === 'undefined') {
        submit('');
        return;
      }
      grecaptcha.ready(function () {
        grecaptcha.execute(recaptchaKey, { action: 'submit' }).then(submit);
      });
    });
  })();
</script>
