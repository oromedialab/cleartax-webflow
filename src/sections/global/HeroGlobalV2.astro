---
/**
 * Global hero — v2 Tailwind-utility port of HeroGlobal.astro.
 * No <style is:global>; all styles as utility classes.
 */
export interface Props {
  videoId?: string;
  posterUrl?: string;
}

const { videoId = 'UX0Yt61EdfY', posterUrl } = Astro.props as Props;
const effectivePoster = posterUrl ?? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;

const trustLogos = [
    { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de348a6065af3c36a69aff_zatca.svg', name: 'zatca' },
    { src: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb3755564ddcfcf0695624_cic.png', name: 'nic' },
  { src: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69e0c09f3a4c77f59ef94ec9_fta%20(1).png', name: 'fta' },
  { src: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69e0e0478f3585b605c04e67_peppol.png', name: 'peppol' },
];
---

<section
  class="bg-[linear-gradient(180deg,_#120420_12.72%,_#2D0A4E_41.69%,_#000000_100%)] pt-37.5 pb-25 w-full relative overflow-hidden  max-lg:pt-25 max-lg:pb-16"
  data-hero-global
  data-video-id={videoId}
>
<svg width="0" height="0" style="position:absolute">
  <filter id="glass">
    <feTurbulence type="fractalNoise" baseFrequency="0.008" numOctaves="2" seed="4" />
    <feDisplacementMap in="SourceGraphic" scale="30" />
  </filter>
</svg>


<img class="globe-container transition-transform mix-blend-luminosity absolute w-full min-h-80 h-auto left-0 bottom-0 pointer-events-none object-cover z-0" src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb0cf19b34f198b94079cc_globe.webp" alt="">
<img class="globe-gradient-overlay transition-transform mix-blend-luminosity absolute w-full h-auto min-h-142 left-0 -bottom-0.5 pointer-events-none z-1" src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb0cf1c632b7e1def5a205_globe-gradient.webp" alt="">
  <div class="max-w-[var(--container-max)] relative z-10 mx-auto px-6">
    <div class="flex flex-row flex-nowrap items-start justify-between gap-10 max-lg:flex-col max-lg:flex-wrap max-lg:gap-12">
      <div class="basis-[593px] w-1/2 text-left max-lg:w-full max-lg:max-w-full max-lg:basis-auto">
        <h1 class="text-[56px]! leading-[1.12]! font-medium! text-white! m-0! mb-6! tracking-[-1.5px]! max-lg:text-[32px]!">
          <span
            class="animated-gradient-text inline-flex"
            data-gradient-colors="#CC9DFF, #CC9DFF, #FFFFFF, #CC9DFF, #CC9DFF"
            data-animation-speed="4"
          >
            <span class="text-content">100% e-Invoicing Compliance Today.</span>
          </span>
          <br />Tax Assurance for Tomorrow.
        </h1>
        <p class="text-base lg:text-lg! leading-[1.6]! text-white/80 font-medium mb-10! max-w-148 max-lg:max-w-full">
          ClearTax helps you do more than meet the e-invoicing deadline. We prepare you for a future of automated tax scrutiny and always-on compliance.
        </p>
        <a
          href="#contact"
          class="inline-flex! items-center! gap-2! px-10! py-4! text-base! font-bold! text-white! bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)]! rounded-full! no-underline! transition-transform! duration-300! hover:-translate-y-px! [&:hover_span]:translate-x-[3px]! border border-white/50"
        >
          Request Demo <span class="inline-block! transition-transform! duration-300!">→</span>
        </a>
        <div>
            <div class="inline-flex items-center gap-8 lg:gap-14 mt-10 py-2 px-8 bg-white/10 backdrop-blur-[15px] backdrop-saturate-180 rounded-full border border-white/20 shadow-[inset_1px_1px_0_rgba(255,255,255,0.8),inset_-1px_-1px_0_rgba(255,255,255,0.1),0_8px_32px_rgba(0,0,0,0.2)]">
            <!-- <div class="inline-flex items-center gap-8 lg:gap-14 mt-10 py-2 px-8 bg-white/10 rounded-full border border-white/20 glass-real"> -->
              {trustLogos.map((l) => (
                <div class="flex flex-col items-center gap-1.5">
                  <img src={l.src} alt={l.name} class="w-auto h-12 max-w-12 object-contain drop-shadow-[0_0_16px_#FFFFFF73]" loading="lazy" />
                  <p class="text-xs text-white uppercase m-0 drop-shadow-[0_4px_4px_#00000040]">{l.name}</p>
                </div>
              ))}
            </div>
        </div>
      </div>

      <div class="basis-[606px] w-1/2 flex justify-end max-lg:w-full max-lg:max-w-full max-lg:basis-auto max-lg:justify-start">
        <div class="group/video w-full max-w-156 aspect-606/328 bg-[#171E28] rounded-xl relative overflow-hidden cursor-pointer shadow-[0_24px_80px_rgba(23,30,40,0.25)]" data-video-card>
          <div class="absolute inset-0 z-10" data-video-placeholder>
            <img class="absolute inset-0 w-full h-full object-cover" src={effectivePoster} alt="" />
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-13 h-13 bg-[rgba(53,_39,_98,_0.5)] backdrop-blur-[2px] rounded-full flex items-center justify-center transition-transform duration-300 group-hover/video:scale-110 [&>svg]:fill-white [&>svg]:w-6 [&>svg]:h-6">
                <div class="absolute z-10 inset-1.25 rounded-full backdrop-blur-[2px] bg-[rgba(53,_39,_98,_0.8)] "></div>
                <svg class="absolute z-20" width="24" height="24" viewBox="0 0 24 24"><polygon points="8,5 20,12 8,19"></polygon></svg>
            </div>
          </div>
          <div class="absolute inset-0 hidden z-[5] [&_iframe]:absolute [&_iframe]:inset-0 [&_iframe]:w-full [&_iframe]:h-full [&_iframe]:border-0"
            data-video-wrap
          ></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const section = document.currentScript.previousElementSibling;
    if (!section) return;
    const card = section.querySelector('[data-video-card]');
    const placeholder = section.querySelector('[data-video-placeholder]');
    const wrap = section.querySelector('[data-video-wrap]');
    const videoId = section.getAttribute('data-video-id');
    if (!card || !placeholder || !wrap) return;

    card.addEventListener('click', function () {
      if (card.classList.contains('playing')) return;
      card.classList.add('playing');
      placeholder.style.display = 'none';
      wrap.style.display = 'block';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1&iv_load_policy=3&disablekb`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      wrap.appendChild(iframe);
    });
  })();

  // Gradient Text Animation Logic
  (function () {
    const elements = document.querySelectorAll('.animated-gradient-text');
    
    elements.forEach(el => {
      const textContent = el.querySelector('.text-content');
      if (!textContent) return;

      const colors = el.dataset.gradientColors || '#5227FF, #FF9FFC, #B497CF';
      const speed = parseFloat(el.dataset.animationSpeed) || 8;
      const animationDuration = speed * 1000;
      
      // Setup Initial Styles
      const gradientColors = colors.split(',').map(c => c.trim());
      // Design a cleaner shimmer: Purple -> Purple -> White -> Purple -> Purple
      const shimmerColors = `${gradientColors[0]}, ${gradientColors[0]}, ${gradientColors[2] || '#FFFFFF'}, ${gradientColors[0]}, ${gradientColors[0]}`;
      
      textContent.style.backgroundImage = `linear-gradient(110deg, ${shimmerColors})`;
      textContent.style.backgroundSize = '200% 100%';
      textContent.style.backgroundRepeat = 'repeat';

      let elapsed = 0;
      let lastTime = null;

      function update(time) {
        if (!lastTime) {
          lastTime = time;
          requestAnimationFrame(update);
          return;
        }

        const deltaTime = time - lastTime;
        lastTime = time;
        elapsed += deltaTime;

        // Use continuous increment instead of modulo to prevent the 100->0 jump flicker
        const p = (elapsed / animationDuration) * 100;
        textContent.style.backgroundPosition = `${p}% 50%`;

        requestAnimationFrame(update);
      }

      requestAnimationFrame(update);
    });
  })();
</script>

<style is:global>
  .v2-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff !important;
    background: linear-gradient(90deg, #110072 0%, #7A5698 100%);
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 0.3s ease;
}

.animated-gradient-text {
  position: relative;
  display: inline-flex;
  max-width: fit-content;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.text-content {
  display: inline-block;
  position: relative;
  z-index: 2;
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  will-change: background-position;
}
</style>
