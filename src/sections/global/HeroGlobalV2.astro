---
/**
 * Global hero — v2 Tailwind-utility port of HeroGlobal.astro.
 * No <style is:global>; all styles as utility classes.
 */
export interface Props {
  videoId?: string;
  posterUrl?: string;
}

const { videoId = "UX0Yt61EdfY", posterUrl } = Astro.props as Props;
const effectivePoster =
  posterUrl ??
  `https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/6a0dadac887be941c2b915a9_hero-right-play-button.png`;

const trustLogos = [
  {
    src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de348a6065af3c36a69aff_zatca.svg",
    name: "zatca",
  },
  {
    src: "https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb3755564ddcfcf0695624_cic.png",
    name: "nic",
  },
  {
    src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69e0c09f3a4c77f59ef94ec9_fta%20(1).png",
    name: "fta",
  },
  {
    src: "https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69e0e0478f3585b605c04e67_peppol.png",
    name: "peppol",
  },
];
---

<section
  class="bg-[linear-gradient(180deg,_#120420_12.72%,_#2D0A4E_41.69%,_#000000_100%)] pt-37.5 pb-25 w-full relative overflow-hidden max-lg:pt-25 max-lg:pb-16"
  data-hero-global
  data-video-id={videoId}
>
  <svg width="0" height="0" style="position:absolute">
    <filter id="glass">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.008"
        numOctaves="2"
        seed="4"></feTurbulence>
      <feDisplacementMap in="SourceGraphic" scale="30"></feDisplacementMap>
    </filter>
  </svg>

  <img
    class="globe-gradient-overlay transition-transform mix-blend-luminosity absolute w-full h-auto min-h-142 left-0 -bottom-0.5 pointer-events-none z-1"
    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0eece53acdaaeb68c39ff4_BG.png"
    alt=""
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="max-w-[var(--container-max)] relative z-10 mx-auto px-6">
    <div
      class="flex flex-row flex-nowrap items-start justify-between gap-18 max-lg:flex-col max-lg:flex-wrap max-lg:gap-12"
    >
      <div
        class="basis-[593px] w-[35%] text-left max-lg:w-full max-lg:max-w-full max-lg:basis-auto"
      >
        <h1
          class="lg:text-[56px]! leading-[1.12]! font-medium! text-white! m-0! mb-6! max-w-[593px] tracking-[-1.5px]! max-lg:text-[36px]!"
        >
          <span
            class="animated-gradient-text inline-flex"
            data-gradient-colors="#CC9DFF, #CC9DFF, #FFFFFF, #CC9DFF, #CC9DFF"
            data-animation-speed="4"
          >
            <span class="text-content">100% e-Invoicing Compliance Today.</span>
          </span>
          <br />Tax Assurance for Tomorrow.
        </h1>
        <p
          class="max-lg:text-base lg:text-lg leading-[1.6]! text-white/80 font-medium mb-10! max-w-148 max-lg:max-w-full"
        >
          ClearTax helps you do more than meet the e-invoicing deadline. We
          prepare you for a future of automated tax scrutiny and always-on
          compliance.
        </p>

        <!-- Mobile Video Card (Visible only on mobile) -->
        <div
          class="lg:hidden group/video w-full max-w-158 cursor-pointer mb-10 flex flex-col items-center gap-4"
          data-video-card
        >
          <div class="w-full aspect-video rounded-xl relative overflow-hidden">
            <div class="relative z-10 w-full h-full" data-video-placeholder>
              <img
                class="block w-full h-full object-contain"
                src={effectivePoster}
                alt=""
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </div>
            <div
              class="absolute inset-0 hidden z-[5] [&_iframe]:absolute [&_iframe]:inset-0 [&_iframe]:w-full [&_iframe]:h-full [&_iframe]:border-0"
              data-video-wrap
            >
            </div>
            <button
              class="absolute top-3 right-3 z-[30] hidden items-center justify-center w-8 h-8 rounded-full bg-black/60 backdrop-blur-md text-white hover:bg-black/80 transition-colors"
              data-close-video
              aria-label="Close video"
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 14 14"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M13 1L1 13M1 1L13 13"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
          <div
            class="h-[40px] rounded-full p-[1px] bg-gradient-to-br from-white/60 to-white/10 transition-transform duration-300 group-hover/video:scale-105 drop-shadow-md cursor-pointer"
            data-play-button
          >
            <button
              class="flex h-full border-none items-center justify-center gap-2.5 px-5 rounded-full bg-[#120420]/80 backdrop-blur-md"
            >
              <span
                class="text-white font-['Nohemi'] font-medium text-base leading-none"
                >Play Video</span
              >
              <svg
                width="12"
                height="14"
                viewBox="0 0 14 17"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="shrink-0"
              >
                <path
                  d="M0 1.48279V14.5461C0 15.7211 1.30323 16.4278 2.28801 15.7868L12.4595 9.16564C13.3632 8.57738 13.3549 7.25127 12.4439 6.67431L2.27249 0.232146C1.28682 -0.392133 0 0.31606 0 1.48279Z"
                  fill="white"></path>
              </svg>
            </button>
          </div>
        </div>
        <a
          href="#contact"
          class="inline-flex! items-center! justify-center w-full md:w-auto lg:w-auto gap-2! px-10! lg:py-4! py-3.5! lg:text-base! text-sm! font-bold! text-white! bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)]! rounded-full! no-underline! transition-transform! duration-300! hover:-translate-y-px! [&:hover_span]:translate-x-[3px]! border border-white/50"
        >
          Request Demo <span
            class="inline-block! transition-transform! duration-300!">→</span
          >
        </a>
        <div>
          <div
            class="inline-flex items-center justify-between w-full md:w-auto lg:w-auto gap-8 lg:gap-14 mt-10 py-2 px-8 bg-white/10 backdrop-blur-[15px] backdrop-saturate-180 rounded-full border border-white/20 shadow-[inset_1px_1px_0_rgba(255,255,255,0.8),inset_-1px_-1px_0_rgba(255,255,255,0.1),0_8px_32px_rgba(0,0,0,0.2)]"
          >
            <!-- <div class="inline-flex items-center gap-8 lg:gap-14 mt-10 py-2 px-8 bg-white/10 rounded-full border border-white/20 glass-real"> -->
            {
              trustLogos.map((l) => (
                <div class="flex flex-col items-center gap-1.5">
                  <img
                    src={l.src}
                    alt={l.name}
                    class="w-auto lg:h-12 h-8 max-w-12 max-lg:max-w-8 object-contain drop-shadow-[0_0_16px_#FFFFFF73]"
                    loading="lazy"
                  />
                  <p class="lg:text-xs text-[11px] text-white uppercase m-0 drop-shadow-[0_4px_4px_#00000040]">
                    {l.name}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div
        class="basis-[800px] w-[65%] flex justify-end max-lg:w-full max-lg:max-w-full max-lg:basis-auto max-lg:justify-start max-lg:hidden"
      >
        <div
          class="group/video w-full max-w-[800px] cursor-pointer flex flex-col items-center gap-6"
          data-video-card
        >
          <div class="w-full aspect-video relative">
            <!-- Image Layer Separated -->
            <div
              class="absolute inset-0 z-10 flex items-center justify-center pointer-events-none transition-opacity duration-500"
              data-video-placeholder
            >
              <img
                class="block w-full h-[120%] max-w-none object-contain transition-transform duration-300 group-hover/video:-translate-y-[4px]"
                src={effectivePoster}
                alt=""
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
            </div>

            <!-- Video Layer: Strictly bounded and rounded to the 16:9 placeholder shape -->
            <div
              class="absolute inset-0 hidden z-[5] rounded-xl overflow-hidden [&_iframe]:absolute [&_iframe]:inset-0 [&_iframe]:w-full [&_iframe]:h-full [&_iframe]:border-0 translate-y-12"
              data-video-wrap
            >
            </div>
            <button
              class="absolute top-16 right-4 z-[30] hidden items-center justify-center w-11 h-11 rounded-full bg-[#1A1A1A]/80 backdrop-blur-md text-white hover:bg-black border-none transition-colors"
              data-close-video
              aria-label="Close video"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M13 1L1 13M1 1L13 13"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
          <div
            class="h-10 rounded-full p-[1px] z-10 transition-transform duration-300 group-hover/video:-translate-y-[4px] drop-shadow-md cursor-pointer"
            data-play-button
          >
            <button
              class="flex h-full border border-white/20 cursor-pointer items-center justify-center gap-3 px-6 rounded-full bg-white/20 backdrop-blur-md"
            >
              <span
                class="text-white font-[gilroy] font-medium text-[22px] leading-[1.31]"
                >Play Video</span
              >
              <svg
                width="14"
                height="17"
                viewBox="0 0 14 17"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="shrink-0"
              >
                <path
                  d="M0 1.48279V14.5461C0 15.7211 1.30323 16.4278 2.28801 15.7868L12.4595 9.16564C13.3632 8.57738 13.3549 7.25127 12.4439 6.67431L2.27249 0.232146C1.28682 -0.392133 0 0.31606 0 1.48279Z"
                  fill="white"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const section = document.currentScript.previousElementSibling;
    if (!section) return;
    const cards = section.querySelectorAll("[data-video-card]");
    const videoId = section.getAttribute("data-video-id") || "UX0Yt61EdfY";
    if (!cards.length) return;

    cards.forEach((card) => {
      card.addEventListener("click", function () {
        const videoWrap = card.querySelector("[data-video-wrap]");
        if (videoWrap) {
          if (videoWrap.innerHTML.trim() === "") {
            const iframe = document.createElement("iframe");
            const origin = window.location.origin;
            iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&enablejsapi=1&origin=${encodeURIComponent(origin)}`;
            iframe.className = "absolute inset-0 w-full h-full border-0";
            iframe.allow =
              "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
            iframe.allowFullscreen = true;
            iframe.referrerPolicy = "strict-origin-when-cross-origin";
            videoWrap.appendChild(iframe);
          }
          videoWrap.classList.remove("hidden", "z-[5]");
          videoWrap.classList.add("z-[20]");

          const playButton = card.querySelector("[data-play-button]");
          if (playButton) {
            playButton.classList.add("hidden");
          }

          const placeholder = card.querySelector("[data-video-placeholder]");
          if (placeholder) {
            placeholder.classList.add("opacity-0");
          }

          const closeButton = card.querySelector("[data-close-video]");
          if (closeButton) {
            closeButton.classList.remove("hidden");
            closeButton.classList.add("flex");
          }
        }
      });
    });

    const closeButtons = section.querySelectorAll("[data-close-video]");
    closeButtons.forEach((btn) => {
      btn.addEventListener("click", function (e) {
        e.stopPropagation();
        const card = btn.closest("[data-video-card]");
        if (!card) return;
        const videoWrap = card.querySelector("[data-video-wrap]");
        const playButton = card.querySelector("[data-play-button]");

        if (videoWrap) {
          videoWrap.classList.add("hidden", "z-[5]");
          videoWrap.classList.remove("z-[20]");
          videoWrap.innerHTML = "";
        }
        if (playButton) {
          playButton.classList.remove("hidden");
        }

        const placeholder = card.querySelector("[data-video-placeholder]");
        if (placeholder) {
          placeholder.classList.remove("opacity-0");
        }
        btn.classList.add("hidden");
        btn.classList.remove("flex");
      });
    });
  })();

  // Gradient Text Animation Logic
  (function () {
    const elements = document.querySelectorAll(".animated-gradient-text");

    elements.forEach((el) => {
      const textContent = el.querySelector(".text-content");
      if (!textContent) return;

      const colors = el.dataset.gradientColors || "#5227FF, #FF9FFC, #B497CF";
      const speed = parseFloat(el.dataset.animationSpeed) || 8;
      const animationDuration = speed * 1000;

      // Setup Initial Styles
      const gradientColors = colors.split(",").map((c) => c.trim());
      // Design a cleaner shimmer: Purple -> Purple -> White -> Purple -> Purple
      const shimmerColors = `${gradientColors[0]}, ${gradientColors[0]}, ${gradientColors[2] || "#FFFFFF"}, ${gradientColors[0]}, ${gradientColors[0]}`;

      textContent.style.backgroundImage = `linear-gradient(110deg, ${shimmerColors})`;
      textContent.style.backgroundSize = "200% 100%";
      textContent.style.backgroundRepeat = "repeat";

      let elapsed = 0;
      let lastTime = null;

      function update(time) {
        if (!lastTime) {
          lastTime = time;
          requestAnimationFrame(update);
          return;
        }

        const deltaTime = time - lastTime;
        lastTime = time;
        elapsed += deltaTime;

        // Use continuous increment instead of modulo to prevent the 100->0 jump flicker
        const p = (elapsed / animationDuration) * 100;
        textContent.style.backgroundPosition = `${p}% 50%`;

        requestAnimationFrame(update);
      }

      requestAnimationFrame(update);
    });
  })();
</script>

<style is:global>
  .v2-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff !important;
    background: linear-gradient(90deg, #110072 0%, #7a5698 100%);
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .animated-gradient-text {
    position: relative;
    display: inline-flex;
    max-width: fit-content;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .text-content {
    display: inline-block;
    position: relative;
    z-index: 2;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    will-change: background-position;
  }
</style>
