---
/**
 * Global hero — v2 Tailwind-utility port of HeroGlobal.astro with an embedded HubSpot Form.
 * No <style is:global>; all styles as utility classes.
 */
export interface Props {
  hubspotPortalId?: string;
  hubspotFormId?: string;
  hubspotRegion?: string;
}

const {
  hubspotPortalId = "245744706",
  hubspotFormId = "51af6b81-aa59-4bd2-b499-ff081e27324d",
  hubspotRegion = "na2",
} = Astro.props as Props;

const trustLogos = [
  {
    src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de348a6065af3c36a69aff_zatca.svg",
    name: "zatca",
  },
  {
    src: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a28fe4d5cc707b20d0a4b03_nic-logo.png",
    name: "nic",
  },
  {
    src: "https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69e0c09f3a4c77f59ef94ec9_fta%20(1).png",
    name: "fta",
  },
  {
    src: "https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69e0e0478f3585b605c04e67_peppol.png",
    name: "peppol",
  },
];
---

<section
  class="bg-[linear-gradient(180deg,_#120420_12.72%,_#2D0A4E_41.69%,_#000000_100%)] pt-37.5 pb-25 w-full relative overflow-hidden max-lg:pt-25 max-lg:pb-16"
  data-hero-global
>
  <svg width="0" height="0" style="position:absolute">
    <filter id="glass">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.008"
        numOctaves="2"
        seed="4"></feTurbulence>
      <feDisplacementMap in="SourceGraphic" scale="30"></feDisplacementMap>
    </filter>
  </svg>

  <img
    class="globe-gradient-overlay transition-transform mix-blend-luminosity absolute w-full h-auto min-h-142 left-0 -bottom-0.5 pointer-events-none z-1"
    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0eece53acdaaeb68c39ff4_BG.png"
    alt=""
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="max-w-[var(--container-max)] relative z-10 mx-auto px-6">
    <div
      class="flex flex-row flex-nowrap items-center justify-between gap-6 max-lg:flex-col max-lg:flex-wrap max-lg:gap-12"
    >
      <div
        class="basis-[583px] w-[50%] text-left max-lg:w-full max-lg:max-w-full max-lg:basis-auto"
      >
        <h1
          class="lg:text-[56px]! leading-[1.12]! font-medium! text-white! m-0! mb-6! max-w-[593px] tracking-[-1.5px]! max-lg:text-[36px]!"
        >
          <span
            class="animated-gradient-text inline-flex"
            data-gradient-colors="#CC9DFF, #CC9DFF, #FFFFFF, #CC9DFF, #CC9DFF"
            data-animation-speed="4"
          >
            <span class="text-content">E-Invoicing Compliance <i>Today</i>.</span>
          </span>
          <br />Tax Assurance <i>Tomorrow</i>.
        </h1>
        <p
          class="max-lg:text-base lg:text-lg leading-[1.6]! text-white/80 font-medium mb-10! max-w-148 max-lg:max-w-full"
        >
          ClearTax helps you do more than meet the e-invoicing deadline. We
          prepare you for a future of automated tax scrutiny and always-on
          compliance.
        </p>

        <div>
          <div
            class="inline-flex items-center justify-between w-full md:w-auto lg:w-auto gap-8 lg:gap-14 mt-10 py-2 px-8 bg-white/10 backdrop-blur-[15px] backdrop-saturate-180 rounded-full border border-white/20 shadow-[inset_1px_1px_0_rgba(255,255,255,0.8),inset_-1px_-1px_0_rgba(255,255,255,0.1),0_8px_32px_rgba(0,0,0,0.2)]"
          >
            {
              trustLogos.map((l) => (
                <div class="flex flex-col items-center gap-1.5">
                  <img
                    src={l.src}
                    alt={l.name}
                    class="w-auto lg:h-12 h-8 max-w-12 max-lg:max-w-8 object-contain drop-shadow-[0_0_16px_#FFFFFF73]"
                    loading="lazy"
                  />
                  <p class="lg:text-xs text-[11px] text-white uppercase m-0 drop-shadow-[0_4px_4px_#00000040]">
                    {l.name}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Right Column: HubSpot Form Card -->
      <div
        class="w-full max-w-[600px] shrink-0 max-lg:max-w-full z-20"
      >
        <div
          class="rounded-xl border border-[rgba(255,255,255,0.1)] bg-white lg:px-9 lg:py-8 px-6 py-6 shadow-[0_40px_80px_rgba(0,0,0,0.3)] overflow-clip! premium-reveal [transition-delay:500ms]"
        >
          <h3
            class="mb-2 text-[22px] font-semibold leading-[1.36] text-black"
          >
            Book a Demo
          </h3>
          <p class="mb-7 text-base leading-[1.5] text-black/80">
            Our enterprise specialists will walk you through the platform and help map your scale, security, and compliance requirements.
          </p>

          <!-- HubSpot Form Mount Container -->
          <div id="contact" class="global-hs-form-wrap" data-portal-id={hubspotPortalId} data-form-id={hubspotFormId} data-region={hubspotRegion}>
            <!-- Form Skeleton Loader -->
            <div id="form-skeleton" class="form-skeleton">
              <div class="skeleton-row-2">
                <div>
                  <div class="skeleton-label shimmer"></div>
                  <div class="skeleton-input shimmer"></div>
                </div>
                <div>
                  <div class="skeleton-label shimmer"></div>
                  <div class="skeleton-input shimmer"></div>
                </div>
              </div>
              <div>
                <div class="skeleton-label shimmer" style="width: 100px;"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div class="skeleton-row-2">
                <div>
                  <div class="skeleton-label shimmer"></div>
                  <div class="skeleton-input shimmer"></div>
                </div>
                <div>
                  <div class="skeleton-label shimmer"></div>
                  <div class="skeleton-input shimmer"></div>
                </div>
              </div>
              <div class="skeleton-button shimmer"></div>
            </div>
          </div>

          <p class="mt-4 text-center text-sm text-black/80">
            No spam. Just a 30-min call with our specialists.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // HubSpot form embed with URL parameters auto-prefill
  (() => {
    let initialized = false;
    
    const initForm = () => {
      if (initialized) return;
      const container = document.getElementById("contact");
      if (!container) return;
      const portalId = container.getAttribute("data-portal-id");
      const formId = container.getAttribute("data-form-id");
      const region = container.getAttribute("data-region") || "na2";

      if (window.hbspt && window.hbspt.forms) {
        initialized = true;
        window.hbspt.forms.create({
          portalId: portalId,
          formId: formId,
          region: region,
          target: "#contact",
          onFormReady: function($form) {
            // Remove the skeleton loader
            const skeleton = document.getElementById("form-skeleton");
            if (skeleton) {
              skeleton.remove();
            }

            const formEl = ($form && $form[0]) ? $form[0] : $form;
            if (formEl && formEl.querySelector) {
              const urlParams = new URLSearchParams(window.location.search);
              const utms = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
              utms.forEach(utm => {
                const value = urlParams.get(utm);
                if (value) {
                  const input = formEl.querySelector('input[name="' + utm + '"]');
                  if (input) {
                    input.value = value;
                  }
                }
              });
            }
          }
        });
      }
    };

    const checkAndInit = () => {
      if (window.hbspt && window.hbspt.forms) {
        initForm();
      } else {
        const script = document.querySelector('script[src*="hsforms.net"]');
        if (script) {
          script.addEventListener('load', initForm);
        }
        let pollCount = 0;
        const interval = setInterval(() => {
          pollCount++;
          if (window.hbspt && window.hbspt.forms) {
            clearInterval(interval);
            initForm();
          } else if (pollCount > 100) {
            clearInterval(interval);
          }
        }, 100);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", checkAndInit);
    } else {
      checkAndInit();
    }
  })();

  // Gradient Text Animation Logic
  (function () {
    const elements = document.querySelectorAll(".animated-gradient-text");

    elements.forEach((el) => {
      const textContent = el.querySelector(".text-content");
      if (!textContent) return;

      const colors = el.dataset.gradientColors || "#5227FF, #FF9FFC, #B497CF";
      const speed = parseFloat(el.dataset.animationSpeed) || 8;
      const animationDuration = speed * 1000;

      // Setup Initial Styles
      const gradientColors = colors.split(",").map((c) => c.trim());
      const shimmerColors = `${gradientColors[0]}, ${gradientColors[0]}, ${gradientColors[2] || "#FFFFFF"}, ${gradientColors[0]}, ${gradientColors[0]}`;

      textContent.style.backgroundImage = `linear-gradient(110deg, ${shimmerColors})`;
      textContent.style.backgroundSize = "200% 100%";
      textContent.style.backgroundRepeat = "repeat";

      let elapsed = 0;
      let lastTime = null;

      function update(time) {
        if (!lastTime) {
          lastTime = time;
          requestAnimationFrame(update);
          return;
        }

        const deltaTime = time - lastTime;
        lastTime = time;
        elapsed += deltaTime;

        const p = (elapsed / animationDuration) * 100;
        textContent.style.backgroundPosition = `${p}% 50%`;

        requestAnimationFrame(update);
      }

      requestAnimationFrame(update);
    });
  })();
</script>

<style is:global>
  .animated-gradient-text {
    position: relative;
    display: inline-flex;
    max-width: fit-content;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .text-content {
    display: inline-block;
    position: relative;
    z-index: 2;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    will-change: background-position;
  }

  /* Pixel-perfect styles for light glassmorphism HubSpot Form to match layout */
  .global-hs-form-wrap {
    width: 100%;
    min-height: 300px;
  }
  .global-hs-form-wrap .inputs-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .global-hs-form-wrap form {
    display: flex !important;
    flex-direction: column !important;
    gap: 16px !important;
  }
  .global-hs-form-wrap .hs-form-field {
    margin-bottom: 0 !important;
  }
  .global-hs-form-wrap .hs-form-field > label {
    display: block !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    color: rgba(0, 0, 0, 0.8) !important;
    margin-bottom: 5px !important;
  }
  .global-hs-form-wrap .hs-form-field > label .hs-form-required {
    color: #ef4444 !important;
    margin-left: 2px !important;
  }
  .global-hs-form-wrap input[type="text"],
  .global-hs-form-wrap input[type="email"],
  .global-hs-form-wrap input[type="tel"],
  .global-hs-form-wrap input[type="number"],
  .global-hs-form-wrap select,
  .global-hs-form-wrap textarea {
    width: 100% !important;
    border-radius: 8px !important;
    border: 1px solid #e2e8f0 !important;
    background-color: #ffffff !important;
    padding: 11px 14px !important;
    font-size: 14.5px !important;
    color: #1e1b4b !important;
    outline: none !important;
    transition: all 0.25s ease !important;
    box-sizing: border-box !important;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.02) !important;
  }
  .global-hs-form-wrap input:focus,
  .global-hs-form-wrap select:focus,
  .global-hs-form-wrap textarea:focus {
    border-color: #110072 !important;
    box-shadow: 0 0 0 3px rgba(17, 0, 114, 0.12) !important;
  }
  .global-hs-form-wrap textarea {
    min-height: 80px !important;
    resize: vertical !important;
  }
  .global-hs-form-wrap .hs_phone .hs-fieldtype-intl-phone {
    display: flex !important;
    gap: 12px !important;
    width: 102% !important;
  }
  .global-hs-form-wrap select {
    appearance: auto !important;
  }
  .global-hs-form-wrap fieldset {
    max-width: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: row !important;
    gap: 12px !important;
  }
  @media (max-width: 640px) {
    .global-hs-form-wrap fieldset {
      flex-direction: column !important;
      gap: 16px !important;
    }
  }
  .global-hs-form-wrap fieldset .hs-form-field {
    flex: 1 !important;
  }
  .global-hs-form-wrap .input {
    margin-right: 0 !important;
  }
  .global-hs-form-wrap .hs-form-booleancheckbox label,
  .global-hs-form-wrap .legal-consent-container label {
    display: flex !important;
    align-items: flex-start !important;
    font-size: 14px !important;
    color: rgba(0, 0, 0, 0.8) !important;
    line-height: 1.5 !important;
    font-weight: 400 !important;
    cursor: pointer !important;
  }
  .global-hs-form-wrap .hs-form-booleancheckbox label a,
  .global-hs-form-wrap .legal-consent-container label a {
    color: #110072 !important;
    font-weight: 600 !important;
    text-decoration: underline !important;
  }
  .global-hs-form-wrap input[type="checkbox"] {
    margin-top: 3px !important;
    flex-shrink: 0 !important;
    accent-color: #110072 !important;
    width: 15px !important;
    height: 15px !important;
    cursor: pointer !important;
  }
  .global-hs-form-wrap .hs-submit {
    margin-top: 8px !important;
  }
  .global-hs-form-wrap input[type="submit"],
  .global-hs-form-wrap .hs-button {
    width: 100% !important;
    background: linear-gradient(135deg, #110072 0%, #7a5698 100%) !important;
    color: white !important;
    padding: 13px !important;
    border-radius: 30px !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    border: none !important;
    cursor: pointer !important;
    font-family: inherit !important;
    transition: all 0.25s ease !important;
    box-shadow: 0 4px 14px rgba(17, 0, 114, 0.25) !important;
  }
  .global-hs-form-wrap input[type="submit"]:hover,
  .global-hs-form-wrap .hs-button:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 18px rgba(17, 0, 114, 0.35) !important;
    opacity: 0.95 !important;
  }
  .global-hs-form-wrap .hs-error-msgs {
    list-style: none !important;
    padding: 0 !important;
    margin: 4px 0 0 !important;
    font-size: 11.5px !important;
    color: #ef4444 !important;
  }
  .global-hs-form-wrap .hs-error-msg {
    color: #ef4444 !important;
  }
  .global-hs-form-wrap .submitted-message {
    background: #eef2f6 !important;
    color: #1e1b4b !important;
    padding: 18px !important;
    border-radius: 8px !important;
    font-size: 14.5px !important;
    font-weight: 600 !important;
    text-align: center !important;
    border: 1px solid rgba(17, 0, 114, 0.15) !important;
  }
  .global-hs-form-wrap fieldset:has([class*="hs_utm_"]),
  .global-hs-form-wrap .hs-form-field[style*="display: none"] {
    display: none !important;
  }

  /* ==================== FORM SKELETON SHIMMER STYLES ==================== */
  .form-skeleton {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    min-height: 300px;
  }
  .skeleton-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 640px) {
    .skeleton-row-2 {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
  .skeleton-label {
    height: 14px;
    width: 80px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .skeleton-input {
    height: 44px;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    width: 100%;
  }
  .skeleton-button {
    height: 46px;
    background: linear-gradient(135deg, rgba(17, 0, 114, 0.25) 0%, rgba(122, 86, 152, 0.25) 100%);
    border-radius: 30px;
    width: 100%;
    margin-top: 8px;
  }

  /* Shimmer Animation */
  .shimmer {
    position: relative;
    overflow: hidden;
  }
  .shimmer::after {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    transform: translateX(-100%);
    background-image: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.6) 20%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 255, 255, 0) 100%
    );
    animation: shimmer-anim 1.6s infinite;
    content: "";
  }
  @keyframes shimmer-anim {
    100% {
      transform: translateX(100%);
    }
  }
</style>
