---
/**
 * Global navbar — v2 Tailwind-utility port of NavbarGlobal.astro.
 * Fixes v1 CSS typo (`transform: transition …`) → proper transition-transform.
 */
export interface NavLink {
  label: string;
  href?: string;
  dropdown?: { label: string; href: string }[];
}
export interface CountryOption {
  name: string;
  flag: string;
  href: string;
  lang?: string;
}

const links: NavLink[] = [
  {
    label: 'E-Invoicing Platform',
    dropdown: [
      { label: 'Global e-invoicing', href: 'https://www.cleartax.com/electronic-invoicing' },
      { label: 'AI Reconciliation', href: 'https://cleartax.in/gst' },
      { label: 'Integration', href: 'https://cleartax.in/supply-chain-automation-solution' },
      { label: 'Scale & Security', href: 'https://cleartax.in/supply-chain-automation-solution' },
    ],
  },
  {
    label: 'Resources',
    dropdown: [
      { label: 'Blogs', href: 'https://www.cleartax.com/electronic-invoicing#country-select' },
      { label: 'Case Studies', href: 'https://www.cleartax.com/case-studies' },
      { label: 'Press Releases', href: 'https://www.clear.in/s/press?forceCacheReload=1' },
    ],
  },
  { label: 'Contact Us', href: 'https://www.cleartax.com/contact-us' },
  { label: 'Partners', href: 'https://www.cleartax.com/partners' },
];

const countries: CountryOption[] = [
  { name: 'INDIA', flag: '🇮🇳', href: 'https://www.clear.in/' },
  { name: 'MALAYSIA', flag: '🇲🇾', href: 'https://www.cleartax.com/my/en' },
  { name: 'USA', flag: '🇺🇸', href: 'https://www.clear.tech/' },
  { name: 'POLAND', flag: '🇵🇱', href: 'https://www.cleartax.com/pl/en', lang: 'English | Polish' },
  { name: 'SAUDI ARABIA', flag: '🇸🇦', href: 'https://www.cleartax.com/sa', lang: 'English | العربية' },
  { name: 'OMAN', flag: '🇴🇲', href: 'https://www.cleartax.com/om' },
  { name: 'FRANCE', flag: '🇫🇷', href: 'https://www.cleartax.com/fr/en', lang: 'English | French' },
  { name: 'BAHRAIN', flag: '🇧🇭', href: 'https://www.cleartax.com/bh' },
  { name: 'SPAIN', flag: '🇪🇸', href: 'https://www.cleartax.com/es/en' },
  { name: 'UAE', flag: '🇦🇪', href: 'https://www.cleartax.com/ae' },
  { name: 'SINGAPORE', flag: '🇸🇬', href: 'https://www.cleartax.com/sg/e-invoicing-software' },
  { name: 'GERMANY', flag: '🇩🇪', href: 'https://www.cleartax.com/de/en' },
  { name: 'BELGIUM', flag: '🇧🇪', href: 'https://www.cleartax.com/be/en' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-[1000] bg-white border-b border-[var(--color-gray-200)] transition-shadow [transition-duration:var(--transition-base)] [&.scrolled]:shadow-[0_2px_20px_rgba(0,0,0,0.08)]"
  data-nav-root
>
  <div class="max-w-[1328px] mx-auto px-6 h-[var(--navbar-height)] flex items-center justify-between gap-8">
    <a href="/" class="shrink-0 flex items-center text-[var(--color-dark)]">
      <img
        src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
        alt="ClearTax"
        class="h-7 w-auto"
      />
    </a>

    <nav
      class="flex-1 flex justify-center max-lg:fixed max-lg:top-[var(--navbar-height)] max-lg:left-0 max-lg:right-0 max-lg:bottom-0 max-lg:bg-white max-lg:flex-col max-lg:justify-start max-lg:p-[40px_24px] max-lg:translate-x-full max-lg:transition-transform max-lg:duration-[400ms] max-lg:ease-[cubic-bezier(0.16,1,0.3,1)] max-lg:overflow-y-auto max-lg:z-[1050] max-lg:block [&.open]:max-lg:translate-x-0"
      data-nav-menu
    >
      <ul class="flex items-center list-none gap-1 m-0 p-0 max-lg:flex-col max-lg:items-stretch max-lg:w-full max-lg:gap-2">
        {links.map((l) => (
          <li class:list={['relative group/item', l.dropdown && 'has-dropdown']}>
            {l.dropdown ? (
              <>
                <button
                  class="flex items-center gap-[5px] px-4 py-2 text-sm font-medium text-[var(--color-gray-600)] rounded-lg [transition-duration:var(--transition-fast)] transition-colors whitespace-nowrap no-underline bg-transparent border-0 cursor-pointer font-[inherit] hover:text-[var(--color-dark)] hover:bg-[var(--color-gray-50)] group-[.active]/item:text-[var(--color-blue)] group-[.active]/item:bg-[rgba(21,114,237,0.06)]"
                  type="button"
                  data-nav-trigger
                >
                  {l.label}
                  <svg
                    class="shrink-0 transition-transform [transition-duration:var(--transition-fast)] group-[.active]/item:rotate-180"
                    width="10"
                    height="10"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </button>
                <div class="absolute top-full left-1/2 -translate-x-1/2 translate-y-[10px] bg-white rounded-xl shadow-[0_12px_40px_rgba(0,0,0,0.12)] py-2 min-w-[180px] opacity-0 invisible transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] z-[1001] mt-[10px] group-hover/item:opacity-100 group-hover/item:visible group-hover/item:translate-y-0 group-[.active]/item:opacity-100 group-[.active]/item:visible group-[.active]/item:translate-y-0 max-lg:static max-lg:transform-none max-lg:min-w-0 max-lg:shadow-none max-lg:bg-[var(--color-gray-50)] max-lg:mt-2 max-lg:hidden max-lg:opacity-100 max-lg:visible max-lg:group-[.active]/item:block">
                  {l.dropdown.map((d) => (
                    <a
                      href={d.href}
                      class="block px-5 py-2.5 text-sm font-medium text-[#171E28] transition-all duration-200 ease-linear no-underline hover:bg-[#F4F6F9] hover:text-[#5E46E5]"
                    >
                      {d.label}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={l.href}
                class="flex items-center gap-[5px] px-4 py-2 text-sm font-medium text-[var(--color-gray-600)] rounded-lg [transition-duration:var(--transition-fast)] transition-colors whitespace-nowrap no-underline hover:text-[var(--color-dark)] hover:bg-[var(--color-gray-50)]"
              >
                {l.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <div class="relative group/country" data-country-selector>
        <button
          class="flex items-center gap-2 px-3 py-2 rounded-lg transition-colors [transition-duration:var(--transition-fast)] bg-transparent border-0 cursor-pointer font-[inherit] text-[var(--color-dark)] font-semibold text-sm hover:bg-[var(--color-gray-50)]"
          type="button"
          data-country-btn
        >
          <span class="global-icon text-[#5E46E5] flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </span>
          <span data-country-current>Global</span>
          <svg
            class="shrink-0 transition-transform [transition-duration:var(--transition-fast)] lg:group-hover/country:rotate-180 group-[.active]/country:rotate-180"
            width="10"
            height="6"
            viewBox="0 0 10 6"
            fill="none"
          >
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="absolute top-full right-0 w-[380px] bg-transparent pt-[10px] opacity-0 invisible pointer-events-none transition-all [transition-duration:var(--transition-base)] z-[1001] lg:group-hover/country:opacity-100 lg:group-hover/country:visible lg:group-hover/country:pointer-events-auto group-[.active]/country:opacity-100 group-[.active]/country:visible group-[.active]/country:pointer-events-auto max-lg:static max-lg:w-full max-lg:transform-none max-lg:shadow-none max-lg:p-0 max-lg:bg-[var(--color-gray-50)] max-lg:rounded-xl max-lg:mt-2 max-lg:hidden max-lg:group-[.active]/country:block">
          <div class="bg-white rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.12),0_0_0_1px_rgba(0,0,0,0.04)] px-6 py-5 max-lg:bg-transparent max-lg:shadow-none max-lg:p-3">
            <div class="grid grid-cols-2 gap-1 max-lg:grid-cols-1">
              {countries.map((c) => (
                <a
                  href={c.href}
                  class="flex items-center gap-3 px-3 py-2.5 rounded-[10px] transition-colors [transition-duration:var(--transition-fast)] no-underline text-inherit hover:bg-[var(--color-gray-50)]"
                  data-country={c.name}
                  data-flag={c.flag}
                >
                  <span class="country-flag text-lg shrink-0 w-6 text-center">{c.flag}</span>
                  <div class="flex flex-col">
                    <span class="block text-sm font-semibold text-[var(--color-dark)] uppercase tracking-[0.2px]">{c.name}</span>
                    {c.lang && <span class="block text-[11px] text-[var(--color-gray-400)] mt-px">{c.lang}</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a
        href="#contact"
        class="inline-flex items-center gap-1.5 px-6 py-2.5 text-sm font-medium text-white bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)] rounded-full whitespace-nowrap no-underline transition-transform duration-300 ease-in-out hover:-translate-y-px [&:hover_svg]:translate-x-[3px] max-lg:hidden"
      >
        Request a demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>

      <button
        class="group/toggle hidden flex-col gap-[5px] w-8 h-8 justify-center items-center z-[1100] bg-transparent border-0 cursor-pointer max-lg:flex [&.active]:max-lg:flex"
        data-mobile-toggle
        aria-label="Toggle menu"
      >
        <span class="w-6 h-0.5 bg-[var(--color-dark)] rounded-sm transition-all [transition-duration:var(--transition-base)] group-[.active]/toggle:translate-y-[7px] group-[.active]/toggle:rotate-45"></span>
        <span class="w-6 h-0.5 bg-[var(--color-dark)] rounded-sm transition-all [transition-duration:var(--transition-base)] group-[.active]/toggle:opacity-0"></span>
        <span class="w-6 h-0.5 bg-[var(--color-dark)] rounded-sm transition-all [transition-duration:var(--transition-base)] group-[.active]/toggle:-translate-y-[7px] group-[.active]/toggle:-rotate-45"></span>
      </button>
    </div>
  </div>
</header>

<div class="h-[var(--navbar-height)]"></div>

<script is:inline>
  (function () {
    const navbar = document.querySelector('[data-nav-root]');
    if (!navbar) return;
    const menu = navbar.querySelector('[data-nav-menu]');
    const mobileToggle = navbar.querySelector('[data-mobile-toggle]');
    const dropdownItems = navbar.querySelectorAll('.has-dropdown');
    const countrySelector = navbar.querySelector('[data-country-selector]');

    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 10);
    });

    dropdownItems.forEach((item) => {
      const btn = item.querySelector('[data-nav-trigger]');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) {
          e.preventDefault();
          const isActive = item.classList.contains('active');
          dropdownItems.forEach((i) => i.classList.remove('active'));
          item.classList.toggle('active', !isActive);
        }
      });
    });

    if (countrySelector) {
      const countryBtn = countrySelector.querySelector('[data-country-btn]');
      const currentLabel = countrySelector.querySelector('[data-country-current]');
      const globeIcon = countryBtn?.querySelector('.global-icon');
      const options = countrySelector.querySelectorAll('[data-country]');

      countryBtn?.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) {
          e.stopPropagation();
          countrySelector.classList.toggle('active');
        }
      });

      options.forEach((option) => {
        option.addEventListener('click', (e) => {
          e.preventDefault();
          const flag = option.getAttribute('data-flag');
          const name = option.getAttribute('data-country');
          if (globeIcon) globeIcon.innerHTML = `<span class="country-flag text-lg">${flag}</span>`;
          if (currentLabel) currentLabel.textContent = name;
          countrySelector.classList.remove('active');
        });
      });
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.has-dropdown')) {
        dropdownItems.forEach((item) => item.classList.remove('active'));
      }
      if (countrySelector && !e.target.closest('[data-country-selector]')) {
        countrySelector.classList.remove('active');
      }
    });

    mobileToggle?.addEventListener('click', () => {
      menu?.classList.toggle('open');
      mobileToggle.classList.toggle('active');
      document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownItems.forEach((item) => item.classList.remove('active'));
        countrySelector?.classList.remove('active');
        menu?.classList.remove('open');
        mobileToggle?.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
  })();
</script>
