---
/**
 * Global navbar — v2. Floating-pill shell (visual reference: _shared/Navbar.astro)
 * with link dropdowns + full country grid. Tailwind utilities only.
 */
export interface NavLink {
  label: string;
  href?: string;
  dropdown?: { label: string; href: string }[];
}
export interface CountryOption {
  name: string;
  flag: string;
  href: string;
  lang?: string;
}

const links: NavLink[] = [
  {
    label: 'E-Invoicing Platform',
    dropdown: [
      { label: 'Global e-invoicing', href: 'https://www.cleartax.com/electronic-invoicing' },
      { label: 'AI Reconciliation', href: 'https://cleartax.in/gst' },
      { label: 'Integration', href: 'https://cleartax.in/supply-chain-automation-solution' },
      { label: 'Scale & Security', href: 'https://cleartax.in/supply-chain-automation-solution' },
    ],
  },
  {
    label: 'Resources',
    dropdown: [
      { label: 'Blogs', href: 'https://www.cleartax.com/electronic-invoicing#country-select' },
      { label: 'Case Studies', href: 'https://www.cleartax.com/case-studies' },
      { label: 'Press Releases', href: 'https://www.clear.in/s/press?forceCacheReload=1' },
    ],
  },
  { label: 'Contact Us', href: 'https://www.cleartax.com/contact-us' },
  { label: 'Partners', href: 'https://www.cleartax.com/partners' },
];

const countries: CountryOption[] = [
  { name: 'INDIA', flag: '🇮🇳', href: 'https://www.clear.in/' },
  { name: 'MALAYSIA', flag: '🇲🇾', href: 'https://www.cleartax.com/my/en' },
  { name: 'USA', flag: '🇺🇸', href: 'https://www.clear.tech/' },
  { name: 'POLAND', flag: '🇵🇱', href: 'https://www.cleartax.com/pl/en', lang: 'English | Polish' },
  { name: 'SAUDI ARABIA', flag: '🇸🇦', href: 'https://www.cleartax.com/sa', lang: 'English | العربية' },
  { name: 'OMAN', flag: '🇴🇲', href: 'https://www.cleartax.com/om' },
  { name: 'FRANCE', flag: '🇫🇷', href: 'https://www.cleartax.com/fr/en', lang: 'English | French' },
  { name: 'BAHRAIN', flag: '🇧🇭', href: 'https://www.cleartax.com/bh' },
  { name: 'SPAIN', flag: '🇪🇸', href: 'https://www.cleartax.com/es/en' },
  { name: 'UAE', flag: '🇦🇪', href: 'https://www.cleartax.com/ae' },
  { name: 'SINGAPORE', flag: '🇸🇬', href: 'https://www.cleartax.com/sg/e-invoicing-software' },
  { name: 'GERMANY', flag: '🇩🇪', href: 'https://www.cleartax.com/de/en' },
  { name: 'BELGIUM', flag: '🇧🇪', href: 'https://www.cleartax.com/be/en' },
];
---

<div data-nav-root>
  <div
    class="fixed top-4 left-1/2 -translate-x-1/2 w-[calc(100%-48px)] max-w-[1200px] h-[74px] rounded-[63px] z-[1000] bg-white shadow-[0_4px_16px_rgba(0,0,0,0.1)] flex! items-center justify-between pl-0 pr-4 py-2.5 text-sm font-medium max-lg:w-[calc(100%-32px)] max-lg:h-14 max-lg:pr-2 max-lg:py-1.5"
    aria-label="Primary"
  >
    <a href="/" class="flex items-center shrink-0 px-10 py-3 max-lg:px-3 max-lg:py-1.5">
      <img
        src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
        alt="ClearTax"
        class="h-[27px] w-auto max-lg:h-5"
        width="120"
        height="27"
        loading="eager"
        decoding="async"
      />
    </a>

    <ul
      class="flex items-center list-none flex-1 justify-end pl-4 pr-2.5 m-0 max-lg:hidden"
      data-nav-menu
    >
      {links.map((l) => (
        <li class:list={['relative group/item', l.dropdown && 'has-dropdown']}>
          {l.dropdown ? (
            <>
              <button
                type="button"
                data-nav-trigger
                class="flex items-center gap-1.5 text-[#1a1a1a] text-sm font-medium px-3.5 py-4 whitespace-nowrap transition-colors hover:text-[#483C71] bg-transparent border-0 cursor-pointer font-[inherit]"
              >
                {l.label}
                <svg
                  class="shrink-0 transition-transform duration-200 group-hover/item:rotate-180 group-[.active]/item:rotate-180"
                  width="10"
                  height="10"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
              <div
                class="absolute top-full left-1/2 -translate-x-1/2 translate-y-2.5 mt-2.5 bg-white rounded-xl shadow-[0_12px_40px_rgba(0,0,0,0.12)] py-2 min-w-[200px] opacity-0 invisible transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] z-[1001] group-hover/item:opacity-100 group-hover/item:visible group-hover/item:translate-y-0 group-[.active]/item:opacity-100 group-[.active]/item:visible group-[.active]/item:translate-y-0"
              >
                {l.dropdown.map((d) => (
                  <a
                    href={d.href}
                    class="block px-5 py-2.5 text-sm font-medium text-[#171E28] transition-colors duration-200 no-underline hover:bg-[#F4F6F9] hover:text-[#5E46E5]"
                  >
                    {d.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={l.href}
              class="inline-flex items-center text-[#1a1a1a] text-sm font-medium px-3.5 py-4 whitespace-nowrap transition-colors hover:text-[#483C71] no-underline"
            >
              {l.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2.5 shrink-0">
      <div class="relative group/country" data-country-selector>
        <button
          type="button"
          data-country-btn
          class="inline-flex items-center gap-2 pl-2.5 pr-3.5 py-1.5 rounded-full border-[1.5px] border-[var(--color-gray-200,#e5e7eb)] bg-white text-[#1a1a1a] text-sm font-medium transition-colors duration-200 hover:bg-[var(--color-gray-50,#f9fafb)] cursor-pointer max-lg:hidden"
        >
          <span class="global-icon inline-flex items-center justify-center w-[22px] h-[22px] text-[#5E46E5]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </span>
          <span data-country-current>Global</span>
          <svg
            class="shrink-0 transition-transform duration-200 lg:group-hover/country:rotate-180 group-[.active]/country:rotate-180"
            width="10"
            height="6"
            viewBox="0 0 10 6"
            fill="none"
          >
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div
          class="absolute top-full right-0 w-[380px] bg-transparent pt-2.5 opacity-0 invisible pointer-events-none transition-all duration-300 z-[1001] lg:group-hover/country:opacity-100 lg:group-hover/country:visible lg:group-hover/country:pointer-events-auto group-[.active]/country:opacity-100 group-[.active]/country:visible group-[.active]/country:pointer-events-auto max-lg:hidden"
        >
          <div class="bg-white rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.12),0_0_0_1px_rgba(0,0,0,0.04)] px-6 py-5">
            <div class="grid grid-cols-2 gap-1">
              {countries.map((c) => (
                <a
                  href={c.href}
                  data-country={c.name}
                  data-flag={c.flag}
                  class="flex items-center gap-3 px-3 py-2.5 rounded-[10px] transition-colors duration-200 no-underline text-inherit hover:bg-[var(--color-gray-50,#f9fafb)]"
                >
                  <span class="country-flag text-lg shrink-0 w-6 text-center">{c.flag}</span>
                  <div class="flex flex-col">
                    <span class="block text-sm font-semibold text-[#1a1a1a] uppercase tracking-[0.2px]">{c.name}</span>
                    {c.lang && <span class="block text-[11px] text-[var(--color-gray-400,#9ca3af)] mt-px">{c.lang}</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a
        href="#contact"
        class="v2-nav-btn inline-flex items-center gap-2 px-5 py-3 text-sm font-bold text-white! bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)] rounded-full whitespace-nowrap no-underline transition-opacity duration-200 hover:opacity-90 max-lg:px-3.5 max-lg:py-1.5 max-lg:text-[13px] max-sm:[&_svg]:hidden"
      >
        Request a demo
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 6h8M6 2l4 4-4 4" stroke="white" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </a>

      <button
        type="button"
        data-mobile-toggle
        aria-label="Toggle menu"
        aria-expanded="false"
        class="group/toggle hidden max-lg:block relative w-10 h-10 mr-1.5 bg-transparent border-0 cursor-pointer p-2"
      >
        <span class="block absolute left-[9px] top-[13px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-all duration-300 group-[.open]/toggle:top-[19px] group-[.open]/toggle:rotate-45"></span>
        <span class="block absolute left-[9px] top-[19px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-opacity duration-200 group-[.open]/toggle:opacity-0"></span>
        <span class="block absolute left-[9px] top-[25px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-all duration-300 group-[.open]/toggle:top-[19px] group-[.open]/toggle:-rotate-45"></span>
      </button>
    </div>
</div>

  <div
    class="hidden max-lg:block fixed left-4 right-4 top-[72px] bg-white rounded-3xl shadow-[0_8px_24px_rgba(0,0,0,0.12)] z-[999] p-0 opacity-0 -translate-y-2 pointer-events-none max-h-0 overflow-hidden transition-all duration-300 [&.open]:opacity-100 [&.open]:translate-y-0 [&.open]:pointer-events-auto [&.open]:max-h-[80vh] [&.open]:overflow-auto [&.open]:p-4"
    data-mobile-menu
  >
    <ul class="flex flex-col gap-1 list-none m-0 p-0">
      {links.map((l) => (
        <li class:list={['relative group/mitem', l.dropdown && 'has-dropdown-m']}>
          {l.dropdown ? (
            <>
              <button
                type="button"
                data-m-trigger
                class="flex items-center justify-between w-full gap-1.5 text-[#1a1a1a] text-sm font-medium px-4 py-3 whitespace-nowrap bg-transparent border-0 cursor-pointer font-[inherit] rounded-lg hover:bg-[#f4f6f9]"
              >
                <span>{l.label}</span>
                <svg
                  class="shrink-0 transition-transform duration-200 group-[.active]/mitem:rotate-180"
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
              <div class="hidden group-[.active]/mitem:block pl-3 mt-1 mb-2">
                {l.dropdown.map((d) => (
                  <a
                    href={d.href}
                    class="block px-4 py-2.5 text-sm font-medium text-[#171E28] rounded-lg no-underline hover:bg-[#f4f6f9] hover:text-[#5E46E5]"
                  >
                    {d.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={l.href}
              class="v2-nav-link block px-4 py-3 text-sm font-medium text-[#171E28] rounded-lg no-underline hover:bg-[#f4f6f9]"
            >
              {l.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</div>

<script is:inline>
  (function () {
    const navbar = document.querySelector('[data-nav-root]');
    if (!navbar) return;
    const mobileToggle = navbar.querySelector('[data-mobile-toggle]');
    const mobileMenu = navbar.querySelector('[data-mobile-menu]');
    const dropdownItems = navbar.querySelectorAll('.has-dropdown');
    const mDropdownItems = navbar.querySelectorAll('.has-dropdown-m');
    const countrySelector = navbar.querySelector('[data-country-selector]');

    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 10);
    });

    dropdownItems.forEach((item) => {
      const btn = item.querySelector('[data-nav-trigger]');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) return;
        e.preventDefault();
        const isActive = item.classList.contains('active');
        dropdownItems.forEach((i) => i.classList.remove('active'));
        item.classList.toggle('active', !isActive);
      });
    });

    mDropdownItems.forEach((item) => {
      const btn = item.querySelector('[data-m-trigger]');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        item.classList.toggle('active');
      });
    });

    if (countrySelector) {
      const countryBtn = countrySelector.querySelector('[data-country-btn]');
      const currentLabel = countrySelector.querySelector('[data-country-current]');
      const globeIcon = countryBtn?.querySelector('.global-icon');
      const options = countrySelector.querySelectorAll('[data-country]');

      countryBtn?.addEventListener('click', (e) => {
        if (window.innerWidth <= 1024) return;
        e.stopPropagation();
        countrySelector.classList.toggle('active');
      });

      options.forEach((option) => {
        option.addEventListener('click', (e) => {
          e.preventDefault();
          const flag = option.getAttribute('data-flag');
          const name = option.getAttribute('data-country');
          if (globeIcon) globeIcon.innerHTML = `<span class="country-flag text-lg">${flag}</span>`;
          if (currentLabel) currentLabel.textContent = name;
          countrySelector.classList.remove('active');
          const href = option.getAttribute('href');
          if (href) window.location.href = href;
        });
      });
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.has-dropdown')) {
        dropdownItems.forEach((item) => item.classList.remove('active'));
      }
      if (countrySelector && !e.target.closest('[data-country-selector]')) {
        countrySelector.classList.remove('active');
      }
    });

    mobileToggle?.addEventListener('click', () => {
      const open = mobileMenu?.classList.toggle('open');
      mobileToggle.classList.toggle('open', !!open);
      mobileToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownItems.forEach((item) => item.classList.remove('active'));
        countrySelector?.classList.remove('active');
        mobileMenu?.classList.remove('open');
        mobileToggle?.classList.remove('open');
        mobileToggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    });
  })();
</script>
<style is:global>
  .v2-nav-link {
    display: block !important;
    padding: 12px 16px !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #171E28 !important;
    border-radius: 8px !important;
    text-decoration: none !important;
    transition: background 0.15s ease !important;
  }
  .v2-nav-link:hover { background-color: #f4f6f9 !important; }

  .v2-nav-btn {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 12px 20px !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #ffffff !important;
    background: linear-gradient(90deg, #110072 0%, #7A5698 100%) !important;
    border-radius: 9999px !important;
    text-decoration: none !important;
    transition: opacity 0.2s ease !important;
  }
  .v2-nav-btn:hover { opacity: 0.9 !important; }
</style>
