---
/**
 * Trusted-leaders testimonials carousel V2 — Tailwind optimized.
 * Swiper-based.
 */
interface Testimonial {
  logoSrc: string;
  logoClass: string;
  quote: string;
  initials: string;
  name: string;
  role: string;
}

const testimonials: Testimonial[] = [
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df4949e511b373dbb99294_leaders-brand-1.png',
    logoClass: 'w-[198px] aspect-[198/44]',
    quote: 'ClearTax has transformed the way we handle GST compliance. Real-time creation of e-Invoices and e-Way bills plays a significant role in providing us with critical insight into our business.',
    initials: 'P',
    name: 'Pratush Kumar',
    role: 'DGM-IT, JK Tyre (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df494a80821e2087576b23_leaders-brand-2.png',
    logoClass: 'w-[88px] aspect-[88/44]',
    quote: 'ClearTax is simplifying e-Invoicing. They enabled us to implement the e-Invoicing system in time and handled all our business complexities with ease. Thank you for the effort and good job!',
    initials: 'R',
    name: 'Raj Kiran',
    role: 'Head, Taxation & Retail Finance, Puma (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df494a067e75f8309b363b_leaders-brand-3.png',
    logoClass: 'w-[260px] aspect-[260/30] object-cover',
    quote: 'We appreciate ClearTax for successfully completing the complex ZATCA E-Invoicing Phase II Integration project. Their platform enabled seamless management of multiple business units. Kudos to the team for their timely delivery.',
    initials: 'P',
    name: 'Pratush Kumar',
    role: 'DGM-IT, JK Tyre (India)',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69de2f46ea62c039f7e81c4d_gamuda-land.png',
    logoClass: 'w-[260px] aspect-[260/30] object-cover',
    quote: 'Collaborating with ClearTax was an exceptional experience. They streamlined the entire process, even under tight deadlines, for our diverse ERP systems.',
    initials: 'V',
    name: 'V Bharathy',
    role: 'Manager, Finance Applications, Gamuda Land',
  },
  {
    logoSrc: 'https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69df166cc8fd06a5b99629c5_salam-removebg-preview.png',
    logoClass: 'w-[140px] aspect-[140/44] object-cover',
    quote: "Salam's search for a reliable partner ended with ClearTax. Their tailored solutions ensured a smooth transition for all 8 of our systems in just 3 months.",
    initials: 'A',
    name: 'Arslan Choudhary',
    role: 'Director of Enterprise Enablement, Salam Telco',
  },
];

const cardColors = ['#F6E0C5', '#D8EFF2', '#DEDAF6'];
const shuffledColors = [...cardColors].sort(() => Math.random() - 0.5);
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section class="bg-white py-[100px] max-lg:py-[60px] max-lg:pb-20 max-sm:py-10 max-sm:pb-[50px] overflow-x-hidden w-full">
  <div class="max-w-[var(--container-max)] mx-auto px-6">
    <div class="flex justify-between items-end mb-12 max-lg:mb-10 max-sm:flex-col max-sm:items-start max-sm:gap-6 max-sm:mb-8">
      <h2 class="v2-leaders-title max-w-[581px] w-full text-[44px]! font-semibold! leading-[1.18]! text-black! m-0! text-balance max-lg:text-[36px]! max-sm:text-[28px]!">
        Trusted by industry leaders across the world
      </h2>
      <div class="flex gap-3">
        <button class="tl-swipper-left w-12! h-12! rounded-full! cursor-pointer! flex items-center justify-center border-none! bg-[#2D0A4E]! transition-opacity hover:opacity-80 max-lg:w-[42px]! max-lg:h-[42px]! max-sm:w-8! max-sm:h-8!" aria-label="Previous">
          <svg width="7" height="14" viewBox="0 0 9 16" fill="none"><path d="M8 15L1 8L8 1" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <button class="tl-swipper-right w-12! h-12! rounded-full! cursor-pointer! flex items-center justify-center border-none! bg-[#2D0A4E]! transition-opacity hover:opacity-80 max-lg:w-[42px]! max-lg:h-[42px]! max-sm:w-8! max-sm:h-8!" aria-label="Next">
          <svg width="7" height="14" viewBox="0 0 9 16" fill="none"><path d="M8 15L1 8L8 1" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
      </div>
    </div>
  </div>
  
  <div class="ml-20 max-[1280px]:ml-10 max-lg:ml-6 max-sm:ml-4">
    <div class="tl-swiper overflow-visible! m-0">
      <div class="swiper-wrapper">
        {testimonials.map((t, i) => {
          const cardColor = shuffledColors[i % shuffledColors.length];
          return (
            <div class="swiper-slide w-fit!">
              <div class="max-w-[630px] w-full p-7 rounded-[20px] flex flex-col h-[375px] max-lg:p-6 max-lg:h-[330px] max-sm:p-4 max-sm:rounded-[14px] max-sm:h-[270px]" style={`background-color: ${cardColor}`}>
                <img class={`${t.logoClass} object-contain mb-7`} src={t.logoSrc} alt="" />
                <p class="text-xl! leading-[1.5]! mb-4! text-[#343A40]! max-sm:text-sm!">{t.quote}</p>
                <div class="flex gap-3 items-center mt-auto">
                  <div class="w-11 h-11 flex justify-center items-center rounded-full bg-[#3025A0] text-white font-bold">{t.initials}</div>
                  <div>
                    <div class="max-w-[167px] flex items-center gap-2">
                      <p class="m-0! font-bold! text-base! text-[#171E28]!">{t.name}</p>
                    </div>
                    <p class="text-[#6C757D]! text-sm! mt-[2px]! mb-0!">{t.role}</p>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style is:global>
  .v2-leaders-title {
    font-size: 44px;
    font-weight: 600;
    line-height: 1.18;
    color: #000000;
    margin: 0;
    font-size: 44px !important;
    font-weight: 600 !important;
    line-height: 1.18 !important;
    color: #000000 !important;
    margin: 0 !important;
  }
  @media (max-width: 1024px) {
    .v2-leaders-title { font-size: 36px !important; }
  }
  @media (max-width: 640px) {
    .v2-leaders-title { font-size: 28px !important; }
  }

  .tl-swipper-right svg { transform: rotate(180deg); }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script is:inline>
  (function () {
    function boot() {
      if (typeof Swiper === 'undefined') { setTimeout(boot, 50); return; }
      new Swiper('.tl-swiper', {
        loop: true,
        navigation: { nextEl: '.tl-swipper-right', prevEl: '.tl-swipper-left' },
        slidesPerView: 1,
        spaceBetween: 10,
        breakpoints: {
          768: { slidesPerView: 'auto', spaceBetween: 16 },
          1024: { slidesPerView: 2.2, spaceBetween: 20 },
        },
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else boot();
  })();
</script>
