---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="usp-v1-shield" class="bg-white py-20 lg:py-25 w-full">
  <div class="max-w-[var(--container-max)] mx-auto px-6">
    <div class="text-center">
      <h2 id="usp-title-shield" class="text-[32px] lg:text-[44px] font-semibold text-black leading-[1.18] m-0">
        ClearTax is a <span class="">Continuous Compliance Platform</span>
      </h2>
      <p id="usp-subtitle-shield" class="text-[18px] font-medium text-black mt-4">
        Enterprise-grade infrastructure trusted by the world's largest organizations
      </p>
    </div>

    <div class="tw-grid grid-cols-3 gap-7 mt-12 max-xl:grid-cols-2 max-sm:grid-cols-1">
      <!-- card 1: Always-On e-Invoicing -->
      <div class="bg-[#EDEBFA] rounded-[16px] p-5 flex flex-col border border-black/5 relative">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Always-On e-Invoicing</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          Detects, diagnoses, and resubmits failed invoices automatically - no manual intervention, no AR disruption. Your invoices clear. Every time.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full h-auto rounded-lg" />
        </div>
      </div>

      <!-- card 2: Built for Your Busiest Day -->
      <div class="bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col border border-black/5 relative">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Built for Your Busiest Day</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          10,000 e-invoices per second. Infrastructure that auto-scales as transactions grow. Month-end peaks. POS surges. Handled without a slowdown.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full h-auto rounded-lg" />
        </div>
      </div>

      <!-- card 3: Connects to Everything -->
      <div class="bg-[#EDEBFA] rounded-[16px] p-5 flex flex-col border border-black/5 relative">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Connects to Everything You Run On</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          SAP. Oracle. MS Dynamics. OMS. POS. Billing systems. All through pre-built, certified connectors.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full h-auto rounded-lg" />
        </div>
      </div>

      <!-- card 4: Zero Downtime -->
      <div class="bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col border border-black/5 relative">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Zero Downtime. By Design.</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          A cloud outage never becomes a compliance gap. Your data stays in-country - wherever you operate.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full h-auto rounded-lg" />
        </div>
      </div>

      <!-- card 5 (wide): One System for the World -->
      <div class="col-span-2 bg-[#EDEBFA] rounded-[16px] p-5 flex flex-col border border-black/5 relative max-xl:col-span-1">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">One System for the World</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          50+ countries. One API. Switch on new country mandates with configuration, not code.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full lg:max-w-[48%] h-auto rounded-lg max-h-72 object-contain" />
        </div>
      </div>

      <!-- card 6 (wide): Enterprise AI Security -->
      <div class="col-span-2 bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col border border-black/5 relative max-xl:col-span-1">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Enterprise AI Security</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          SOC 2 Type II. ISO 27001:2022. AES 256-bit encryption at rest. Local data residency in every country you operate. Your data never leaves your environment.
        </p>
        <div class="mt-6">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full lg:max-w-[48%] h-auto rounded-lg max-h-72 object-contain" />
        </div>
      </div>

      <!-- card 7: VAT Assurance -->
      <div class="bg-[#EDEBFA] rounded-[16px] p-5 flex flex-col border border-black/5 relative">
        <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">VAT Assurance: Recon AI Agent</h3>
        <p class="text-[16px] font-normal leading-[1.5] text-black/80 m-0">
          Runs every day, automatically. Discrepancies are surfaced with AI-recommended actions. You're notified only when something needs your attention.
        </p>
        <div class="mt-6 flex justify-center">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb6c1e87029e32d83f9407_dummy-image.png" alt="Graphic" class="w-full h-auto rounded-lg" />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
  #usp-title-shield {
    font-size: 44px !important;
    line-height: 1.18 !important;
    font-weight: 600 !important;
    color: black !important;
    text-align: center !important;
    margin: 0 !important;
  }
  #usp-subtitle-shield {
    font-size: 18px !important;
    font-weight: 500 !important;
    color: black !important;
    text-align: center !important;
    margin-top: 16px !important;
  }
  @media (max-width: 1024px) {
    #usp-title-shield { font-size: 32px !important; }
  }
</style>
