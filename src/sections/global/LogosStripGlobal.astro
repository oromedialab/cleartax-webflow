---
/**
 * Global logos marquee — ported from global-e-invoicing-mandate-page/index.html:1190-1298.
 * Different visual from the UAE marquee (white bg, multiply blend, soft mask edges).
 */
const logos = [
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375e2_Group%2018.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea683760b_Group%203.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837629_Group%2028.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375f1_Group%2016.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837615_Group%2023.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375d8_Group%206.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837638_Group%2027.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837633_Group%2036.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea683763d_Group%2026.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea683761a_Group%2024.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375ce_Group%207.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837601_Group%2019.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375e7_Group%2015.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea683762e_Group%2025.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837642_Group%2029.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375fc_Group%2013.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837610_Group%209.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375dd_Group%205.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea683761f_Group%2032.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837606_Group%2012.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea6837624_Group%2030.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375d3_Group%2011.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375ec_Group%2022.avif',
  'https://cdn.prod.website-files.com/6141e3720a248d2024615d96/68c004b7cd20663ea68375f7_Group%208.avif',
];

const doubled = [...logos, ...logos];
---

<section class="logos-section">
  <div class="wf-container">
    <h2 class="logos-heading">Trusted by <span class="logos-heading-highlight">5000+</span> Businesses Worldwide</h2>
    <div class="logos-carousel">
      <div class="logos-track">
        {doubled.map((src, i) => (
          <img src={src} alt={i < logos.length ? 'Customer logo' : ''} aria-hidden={i >= logos.length} class="logo-item" loading="lazy" />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .logos-section { background: #FFFFFF; padding: 48px 0; overflow: hidden; width: 100%; }
  .wf-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .logos-heading { text-align: center; font-size: 28px; font-weight: 600; color: #171E28; margin-bottom: 32px; letter-spacing: -0.5px; }
  .logos-heading-highlight { color: #1572ED; }

  .logos-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #FFFFFF;
    isolation: isolate;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
  }

  .logos-track {
    display: flex;
    align-items: center;
    gap: 32px;
    width: max-content;
    animation: scroll-logos-global 45s linear infinite;
    padding: 8px 0;
    background: #FFFFFF;
  }

  .logo-item {
    flex-shrink: 0;
    height: 88px;
    width: auto;
    object-fit: contain;
    opacity: 1;
    mix-blend-mode: multiply;
    transition: all 150ms ease;
  }
  .logo-item:hover { opacity: 1; transform: scale(1.05); }

  @keyframes scroll-logos-global {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logos-carousel:hover .logos-track { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) {
    .logos-track { animation: none; }
  }

  @media (max-width: 1080px) {
    .logos-heading { font-size: 24px; margin-bottom: 44px; }
    .logo-item { height: 73px; }
    .logos-track { gap: 64px; }
  }
  @media (max-width: 640px) {
    .logos-heading { font-size: 20px; margin-bottom: 36px; }
    .logo-item { height: 56px; }
    .logos-track { gap: 48px; }
  }
</style>
