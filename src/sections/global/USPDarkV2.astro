---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="usp-v1-shield" class="bg-white py-20 lg:py-25 w-full">
  <div class="max-w-[var(--container-max)] mx-auto px-6">
    <div class="text-center">
      <h2 id="usp-title-shield" class="text-[32px]! lg:text-[44px]! font-semibold! text-black leading-[1.18]! m-0!">
        ClearTax is a <span class="">Continuous Compliance Platform</span>
      </h2>
      <p id="usp-subtitle-shield" class="text-[18px]! font-medium! text-black mt-4!">
        Enterprise-grade infrastructure trusted by the world's largest organizations
      </p>
    </div>

    <div class="grid grid-cols-12 gap-6 mt-12 w-full">
      
      <!-- Built for Your Busiest Day (5 columns) -->
      <div class="col-span-5 max-lg:col-span-12 bg-[#FDF2ED] rounded-[24px] p-8 flex flex-col justify-between overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="mb-8 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">Built for Your Busiest Day</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0!">
            10,000 e-invoices per second. Infrastructure auto-scales as transactions grow. Month-end peaks. POS surges handled without slowdown.
          </p>
        </div>
        <div class="mt-auto flex justify-center items-end -mb-8 pt-4 max-w-[523px] w-full">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c747a14c80e75f5729_platform-1.png" alt="Speedometer" class="w-full h-auto object-contain" />
        </div>
      </div>

      <!-- Connects to Everything (7 columns) -->
      <div class="col-span-7 max-lg:col-span-12 bg-[#EDEBFA] rounded-[24px] p-8 flex flex-col justify-between overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="mb-8 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">Connects to Everything You Run On</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0! max-w-lg!">
            SAP. Oracle. MS Dynamics. OMS. POS. Billing systems. All through pre-built, certified connectors you run on.
          </p>
        </div>
        <div class="flex justify-end items-end ml-auto -mt-8 pt-4 max-w-[489px] w-full">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c7e0dfeb2eaaeb8f3d_platform-2.png" alt="Connectors" class="w-full h-auto object-contain" />
        </div>
      </div>

      <!-- Always-On e-Invoicing (4 columns) -->
      <div class="col-span-4 max-lg:col-span-12 bg-[#ECF7ED] rounded-[24px] p-8 flex flex-col justify-between overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="mb-8 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">Always-On e-Invoicing</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0!">
            Detects, diagnoses, resubmits failed invoices automatically - no manual intervention, no AR disruption. Invoices clear. Every time.
          </p>
        </div>
        <div class="mt-auto flex justify-center items-end pt-4 max-w-[384px] w-full -mb-8">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c747a14c80e75f5748_platform-3.png" alt="Always-On" class="w-full h-auto object-contain" />
        </div>
      </div>

      <!-- Zero Downtime (8 columns) -->
      <div class="col-span-8 max-lg:col-span-12 bg-[#FDF2ED] rounded-[24px] p-8 flex flex-col justify-between overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="mb-8 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">Zero Downtime. By Design.</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0! max-w-md!">
            Cloud outage never becomes a compliance gap. Your data stays in-country wherever you operate. Zero downtime design.
          </p>
        </div>
        <div class="mt-auto flex justify-end items-end ml-auto pt-4 max-w-[340px] w-full">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c71569540f5a633423_platform-4.png" alt="Zero Downtime" class="w-full h-auto object-contain" />
        </div>
      </div>

      <!-- VAT Assurance (7 columns) -->
      <div class="col-span-7 max-lg:col-span-12 bg-[#EDEBFA] rounded-[24px] p-0 flex flex-col lg:flex-row overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="lg:w-[45%] p-8 flex flex-col justify-end order-2 lg:order-1 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">VAT Assurance: Recon AI Agent</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0!">
            Runs every day, automatically. Discrepancies surfaced with AI-recommended actions. You're notified only when something needs attention.
          </p>
        </div>
        <div class="max-w-[374px] w-full flex items-start justify-end order-1 lg:order-2 ml-auto">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c812a8c59d37514804_platform-5.png" alt="VAT Assurance" class="w-full h-auto object-contain origin-top-right -mr-8mt-auto flex justify-center items-end -mb-8 pt-4" />
        </div>
      </div>

      <!-- Enterprise AI Security (5 columns) -->
      <div class="col-span-5 max-lg:col-span-12 bg-[#EAF4FF] rounded-[24px] p-8 flex flex-col justify-between overflow-hidden border border-black/5 relative min-h-[340px]">
        <div class="mb-8 relative z-10">
          <h3 class="text-[22px]! leading-[1.36]! font-semibold! text-black m-0! mb-3!">Enterprise AI Security</h3>
          <p class="text-[15px]! font-normal! leading-[1.5]! text-black/80! m-0!">
            SOC 2 Type II. ISO 27001:2022. AES 256-bit encryption at rest. Local data residency in every country you operate. Your data never leaves your environment and is never used to train models.
          </p>
        </div>
        <div class="mt-auto flex justify-center items-end pt-4 max-w-[408px] w-full">
          <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c66c6386f1d508302b_platform-6.png" alt="Security" class="w-full h-auto object-contain" />
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
  #usp-title-shield {
    font-size: 44px !important;
    line-height: 1.18 !important;
    font-weight: 600 !important;
    color: black !important;
    text-align: center !important;
    margin: 0 !important;
  }
  #usp-subtitle-shield {
    font-size: 18px !important;
    font-weight: 500 !important;
    color: black !important;
    text-align: center !important;
    margin-top: 16px !important;
  }
  @media (max-width: 1024px) {
    #usp-title-shield { font-size: 32px !important; }
  }
</style>
