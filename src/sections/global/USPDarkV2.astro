---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="usp-v1-shield" class="bg-white py-20 lg:py-25 w-full">
  <div class="max-w-[var(--container-max)] mx-auto px-6">
    <div class="text-center">
      <h2 id="usp-title-shield" class="text-[32px]! lg:text-[44px]! font-semibold! text-black leading-[1.18]! m-0!">
        ClearTax is a <span class="">Continuous Compliance Platform</span>
      </h2>
      <p id="usp-subtitle-shield" class="text-[18px]! font-medium! text-black mt-4!">
        Enterprise-grade infrastructure trusted by the world's largest organizations
      </p>
    </div>

    <div class="grid grid-cols-12 gap-6 mt-12 w-full">
      
      <!-- Built for Your Busiest Day (6 columns) -->
      <div class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full">
          <div class="mb-8 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Built for Your Busiest Day</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0">
              10,000 e-invoices per second. Infrastructure auto-scales as transactions grow. Month-end peaks. POS surges handled without slowdown.
            </p>
          </div>
          <div class="mt-auto flex justify-center items-end -mb-8 pt-4 max-w-[523px] w-full mx-auto tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c747a14c80e75f5729_platform-1.png" alt="Speedometer" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

      <!-- Connects to Everything (6 columns) -->
      <div class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full">
          <div class="mb-8 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Connects to Everything You Run On</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0 max-w-[468px] w-full">
              SAP Oracle MS Dynamics OMS POS Billing systems All through pre-built certified connectors you run on.
            </p>
          </div>
          <div class="flex justify-end items-end ml-auto mt-auto -mr-5 pt-4 max-w-[489px] w-full tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c7e0dfeb2eaaeb8f3d_platform-2.png" alt="Connectors" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

      <!-- Always-On e-Invoicing (5 columns) -->
      <div class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full">
          <div class="mb-8 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Always-On e-Invoicing</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0">
              Detects diagnoses resubmits failed invoices automatically no manual intervention no AR disruption invoices clear every time.
            </p>
          </div>
          <div class="mt-auto flex justify-center items-end pt-4 max-w-[384px] w-full -mb-4 mx-auto tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c747a14c80e75f5748_platform-3.png" alt="Always-On" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

      <!-- Zero Downtime (7 columns) -->
      <div class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 flex max-sm:flex-col justify-between overflow-hidden relative h-full">
          <div class="mb-8 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Zero Downtime. By Design.</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0 max-w-[348px] w-full">
              Cloud outage never becomes compliance gap Your data stays in-country wherever you operate zero downtime design
            </p>
          </div>
          <div class="mt-auto flex justify-end items-end ml-auto pt-4 max-w-[340px] w-full tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c71569540f5a633423_platform-4.png" alt="Zero Downtime" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

      <!-- VAT Assurance (7 columns) -->
      <div class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-0 flex flex-col lg:flex-row overflow-hidden relative h-full">
          <div class="p-5 flex flex-col justify-end order-2 lg:order-1 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3 max-w-[249px] w-full">VAT Assurance: Recon AI Agent</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0 max-w-[394px] w-full">
              Runs every day automatically Discrepancies surfaced with AI-recommended actions You're notified only when something needs attention
            </p>
          </div>
          <div class="max-w-[374px] w-full flex items-start justify-end order-1 lg:order-2 ml-auto tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c812a8c59d37514804_platform-5.png" alt="VAT Assurance" class="w-full h-auto object-contain origin-top-right flex justify-center items-end pt-3" />
          </div>
        </div>
      </div>

      <!-- Enterprise AI Security (5 columns) -->
      <div class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px]">
        <div class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full">
          <div class="mb-8 relative z-10">
            <h3 class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3">Enterprise AI Security</h3>
            <p class="text-base font-normal leading-normal text-black/80 m-0">
              SOC 2 Type II. ISO 27001:2022. AES 256-bit encryption at rest. Local data residency in every country you operate. Your data never leaves your environment and is never used to train models.
            </p>
          </div>
          <div class="mt-auto flex justify-center items-end pt-4 max-w-[408px] w-full mx-auto tilted-card-img-wrapper">
            <img src="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69f0a5c66c6386f1d508302b_platform-6.png" alt="Security" class="w-full h-auto object-contain" />
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style is:global>
  /* Tilted Card Styles */
  .tilted-card {
    perspective: 1000px;
    z-index: 1;
  }
  .tilted-card-inner {
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform 0.1s ease-out; /* Fallback */
  }
  .tilted-card-img-wrapper {
    transform: translateZ(20px);
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }
  .tilted-card-img-wrapper img {
    transform: translateZ(10px);
  }

  /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
  #usp-title-shield {
    font-size: 44px !important;
    line-height: 1.18 !important;
    font-weight: 600 !important;
    color: black !important;
    text-align: center !important;
    margin: 0 !important;
  }
  #usp-subtitle-shield {
    font-size: 18px !important;
    font-weight: 500 !important;
    color: black !important;
    text-align: center !important;
    margin-top: 16px !important;
  }
  @media (max-width: 1024px) {
    #usp-title-shield { font-size: 32px !important; }
  }
</style>

<script is:inline>
  function initTiltedCards() {
    const cards = document.querySelectorAll('.tilted-card');
    
    cards.forEach(card => {
      const inner = card.querySelector('.tilted-card-inner');
      if (!inner) return;

      const rotateAmplitude = 12; // Controls how much the card tilts
      const scaleOnHover = 1.02;
      
      let targetRotateX = 0;
      let targetRotateY = 0;
      let targetScale = 1;
      
      let currentRotateX = 0;
      let currentRotateY = 0;
      let currentScale = 1;
      
      let rafId = null;

      function update() {
        // Smooth lerp for premium feel
        currentRotateX += (targetRotateX - currentRotateX) * 0.1;
        currentRotateY += (targetRotateY - currentRotateY) * 0.1;
        currentScale += (targetScale - currentScale) * 0.1;
        
        inner.style.transform = `rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) scale(${currentScale})`;
        
        if (
          Math.abs(targetRotateX - currentRotateX) > 0.01 || 
          Math.abs(targetRotateY - currentRotateY) > 0.01 || 
          Math.abs(targetScale - currentScale) > 0.001
        ) {
          rafId = requestAnimationFrame(update);
        } else {
          rafId = null;
        }
      }

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const offsetX = e.clientX - rect.left - rect.width / 2;
        const offsetY = e.clientY - rect.top - rect.height / 2;

        targetRotateX = (offsetY / (rect.height / 2)) * -rotateAmplitude;
        targetRotateY = (offsetX / (rect.width / 2)) * rotateAmplitude;
        targetScale = scaleOnHover;
        
        if (!rafId) rafId = requestAnimationFrame(update);
      });

      card.addEventListener('mouseenter', () => {
        targetScale = scaleOnHover;
        if (!rafId) rafId = requestAnimationFrame(update);
      });

      card.addEventListener('mouseleave', () => {
        targetRotateX = 0;
        targetRotateY = 0;
        targetScale = 1;
        if (!rafId) rafId = requestAnimationFrame(update);
      });
    });
  }

  // Handle both initial load and Astro page transitions if any
  document.addEventListener('DOMContentLoaded', initTiltedCards);
</script>
