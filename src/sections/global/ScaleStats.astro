---
/**
 * "Proven at Global Scale" stat-card section — ported from
 * global-e-invoicing-mandate-page/index.html:2307-2348 (the `container-main` block).
 * Renamed to ScaleStats to avoid colliding with Astro container conventions.
 */
---

<section class="container-main section-spacing">
  <div class="wf-container">
    <div class="global-container">
      <h2 class="global-h2">Proven at Global Scale</h2>
      <p class="global-p">Handle high-volume invoicing with speed, accuracy, and consistency across markets</p>
      <div class="sc-cards">
        <div class="sc-card card-globe">
          <div class="sc-card-content">
            <h3 class="global-h3">10,000+</h3>
            <p class="sc-card-desription">Reconcillation every minute</p>
          </div>
        </div>
        <div class="sc-card sc-card-grid">
          <div class="sc-card-content">
            <h3 class="global-h3">300M+</h3>
            <p class="sc-card-desription">Invoice processed every year</p>
          </div>
        </div>
        <div class="sc-card card-dollar">
          <div class="sc-card-content">
            <h3 class="global-h3">$400B+</h3>
            <p class="sc-card-desription">Worth of invoices handled</p>
          </div>
        </div>
      </div>
      <div class="cta-demo-section">
        <a href="#contact" class="contact-a">
          <button class="demo-btn">
            Request Demo
            <svg class="btn-arrow" width="17" height="9" viewBox="0 0 17 9" fill="none">
              <path d="M0 5.166V3.465H13.242L10.812 1.035L11.847 0L16.167 4.32L11.847 8.64L10.812 7.605L13.251 5.166H0Z" fill="#171E28" />
            </svg>
          </button>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .container-main { background-color: #171E28; }
  .section-spacing { padding: 100px 0; }
  .wf-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }

  .global-container { display: flex; flex-direction: column; align-items: center; justify-content: center; background-color: #171E28; max-width: 1238px; margin: 0 auto; }
  .global-h2 { font-size: 44px; font-weight: 600; color: #fff; line-height: 1.18; margin: 0; text-align: center; }
  .global-h3 { font-size: 28px; font-weight: 600; color: #FFF9F9; margin-bottom: 8px; line-height: 34px; }
  .global-p { font-size: 18px; font-weight: 400; color: #FFFFFF99; line-height: 26px; margin: 16px 0 0; text-align: center; }

  .sc-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; width: 100%; }

  .card-globe { background-image: url('https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df4910856c9af13792e816_globe-connected.png'); background-repeat: no-repeat; background-position: top left; background-size: 223px; }
  .sc-card-grid { background-image: url('https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df49111735bc178fb89ca4_slant-grid.png'); background-repeat: no-repeat; background-position: left; background-size: 400px; }
  .card-dollar { background-image: url('https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69df4a65564a7dee64990703_dollar-connections.png'); background-repeat: no-repeat; background-position: top left; background-size: 211px; }

  .sc-card { border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.2); width: 100%; min-height: 254px; padding: 28px; display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-end; text-align: right; }
  .sc-card-desription { font-size: 18px; font-weight: 400; color: rgba(255, 255, 255, 0.6); line-height: 1.5; margin: 0; }

  .cta-demo-section { display: flex; justify-content: center; margin-top: 48px; width: 100%; }
  .contact-a { text-decoration: none; }
  .demo-btn { display: flex; align-items: center; gap: 8px; padding: 16px 40px; background-color: #FFCF32; border: none; border-radius: 50px; font-size: 16px; line-height: 24px; font-weight: 500; color: #171E28; cursor: pointer; font-family: inherit; }
  .btn-arrow { transition: transform 0.3s ease; }
  .demo-btn:hover .btn-arrow { transform: translateX(10px); }

  @media (max-width: 1024px) {
    .sc-cards { grid-template-columns: repeat(2, 1fr); }
    .global-h2 { font-size: 32px; }
    .global-p { font-size: 16px; }
    .sc-card-desription { font-size: 16px; }
    .sc-card { padding: 16px; }
  }
  @media (max-width: 768px) {
    .sc-cards { grid-template-columns: 1fr; gap: 16px; }
    .sc-card { min-height: 240px; }
  }
  @media (max-width: 400px) {
    .demo-btn { padding: 16px 32px; font-size: 15px; }
  }
</style>
