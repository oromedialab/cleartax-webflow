---
/**
 * ListComp - A horizontal statistics/list section.
 * Ported from image showing 4 key metrics with dividers.
 */
const stats = [
    { value: "250M+", label: "Invoices processed" },
    { value: "99.9%", label: "Uptime achieved" },
    { value: "<1s", label: "Avg. submission time" },
    { value: "5000+", label: "Enterprise clients" },
];
---

<section class="list-comp pb-12 bg-[#F3F1F9]!">
    <div
        class="mx-auto max-w-[var(--container-max)] px-4 lg:px-6 border-t border-black/10 pt-12"
    >
        <div
            class="flex flex-wrap md:flex-nowrap justify-between items-center gap-8 md:gap-0"
        >
            {
                stats.map((stat, index) => (
                    <>
                        <div
                            class="flex-1 min-w-[140px] md:min-w-0 text-center px-6 premium-reveal"
                            style={`transition-delay: ${index * 100}ms`}
                        >
                            <div class="text-[26px] font-semibold text-[#16075F] mb-3 leading-tight tracking-tight">
                                {stat.value}
                            </div>
                            <p class="text-sm lg:text-base font-normal text-[#000000]/80 text-balance leading-relaxed">
                                {stat.label}
                            </p>
                        </div>
                        {index < stats.length - 1 && (
                            <div class="hidden md:block w-[1px] h-16 bg-[#1E1256]/10 shrink-0" />
                        )}
                    </>
                ))
            }
        </div>
    </div>
</section>

<style is:global>
    .list-comp {
        /* Subtle inner shadow for depth */
        box-shadow: inset 0 2px 40px rgba(0, 0, 0, 0.02);
    }
</style>
