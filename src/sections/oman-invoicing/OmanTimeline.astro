---
export interface Props {
    //
}

const steps = [
    {
        dateLine1: "AUG",
        dateLine2: "2026",
        phase: "PHASE 1 • WAVE 1 - ACTIVE",
        phaseColor: "text-[#4D3BE2]",
        desc: "Selected large VAT-registered businesses go live",
        active: true,
        lineSolid: true
    },
    {
        dateLine1: "FEB",
        dateLine2: "2027",
        phase: "PHASE 1 • WAVE 2",
        phaseColor: "text-black/80",
        desc: "All large VAT-registered businesses",
        active: false,
        lineSolid: false
    },
    {
        dateLine1: "AUG",
        dateLine2: "2027",
        phase: "PHASE 2",
        phaseColor: "text-black/80",
        desc: "All remaining VAT-registered businesses",
        active: false,
        lineSolid: false
    },
    {
        dateLine1: "AUG",
        dateLine2: "2028",
        phase: "PHASE 3 • B2G",
        phaseColor: "text-black/80",
        desc: "Government entities (B2G transactions)",
        active: false,
        lineSolid: false
    }
];
---

<section class="py-20 lg:py-28 lg:pb-12 bg-[#F3F1F9] overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-6">
        <div class="text-center premium-reveal">
            <h2 class="text-3xl md:text-[40px] lg:text-[44px] font-semibold tracking-tight text-[#030203]">
                Oman E-Invoicing <span class="text-[#655DFF]">Timeline</span>
            </h2>
            <p class="text-center font-normal text-black/80 mt-3 lg:mt-4 text-base lg:text-lg">
                Four phased waves — know your deadline before it arrives.
            </p>
        </div>

        <div class="flex flex-col gap-12 lg:grid lg:grid-cols-4 lg:gap-0 mt-16 lg:mt-24 relative z-10 max-w-[400px] lg:max-w-none mx-auto premium-reveal [transition-delay:200ms]">
            {steps.map((step, index) => (
                <div class="relative flex flex-row lg:flex-col items-start lg:items-center group">
                    <div class="relative shrink-0 flex justify-center w-[96px]">
                        <div class={`w-[96px] h-[96px] rounded-full flex flex-col items-center justify-center font-semibold text-white text-base leading-[1.2] transition-transform duration-300 group-hover:-translate-y-1 ${step.active ? 'bg-[#6B5CE7] glow-pulse ring-[6px] ring-[#6B5CE7]/20 scale-105' : 'bg-[#A198EE]'}`}>
                            <span>{step.dateLine1}</span>
                            <span>{step.dateLine2}</span>
                        </div>
                    </div>
                    
                    <div class="ml-6 lg:ml-0 lg:mt-10 flex-1 lg:text-center pt-2 lg:pt-0">
                        <div class={`text-[16px] tracking-[1.5px] uppercase font-normal ${step.phaseColor}`}>
                            {step.phase}
                        </div>
                        <div class="text-lg text-black/80 max-w-[253px] font-normal mt-1.5 leading-[1.4]  lg:mx-auto">
                            {step.desc}
                        </div>
                    </div>

                    {index < steps.length - 1 && (
                        <>
                            <!-- Desktop Line -->
                            <div class={`hidden lg:block absolute top-[48px] left-1/2 w-full -z-10 ${step.lineSolid ? 'h-[2px] bg-[#655DFF]' : 'h-0 border border-dashed border-[#A198EE]'}`}></div>
                            
                            <!-- Mobile Line -->
                            <div class={`lg:hidden absolute top-[96px] left-[48px] -translate-x-1/2 -bottom-12 -z-10 ${step.lineSolid ? 'w-[2px] bg-[#655DFF]' : 'w-0 border border-dashed border-[#A198EE]'}`}></div>
                        </>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .glow-pulse {
        animation: pulse-glow 2s infinite ease-in-out;
    }
    @keyframes pulse-glow {
        0% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0.6);
        }
        70% {
            box-shadow: 0 0 0 12px rgba(107, 92, 231, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(107, 92, 231, 0);
        }
    }
</style>
