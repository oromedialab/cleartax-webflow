---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="why-cleartax" class="bg-[#FFFFFF] py-12 lg:py-25 w-full">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center">
            <h2
                id="oman-title-shield"
                class="text-[26px]! sm:text-[32px]! lg:text-[44px]! font-semibold! text-black leading-[1.18]! m-0! premium-reveal"
            >
                Oman E-Invoicing Mandate <span class="text-[#655DFF]"
                    >at a Glance</span
                >
            </h2>
            <p
                id="oman-subtitle-shield"
                class="lg:text-lg! text-base! font-medium! text-black/80! mt-4! premium-reveal [transition-delay:150ms]"
            >
                Everything your business needs to know about the Fawtara
                framework before the mandate goes live.
            </p>
        </div>

        <div class="grid grid-cols-12 gap-6 mt-12 w-full">
            <!-- Built for Your Busiest Day (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="mt-auto px-5 flex justify-center items-end -mb-8 pt-4 max-w-[626px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1e72579d07301d20574434_img-1.png"
                            alt="Speedometer"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="mb-8 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3"
                        >
                            Transmission Model
                        </h3>
                        <p
                            class="text-base max-w-124 font-normal leading-normal text-black/80 m-0"
                        >
                            Decentralised 5-corner model (Fawtara). Invoices
                            flow through OTA-accredited service providers
                            ensuring end-to-end traceability.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Connects to Everything (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3"
                        >
                            Applicability
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            All VAT-registered businesses in Oman. VAT group
                            members must each follow e-invoicing procedures and
                            share a single service provider.
                        </p>
                    </div>
                    <div
                        class="flex max-w-[626px] mx-auto w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1441792907a6105057c3a7_img-2.png"
                            alt="Connectors"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Always-On e-Invoicing (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="flex pb-4 max-w-[504px] w-full ml-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1e726035b657ba4b21b83c_img-3.png"
                            alt="Always-On"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3"
                        >
                            Acceptable Formats
                        </h3>
                        <p
                            class="text-balance font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            Invoices must be issued in XML or PDF/A-3 format. A
                            digital certificate is required to ensure
                            reliability and verification.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Zero Downtime (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="mb-8 relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3"
                        >
                            Transmission Methods
                        </h3>
                        <p
                            class="text-base font-normal max-w-132 leading-normal text-black/80 m-0"
                        >
                            All invoices must be transmitted via an
                            OTA-accredited Service Provider such as ClearTax.
                        </p>
                    </div>
                    <div
                        class="mt-auto px-10 pb-6 flex pt-4 max-w-[748px] w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1e726d2c060e640c863722_img-4.png"
                            alt="Zero Downtime"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- VAT Assurance (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-5 gap-8 flex flex-col lg:flex-row overflow-hidden relative h-full"
                >
                    <div
                        class="flex flex-col justify-start order-2 lg:order-1 relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3 w-full"
                        >
                            Archival
                        </h3>
                        <p
                            class="text-base max-w-64 font-normal leading-normal text-black/80 m-0 w-full"
                        >
                            Invoices must be archived for 10 years — 5 years in
                            the system and 5 years in an electronic archive.
                        </p>
                    </div>
                    <div
                        class="max-w-[406px] w-full flex items-start justify-end order-1 lg:order-2 ml-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1e7275576b92ed6daf29f0_img-5.png"
                            alt="VAT Assurance"
                            class="w-full h-auto object-contain origin-top-right flex justify-center items-end pt-3"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Enterprise AI Security (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="mb-8 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-3"
                        >
                            Penalties
                        </h3>
                        <p
                            class="text-base font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            Penalties applied per regulations for
                            non-compliance. A grace period is available before
                            full enforcement begins.
                        </p>
                    </div>
                    <div
                        class="mt-auto flex justify-center items-end pt-4 max-w-[366px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1e727cf0513cfd007535a2_img-6.png"
                            alt="Security"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Tilted Card Styles */
    .tilted-card {
        perspective: 1000px;
        z-index: 1;
    }
    .tilted-card-inner {
        transform-style: preserve-3d;
        will-change: transform;
        transition:
            transform 0.1s ease-out,
            box-shadow 0.3s ease; /* Fallback */
    }
    .tilted-card-img-wrapper {
        transform: translateZ(20px);
        transform-style: preserve-3d;
        backface-visibility: hidden;
    }
    .tilted-card-img-wrapper img {
        transform: translateZ(10px);
    }

    /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
    #usp-title-shield {
        font-size: 44px !important;
        line-height: 1.18 !important;
        font-weight: 600 !important;
        color: black !important;
        text-align: center !important;
        margin: 0 !important;
    }
    #usp-subtitle-shield {
        font-size: 18px !important;
        font-weight: 500 !important;
        color: black !important;
        opacity: 0.8 !important;
        text-align: center !important;
        margin-top: 16px !important;
    }
    @media (max-width: 1024px) {
        #usp-title-shield {
            font-size: 32px !important;
        }
    }
    @media (max-width: 640px) {
        #usp-title-shield {
            font-size: 26px !important;
        }
        #usp-subtitle-shield {
            font-size: 16px !important;
        }
    }
</style>

<script is:inline>
    (function () {
        let initialized = false;
        const section = document.getElementById("why-cleartax");

        function initTiltedCards() {
            if (initialized) return;
            initialized = true;

            const cards = document.querySelectorAll(".tilted-card");
            cards.forEach((card) => {
                const inner = card.querySelector(".tilted-card-inner");
                if (!inner) return;

                const rotateAmplitude = 12;
                const scaleOnHover = 1.02;

                let targetRotateX = 0,
                    targetRotateY = 0,
                    targetScale = 1;
                let currentRotateX = 0,
                    currentRotateY = 0,
                    currentScale = 1;
                let rafId = null;

                function update() {
                    currentRotateX += (targetRotateX - currentRotateX) * 0.1;
                    currentRotateY += (targetRotateY - currentRotateY) * 0.1;
                    currentScale += (targetScale - currentScale) * 0.1;
                    inner.style.transform = `rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) scale(${currentScale})`;
                    if (
                        Math.abs(targetRotateX - currentRotateX) > 0.01 ||
                        Math.abs(targetRotateY - currentRotateY) > 0.01 ||
                        Math.abs(targetScale - currentScale) > 0.001
                    ) {
                        rafId = requestAnimationFrame(update);
                    } else {
                        rafId = null;
                    }
                }

                card.addEventListener("mousemove", (e) => {
                    const rect = card.getBoundingClientRect();
                    const offsetX = e.clientX - rect.left - rect.width / 2;
                    const offsetY = e.clientY - rect.top - rect.height / 2;
                    targetRotateX =
                        (offsetY / (rect.height / 2)) * -rotateAmplitude;
                    targetRotateY =
                        (offsetX / (rect.width / 2)) * rotateAmplitude;
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseenter", () => {
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseleave", () => {
                    targetRotateX = 0;
                    targetRotateY = 0;
                    targetScale = 1;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });
            });
        }

        if (section) {
            section.addEventListener("mouseenter", initTiltedCards, {
                once: true,
            });
            section.addEventListener("touchstart", initTiltedCards, {
                once: true,
            });
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        if (entries[0].isIntersecting) {
                            initTiltedCards();
                            obs.disconnect();
                        }
                    },
                    { rootMargin: "100px" },
                );
                obs.observe(section);
            } else {
                initTiltedCards();
            }
        }
    })();
</script>
