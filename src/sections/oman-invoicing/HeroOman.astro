<script is:inline>
    (() => {
        const bootHero = () => {
            // 1. More robust section targeting
            const section = document.querySelector(".hero-oman");
            if (!section) return;



            // Ensure the meta tag for referrer policy exists immediately (Critical for Error 153)
            if (!document.querySelector('meta[name="referrer"]')) {
                const meta = document.createElement("meta");
                meta.name = "referrer";
                meta.content = "strict-origin-when-cross-origin";
                document.head.appendChild(meta);
            }

            // Countdown
            try {
                const targetStr = section.getAttribute("data-countdown-target");
                if (targetStr) {
                    const [datePart, timePart] = targetStr.split("T");
                    const [y, mo, d] = datePart.split("-").map(Number);
                    const [h, mi, s] = timePart.split(":").map(Number);
                    const target = new Date(y, mo - 1, d, h, mi, s).getTime();
                    const nodes = {
                        days: section.querySelector('[data-ct="days"]'),
                        hours: section.querySelector('[data-ct="hours"]'),
                        mins: section.querySelector('[data-ct="mins"]'),
                        secs: section.querySelector('[data-ct="secs"]'),
                    };
                    const label = section.querySelector(".hero-countdown");

                    function tick() {
                        const dist = target - Date.now();
                        if (dist < 0) {
                            if (label)
                                label.innerHTML =
                                    "<span class='text-sm font-bold text-[#110072]/60 uppercase tracking-[1.5px]'>Pilot Program is Live!</span>";
                            return;
                        }
                        const days = Math.floor(dist / 86400000);
                        const hours = Math.floor((dist % 86400000) / 3600000);
                        const mins = Math.floor((dist % 3600000) / 60000);
                        const secs = Math.floor((dist % 60000) / 1000);
                        if (nodes.days)
                            nodes.days.textContent = String(days).padStart(
                                2,
                                "0",
                            );
                        if (nodes.hours)
                            nodes.hours.textContent = String(hours).padStart(
                                2,
                                "0",
                            );
                        if (nodes.mins)
                            nodes.mins.textContent = String(mins).padStart(
                                2,
                                "0",
                            );
                        if (nodes.secs)
                            nodes.secs.textContent = String(secs).padStart(
                                2,
                                "0",
                            );
                    }
                    tick();
                    setInterval(tick, 1000);
                }
            } catch (e) {
                console.error("Countdown failed", e);
            }

  // HubSpot form embed with URL parameters auto-prefill
  (() => {
    let initialized = false;
    
    const initForm = () => {
      if (initialized) return;
      if (window.hbspt && window.hbspt.forms) {
        initialized = true;
        window.hbspt.forms.create({
          portalId: "245744706",
          formId: "51af6b81-aa59-4bd2-b499-ff081e27324d",
          region: "na2",
          target: "#oman-hero-form",
          onFormReady: function($form) {
            // Remove the skeleton loader
            const skeleton = document.getElementById("form-skeleton");
            if (skeleton) {
              skeleton.remove();
            }

            const formEl = ($form && $form[0]) ? $form[0] : $form;
            if (formEl && formEl.querySelector) {
              const urlParams = new URLSearchParams(window.location.search);
              const utms = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
              utms.forEach(utm => {
                const value = urlParams.get(utm);
                if (value) {
                  const input = formEl.querySelector('input[name="' + utm + '"]');
                  if (input) {
                    input.value = value;
                  }
                }
              });
            }
          }
        });
      }
    };

    const checkAndInit = () => {
      if (window.hbspt && window.hbspt.forms) {
        initForm();
      } else {
        // Look for HubSpot script and attach load listener
        const script = document.querySelector('script[src*="hsforms.net"]');
        if (script) {
          script.addEventListener('load', initForm);
        }
        // Also poll as a robust fallback
        let pollCount = 0;
        const interval = setInterval(() => {
          pollCount++;
          if (window.hbspt && window.hbspt.forms) {
            clearInterval(interval);
            initForm();
          } else if (pollCount > 100) { // Stop polling after 10 seconds
            clearInterval(interval);
          }
        }, 100);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", checkAndInit);
    } else {
      checkAndInit();
    }
  })();

            // Force reveal Hero elements immediately
            setTimeout(() => {
                section
                    .querySelectorAll(".premium-reveal, .clip-reveal")
                    .forEach((el) => {
                        el.classList.add("is-visible");
                    });
            }, 100);
        };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", bootHero);
        } else {
            bootHero();
        }
    })();
</script>
