        </div>

        <!-- Call to Action button -->
        <a 
          href="#roadmap" 
          class="inline-flex items-center justify-center px-8 py-2 md:py-3.5 rounded-full font-medium text-white transition-all duration-300 hover:-translate-y-1 text-base cursor-pointer"
          style="background: linear-gradient(135deg, #4F46E5 0%, #312E81 100%);"
        >
          See How It Works
        </a>
      </div>

      <!-- Hero Right Column: Lead Form Card -->
      <aside class="hero-form bg-white/80 backdrop-blur-xl text-[#111827] rounded-xl p-6 sm:p-8 [box-shadow:_-1px_1px_22px_0px_#00000029] border border-white/60 w-full max-w-[633px] scroll-mt-28" id="heroForm">
        <h3 class="text-[22px] font-medium text-black mb-3 leading-[1.36]">Book a Demo</h3>
        <p class="text-base text-black/80 mb-6">Get a personalized walkthrough of our Germany-ready e-invoicing solution.</p>

        <!-- HubSpot Form Mount Container -->
        <div id="hero-hubspot-form" class="hs-form-wrap-light">
          <!-- Form Skeleton Loader -->
          <div id="form-skeleton" class="form-skeleton">
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div>
              <div class="skeleton-label shimmer" style="width: 100px;"></div>
              <div class="skeleton-input shimmer"></div>
            </div>
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div class="skeleton-button shimmer"></div>
          </div>
        </div>
        
        <p class="text-sm text-black/80 text-center mt-4">No spam. Just a 30-min call with our Germany specialists.</p>
      </aside>

    </div>
  </div>
</section>

<script is:inline>
  // HubSpot form embed with URL parameters auto-prefill
  (() => {
    let initialized = false;
    
    const initForm = () => {
      if (initialized) return;
      if (window.hbspt && window.hbspt.forms) {
        initialized = true;
        window.hbspt.forms.create({
          portalId: "245744706",
          formId: "51af6b81-aa59-4bd2-b499-ff081e27324d",
          region: "na2",
          target: "#hero-hubspot-form",
          onFormReady: function($form) {
            // Remove the skeleton loader
            const skeleton = document.getElementById("form-skeleton");
            if (skeleton) {
              skeleton.remove();
            }

            const formEl = ($form && $form[0]) ? $form[0] : $form;
            if (formEl && formEl.querySelector) {
              const urlParams = new URLSearchParams(window.location.search);
              const utms = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
              utms.forEach(utm => {
                const value = urlParams.get(utm);
                if (value) {
                  const input = formEl.querySelector('input[name="' + utm + '"]');
                  if (input) {
                    input.value = value;
                  }
                }
              });
            }
          }
        });
      }
    };

    const checkAndInit = () => {
      if (window.hbspt && window.hbspt.forms) {
        initForm();
      } else {
        // Look for HubSpot script and attach load listener
        const script = document.querySelector('script[src*="hsforms.net"]');
        if (script) {
          script.addEventListener('load', initForm);
        }
        // Also poll as a robust fallback
        let pollCount = 0;
        const interval = setInterval(() => {
          pollCount++;
          if (window.hbspt && window.hbspt.forms) {
            clearInterval(interval);
            initForm();
          } else if (pollCount > 100) { // Stop polling after 10 seconds
            clearInterval(interval);
          }
        }, 100);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", checkAndInit);
    } else {
      checkAndInit();
    }
  })();
</script>

<style is:global>
  /* Pixel-perfect styles for light glassmorphism HubSpot Form to match layout */
  .hs-form-wrap-light {
    width: 100%;
    min-height: 300px;
  }
  .hs-form-wrap-light .inputs-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .hs-form-wrap-light form {
    display: flex !important;
    flex-direction: column !important;
    gap: 16px !important;
  }
  .hs-form-wrap-light .hs-form-field {
    margin-bottom: 0 !important;
  }
  .hs-form-wrap-light .hs-form-field > label {
    display: block !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    color: #1E1B4B !important;
    margin-bottom: 5px !important;
  }
  .hs-form-wrap-light .hs-form-field > label .hs-form-required {
    color: #ef4444 !important;
    margin-left: 2px !important;
  }
  .hs-form-wrap-light input[type="text"],
  .hs-form-wrap-light input[type="email"],
  .hs-form-wrap-light input[type="tel"],
  .hs-form-wrap-light input[type="number"],
  .hs-form-wrap-light select,
  .hs-form-wrap-light textarea {
    width: 100% !important;
    border-radius: 8px !important;
    border: 1px solid #E2E8F0 !important;
    background-color: #ffffff !important;
    padding: 11px 14px !important;
    font-size: 14.5px !important;
    color: #1E1B4B !important;
    outline: none !important;
    transition: all 0.25s ease !important;
    box-sizing: border-box !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.02) !important;
  }
  .hs-form-wrap-light input:focus,
  .hs-form-wrap-light select:focus,
  .hs-form-wrap-light textarea:focus {
    border-color: #4F46E5 !important;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.12) !important;
  }
  .hs-form-wrap-light textarea {
    min-height: 80px !important;
    resize: vertical !important;
  }
  .hs-form-wrap-light .hs_phone .hs-fieldtype-intl-phone{
    display: flex !important;
    gap: 12px !important;
    width: 102% !important;
  }
  .hs-form-wrap-light select {
    appearance: auto !important;
  }
  .hs-form-wrap-light fieldset {
    max-width: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: row !important;
    gap: 12px !important;
  }
  @media (max-width: 640px) {
    .hs-form-wrap-light fieldset {
      flex-direction: column !important;
      gap: 16px !important;
    }
  }
  .hs-form-wrap-light fieldset .hs-form-field {
    flex: 1 !important;
  }
  .hs-form-wrap-light .input {
    margin-right: 0 !important;
  }
  .hs-form-wrap-light .hs-form-booleancheckbox label,
  .hs-form-wrap-light .legal-consent-container label {
    display: flex !important;
    align-items: flex-start !important;
    font-size: 14px !important;
    color: rgba(0, 0, 0, 0.8) !important;
    line-height: 1.5 !important;
    font-weight: 400 !important;
    cursor: pointer !important;
  }
  .hs-form-wrap-light .hs-form-booleancheckbox label a,
  .hs-form-wrap-light .legal-consent-container label a {
    color: #4F46E5 !important;
    font-weight: 600 !important;
    text-decoration: underline !important;
  }
  .hs-form-wrap-light input[type="checkbox"] {
    margin-top: 3px !important;
    flex-shrink: 0 !important;
    accent-color: #4F46E5 !important;
    width: 15px !important;
    height: 15px !important;
    cursor: pointer !important;
  }
  .hs-form-wrap-light .hs-submit {
    margin-top: 8px !important;
  }
  .hs-form-wrap-light input[type="submit"],
  .hs-form-wrap-light .hs-button {
    width: 100% !important;
    background: linear-gradient(135deg, #4F46E5 0%, #312E81 100%) !important;
    color: white !important;
    padding: 13px !important;
    border-radius: 30px !important;
    font-weight: 700 !important;
    font-size: 15px !important;
    border: none !important;
    cursor: pointer !important;
    font-family: inherit !important;
    transition: all 0.25s ease !important;
    box-shadow: 0 4px 14px rgba(79, 70, 229, 0.25) !important;
  }
  .hs-form-wrap-light input[type="submit"]:hover,
  .hs-form-wrap-light .hs-button:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 18px rgba(79, 70, 229, 0.35) !important;
    opacity: 0.95 !important;
  }
  .hs-form-wrap-light .hs-error-msgs {
    list-style: none !important;
    padding: 0 !important;
    margin: 4px 0 0 !important;
    font-size: 11.5px !important;
    color: #ef4444 !important;
  }
  .hs-form-wrap-light .hs-error-msg {
    color: #ef4444 !important;
  }
  .hs-form-wrap-light .submitted-message {
    background: #EEF2F6 !important;
    color: #1E1B4B !important;
    padding: 18px !important;
    border-radius: 8px !important;
    font-size: 14.5px !important;
    font-weight: 600 !important;
    text-align: center !important;
    border: 1px solid rgba(79, 70, 229, 0.15) !important;
  }
  .hs-form-wrap-light fieldset:has([class*="hs_utm_"]),
  .hs-form-wrap-light .hs-form-field[style*="display: none"] {
    display: none !important;
  }

  /* ==================== FORM SKELETON SHIMMER STYLES ==================== */
  .form-skeleton {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    min-height: 300px;
  }
  .skeleton-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  @media (max-width: 640px) {
    .skeleton-row-2 {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
  .skeleton-label {
    height: 14px;
    width: 80px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .skeleton-input {
    height: 44px;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    width: 100%;
  }
  .skeleton-button {
    height: 46px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.25) 0%, rgba(49, 46, 129, 0.25) 100%);
    border-radius: 30px;
    width: 100%;
    margin-top: 8px;
  }
  
  /* Shimmer Animation */
  .shimmer {
    position: relative;
    overflow: hidden;
  }
  .shimmer::after {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    transform: translateX(-100%);
    background-image: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.6) 20%,
      rgba(255, 255, 255, 0.6) 60%,
      rgba(255, 255, 255, 0) 100%
    );
    animation: shimmer-anim 1.6s infinite;
    content: '';
  }
  @keyframes shimmer-anim {
    100% {
      transform: translateX(100%);
    }
  }
</style>
