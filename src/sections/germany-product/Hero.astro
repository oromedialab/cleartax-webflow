            <path d="M13.6166 4.49374L11.7456 2.62275C9.22637 0.103508 5.14193 0.103508 2.62274 2.62275C0.103454 5.14198 0.103454 9.22642 2.62274 11.7456L3.31056 12.4335" stroke="#432984" stroke-width="1.46665" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M7.68574 21.0163L7.70879 21.0394C8.41933 21.7499 9.57128 21.7499 10.2818 21.0394L12.6293 18.6919C13.3398 17.9814 13.3398 16.8295 12.6293 16.1189L12.6062 16.0958C11.8957 15.3853 10.7437 15.3853 10.0332 16.0958L7.68574 18.4433C6.9752 19.1538 6.9752 20.3058 7.68574 21.0163Z" stroke="#432984" stroke-width="1.46665" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M5.08955 18.4203L5.1126 18.4434C5.82314 19.1539 6.97509 19.1539 7.68564 18.4434L10.0331 16.0959C10.7436 15.3854 10.7436 14.2334 10.0331 13.5229L10.01 13.4998C9.29949 12.7893 8.14748 12.7893 7.43699 13.4998L5.08955 15.8473C4.379 16.5578 4.379 17.7098 5.08955 18.4203Z" stroke="#432984" stroke-width="1.46665" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
