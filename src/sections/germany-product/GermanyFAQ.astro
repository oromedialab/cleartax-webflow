---
/**
 * Germany FAQ accordion — adapted from UAE standard page styling and structure.
 * Features 6 Germany B2B & ViDA enterprise questions with support for paragraph, list,
 * and mixed content blocks. Uses native javascript height transition animations that remain resize-safe.
 */
interface FaqItem {
  q: string;
  /** Plain string OR array of paragraphs / lists. */
  a:
    | string
    | Array<
        { kind: "p"; html: string } | { kind: "ul" | "ol"; items: string[] }
      >;
}

const items: FaqItem[] = [
  {
    q: "How much does an e-Invoicing program cost?",
    a: "Costs vary by volume and complexity: basic tools may be low-cost per month, while enterprise solutions add setup/integration and per-invoice fees. Budget for ERP integration, validation, archiving (10 years), support, and change management.",
  },
  {
    q: "Can I create an e-Invoice using Excel?",
    a: "Not reliably. Excel can store invoice data, but Germany requires structured e-invoice formats (EN 16931-compliant XML/hybrid). You’d still need software/middleware to convert Excel data into XRechnung/ZUGFeRD and validate it."
  },
  {
    q: "Do businesses need to register on a government system to send e-invoices in Germany?",
    a: "No registration is required. Germany follows a decentralised model. Businesses are responsible for ensuring their invoices meet EN 16931 standards and are exchanged through approved digital channels such as Peppol, EDI or compliant e-Invoicing software. There is no clearance or central approval portal.",
  },
  {
    q: "What is the format for e-Invoice in Germany?",
    a: "Germany’s common formats are XRechnung (structured XML) and ZUGFeRD (PDF with embedded EN 16931 XML). The invoice must be machine-readable and compliant with the European standard EN 16931.",
  },
  {
    q: "What software do I need for e-Invoicing in Germany?",
    a: "You need software that can generate, send, receive, validate, and archive EN 16931-compliant invoices (XRechnung/ZUGFeRD). This can be your ERP’s e-invoicing capability or a third-party e-invoicing provider integrated with ERP/accounting."
  },
  {
    q: "What are the advantages of using e-Invoicing software?",
    a: "It reduces manual entry, errors, and processing time; improves audit trails; supports automated matching and approvals; speeds dispute resolution; and ensures compliance. It also centralizes monitoring and helps meet archiving and reporting needs efficiently.",
  },
  {
    q: "What should companies do that are currently working without an e-Invoicing program?",
    a: "Start now: map invoice flows, confirm which B2B invoices are in scope, ensure “receive” readiness, select a solution/provider, integrate with ERP/accounting, set validation/archiving, train teams, and pilot with key suppliers/customers.",
  },
  {
    q: "Does the e-Invoicing requirement also apply to small businesses?",
    a: "Yes, mainly for B2B. All businesses must be able to receive e-invoices from Jan 1, 2025; issuing becomes mandatory for everyone by Jan 1, 2028. Some exemptions exist (e.g., low-value invoices).",
  },
  {
    q: "Which program can I use to receive e-Invoices?",
    a: "Any system that can accept and process EN 16931 invoices: ERP/AP automation, accounting software with e-invoice import, or an e-invoicing provider portal. Many companies use a provider to validate, route, and archive invoices centrally.",
  },
  {
    q: "What are the main requirements of the Germany e-Invoicing mandate?",
    a: "All German businesses must be able to receive structured e-invoices from 2025. Companies with revenue above 800,000 euros must issue e-invoices from 2027. By 2028, e-invoice issuance becomes mandatory for all companies. Structured invoices must follow EN 16931 formatting rules and be exchanged digitally.",
  },
  {
    q: "How do I choose the right e-Invoicing software for my business in Germany?",
    a: "Select an e-Invoicing software that supports EN 16931 formats such as XRechnung, ZUGFeRD and Peppol BIS. Ensure it integrates with your ERP, automates validation, reduces manual entry and offers secure long-term archiving. A reliable solution should simplify compliance and reduce operational effort.",
  },
  {
    q: "Do businesses need to register on a government system to send e-invoices in Germany?",
    a: "No registration is required. Germany follows a decentralised model. Businesses are responsible for ensuring their invoices meet EN 16931 standards and are exchanged through approved digital channels such as Peppol, EDI or compliant e-Invoicing software. There is no clearance or central approval portal.",
  },
];
---

<section
  class="faq-section box-border bg-[#FFFFFF] py-12 font-['Manrope'] text-[#0F1020] sm:py-20"
  id="faq"
>
  <div class="faq-container mx-auto max-w-[1200px] px-4 sm:px-6">
    <div class="faq-header mb-8 max-w-[720px] mx-auto text-center sm:mb-12">
      <h2
        class="faq-heading mb-4 lg:text-[44px] sm:text-[32px] text-[26px] font-semibold leading-[1.18] tracking-[-1.2px] text-black"
      >
        Frequently Asked <em class="not-italic text-[#655DFF]">Questions</em>
      </h2>
      <p
        class="faq-sub max-w-147 mx-auto lg:text-lg text-base leading-[1.44] text-black/80"
      >
        Everything you need to know about Germany e-invoicing and ClearTax.
      </p>
    </div>

    <div class="faq-list flex flex-col gap-5" data-faq-root>
      {
        items.map((it, i) => (
          <div
            class={`faq-item group overflow-hidden rounded-[8px] border border-[rgba(15,16,32,0.08)] bg-white transition-[border-color,box-shadow] duration-300 ease-in-out [box-sizing:border-box] [&.faq-open]:border-[rgba(0,87,255,0.35)] [&.faq-open]:shadow-[0_6px_24px_-12px_rgba(0,87,255,0.25)] ${i >= 5 ? "hidden hidden-faq" : ""}`}
            style={`transition-delay: ${200 + (i * 50)}ms`}
          >
            <button
              class="faq-trigger flex w-full appearance-none items-center justify-between gap-4 border-0 bg-transparent px-[18px] py-[18px] text-left text-[15.5px] leading-[1.4] text-[#0F1020] [box-sizing:border-box] cursor-pointer focus-visible:rounded-[14px] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[#0057FF] sm:px-6 sm:py-[22px] sm:text-[17px]"
              type="button"
              aria-expanded="false"
            >
              <h4 class="faq-question min-w-0 flex-1 font-medium text-[18px] leading-[1.32] break-words text-[#0F172A] text-left">
                {it.q}
              </h4>
              <span
                class="faq-icon flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[rgba(0,87,255,0.1)] text-[#0057FF] transition-[transform,background,color] duration-300 ease-in-out group-[.faq-open]:rotate-45 group-[.faq-open]:bg-[#0057FF] group-[.faq-open]:text-white"
                aria-hidden="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 14 14"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M6.69995 0.700195V12.7002M0.699951 6.7002H12.7"
                    stroke="#6355D8"
                    stroke-width="1.4"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
            </button>
            <div class="faq-panel h-0 overflow-hidden transition-[height] duration-[320ms] [transition-timing-function:cubic-bezier(.4,0,.2,1)]">
              <div class="faq-answer px-[18px] pb-[18px] text-[14px] leading-[1.7] text-[#5A6070] sm:px-6 sm:pb-[22px] sm:text-[16px] [&_li]:mb-1.5 [&_ol]:m-0 [&_ol]:pl-5 [&_p:last-child]:mb-0 [&_p]:mb-2.5 [&_p]:mt-0 [&_strong]:text-[#0F1020] [&_ul]:m-0 [&_ul]:pl-5">
                {typeof it.a === "string" ? (
                  <p set:html={it.a} />
                ) : (
                  it.a.map((block) =>
                    block.kind === "p" ? (
                      <p set:html={block.html} />
                    ) : block.kind === "ul" ? (
                      <ul>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ul>
                    ) : (
                      <ol>
                        {block.items.map((li) => (
                          <li set:html={li} />
                        ))}
                      </ol>
                    ),
                  )
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      items.length > 5 && (
        <div
          class="mt-12 mx-auto flex items-center justify-center"
          id="faq-load-more-container"
        >
          <button
            id="faq-load-more-btn"
            class="inline-flex h-10 items-center gap-2 justify-center rounded-3xl border border-[#110072] bg-white px-10 py-4 text-base font-bold font-['gilroy'] leading-[1.4] text-[#1C0976] outline-offset-[-2px] transition-all duration-300 ease-in-out hover:scale-105 active:scale-95 cursor-pointer"
          >
            Load More
            <span class="flex items-center justify-center">
              <svg
                width="10"
                height="11"
                viewBox="0 0 10 11"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M4.79999 0.799805V9.7998M0.799988 5.7998L4.79999 9.7998L8.79999 5.7998"
                  stroke="#1C0976"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </button>
        </div>
      )
    }
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-faq-root]");
    if (!root) return;
    const items = root.querySelectorAll(".faq-item");

    const loadMoreBtn = document.getElementById("faq-load-more-btn");
    const loadMoreContainer = document.getElementById(
      "faq-load-more-container",
    );
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", function () {
        const hiddenItems = root.querySelectorAll(".hidden-faq");
        hiddenItems.forEach(function (item) {
          item.classList.remove("hidden", "hidden-faq");
        });
        if (loadMoreContainer) {
          loadMoreContainer.style.display = "none";
        }
      });
    }
    items.forEach(function (item) {
      const trigger = item.querySelector(".faq-trigger");
      const panel = item.querySelector(".faq-panel");
      if (!trigger || !panel) return;

      trigger.addEventListener("click", function () {
        const isOpen = item.classList.contains("faq-open");
        if (isOpen) {
          panel.style.height = panel.scrollHeight + "px";
          requestAnimationFrame(function () {
            panel.style.height = "0px";
          });
          item.classList.remove("faq-open");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          panel.style.height = panel.scrollHeight + "px";
          item.classList.add("faq-open");
          trigger.setAttribute("aria-expanded", "true");
          panel.addEventListener("transitionend", function handler(e) {
            if (e.propertyName !== "height") return;
            panel.removeEventListener("transitionend", handler);
            if (item.classList.contains("faq-open"))
              panel.style.height = "auto";
          });
        }
      });

      window.addEventListener("resize", function () {
        if (item.classList.contains("faq-open")) panel.style.height = "auto";
      });
    });
  })();
</script>
