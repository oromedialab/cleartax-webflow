    points: [
      { label: "Single compliance API" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0ab03469603fde437930a4_api.png'},
      { label: "ViDA and DRR ready" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ec7eb0e13008a796548fc_tabs-6.png'},
      { label: "Country-level configuration" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ec7f32798f059d85494e8_tabs-7.png'},
      { label: "No repeated vendor setup" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ec7f95d0099962a13237a_tabs-8.png'}
    ]
  },
  {
    id: "auto-healing",
    label: "Auto-Healing",
    icon: 'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ec7d2ad88feb345367268_tabs-3.png',
    image: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1ed386937d8f2e58a0c01a_invoices.png",
    title: "Auto-healing keeps invoices flowing",
    description: "ClearTax validates every invoice before submission and flags issues early. Duplicate detection, abnormal value alerts, and vendor anomaly checks help prevent failures before they affect compliance.",
