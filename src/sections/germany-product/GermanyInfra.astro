      { label: "100+ ready connectors" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0aa6fd02fea217046406bb_invoice-icon.png'},
      { label: "Lower IT effort after go-live" ,cardIcon:'https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a0aa71323d9a93d2c979e71_residency.png' }
