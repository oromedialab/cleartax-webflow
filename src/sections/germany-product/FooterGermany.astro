---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img
            src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfa05ecb34c38b5b8b5f54_cleartax-logo-light.png"
            alt="ClearTax"
            height="28"
            style="filter: brightness(0) invert(1);"
            loading="lazy"
            decoding="async"
          />
        </a>
        <div class="footer-social">
          <p class="footer-social-label">Follow us on</p>
          <div class="footer-social-icons">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  class="footer-social-icon"
                  aria-label={s.label}
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    set:html={s.icon}
                  />
                </a>
              ))
            }
          </div>
        </div>
      </div>

      {
        columns.map((col) => (
          <div class="footer-col">
            <h4 class="footer-col-title" set:html={col.title} />
            <ul class="footer-links">
              {col.items.map((it) => (
                <li>
                  <a href={it.href}>{it.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <div class="footer-bottom-left">
          <div class="footer-legal-links">
            <a href="https://www.clear.in/s/legal?__hstc=242523997.481d8358904aad7b4f3a4c8d56d4663f.1779361992871.1780557556211.1780572283636.18&__hssc=242523997.1.1780572283636&__hsfp=3e547f8041a8b7eb88ecebd9564c3ed0" class="footer-legal-link">Legal</a>
            <a href="https://www.cleartax.com/meta/privacy" class="footer-legal-link">Privacy Policy</a>
          </div>
          <div class="footer-address">
            <p>House A, 1st floor, Edisonstraße 63, Berlin 12459 Germany</p>
            <p class="mt-1">Cleartax is a product by Defmacro Software Pvt. Ltd.</p>
          </div>
        </div>
        <div class="footer-bottom-right">
          <img loading="lazy" alt="website-footer-log" src="https://assets.clear.in/cleartax/images/1776428278_frame21472248601.png" width="150" height="30">
          <p class="footer-badges-text">Your data security and privacy matter most to us.</p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background: #0a0a0a !important;
    padding: 72px 0 32px;
  }
  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 220px repeat(4, 1fr);
    gap: 40px;
    text-align: left;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .footer-logo img {
    height: 28px;
  }
  .footer-social {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-social-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
    margin: 0;
  }
  .footer-social-icons {
    display: flex;
    gap: 12px;
  }
  .footer-social-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-white);
    transition: background var(--transition-fast);
  }
  .footer-social-icon:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer-col-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
  }
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-links a {
    font-size: 14px;
    color: var(--color-gray-400);
    transition: color var(--transition-fast);
    line-height: 1.4;
  }
  .footer-links a:hover {
    color: var(--color-white);
  }

  .footer-bottom {
    margin-top: 56px;
    padding: 32px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }
  .footer-bottom-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer-legal-links {
    display: flex;
    gap: 24px;
  }
  .footer-legal-link {
    font-size: 14px;
    color: var(--color-gray-400);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer-legal-link:hover {
    color: var(--color-white);
  }
  .footer-address {
    font-size: 13px;
    color: var(--color-gray-500);
    line-height: 1.6;
  }
  .footer-address p {
    margin: 0;
  }
  .footer-address .mt-1 {
    margin-top: 4px;
  }
  .footer-bottom-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    text-align: right;
  }

  .footer-badges-text {
    font-size: 14px;
    color: var(--color-gray-400);
    margin: 16px 0 0;
  }

  @media (max-width: 1080px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px 32px;
    }
    .footer-brand {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: start;
      gap: 48px;
      flex-wrap: wrap;
    }
  }
  @media (max-width: 768px) {
    .footer-bottom-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }
    .footer-bottom-right {
      align-items: flex-start;
      text-align: left;
      margin-top: 16px;
    }
  }
  @media (max-width: 640px) {
    .footer {
      padding: 48px 0 32px;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px 24px;
    }
    .footer-brand {
      flex-direction: column;
      gap: 24px;
    }
    .footer-bottom {
      margin-top: 40px;
    }
  }
</style>
