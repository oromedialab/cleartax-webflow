---

<section class="bg-[#F3F1F9] py-16 max-lg:md:py-20 lg:py-25">
  <div class="lg:container px-4 lg:px-6 mx-auto">
    <div class="max-w-[659px] w-full mx-auto">
      <h2
        class="font-semibold text-2xl sm:text-4xl lg:text-[44px] text-black leading-[1.18] text-center"
      >
        Germany Looks Simple Today.
        <span class="text-[#655DFF]">It Won't Stay That Way.</span>
      </h2>
      <p class="text-center text-lg text-black mt-4 leading-[1.44]">
        E-invoicing is phase one of a multi-year digital transformation of
        German tax. ClearTax is already built for what comes next.
      </p>
    </div>
    <div class="grid gird-cols-1 max-lg:sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-12 justify-center">
      {
        roadmapCards.map((card) => {
          const themeColor =
            card.theme === "orange"
              ? "#DC8F56"
              : card.theme === "teal"
                ? "#338878"
                : "#1572ED";
          
          return (
            <div class="bg-white rounded-xl p-5 max-lg:md:p-6 lg:p-7 flex flex-col max-md:max-w-103">
              <div class="size-14 shrink-0">
                <Fragment set:html={card.icon} />
              </div>
              <h3 class="font-medium text-lg text-black mt-6">{card.year} - {card.badgeTitle}</h3>
              <p class="text-base text-[#000000CC] mt-3 pb-7 border-b border-[#00000018] min-h-[72px]">
                {card.description}
              </p>
              <ul class="mt-7 flex flex-col gap-3 ">
                {card.points.map((point) => (
                  <li class="flex gap-4 items-start">
                    <svg
                      class="size-4 shrink-0 mt-1"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M6.16 7.44012C5.84 7.12012 5.36 7.12012 5.04 7.44012C4.72 7.76012 4.72 8.24012 5.04 8.56012L7.44 10.9601C7.6 11.1201 7.76 11.2001 8 11.2001C8.24 11.2001 8.4 11.1201 8.56 10.9601L14.16 4.56012C14.4 4.16012 14.4 3.68012 14 3.44012C13.68 3.20012 13.2 3.20012 12.96 3.52012L8 9.20012L6.16 7.44012Z"
                        fill={themeColor}></path>
                      <path
                        d="M15.2 7.2C14.72 7.2 14.4 7.52 14.4 8C14.4 11.52 11.52 14.4 8 14.4C4.48 14.4 1.6 11.52 1.6 8C1.6 6.32 2.24 4.72 3.44 3.52C4.64 2.24 6.24 1.6 8 1.6C8.48 1.6 9.04 1.68 9.52 1.76C9.92 1.92 10.4 1.68 10.56 1.2C10.72 0.72 10.4 0.4 10 0.24H9.92C9.28 0.08 8.64 0 8 0C3.6 0 0 3.6 0 8.08C0 10.16 0.88 12.24 2.32 13.68C3.84 15.2 5.84 16 7.92 16C12.32 16 15.92 12.4 15.92 8C16 7.52 15.6 7.2 15.2 7.2Z"
                        fill={themeColor}></path>
                    </svg>
                    <p class="text-lg text-black leading-[1.44]">{point}</p>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>

  </div>
</section>
