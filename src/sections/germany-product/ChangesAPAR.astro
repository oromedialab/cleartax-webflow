---
/**
 * Germany Changes for AP & AR Section
 * Interactive tabbed Swiper component that highlights functional transitions for AR & AP teams.
 */
---

<section id="changes-ap-ar" class="bg-[#F3F1F9] py-16 lg:py-24 overflow-hidden w-full relative">


  <div class="lg:container mx-auto px-4 md:px-6">
    <!-- Header Grid -->
    <div class="flex flex-col lg:flex-row gap-6 items-start mb-12">
      <div class="lg:w-2/3">
        <h2 class="text-[26px] sm:text-[32px] lg:text-[44px] font-semibold text-black leading-[1.15] m-0 premium-reveal">
          What Actually Changes For <span class="text-[#655DFF]">AP & AR</span>
        </h2>
      </div>
      <div class="lg:w-1/3">
        <p class="text-base sm:text-lg text-black/80 leading-normal m-0 premium-reveal [transition-delay:150ms]">
          E-invoicing isn't just a technology project – it transforms how your accounts receivable and payable teams operate, for the better.
        </p>
      </div>
    </div>

    <!-- Tabs and Nav Buttons Flex row -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between pb-0 mb-8 gap-4 premium-reveal [transition-delay:200ms]">
      <!-- Tabs (Left) -->
      <div class="flex gap-8">
        <button 
          id="tab-ar" 
          class="relative pb-5 text-[18px] sm:text-[20px] text-left font-semibold text-black md:min-w-[240px] w-full transition-all cursor-pointer focus:outline-none bg-transparent border-0 p-0 m-0"
        >
          Accounts Receivable
          <!-- Background track line -->
          <span class="absolute bottom-0 left-0 w-full h-[3px] bg-black/8"></span>
          <!-- Active progress line -->
          <span id="progress-ar" class="progress-bar-anim absolute bottom-0 left-0 w-0 h-[3px] bg-[#655DFF]"></span>
        </button>
        <button 
          id="tab-ap" 
          class="relative pb-5 text-[18px] sm:text-[20px] leading-normal text-left font-semibold text-black/28 md:min-w-[240px] w-full hover:text-black transition-all cursor-pointer focus:outline-none bg-transparent border-0 p-0 m-0"
        >
          Accounts Payable
          <!-- Background track line -->
          <span class="absolute bottom-0 left-0 w-full h-[3px] bg-black/8"></span>
          <!-- Active progress line -->
          <span id="progress-ap" class="progress-bar-anim absolute bottom-0 left-0 w-0 h-[3px] bg-[#655DFF]"></span>
        </button>
      </div>

      <!-- Swiper Navigation (Right) -->
      <div class="flex gap-2 sm:gap-3 pb-3 sm:pb-2">
        <button 
          id="swiper-btn-prev" 
          class="w-9 h-9 sm:w-12 sm:h-12 rounded-full bg-[#EAE6F5] flex items-center justify-center text-[#2D0A4E] border-0 cursor-not-allowed focus:outline-none transition-colors"
          aria-label="Previous slide"
        >
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button 
          id="swiper-btn-next" 
          class="w-9 h-9 sm:w-12 sm:h-12 rounded-full bg-[#2D0A4E] flex items-center justify-center text-white hover:bg-[#2E186F] border-0 cursor-pointer focus:outline-none transition-colors"
          aria-label="Next slide"
        >
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Swiper Tabs Wrapper for smooth transition and equal height -->
    <div class="swiper-tabs-wrapper">
      <!-- Accounts Receivable Swiper Container -->
      <div id="swiper-ar-container" class="swiper-container-wrapper active-pane w-full premium-reveal [transition-delay:250ms]">
        <div id="swiper-ar" class="swiper !overflow-visible">
        <div class="swiper-wrapper" style="height: auto;">
          <!-- Slide 1 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #EDEBFA; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[38px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196f04313b28cc789ddd_ar-1.png" 
                    alt="DSO shortens significantly" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">DSO shortens significantly</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Customers process valid structured invoices in days, not weeks. Working capital improves directly.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 2 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #D8EFF2; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[30px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196fd6767da2cb1aff80_ar-2.png" 
                    alt="Fewer rejection cycles" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Fewer rejection cycles</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Country-specific validation catches field errors before invoices reach the customer, removing payment delays at source.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 3 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #FDF2ED; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[28px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196f022b1c37643122f0_ar-3.png" 
                    alt="ERP-connected, no manual exports" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">ERP-connected, no manual exports</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  AR workflows connect directly to your ERP and order management. No manual export-import cycles.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 4 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #ECF7ED; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[30px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196facd02d6bcc06eebe_ar-4.png" 
                    alt="Business continuity guaranteed" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Business continuity guaranteed</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Invoicing keeps running even when government portals go down. Revenue recognition stays on schedule.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Accounts Payable Swiper Container -->
    <div id="swiper-ap-container" class="swiper-container-wrapper inactive-pane w-full premium-reveal [transition-delay:250ms]">
      <div id="swiper-ap" class="swiper !overflow-visible">
        <div class="swiper-wrapper" style="height: auto;">
          <!-- Slide 1 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #EDEBFA; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[28px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196f2a4e106a5df1c023_ap-1.png" 
                    alt="Faster invoice processing" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Faster invoice processing</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Structured e-invoicing compresses the invoice cycle end to end. No manual data entry, no keying errors.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 2 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #D8EFF2; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[28px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196f749a15353ae39143_ap-2.png" 
                    alt="Early payment discount capture" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Early payment discount capture</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Real-time visibility into payables lets you optimise payment timing and capture discounts you'd otherwise miss.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 3 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #FDF2ED; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[28px] w-full">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196ffc352801f14ed7fd_ap-3.png" 
                    alt="Audit readiness built in" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Audit readiness built in</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Validation rules, approval trails, and invoice data captured automatically. No manual prep for audits, ever.
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 4 -->
          <div class="swiper-slide !h-auto flex">
            <div class="w-full rounded-xl p-7 flex flex-col justify-between" style="background-color: #ECF7ED; border: 1px solid rgba(101, 93, 255, 0.2);">
              <div>
                <div class="mb-7.5 max-w-[44px]">
                  <img 
                    src="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a21196fa20130a4b9d29035_ap-4.png" 
                    alt="Stronger supplier relationships" 
                    class="w-full h-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3 class="text-xl font-medium leading-[1.4] text-black mb-3">Stronger supplier relationships</h3>
                <p class="text-base text-black/80 leading-normal m-0">
                  Faster approvals and on-time payments improve supplier trust and your negotiating position.
                </p>
              </div>
            </div>
          </div>
    </div>
    </div>
  </div>
</section>



<style is:global>
  @keyframes tabProgressAnim {
    0% { width: 0%; }
    100% { width: 100%; }
  }
  .progress-bar-anim {
    width: 0%;
  }
  .progress-bar-anim.active {
    animation: tabProgressAnim 5000ms linear forwards;
  }
  /* Pause state when interactive elements are hovered */
  #changes-ap-ar:has(#swiper-ar:hover) .progress-bar-anim.active,
  #changes-ap-ar:has(#swiper-ap:hover) .progress-bar-anim.active,
  #changes-ap-ar:has(#swiper-btn-prev:hover) .progress-bar-anim.active,
  #changes-ap-ar:has(#swiper-btn-next:hover) .progress-bar-anim.active,
  #tab-ar:hover #progress-ar.active,
  #tab-ap:hover #progress-ap.active {
    animation-play-state: paused;
  }
  /* Ensure button elements inherit font-family from page theme */
  #changes-ap-ar button {
    font-family: inherit;
  }
  /* Swiper Tabs Wrapper for smooth height transitioned crossfade */
  .swiper-tabs-wrapper {
    position: relative;
    width: 100%;
    transition: height 350ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .swiper-container-wrapper {
    width: 100%;
    min-width: 0;
    transition: opacity 350ms ease-in-out;
  }
  .swiper-container-wrapper.active-pane {
    position: relative;
    opacity: 1;
    pointer-events: auto;
    z-index: 1;
  }
  .swiper-container-wrapper.inactive-pane {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('#changes-ap-ar');
    if (!section) return;

    const tabAR = section.querySelector('#tab-ar');
    const tabAP = section.querySelector('#tab-ap');
    const progressAR = section.querySelector('#progress-ar');
    const progressAP = section.querySelector('#progress-ap');
    const swiperARContainer = section.querySelector('#swiper-ar-container');
    const swiperAPContainer = section.querySelector('#swiper-ap-container');
    const swiperWrapper = section.querySelector('.swiper-tabs-wrapper');
    const nextBtn = section.querySelector('#swiper-btn-next');
    const prevBtn = section.querySelector('#swiper-btn-prev');

    let activeTab = 'ar';
    let arSwiper = null;
    let apSwiper = null;

    // Initialize Swiper
    // Slides do not autoplay. They only change on manual drag or navigation button clicks.
    function initSwipers() {
      if (typeof Swiper === 'undefined') {
        setTimeout(initSwipers, 50);
        return;
      }

      arSwiper = new Swiper('#swiper-ar', {
        slidesPerView: 1,
        spaceBetween: 16,
        grabCursor: true,
        breakpoints: {
          640: {
            slidesPerView: 2.15,
            spaceBetween: 20
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 24
          }
        }
      });

      apSwiper = new Swiper('#swiper-ap', {
        slidesPerView: 1,
        spaceBetween: 16,
        grabCursor: true,
        breakpoints: {
          640: {
            slidesPerView: 2.15,
            spaceBetween: 20
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 24
          }
        }
      });

      // Hook Swiper Change events to update navigation button styles
      arSwiper.on('slideChange', () => {
        updateNavButtons();
      });

      apSwiper.on('slideChange', () => {
        updateNavButtons();
      });

      // Initial updates after Swiper is fully ready
      setTimeout(() => {
        updateNavButtons();
        restartProgress();
      }, 100);
    }

    initSwipers();

    // Swiper Navigation Click Hooks
    prevBtn.addEventListener('click', () => {
      if (prevBtn.classList.contains('cursor-not-allowed')) return;
      if (activeTab === 'ar' && arSwiper) arSwiper.slidePrev();
      if (activeTab === 'ap' && apSwiper) apSwiper.slidePrev();
    });

    nextBtn.addEventListener('click', () => {
      if (nextBtn.classList.contains('cursor-not-allowed')) return;
      if (activeTab === 'ar' && arSwiper) arSwiper.slideNext();
      if (activeTab === 'ap' && apSwiper) apSwiper.slideNext();
    });

    // Update swiper buttons visual style depending on the active slide position
    function updateNavButtons() {
      const swiper = activeTab === 'ar' ? arSwiper : apSwiper;
      if (!swiper) return;

      // Update Prev Button
      if (swiper.isBeginning) {
        prevBtn.classList.remove('bg-[#2D0A4E]', 'text-white', 'hover:bg-[#2E186F]', 'cursor-pointer');
        prevBtn.classList.add('bg-[#EAE6F5]', 'text-[#2D0A4E]', 'cursor-not-allowed');
      } else {
        prevBtn.classList.add('bg-[#2D0A4E]', 'text-white', 'hover:bg-[#2E186F]', 'cursor-pointer');
        prevBtn.classList.remove('bg-[#EAE6F5]', 'text-[#2D0A4E]', 'cursor-not-allowed');
      }

      // Update Next Button
      if (swiper.isEnd) {
        nextBtn.classList.remove('bg-[#2D0A4E]', 'text-white', 'hover:bg-[#2E186F]', 'cursor-pointer');
        nextBtn.classList.add('bg-[#EAE6F5]', 'text-[#2D0A4E]', 'cursor-not-allowed');
      } else {
        nextBtn.classList.add('bg-[#2D0A4E]', 'text-white', 'hover:bg-[#2E186F]', 'cursor-pointer');
        nextBtn.classList.remove('bg-[#EAE6F5]', 'text-[#2D0A4E]', 'cursor-not-allowed');
      }
    }

    // Restart the CSS progress animation
    function restartProgress() {
      const activeBar = activeTab === 'ar' ? progressAR : progressAP;
      const inactiveBar = activeTab === 'ar' ? progressAP : progressAR;

      // Clear states
      progressAR.classList.remove('active');
      progressAP.classList.remove('active');

      // Force reflow/repaint
      void activeBar.offsetWidth;
      void inactiveBar.offsetWidth;

      // Enable animation on the active tab's bar
      activeBar.classList.add('active');
    }

    // Switch active state visuals and slider visibility
    function setTab(tab) {
      const activeContainer = activeTab === 'ar' ? swiperARContainer : swiperAPContainer;
      const inactiveContainer = activeTab === 'ar' ? swiperAPContainer : swiperARContainer;

      // Measure current and incoming heights
      const hActive = activeContainer.offsetHeight;
      const hInactive = inactiveContainer.offsetHeight;

      // Lock parent height to active height
      if (swiperWrapper) {
        swiperWrapper.style.height = `${hActive}px`;
        // Force reflow
        void swiperWrapper.offsetHeight;
        // Set to new target height to start transition
        swiperWrapper.style.height = `${hInactive}px`;
      }

      if (tab === 'ar') {
        activeTab = 'ar';
        tabAR.classList.add('text-black');
        tabAR.classList.remove('text-black/28');
        tabAP.classList.remove('text-black');
        tabAP.classList.add('text-black/28');
        
        swiperARContainer.classList.remove('inactive-pane');
        swiperARContainer.classList.add('active-pane');
        swiperAPContainer.classList.remove('active-pane');
        swiperAPContainer.classList.add('inactive-pane');

        if (arSwiper) {
          arSwiper.update();
          arSwiper.slideTo(0);
        }
      } else {
        activeTab = 'ap';
        tabAP.classList.add('text-black');
        tabAP.classList.remove('text-black/28');
        tabAR.classList.remove('text-black');
        tabAR.classList.add('text-black/28');

        swiperAPContainer.classList.remove('inactive-pane');
        swiperAPContainer.classList.add('active-pane');
        swiperARContainer.classList.remove('active-pane');
        swiperARContainer.classList.add('inactive-pane');

        if (apSwiper) {
          apSwiper.update();
          apSwiper.slideTo(0);
        }
      }

      // Reset height to auto after transition completes
      setTimeout(() => {
        if (swiperWrapper) {
          swiperWrapper.style.height = '';
        }
      }, 350);

      updateNavButtons();
      restartProgress();
    }

    tabAR.addEventListener('click', () => {
      if (activeTab !== 'ar') {
        setTab('ar');
      }
    });

    tabAP.addEventListener('click', () => {
      if (activeTab !== 'ap') {
        setTab('ap');
      }
    });

    // Auto-advance logic on animationend: toggle tabs immediately
    function handleAnimationEnd() {
      const swiperArEl = section.querySelector('#swiper-ar');
      const swiperApEl = section.querySelector('#swiper-ap');
      const isInteractiveHovered = 
        (swiperArEl && swiperArEl.matches(':hover')) ||
        (swiperApEl && swiperApEl.matches(':hover')) ||
        (tabAR && tabAR.matches(':hover')) ||
        (tabAP && tabAP.matches(':hover')) ||
        (prevBtn && prevBtn.matches(':hover')) ||
        (nextBtn && nextBtn.matches(':hover'));

      if (isInteractiveHovered) return;

      const nextTab = activeTab === 'ar' ? 'ap' : 'ar';
      setTab(nextTab);
    }

    progressAR.addEventListener('animationend', handleAnimationEnd);
    progressAP.addEventListener('animationend', handleAnimationEnd);
  });
</script>
