---
/**
 * USP Section V2 — Tailwind optimized
 * Exact visual match of Version 1 (White background, light cards).
 */
---

<section id="why-cleartax" class="bg-[#FFFFFF] py-12 lg:py-25 w-full">
    <div class="max-w-[var(--container-max)] mx-auto lg:px-6 px-4">
        <div class="text-center max-w-[856px] w-full mx-auto">
            <h2
                id="oman-title-shield"
                class="text-[26px]! sm:text-[32px]! lg:text-[44px]! font-semibold! text-black leading-[1.18]! m-0! premium-reveal"
            >
                What Germany's Mandate Requires And <span class="text-[#655DFF]"
                    >What ClearTax Covers</span
                >
            </h2>
            <p
                id="oman-subtitle-shield"
                class="lg:text-lg! text-base! font-normal! text-black/80! mt-4! premium-reveal [transition-delay:150ms]"
            >
                 Germany uses a decentralised model: direct exchange between supplier and buyer. ClearTax handles every requirement out of the box.
            </p>
        </div>

        <div class="grid grid-cols-12 gap-6 mt-12 w-full">
            <!-- Built for Your Busiest Day (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#FDF2ED] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="mt-auto flex justify-center items-end ml-auto max-w-[490px] w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-1.png"
                            alt="Speedometer"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Format
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            XRechnung · ZUGFeRD 2.x · Peppol BIS 3.0 - All mandatory structured invoice formats supported with full schema validation before transmission.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Connects to Everything (6 columns) -->
            <div
                class="col-span-6 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="relative z-10 p-5">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Transmission
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            Peppol · Email · EDI — one dashboard Every inbound and outbound channel unified. No invisible gaps, no missed invoices, no fragmented audit trail.
                        </p>
                    </div>
                    <div
                        class="flex max-w-[626px] mx-auto w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-2.png"
                            alt="Connectors"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Always-On e-Invoicing (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#ECF7ED] rounded-[16px] flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div
                        class="flex max-w-[504px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-3.png"
                            alt="Always-On"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <div class="relative z-10 p-5 pt-0">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Validation
                        </h3>
                        <p
                            class="text-balance font-normal max-w-99 leading-normal text-black/80 m-0"
                        >
                            Deep pre-transmission checks Field completeness, business rule validation, and auto-healing before an invoice ever reaches the buyer.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Zero Downtime (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#E8F5F7] rounded-[16px] flex justify-between overflow-hidden relative h-full p-5"
                >
                    <div class="relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Archival
                        </h3>
                        <p
                            class="text-base font-normal max-w-74 leading-normal text-black/80 m-0"
                        >
                            8-year GoBD-certified archival Invoices stored in immutable, structured format per §147 AO. No manual prep needed for audit readiness.
                        </p>
                    </div>
                    <div
                        class="mt-auto flex max-w-[350px] w-full tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-4.png"
                            alt="Zero Downtime"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- VAT Assurance (7 columns) -->
            <div
                class="col-span-7 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EDEBFA] rounded-[16px] p-5 gap-8 flex flex-col lg:flex-row overflow-hidden relative h-full"
                >
                    <div
                        class="flex flex-col justify-start order-2 lg:order-1 relative z-10"
                    >
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4 w-full"
                        >
                            Scope
                        </h3>
                        <p
                            class="text-base max-w-80 font-normal leading-normal text-black/80 m-0 w-full"
                        >
                            Domestic B2B & B2G transactions Covers all VAT-registered entities in Germany — both sides of every invoice, both sending and receiving.
                        </p>
                    </div>
                    <div
                        class="max-w-[293px] w-full flex items-start justify-end order-1 lg:order-2 ml-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-5.png"
                            alt="VAT Assurance"
                            class="w-full h-auto object-contain origin-top-right flex justify-center items-end pt-3"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>

            <!-- Enterprise AI Security (5 columns) -->
            <div
                class="col-span-5 max-lg:col-span-12 tilted-card min-h-[300px] premium-reveal"
            >
                <div
                    class="tilted-card-inner bg-[#EBF4FE] rounded-[16px] p-5 flex flex-col justify-between overflow-hidden relative h-full"
                >
                    <div class="mb-8 relative z-10">
                        <h3
                            class="text-[22px] leading-[1.36] font-medium text-black m-0 mb-4"
                        >
                            Security
                        </h3>
                        <p
                            class="text-base font-normal leading-normal text-black/80 m-0"
                        >
                            GDPR · ISO 27001:2022 · AWS Europe Enterprise-grade encryption at rest (AES-256), SSL in transit, role-based access, and multi-AZ data residency in Europe.
                        </p>
                    </div>
                    <div
                        class="mt-auto flex justify-center items-center pt-4 max-w-[430px] w-full mx-auto tilted-card-img-wrapper"
                    >
                        <img
                            src="/images/germany-product/why-cleartax-6.png"
                            alt="Security"
                            class="w-full h-auto object-contain"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Tilted Card Styles */
    .tilted-card {
        perspective: 1000px;
        z-index: 1;
    }
    .tilted-card-inner {
        transform-style: preserve-3d;
        will-change: transform;
        transition:
            transform 0.1s ease-out,
            box-shadow 0.3s ease; /* Fallback */
    }
    .tilted-card-img-wrapper {
        transform: translateZ(20px);
        transform-style: preserve-3d;
        backface-visibility: hidden;
    }
    .tilted-card-img-wrapper img {
        transform: translateZ(10px);
    }

    /* WEBFLOW FIX: Shielding the titles against global H2/P overrides */
    #usp-title-shield {
        font-size: 44px !important;
        line-height: 1.18 !important;
        font-weight: 600 !important;
        color: black !important;
        text-align: center !important;
        margin: 0 !important;
    }
    #usp-subtitle-shield {
        font-size: 18px !important;
        font-weight: 500 !important;
        color: black !important;
        opacity: 0.8 !important;
        text-align: center !important;
        margin-top: 16px !important;
    }
    @media (max-width: 1024px) {
        #usp-title-shield {
            font-size: 32px !important;
        }
    }
    @media (max-width: 640px) {
        #usp-title-shield {
            font-size: 26px !important;
        }
        #usp-subtitle-shield {
            font-size: 16px !important;
        }
    }
</style>

<script is:inline>
    (function () {
        let initialized = false;
        const section = document.getElementById("why-cleartax");

        function initTiltedCards() {
            if (initialized) return;
            initialized = true;

            const cards = document.querySelectorAll(".tilted-card");
            cards.forEach((card) => {
                const inner = card.querySelector(".tilted-card-inner");
                if (!inner) return;

                const rotateAmplitude = 12;
                const scaleOnHover = 1.02;

                let targetRotateX = 0,
                    targetRotateY = 0,
                    targetScale = 1;
                let currentRotateX = 0,
                    currentRotateY = 0,
                    currentScale = 1;
                let rafId = null;

                function update() {
                    currentRotateX += (targetRotateX - currentRotateX) * 0.1;
                    currentRotateY += (targetRotateY - currentRotateY) * 0.1;
                    currentScale += (targetScale - currentScale) * 0.1;
                    inner.style.transform = `rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) scale(${currentScale})`;
                    if (
                        Math.abs(targetRotateX - currentRotateX) > 0.01 ||
                        Math.abs(targetRotateY - currentRotateY) > 0.01 ||
                        Math.abs(targetScale - currentScale) > 0.001
                    ) {
                        rafId = requestAnimationFrame(update);
                    } else {
                        rafId = null;
                    }
                }

                card.addEventListener("mousemove", (e) => {
                    const rect = card.getBoundingClientRect();
                    const offsetX = e.clientX - rect.left - rect.width / 2;
                    const offsetY = e.clientY - rect.top - rect.height / 2;
                    targetRotateX =
                        (offsetY / (rect.height / 2)) * -rotateAmplitude;
                    targetRotateY =
                        (offsetX / (rect.width / 2)) * rotateAmplitude;
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseenter", () => {
                    targetScale = scaleOnHover;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });

                card.addEventListener("mouseleave", () => {
                    targetRotateX = 0;
                    targetRotateY = 0;
                    targetScale = 1;
                    if (!rafId) rafId = requestAnimationFrame(update);
                });
            });
        }

        if (section) {
            section.addEventListener("mouseenter", initTiltedCards, {
                once: true,
            });
            section.addEventListener("touchstart", initTiltedCards, {
                once: true,
            });
            if ("IntersectionObserver" in window) {
                const obs = new IntersectionObserver(
                    (entries) => {
                        if (entries[0].isIntersecting) {
                            initTiltedCards();
                            obs.disconnect();
                        }
                    },
                    { rootMargin: "100px" },
                );
                obs.observe(section);
            } else {
                initTiltedCards();
            }
        }
    })();
</script>
