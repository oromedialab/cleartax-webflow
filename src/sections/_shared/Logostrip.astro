---
/**
 * Global logos marquee V2 — Tailwind optimized
 * Different visual from the UAE marquee (white bg, multiply blend, soft mask edges).
 */
const logos = [
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc5fd373e2872bd820152_brand-1-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc6046e7426adbd019ed6_brand-2-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc60a6c38dc1440e954cd_brand-3-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc6116c38dc1440e9643c_brand-4-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc61609b3bd73c0f39c81_brand-5-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc61c3ca1726d5e2aa651_brand-6-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc623c06d0a708d98acf5_brand-7-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc628ad92208b0c0d0bcf_brand-8-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc62fe6176c452e670d85_brand-9-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc63571c2777eb595fc0a_brand-10-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc63b994e6f0061916071_brand-11-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc6410183fdb4f4d5dc99_brand-12-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc646a365fcbc02c11af3_brand-13-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc64da365fcbc02c11de4_brand-14-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc654a4df647a7bb2f894_brand-15-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc65af3eec20e67f5cd1c_brand-16-img.png",
  "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a2fc661da8cceda23ec5615_brand-17-img.png",
];

const doubled = [...logos, ...logos];
---

<section class="bg-gradient-to-b from-[#F3F1F9] to-[#FFFFFF] py-12 overflow-hidden w-full">
  <div class="max-w-[var(--container-max)] mx-auto px-4 md:px-6">
    <h2
      class="v2-logos-title text-center text-[32px] font-normal text-[#171E28] mb-8 tracking-[-0.5px] max-lg:text-2xl max-lg:mb-11 max-sm:text-xl max-sm:mb-9"
    >
      Trusted by <span class="text-[#1572ED]">5000+</span> Businesses Worldwide
    </h2>
    <div
      class="relative w-full overflow-hidden bg-transparent [mask-image:linear-gradient(to_right,transparent_0%,black_4%,black_96%,transparent_100%)] [-webkit-mask-image:linear-gradient(to_right,transparent_0%,black_4%,black_96%,transparent_100%)] group"
    >
      <div
        class="flex items-center gap-16 [zoom:1.3] w-max origin-left animate-[scroll-logos-global_45s_linear_infinite] py-2 group-hover:[animation-play-state:paused] max-lg:gap-16 max-sm:gap-12 motion-reduce:animate-none"
      >
        {
          doubled.map((src, i) => (
            <img
              src={src}
              alt={i < logos.length ? "Customer logo" : ""}
              aria-hidden={i >= logos.length}
              class="shrink-0 h-[26px] w-[86px] object-contain mix-blend-multiply transition-all duration-150 ease-in-out hover:scale-105 max-lg:h-[26px] max-lg:w-[76px] max-sm:h-14 max-sm:w-[60px]"
              loading="lazy"
              decoding="async"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  .v2-logos-title {
    text-align: center !important;
    font-size: 32px !important;
    font-weight: 400 !important;
    color: #171e28 !important;
    margin-bottom: 32px !important;
    letter-spacing: -0.5px !important;
  }
  @media (max-width: 1024px) {
    .v2-logos-title {
      font-size: 24px !important;
      margin-bottom: 44px !important;
    }
  }
  @media (max-width: 640px) {
    .v2-logos-title {
      font-size: 20px !important;
      margin-bottom: 36px !important;
    }
  }

  @keyframes scroll-logos-global {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
