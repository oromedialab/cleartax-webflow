---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfa05ecb34c38b5b8b5f54_cleartax-logo-light.png" alt="ClearTax" height="28" style="filter: brightness(0) invert(1);" />
        </a>
        <div class="footer-social">
          <p class="footer-social-label">Follow us on</p>
          <div class="footer-social-icons">
            {socials.map((s) => (
              <a href={s.href} class="footer-social-icon" aria-label={s.label}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon} />
              </a>
            ))}
          </div>
        </div>
        <div class="footer-query">
          <p class="footer-query-label">Have a query?</p>
          <a href="https://www.cleartax.com/contact-us" class="footer-query-link">Support</a>
        </div>
      </div>

      {columns.map((col) => (
        <div class="footer-col">
          <h4 class="footer-col-title" set:html={col.title} />
          <ul class="footer-links">
            {col.items.map((it) => <li><a href={it.href}>{it.label}</a></li>)}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">© 2026 ClearTax Pvt. Ltd. All rights reserved.</p>
    </div>
  </div>
</footer>

<style is:global>
  .footer { background: var(--color-dark); padding: 72px 0 0; }
  .footer-container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .footer-grid { display: grid; grid-template-columns: 220px repeat(4, 1fr); gap: 40px; }

  .footer-brand { display: flex; flex-direction: column; gap: 32px; text-align: left; }
  .footer-logo img { height: 28px; }
  .footer-social { display: flex; flex-direction: column; gap: 12px; }
  .footer-social-label { font-size: 14px; font-weight: 600; color: var(--color-white); margin: 0; }
  .footer-social-icons { display: flex; gap: 12px; }
  .footer-social-icon { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, 0.1); border-radius: 8px; color: var(--color-white); transition: background var(--transition-fast); }
  .footer-social-icon:hover { background: rgba(255, 255, 255, 0.2); }

  .footer-query { display: flex; flex-direction: column; gap: 6px; }
  .footer-query-label { font-size: 14px; font-weight: 600; color: var(--color-white); margin: 0; }
  .footer-query-link { font-size: 14px; color: var(--color-gray-400); text-decoration: underline; text-underline-offset: 3px; transition: color var(--transition-fast); }
  .footer-query-link:hover { color: var(--color-white); }

  .footer-col { display: flex; flex-direction: column; gap: 16px; }
  .footer-col-title { font-size: 15px; font-weight: 700; color: var(--color-white); margin: 0; }
  .footer-links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .footer-links a { font-size: 14px; color: var(--color-gray-400); transition: color var(--transition-fast); }
  .footer-links a:hover { color: var(--color-white); }

  .footer-bottom { margin-top: 56px; padding: 24px 0; border-top: 1px solid rgba(255, 255, 255, 0.08); }
  .footer-copyright { font-size: 13px; color: var(--color-gray-500); margin: 0; }

  @media (max-width: 1080px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); gap: 40px 32px; }
    .footer-brand { grid-column: 1 / -1; flex-direction: row; align-items: start; gap: 48px; flex-wrap: wrap; }
  }
  @media (max-width: 640px) {
    .footer { padding: 48px 0 0; }
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 36px 24px; }
    .footer-brand { flex-direction: column; gap: 24px; }
    .footer-bottom { margin-top: 40px; }
  }
</style>

