---
/**
 * Shared contact / lead form. Used by UAE + Global pages.
 * Ported from uae-landing-page/index.html:1568-1817.
 *
 * Posts to https://www.cleartax.com/f/common-lead/lead/?captcha_token=...
 * with reCAPTCHA v3 token. The reCAPTCHA script loads from the section so the
 * embed remains self-contained when pasted into Webflow.
 *
 * Per-country tuning via props: country code default, sheet name, origin label.
 */
export interface Props {
  recaptchaSiteKey?: string;
  defaultCountryCode?: string;
  sheetName?: string;
  originCountry?: string;
  thankYouUrl?: string;
  formType?: string;
  leadType?: string;
}

const {
  recaptchaSiteKey = '6Lc5ZG0mAAAAAGwClrZwtcyttcUMYDUPxg4MM4p3',
  defaultCountryCode = '+1',
  sheetName = 'uaeRAD',
  originCountry = 'UAE',
  thankYouUrl = 'https://cleartax.com/ae/en-e-invoicing/thank-you/',
  formType = 'GCC-contact-sales-form',
  leadType = 'GCC',
} = Astro.props as Props;

const countryCodes: { value: string; label: string }[] = [
  { value: '+1', label: 'USA (+1)' },
  { value: '+971', label: 'UAE (+971)' },
  { value: '+966', label: 'Saudi (+966)' },
  { value: '+33', label: 'France (+33)' },
  { value: '+968', label: 'Oman (+968)' },
  { value: '+973', label: 'Bahrain (+973)' },
  { value: '+965', label: 'Kuwait (+965)' },
  { value: '+974', label: 'Qatar (+974)' },
  { value: '+91', label: 'India (+91)' },
  { value: '+34', label: 'Spain (+34)' },
  { value: '+48', label: 'Poland (+48)' },
  { value: '+60', label: 'Malaysia (+60)' },
];

const points = [
  { icon: '🚀', title: 'Fast Onboarding', desc: 'Most enterprises go live in under 2 weeks with dedicated implementation support.' },
  { icon: '🇦🇪', title: 'UAE-Based Team', desc: 'Local implementation consultants and FTA compliance specialists in Dubai and Abu Dhabi.' },
  { icon: '🔧', title: 'Tailored Integration', desc: 'Custom-fit to your ERP and business processes — no one-size-fits-all approach.' },
];
---

<script is:inline src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}></script>

<section class="contact-section" id="contact"
  data-recaptcha-key={recaptchaSiteKey}
  data-sheet-name={sheetName}
  data-origin-country={originCountry}
  data-thankyou-url={thankYouUrl}
  data-form-type={formType}
  data-lead-type={leadType}>
  <div class="section-inner">
    <div class="contact-grid">
      <div class="contact-left">
        <div class="section-eyebrow" style="color:#A89FF0">Talk to Us</div>
        <h2 class="section-h2" style="color:white; text-align:left;">
          Ready to become<br/>
          <em style="color:#8B7EE8">FTA compliant?</em>
        </h2>
        <p class="section-sub" style="color:rgba(255,255,255,0.5); text-align:left; max-width:420px; margin: 0;">
          Speak with our UAE e-invoicing specialists. We'll assess your current setup and map out a tailored compliance roadmap — typically live within 2 weeks.
        </p>

        <div class="contact-points">
          {points.map((p) => (
            <div class="contact-point">
              <div class="cp-icon">{p.icon}</div>
              <div>
                <div class="cp-title">{p.title}</div>
                <div class="cp-desc">{p.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="form-card">
        <h3>Book a Demo</h3>
        <p>Our UAE specialists will walk you through the platform and build your compliance roadmap.</p>
        <form data-lead-form>
          <div class="fg">
            <label for="cf-name">Full Name *</label>
            <input id="cf-name" type="text" required placeholder="Ahmed Al Mansouri" data-field="name" />
          </div>

          <div class="fg">
            <label for="cf-phone">Phone Number *</label>
            <div class="fg-row">
              <div class="select-wrap">
                <select id="cf-isd" data-field="isd">
                  {countryCodes.map((c) => (
                    <option value={c.value} selected={c.value === defaultCountryCode}>{c.label}</option>
                  ))}
                </select>
                <span class="select-display" data-isd-display aria-hidden="true">{defaultCountryCode}</span>
              </div>
              <input id="cf-phone" type="tel" required placeholder="50 123 4567" data-field="phone" />
            </div>
          </div>

          <div class="fg">
            <label for="cf-email">Company Email *</label>
            <input id="cf-email" type="email" required placeholder="ahmed@company.ae" data-field="email" />
          </div>

          <div class="fg">
            <label for="cf-company">Company Name *</label>
            <input id="cf-company" type="text" required placeholder="Your company name" data-field="company" />
          </div>

          <div class="consent-row">
            <input id="cf-consent" type="checkbox" required />
            <label for="cf-consent">
              I agree to ClearTax's <a href="#">Privacy Policy</a> and <a href="#">Terms of Service</a>.
              I consent to receiving communications about ClearTax products and UAE e-invoicing updates.
            </label>
          </div>

          <button type="submit" class="btn-submit" data-submit>Book a Demo →</button>
          <p class="form-note">No spam. Just a 30-min call with our UAE specialists.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section { background: var(--color-dark); padding: 100px 0; }
  .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(99, 85, 216, 0.10);
    border: 1px solid rgba(99, 85, 216, 0.25);
    color: var(--color-purple);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 100px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .section-h2 {
    font-size: clamp(30px, 3.5vw, 46px);
    font-weight: 900;
    color: var(--color-white);
    letter-spacing: -1.2px;
    line-height: 1.18;
    margin-bottom: 16px;
  }
  .section-h2 em { font-style: normal; }
  .section-sub { font-size: 17px; color: rgba(255, 255, 255, 0.5); line-height: 1.72; margin: 0; }

  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 24px; align-items: start; }
  .contact-points { display: flex; flex-direction: column; gap: 24px; margin-top: 40px; }
  .contact-point { display: flex; gap: 16px; align-items: flex-start; }
  .cp-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(99, 85, 216, 0.15); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .cp-title { font-size: 15px; font-weight: 700; color: var(--color-white); margin-bottom: 4px; }
  .cp-desc { font-size: 13.5px; color: rgba(255, 255, 255, 0.5); line-height: 1.6; }

  .form-card {
    background: var(--color-dark-2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 40px 36px;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.3);
  }
  .form-card h3 { color: white; font-size: 24px; margin-bottom: 8px; font-weight: 800; }
  .form-card p { color: rgba(255, 255, 255, 0.5); font-size: 14.5px; margin-bottom: 30px; line-height: 1.6; }

  .fg { margin-bottom: 20px; }
  .fg label { display: block; font-size: 13px; font-weight: 600; color: rgba(255, 255, 255, 0.7); margin-bottom: 8px; }
  .fg input,
  .fg select {
    width: 100%;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    color: white;
    font-size: 14.5px;
    outline: none;
    font-family: inherit;
  }
  .fg-row { display: grid; grid-template-columns: 100px 1fr; gap: 10px; }

  .select-wrap { position: relative; width: 100%; }
  .select-wrap::after {
    content: "";
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid rgba(255, 255, 255, 0.8);
    pointer-events: none;
    z-index: 2;
  }
  .select-wrap select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
    appearance: none;
    -webkit-appearance: none;
  }
  .select-wrap select option {
    background-color: var(--color-dark-2);
    color: white;
  }
  .select-wrap .select-display {
    display: block;
    padding: 14px;
    padding-right: 24px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    color: white;
    font-size: 14.5px;
    pointer-events: none;
    z-index: 1;
  }

  .consent-row { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 24px; }
  .consent-row input[type="checkbox"] { margin-top: 4px; }
  .consent-row label { font-size: 12px; color: rgba(255, 255, 255, 0.45); line-height: 1.6; margin: 0; }
  .consent-row a { color: #A89FF0; text-decoration: none; }

  .btn-submit {
    width: 100%;
    padding: 16px;
    background: var(--grad-btn);
    border-radius: 100px;
    color: white;
    font-size: 15px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all 0.25s;
  }
  .form-note { font-size: 12px; color: rgba(255, 255, 255, 0.3); text-align: center; margin-top: 16px; }

  @media (max-width: 1024px) {
    .contact-section { padding: 48px 0; }
    .contact-grid { grid-template-columns: 1fr; gap: 24px; }
    .section-h2,
    .section-sub { text-align: left; }
    .contact-points { align-items: flex-start; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 768px) {
    .contact-section { padding: 60px 0; }
    .form-card { padding: 30px 20px; }
  }
</style>

<script is:inline>
  (function () {
    const section = document.currentScript.previousElementSibling;
    if (!section) return;
    const form = section.querySelector('[data-lead-form]');
    const isdSelect = section.querySelector('[data-field="isd"]');
    const isdDisplay = section.querySelector('[data-isd-display]');
    if (!form) return;

    if (isdSelect && isdDisplay) {
      const sync = () => { isdDisplay.textContent = isdSelect.value; };
      isdSelect.addEventListener('change', sync);
      sync();
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const btn = form.querySelector('[data-submit]');
      const originalText = btn.textContent;
      btn.textContent = 'Connecting...';
      btn.disabled = true;

      const recaptchaKey = section.getAttribute('data-recaptcha-key');
      const sheetName = section.getAttribute('data-sheet-name');
      const originCountry = section.getAttribute('data-origin-country');
      const thankYouUrl = section.getAttribute('data-thankyou-url');
      const formType = section.getAttribute('data-form-type');
      const leadType = section.getAttribute('data-lead-type');

      function readField(name) {
        const el = form.querySelector(`[data-field="${name}"]`);
        return el ? el.value : '';
      }

      function submitWithToken(token) {
        const payload = {
          lead_platforms: { google_sheet: { sheet_name: sheetName }, pardot: true, salesforce: true },
          extra_payload: { origin_country: originCountry },
          lead_data: {
            name: readField('name'),
            phone_number: readField('phone'),
            email: readField('email'),
            company_name: readField('company'),
            ISD: readField('isd'),
            form_type: formType,
            lead_type: leadType,
            lead_source_url: window.location.href,
          },
        };

        fetch(`https://www.cleartax.com/f/common-lead/lead/?captcha_token=${token}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then((response) => {
            if (response.status === 201) {
              window.location.href = thankYouUrl;
            } else {
              throw new Error('API Error');
            }
          })
          .catch(() => {
            btn.textContent = '✕ Submission Failed';
            btn.style.background = '#EF4444';
            btn.disabled = false;
            setTimeout(() => {
              btn.textContent = originalText;
              btn.style.background = '';
            }, 4000);
          });
      }

      if (typeof grecaptcha === 'undefined') {
        // Recaptcha not loaded yet — submit without token; backend will reject if required.
        submitWithToken('');
        return;
      }
      grecaptcha.ready(function () {
        grecaptcha.execute(recaptchaKey, { action: 'submit' }).then(submitWithToken);
      });
    });
  })();
</script>
