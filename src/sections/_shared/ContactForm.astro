          Ready to become<br />
          <em class="not-italic text-[#8B7EE8]">FTA compliant?</em>
        </h2>
        <p
          class="m-0 max-w-[463px] text-left lg:text-lg text-base leading-[1.4] text-black/80 premium-reveal [transition-delay:150ms]"
        >
          Speak with our UAE e-invoicing specialists. We'll assess your current
          setup and map out a tailored compliance roadmap — typically live
          within 2 weeks.
        </p>

        <div class="mt-8 lg:mt-auto flex flex-col gap-6 justify-end">
          {
            points.map((p, index) => (
              <div
                class="flex items-start lg:gap-4 gap-3 premium-reveal"
                style={`transition-delay: ${300 + index * 100}ms`}
              >
                <div class="flex h-[44px] w-[44px] shrink-0 items-start justify-center rounded-lg text-[20px] [&_svg]:h-[24px] [&_svg]:w-[24px]">
                  <Fragment set:html={p.icon} />
                </div>
                <div>
                  <div class="mb-1 text-[20px] font-semibold text-black">
                    {p.title}
                  </div>
                  <div class="text-base leading-[1.5] text-black">{p.desc}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="rounded-xl border border-[rgba(255,255,255,0.1)] bg-white lg:px-10 lg:py-[30px] px-6 py-6 shadow-[0_40px_80px_rgba(0,0,0,0.3)] lg:px-9 lg:py-10 premium-reveal [transition-delay:500ms] overflow-clip!"
      >
        <h3 class="mb-2 text-[22px] font-semibold leading-[1.36] text-black">
          Book a Demo
        </h3>
        <p class="mb-7 text-base leading-[1.5] text-black/80">
          Our UAE specialists will walk you through the platform and build your
          compliance roadmap.
        </p>

        <!-- HubSpot Form Mount Container -->
        <div id="contact" class="uae-hs-form-wrap" data-portal-id={hubspotPortalId} data-form-id={hubspotFormId} data-region={hubspotRegion}>
          <!-- Form Skeleton Loader -->
          <div id="form-skeleton" class="form-skeleton">
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div>
              <div class="skeleton-label shimmer" style="width: 100px;"></div>
              <div class="skeleton-input shimmer"></div>
            </div>
            <div class="skeleton-row-2">
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
              <div>
                <div class="skeleton-label shimmer"></div>
                <div class="skeleton-input shimmer"></div>
              </div>
            </div>
            <div class="skeleton-button shimmer"></div>
          </div>
        </div>

        <p class="mt-4 text-center text-sm text-black/80">
          No spam. Just a 30-min call with our UAE specialists.
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // HubSpot form embed with URL parameters auto-prefill
  (() => {
    let initialized = false;
    
    const initForm = () => {
      if (initialized) return;
      const container = document.getElementById("contact");
      if (!container) return;
      const portalId = container.getAttribute("data-portal-id");
      const formId = container.getAttribute("data-form-id");
      const region = container.getAttribute("data-region") || "na2";

      if (window.hbspt && window.hbspt.forms) {
        initialized = true;
        window.hbspt.forms.create({
          portalId: portalId,
          formId: formId,
          region: region,
          target: "#contact",
          onFormReady: function($form) {
            // Remove the skeleton loader
            const skeleton = document.getElementById("form-skeleton");
            if (skeleton) {
              skeleton.remove();
            }

            const formEl = ($form && $form[0]) ? $form[0] : $form;
            if (formEl && formEl.querySelector) {
              const urlParams = new URLSearchParams(window.location.search);
              const utms = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
              utms.forEach(utm => {
                const value = urlParams.get(utm);
                if (value) {
                  const input = formEl.querySelector('input[name="' + utm + '"]');
                  if (input) {
                    input.value = value;
                  }
                }
              });
            }
          }
        });
      }
    };

    const checkAndInit = () => {
      if (window.hbspt && window.hbspt.forms) {
        initForm();
      } else {
        const script = document.querySelector('script[src*="hsforms.net"]');
        if (script) {
          script.addEventListener('load', initForm);
        }
        let pollCount = 0;
        const interval = setInterval(() => {
          pollCount++;
          if (window.hbspt && window.hbspt.forms) {
            clearInterval(interval);
            initForm();
          } else if (pollCount > 100) {
            clearInterval(interval);
          }
        }, 100);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", checkAndInit);
    } else {
      checkAndInit();
    }
  })();
</script>

