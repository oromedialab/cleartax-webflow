<section class="bg-[#F3F1F9] py-[48px] lg:py-[100px]">
  <div class="mx-auto w-full max-w-[1200px] px-4 lg:px-10">
    <div class="tw-grid items-start gap-6 lg:grid-cols-[1fr_1.1fr]">
      <div class="flex flex-col h-full">
