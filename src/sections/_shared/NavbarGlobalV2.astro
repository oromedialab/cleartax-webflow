---
/**
 * Global navbar — v2. Floating-pill shell (visual reference: _shared/Navbar.astro)
 * with link dropdowns + full country grid. Tailwind utilities only.
 */
export interface NavLink {
  label: string;
  href?: string;
  dropdown?: { label: string; href: string }[];
}
export interface CountryOption {
  name: string;
  flag: string;
  href: string;
  lang?: string;
}

const links: NavLink[] = [
  {
    label: "Products",
    dropdown: [
      {
        label: "AI Reconciliation",
        href: "http://cleartax.com/global/recon-ai",
      },
      { label: "Compliance", href: "http://cleartax.com/global/compliance" },
      {
        label: "Global E-Invoicing",
        href: "https://www.cleartax.com/global/e-invoicing-solution",
      },
      {
        label: "Integration",
        href: "http://cleartax.com/global/erp-integration",
      },
      {
        label: "Scale & Security",
        href: "http://cleartax.com/global/scale-security",
      },
    ],
  },
  {
    label: "Resources",
    dropdown: [
      {
        label: "Blogs",
        href: "https://www.cleartax.com/electronic-invoicing#country-select",
      },
      { label: "Case Studies", href: "https://www.cleartax.com/case-studies" },
      {
        label: "Press Releases",
        href: "https://www.cleartax.com/ae/press",
      },
    ],
  },
  { label: "Contact Us", href: "https://www.cleartax.com/contact-us" },
  { label: "Partners", href: "https://www.cleartax.com/global/partner-program" },
];

const countries: CountryOption[] = [
  { name: "INDIA", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/649999dbc3faf054134a1e01_India_flag.png", href: "https://www.clear.in/" },
  { name: "MALAYSIA", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/649a7b4653733f5dbda826ea_malaysia%20v1.png", href: "https://www.cleartax.com/my/en" },
  { name: "USA", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/64999a14db4af851a9f7ce5b_usa%20flag.png", href: "https://www.clear.tech/" },
  {
    name: "POLAND",
    flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/64999b053b3f5248132a620d_poland%20flag.png",
    href: "https://www.cleartax.com/pl/en",
    lang: "English | Polish",
  },
  {
    name: "SAUDI ARABIA",
    flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/63e28756aeabe12df79ff5d5_Rectangle%202515530.svg",
    href: "https://www.cleartax.com/sa",
    lang: "English | العربية",
  },
  { name: "OMAN", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/63e29d499e782b5935404547_Group%201000003291.svg", href: "https://www.cleartax.com/om" },
  {
    name: "FRANCE",
    flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/64999768870655432964457d_france_flag.png",
    href: "https://www.cleartax.com/fr/en",
    lang: "English | French",
  },
  { name: "BAHRAIN", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/63e29d6c2e1ddc75a632d00f_Group%201000003292.svg", href: "https://www.cleartax.com/bh" },
  { name: "SPAIN", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/64999a546cfce1e0515f0f60_spain%20flag.png", href: "https://www.cleartax.com/es/en" },
  { name: "UAE", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/63e29d24f310792735ab4bba_Mask%20group%20(3).svg", href: "https://www.cleartax.com/ae" },
  {
    name: "SINGAPORE",
    flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/66716d4c6753fb52078bec02_singapore%20flag%203.png",
    href: "https://www.cleartax.com/sg/e-invoicing-software",
  },
  { name: "GERMANY", flag: "https://assets.clear.in/cleartax/images/1771829770_flagforflaggermanysvgrepocom1.svg", href: "https://www.cleartax.com/de/en" },
  { name: "BELGIUM", flag: "https://cdn.prod.website-files.com/6141e3720a248d2024615d96/67e3e6ae1e19488131f26dfd_belgium_flag.png", href: "https://www.cleartax.com/be/en" },
  { name: "JORDAN", flag: "https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a28fbf31fa87b7ea058b504_jordan-flag-icon%201.png", href: "https://www.cleartax.com/jo/e-invoicing-software" },
];
---

<div data-nav-root>
  <div
    class="fixed top-4 left-1/2 -translate-x-1/2 lg:w-[calc(100%-48px)] max-lg:w-[calc(100%-32px)] max-w-[1200px] lg:h-[74px] max-lg:h-14 rounded-[63px] z-[1000] p-[6px] glass-nav-outer"
    aria-label="Primary"
  >
    <div
      class="w-full h-full bg-white/95 rounded-[59px] flex! items-center justify-between pl-0 lg:pr-4 max-lg:pr-2 lg:py-2.5 max-lg:py-1.5 text-sm font-medium shadow-[0_4px_16px_rgba(0,0,0,0.06)] glass-nav-inner"
    >
      <a
        href="/"
        class="flex items-center shrink-0 lg:px-10 max-lg:px-3 lg:py-3 max-lg:py-1.5"
      >
        <img
          src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
          alt="ClearTax"
          class="lg:h-7 max-lg:h-5 w-auto"
          width="120"
          height="27"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </a>

      <ul
        class="lg:flex items-center list-none flex-1 justify-end pl-4 pr-2.5 m-0 max-lg:hidden"
        data-nav-menu
      >
        {
          links.map((l) => (
            <li
              class:list={["relative group/item", l.dropdown && "has-dropdown"]}
            >
              {l.dropdown ? (
                <>
                  <button
                    type="button"
                    data-nav-trigger
                    class="flex items-center gap-1.5 text-[#1a1a1a] text-sm font-medium px-3.5 py-4 whitespace-nowrap transition-colors hover:text-[#483C71] bg-transparent border-0 cursor-pointer font-[inherit]"
                  >
                    {l.label}
                    <svg
                      class="shrink-0 transition-transform duration-200 group-hover/item:rotate-180 group-[.active]/item:rotate-180"
                      width="10"
                      height="10"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </button>
                  <div class="absolute top-full left-1/2 -translate-x-1/2 translate-y-2.5 mt-2.5 bg-white rounded-xl shadow-[0_12px_40px_rgba(0,0,0,0.12)] py-2 min-w-[200px] opacity-0 invisible transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] z-[1001] group-hover/item:opacity-100 group-hover/item:visible group-hover/item:translate-y-0 group-[.active]/item:opacity-100 group-[.active]/item:visible group-[.active]/item:translate-y-0">
                    {l.dropdown.map((d) => (
                      <a
                        href={d.href}
                        class="tw-block px-5 py-2.5 text-sm font-medium text-[#171E28] transition-colors duration-200 no-underline hover:bg-[#F4F6F9] hover:text-[#5E46E5]"
                      >
                        {d.label}
                      </a>
                    ))}
                  </div>
                </>
              ) : (
                <a
                  href={l.href}
                  class="inline-flex items-center text-[#1a1a1a] text-sm font-medium px-3.5 py-4 whitespace-nowrap transition-colors hover:text-[#483C71] no-underline"
                >
                  {l.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-2.5 shrink-0">
        <div class="relative group/country" data-country-selector>
          <button
            type="button"
            data-country-btn
            class="inline-flex items-center lg:gap-2 max-lg:gap-1.5 lg:pl-2.5 lg:pr-3.5 lg:py-1.5 max-lg:px-2 max-lg:py-1.5 rounded-full border-[1.5px] border-[var(--color-gray-200,#e5e7eb)] bg-white text-[#1a1a1a] text-sm font-medium transition-colors duration-200 hover:bg-[var(--color-gray-50,#f9fafb)] cursor-pointer"
          >
            <span
              class="global-icon inline-flex items-center justify-center lg:w-[22px] lg:h-[22px] max-lg:w-5 max-lg:h-5 text-[#5E46E5]"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path
                  d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                ></path>
              </svg>
            </span>
            <span data-country-current class="lg:inline max-lg:hidden"
              >Global</span
            >
            <svg
              class="shrink-0 transition-transform duration-200 lg:group-hover/country:rotate-180 group-[.active]/country:rotate-180"
              width="10"
              height="6"
              viewBox="0 0 10 6"
              fill="none"
            >
              <path
                d="M1 1L5 5L9 1"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <div
            class="lg:tw-block max-lg:hidden absolute top-full right-0 w-[380px] bg-transparent pt-2.5 opacity-0 invisible pointer-events-none transition-all duration-300 z-[1001] lg:group-hover/country:opacity-100 lg:group-hover/country:visible lg:group-hover/country:pointer-events-auto group-[.active]/country:opacity-100 group-[.active]/country:visible group-[.active]/country:pointer-events-auto"
          >
            <div
              class="bg-white rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.12),0_0_0_1px_rgba(0,0,0,0.04)] px-6 py-5"
            >
              <div class="tw-grid grid-cols-2 gap-1">
                {
                  countries.map((c) => (
                    <a
                      href={c.href}
                      data-country={c.name}
                      data-flag={c.flag}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-3 px-3 py-2.5 rounded-[10px] transition-colors duration-200 no-underline text-inherit hover:bg-[var(--color-gray-50,#f9fafb)]"
                    >
                      <span class="country-flag text-lg shrink-0 w-6 text-center"><img src={c.flag} alt={`${c.name} flag`} class="inline-block w-full h-auto align-middle max-h-[16px] object-contain" /></span>
                      <div class="flex flex-col">
                        <span class="tw-block text-sm font-semibold text-[#1a1a1a] uppercase tracking-[0.2px]">
                          {c.name}
                        </span>
                        {c.lang && (
                          <span class="tw-block text-[11px] text-[var(--color-gray-400,#9ca3af)] mt-px">
                            {c.lang}
                          </span>
                        )}
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <a
          href="#contact"
          class="lg:inline-flex! max-lg:hidden! items-center gap-2 px-5 py-3 text-sm font-bold text-white! bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)] rounded-full whitespace-nowrap no-underline transition-opacity duration-200 hover:opacity-90"
        >
          Request a demo
          <svg
            width="12"
            height="12"
            viewBox="0 0 12 12"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M2 6h8M6 2l4 4-4 4"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"></path>
          </svg>
        </a>

        <button
          type="button"
          data-mobile-toggle
          aria-label="Toggle menu"
          aria-expanded="false"
          class="group/toggle lg:hidden max-lg:tw-block relative w-10 h-10 mr-1.5 bg-transparent border-0 cursor-pointer p-2"
        >
          <span
            class="tw-block absolute left-[9px] top-[13px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-all duration-300 group-[.open]/toggle:top-[19px] group-[.open]/toggle:rotate-45"
          ></span>
          <span
            class="tw-block absolute left-[9px] top-[19px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-opacity duration-200 group-[.open]/toggle:opacity-0"
          ></span>
          <span
            class="tw-block absolute left-[9px] top-[25px] w-[22px] h-0.5 bg-[#1a1a1a] rounded-sm transition-all duration-300 group-[.open]/toggle:top-[19px] group-[.open]/toggle:-rotate-45"
          ></span>
        </button>
      </div>
    </div>
  </div>

  <div
    class="lg:hidden max-lg:tw-block fixed inset-0 z-[1100] bg-white translate-x-full pointer-events-none transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] [&.open]:translate-x-0 [&.open]:pointer-events-auto flex flex-col"
    data-mobile-menu
    aria-hidden="true"
  >
    <div
      class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-gray-100,#f3f4f6)]"
    >
      <a href="/" class="flex items-center shrink-0">
        <img
          src="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
          alt="ClearTax"
          class="h-6 w-auto"
          width="120"
          height="27"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </a>
      <button
        type="button"
        data-mobile-close
        aria-label="Close menu"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-transparent border-0 cursor-pointer text-[#1a1a1a] hover:bg-[#f4f6f9] transition-colors"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <ul
      class="flex-1 overflow-y-auto flex flex-col gap-1 list-none m-0 px-4 py-4"
    >
      {
        links.map((l) => (
          <li
            class:list={[
              "relative group/mitem",
              l.dropdown && "has-dropdown-m",
            ]}
          >
            {l.dropdown ? (
              <>
                <button
                  type="button"
                  data-m-trigger
                  class="flex items-center justify-between w-full gap-1.5 text-[#1a1a1a] text-base font-medium px-4 py-3.5 whitespace-nowrap bg-transparent border-0 cursor-pointer font-[inherit] rounded-xl hover:bg-[#f4f6f9]"
                >
                  <span>{l.label}</span>
                  <svg
                    class="shrink-0 transition-transform duration-300 group-[.active]/mitem:rotate-180"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </button>
                <div class="tw-grid grid-rows-[0fr] group-[.active]/mitem:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out">
                  <div class="overflow-hidden">
                    <div class="pl-3 pt-1 pb-2 flex flex-col">
                      {l.dropdown.map((d) => (
                        <a
                          href={d.href}
                          class="tw-block px-4 py-2.5 text-sm font-medium text-[#171E28] rounded-lg no-underline hover:bg-[#f4f6f9] hover:text-[#5E46E5]"
                        >
                          {d.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </>
            ) : (
              <a
                href={l.href}
                class="v2-nav-link tw-block px-4 py-3.5 text-base font-medium text-[#171E28] rounded-xl no-underline hover:bg-[#f4f6f9]"
              >
                {l.label}
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <div class="px-5 py-4 border-t border-[var(--color-gray-100,#f3f4f6)]">
      <a
        href="#contact"
        class="inline-flex items-center justify-center w-full gap-2 px-5 py-3.5 text-sm font-bold text-white! bg-[linear-gradient(90deg,#110072_0%,#7A5698_100%)] rounded-full no-underline transition-opacity duration-200 hover:opacity-90"
      >
        Request a demo
        <svg
          width="14"
          height="14"
          viewBox="0 0 12 12"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 6h8M6 2l4 4-4 4"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <div
    class="lg:hidden max-lg:tw-block fixed inset-0 z-[1199] bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 [&.open]:opacity-100 [&.open]:pointer-events-auto"
    data-country-backdrop
    aria-hidden="true"
  >
  </div>

  <div
    class="lg:hidden max-lg:tw-block fixed inset-x-0 bottom-0 z-[1200] translate-y-full transition-transform duration-350 ease-[cubic-bezier(0.16,1,0.3,1)] [&.open]:translate-y-0 bg-white rounded-t-3xl shadow-[0_-12px_40px_rgba(0,0,0,0.18)] max-h-[85vh] flex flex-col"
    data-country-sheet
    role="dialog"
    aria-modal="true"
    aria-label="Select country"
    aria-hidden="true"
  >
    <div class="flex flex-col items-center pt-3 pb-1">
      <span
        class="tw-block w-9 h-1 rounded-full bg-[var(--color-gray-200,#e5e7eb)]"
        aria-hidden="true"></span>
    </div>
    <div
      class="flex items-center justify-between px-5 py-3 border-b border-[var(--color-gray-100,#f3f4f6)]"
    >
      <span class="text-base font-semibold text-[#1a1a1a]">Select country</span>
      <button
        type="button"
        data-country-close
        aria-label="Close country selector"
        class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-transparent border-0 cursor-pointer text-[#1a1a1a] hover:bg-[#f4f6f9] transition-colors"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto px-4 py-3">
      <div class="tw-grid grid-cols-2 gap-1">
        {
          countries.map((c) => (
            <a
              href={c.href}
              data-country-sheet-option
              data-country={c.name}
              data-flag={c.flag}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 px-3 py-3 rounded-[10px] transition-colors duration-200 no-underline text-inherit hover:bg-[var(--color-gray-50,#f9fafb)]"
            >
              <span class="country-flag text-lg shrink-0 w-6 text-center"><img src={c.flag} alt={`${c.name} flag`} class="inline-block w-full h-auto align-middle max-h-[16px] object-contain" /></span>
              <div class="flex flex-col">
                <span class="tw-block text-sm font-semibold text-[#1a1a1a] uppercase tracking-[0.2px]">
                  {c.name}
                </span>
                {c.lang && (
                  <span class="tw-block text-[11px] text-[var(--color-gray-400,#9ca3af)] mt-px">
                    {c.lang}
                  </span>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const navbar = document.querySelector("[data-nav-root]");
    if (!navbar) return;
    const mobileToggle = navbar.querySelector("[data-mobile-toggle]");
    const mobileMenu = navbar.querySelector("[data-mobile-menu]");
    const mobileClose = navbar.querySelector("[data-mobile-close]");
    const dropdownItems = navbar.querySelectorAll(".has-dropdown");
    const mDropdownItems = navbar.querySelectorAll(".has-dropdown-m");
    const countrySelector = navbar.querySelector("[data-country-selector]");
    const countrySheet = navbar.querySelector("[data-country-sheet]");
    const countryBackdrop = navbar.querySelector("[data-country-backdrop]");
    const countrySheetClose = navbar.querySelector("[data-country-close]");

    let scrollLockCount = 0;
    const lockScroll = () => {
      scrollLockCount += 1;
      if (scrollLockCount === 1) document.body.style.overflow = "hidden";
    };
    const unlockScroll = () => {
      scrollLockCount = Math.max(0, scrollLockCount - 1);
      if (scrollLockCount === 0) document.body.style.overflow = "";
    };

    const setMenuOpen = (open) => {
      if (!mobileMenu) return;
      const wasOpen = mobileMenu.classList.contains("open");
      if (open === wasOpen) return;
      mobileMenu.classList.toggle("open", open);
      mobileMenu.setAttribute("aria-hidden", open ? "false" : "true");
      mobileToggle?.classList.toggle("open", open);
      mobileToggle?.setAttribute("aria-expanded", open ? "true" : "false");
      if (open) lockScroll();
      else unlockScroll();
    };

    const setSheetOpen = (open) => {
      if (!countrySheet || !countryBackdrop) return;
      const wasOpen = countrySheet.classList.contains("open");
      if (open === wasOpen) return;
      countrySheet.classList.toggle("open", open);
      countryBackdrop.classList.toggle("open", open);
      countrySheet.setAttribute("aria-hidden", open ? "false" : "true");
      if (open) lockScroll();
      else unlockScroll();
    };

    window.addEventListener("scroll", () => {
      navbar.classList.toggle("scrolled", window.scrollY > 10);
    });

    dropdownItems.forEach((item) => {
      const btn = item.querySelector("[data-nav-trigger]");
      if (!btn) return;
      btn.addEventListener("click", (e) => {
        if (window.innerWidth <= 1024) return;
        e.preventDefault();
        const isActive = item.classList.contains("active");
        dropdownItems.forEach((i) => i.classList.remove("active"));
        item.classList.toggle("active", !isActive);
      });
    });

    mDropdownItems.forEach((item) => {
      const btn = item.querySelector("[data-m-trigger]");
      if (!btn) return;
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        item.classList.toggle("active");
      });
    });

    if (countrySelector) {
      const countryBtn = countrySelector.querySelector("[data-country-btn]");
      const currentLabel = countrySelector.querySelector(
        "[data-country-current]",
      );
      const globeIcon = countryBtn?.querySelector(".global-icon");
      const options = countrySelector.querySelectorAll("[data-country]");

      countryBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        if (window.innerWidth <= 1024) {
          setSheetOpen(!countrySheet?.classList.contains("open"));
          return;
        }
        countrySelector.classList.toggle("active");
      });

      options.forEach((option) => {
        option.addEventListener("click", (e) => {
          e.preventDefault();
          const flag = option.getAttribute("data-flag");
          const name = option.getAttribute("data-country");
          if (globeIcon)
            globeIcon.innerHTML = `<span class="country-flag text-lg shrink-0 w-6 text-center"><img src="${flag}" alt="${name} flag" class="inline-block w-full h-auto align-middle max-h-[16px] object-contain" /></span>`;
          if (currentLabel) currentLabel.textContent = name;
          countrySelector.classList.remove("active");
          const href = option.getAttribute("href");
          const target = option.getAttribute("target");
          if (href) {
            if (target === "_blank") {
              window.open(href, "_blank");
            } else {
              window.location.href = href;
            }
          }
        });
      });
    }

    if (countrySheet) {
      const sheetOptions = countrySheet.querySelectorAll(
        "[data-country-sheet-option]",
      );
      sheetOptions.forEach((option) => {
        option.addEventListener("click", (e) => {
          e.preventDefault();
          setSheetOpen(false);
          const href = option.getAttribute("href");
          const target = option.getAttribute("target");
          if (href) {
            if (target === "_blank") {
              window.open(href, "_blank");
            } else {
              window.location.href = href;
            }
          }
        });
      });
    }

    countrySheetClose?.addEventListener("click", () => setSheetOpen(false));
    countryBackdrop?.addEventListener("click", () => setSheetOpen(false));

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".has-dropdown")) {
        dropdownItems.forEach((item) => item.classList.remove("active"));
      }
      if (countrySelector && !e.target.closest("[data-country-selector]")) {
        countrySelector.classList.remove("active");
      }
    });

    mobileToggle?.addEventListener("click", () => {
      setMenuOpen(!mobileMenu?.classList.contains("open"));
    });
    mobileClose?.addEventListener("click", () => setMenuOpen(false));

    mobileMenu?.addEventListener("click", (e) => {
      const link = e.target.closest("a[href]");
      if (!link) return;
      setMenuOpen(false);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      dropdownItems.forEach((item) => item.classList.remove("active"));
      countrySelector?.classList.remove("active");
      setSheetOpen(false);
      setMenuOpen(false);
    });

    function handleTicker() {
      const ticker = document.getElementById("ct-announcement-ticker-inner");
      const main = document.getElementById("main");
      const hero = document.getElementById("hero");
      const navContainer = navbar.querySelector(".glass-nav-outer");
      if (!ticker) return;

      const isVisible = !!(ticker.offsetWidth || ticker.offsetHeight || ticker.getClientRects().length);
      if (isVisible) {
        const tickerHeight = ticker.offsetHeight;
        const isInsideHero = hero && hero.contains(ticker);

        if (isInsideHero) {
          if (ticker.style.marginTop !== "76px") {
            ticker.style.marginTop = "76px";
          }
          if (navContainer) {
            navContainer.style.top = "";
          }
          if (main) {
            main.style.marginTop = "";
          }
        } else {
          if (ticker.style.marginTop !== "") {
            ticker.style.marginTop = "";
          }
          if (main) {
            main.style.marginTop = tickerHeight + "px";
          }
          if (navContainer) {
            const tickerRect = ticker.getBoundingClientRect();
            const isStickyOrFixed = window.scrollY > 5 && tickerRect.top > -10;
            if (isStickyOrFixed) {
              navContainer.style.top = (tickerHeight + 16) + "px";
            } else {
              if (window.scrollY < tickerHeight) {
                navContainer.style.top = (tickerHeight + 16 - window.scrollY) + "px";
              } else {
                navContainer.style.top = "16px";
              }
            }
          }
        }
      } else {
        if (ticker) {
          ticker.style.marginTop = "";
        }
        if (main) {
          main.style.marginTop = "";
        }
        if (navContainer) {
          navContainer.style.top = "";
        }
      }
    }

    window.addEventListener("scroll", handleTicker);
    window.addEventListener("resize", handleTicker);
    if (typeof MutationObserver !== "undefined") {
      const observer = new MutationObserver(handleTicker);
      observer.observe(document.body, { childList: true, subtree: true, attributes: true });
    }
    handleTicker();
  })();
</script>
