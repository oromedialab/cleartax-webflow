---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/uae.css";
import Navbar from "../sections/_shared/Navbar.astro";
import HeroUAE from "../sections/uae/HeroUAE.astro";
import LogosStrip from "../sections/uae/LogosStrip.astro";
import WhyCleartax from "../sections/uae/WhyCleartax.astro";
import CaseStudies from "../sections/uae/CaseStudies.astro";
import ContactForm from "../sections/_shared/ContactFormLead.astro";
import Scale from "../sections/uae/Scale.astro";
import FAQ from "../sections/uae/FAQ.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax UAE — E-Invoicing Compliance Solution</title>
    <meta
      name="description"
      content="Stay compliant with UAE's FTA-mandated e-invoicing regulations. ClearTax helps UAE businesses automate, generate, and submit e-invoices seamlessly."
    />
    <meta content="noindex, nofollow" name="robots"/>
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="preload" as="image" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/69fb0e1e59fcac212140457b_hero-v2.png" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="shortcut icon" type="image/png" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />
    <link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />

    <!-- Premium Interactions -->
    <script is:inline>
      (function() {
        document.documentElement.classList.add('js-enabled');
        
        // 1. Critical setup & CMP (Immediate but defensive)
        const setupCritical = () => {
          const elements = document.querySelectorAll('.premium-reveal, .blur-reveal, .clip-reveal');
          elements.forEach(el => el.classList.add('is-ready'));

          // Load Usercentrics CMP (Critical for consent-aware deferral)
          try {
            if (!document.getElementById('usercentrics-cmp')) {
              const cmpBlocker = document.createElement('script');
              cmpBlocker.src = "https://web.cmp.usercentrics.eu/modules/autoblocker.js";
              document.head.appendChild(cmpBlocker);

              const cmpLoader = document.createElement('script');
              cmpLoader.id = "usercentrics-cmp";
              cmpLoader.src = "https://web.cmp.usercentrics.eu/ui/loader.js";
              cmpLoader.setAttribute('data-settings-id', 'utqqyaEbvbzrTk');
              cmpLoader.async = true;
              document.head.appendChild(cmpLoader);
            }
          } catch (e) { console.error('CMP load failed', e); }

          // 2. Scroll Unlocker Safety (Ensures page is always scrollable)
          try {
            document.documentElement.style.overflow = 'auto';
            document.body.style.overflow = 'auto';
            // Ensure no other scripts locked it
            setTimeout(() => {
              if (window.getComputedStyle(document.body).overflow === 'hidden') {
                document.body.style.overflow = 'auto';
              }
            }, 500);
          } catch (e) {}

          // Reveal Observer
          try {
            const revealObserver = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  revealObserver.unobserve(entry.target);
                }
              });
            }, { threshold: 0.1 });
            elements.forEach(el => revealObserver.observe(el));
          } catch (e) { console.error('Observer init failed', e); }
        };

        // 2. Deferred Non-Critical JS & Tracking (Load on interaction/idle)
        const setupDeferred = () => {
          if (window.DEFERRED_LOADED) return;
          window.DEFERRED_LOADED = true;

          // Load Google Tag Manager
          try {
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-P5NDQXGH');
          } catch (e) { console.error('GTM load failed', e); }

          // Load Swiper Resources
          try {
            if (!document.querySelector('link[href*="swiper-bundle"]')) {
              const swiperCss = document.createElement('link');
              swiperCss.rel = 'stylesheet';
              swiperCss.href = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css";
              document.head.appendChild(swiperCss);
            }
          } catch (e) { console.error('Swiper CSS failed', e); }

          // Load Aura and Scroll Progress (already defined in uae.astro)
          try {
            const aura = document.querySelector('.ambient-aura');
            if (aura) aura.classList.add('is-active');
            
            window.addEventListener('scroll', () => {
              const progress = document.getElementById('scroll-progress');
              if (progress) {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = (winScroll / height) * 100;
                progress.style.width = scrolled + "%";
              }
            }, { passive: true });
          } catch (e) { console.error('UI Deferral failed', e); }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setupCritical);
        } else {
          setupCritical();
        }

        // Interaction Listeners for Deferral
        ['mousemove', 'touchstart', 'scroll', 'keydown'].forEach(ev => {
          window.addEventListener(ev, setupDeferred, { once: true, passive: true });
        });
      })();
    </script>
  </head>
  <body class="bg-[#FCFCFD]">
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P5NDQXGH"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
    <div class="ambient-aura"></div>
    <div id="scroll-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-[#110072] to-[#7A5698] z-[100] w-0 transition-[width] duration-150 ease-out"></div>
    <Navbar countryLabel="UAE" />
    <HeroUAE />
    <LogosStrip />
    <WhyCleartax />
    <CaseStudies />
    <Scale />
    <ContactForm
      sheetName="uaeRAD"
      originCountry="UAE"
      thankYouUrl="https://www.cleartax.com/thank-you"
    />
    <FAQ />
  </body>
</html>