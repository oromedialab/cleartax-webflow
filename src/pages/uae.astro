---
import Navbar from '../sections/_shared/Navbar.astro';
import HeroUAE from '../sections/uae/HeroUAE.astro';
import LogosStrip from '../sections/uae/LogosStrip.astro';
import WhyCleartax from '../sections/uae/WhyCleartax.astro';
import CaseStudies from '../sections/uae/CaseStudies.astro';
import Platform from '../sections/uae/Platform.astro';
import Security from '../sections/uae/Security.astro';
import ContactForm from '../sections/_shared/ContactForm.astro';
import FAQ from '../sections/uae/FAQ.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax UAE — E-Invoicing Compliance Solution</title>
    <meta name="description" content="Stay compliant with UAE's FTA-mandated e-invoicing regulations. ClearTax helps UAE businesses automate, generate, and submit e-invoices seamlessly." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/shared.css" />
    <link rel="stylesheet" href="/css/uae.css" />
  </head>
  <body>
    <Navbar countryLabel="UAE" />
    <HeroUAE />
    <LogosStrip />
    <WhyCleartax />
    <CaseStudies />
    <Platform />
    <Security />
    <ContactForm
      sheetName="uaeRAD"
      originCountry="UAE"
      thankYouUrl="https://cleartax.com/ae/en-e-invoicing/thank-you/"
    />
    <FAQ />
  </body>
</html>
