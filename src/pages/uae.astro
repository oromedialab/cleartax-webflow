---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/uae.css";
import Navbar from "../sections/_shared/Navbar.astro";
import HeroUAE from "../sections/uae/HeroUAE.astro";
import LogosStrip from "../sections/uae/LogosStrip.astro";
import WhyCleartax from "../sections/uae/WhyCleartax.astro";
import CaseStudies from "../sections/uae/CaseStudies.astro";
import ContactForm from "../sections/_shared/ContactForm.astro";
import Scale from "../sections/uae/Scale.astro";
import FAQ from "../sections/uae/FAQ.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax UAE — E-Invoicing Compliance Solution</title>
    <meta
      name="description"
      content="Stay compliant with UAE's FTA-mandated e-invoicing regulations. ClearTax helps UAE businesses automate, generate, and submit e-invoices seamlessly."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#FCFCFD]">
    <div class="ambient-aura"></div>
    <div id="scroll-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-[#110072] to-[#7A5698] z-[100] w-0 transition-[width] duration-150 ease-out"></div>
    <Navbar countryLabel="UAE" />
    <HeroUAE />
    <LogosStrip />
    <WhyCleartax />
    <CaseStudies />
    <Scale />
    <ContactForm
      sheetName="uaeRAD"
      originCountry="UAE"
      thankYouUrl="https://cleartax.com/ae/en-e-invoicing/thank-you/"
    />
    <FAQ />

    <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
    <script is:inline>
      // 1. Lenis Smooth Scroll
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true
      });
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // 2. Ambient Aura
      const aura = document.querySelector('.ambient-aura');
      
      let mouseX = 0, mouseY = 0;
      let auraX = 0, auraY = 0;

      window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      function updateInteractive() {
        // Very smooth follow for aura
        auraX += (mouseX - auraX) * 0.05;
        auraY += (mouseY - auraY) * 0.05;
        if (aura) aura.style.left = `${auraX}px`;
        if (aura) aura.style.top = `${auraY}px`;

        requestAnimationFrame(updateInteractive);
      }
      updateInteractive();

      // 3. Intersection Observer for Premium Reveals
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });

      document.querySelectorAll('.premium-reveal, .blur-reveal, .svg-draw-reveal, .clip-reveal').forEach((el) => {
        revealObserver.observe(el);
      });

      // Scroll Progress Bar
      const progress = document.getElementById('scroll-progress');
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        if (progress) progress.style.width = scrolled + "%";
      });
    </script>
  </body>
</html>
