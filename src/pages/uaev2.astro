---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/uaev2.css";
import Navbar from "../sections/_shared/Navbar.astro";
import HeroUAE from "../sections/uaev2/HeroUAE.astro";
import LogosStrip from "../sections/uaev2/LogosStrip.astro";
import WhyCleartax from "../sections/uaev2/WhyCleartax.astro";
import CaseStudies from "../sections/uaev2/CaseStudies.astro";
import ContactForm from "../sections/_shared/ContactForm.astro";
import Scale from "../sections/uaev2/Scale.astro";
import FAQ from "../sections/uaev2/FAQ.astro";
import FooterUAE from "../sections/_shared/FooterUAE.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax UAE v2 — E-Invoicing Compliance Solution</title>
    <meta
      name="description"
      content="Stay compliant with UAE's FTA-mandated e-invoicing regulations. ClearTax helps UAE businesses automate, generate, and submit e-invoices seamlessly."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <!-- Preconnect to HubSpot CDNs -->
    <link rel="preconnect" href="https://js-na2.hsforms.net" />
    <link rel="preconnect" href="https://forms.hsforms.com" />
    <link rel="preconnect" href="https://forms-na2.hsforms.com" />

    <!-- HubSpot Embed Script -->
    <script is:inline defer src="https://js-na2.hsforms.net/forms/embed/v2.js"></script>
  </head>
  <body>
    <Navbar countryLabel="UAE" />
    <HeroUAE />
    <LogosStrip />
    <WhyCleartax />
    <CaseStudies />
    <Scale />
    <ContactForm />
    <FAQ />
    <FooterUAE />
  </body>
</html>
