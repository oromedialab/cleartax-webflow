---
import NavbarGlobal from '../sections/global/NavbarGlobal.astro';
import HeroGlobal from '../sections/global/HeroGlobal.astro';
import LogosStripGlobal from '../sections/global/LogosStripGlobal.astro';
import USPDark from '../sections/global/USPDark.astro';
import ScaleStats from '../sections/global/ScaleStats.astro';
import SeamlessIntegration from '../sections/global/SeamlessIntegration.astro';
import TrustedLeaders from '../sections/global/TrustedLeaders.astro';
import EnterpriseSecurity from '../sections/global/EnterpriseSecurity.astro';
import ContactGlobal from '../sections/global/ContactGlobal.astro';
import Footer from '../sections/_shared/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax — Global E-Invoicing Compliance Platform</title>
    <meta name="description" content="Continuous compliance platform for global e-invoicing. Trusted by 5000+ enterprises. Scale, security and reliability for enterprise tax operations." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/shared.css" />
    <link rel="stylesheet" href="/css/global.css" />
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body>
    <NavbarGlobal />
    <HeroGlobal />
    <LogosStripGlobal />
    <USPDark />
    <ScaleStats />
    <SeamlessIntegration />
    <TrustedLeaders />
    <EnterpriseSecurity />
    <ContactGlobal />
    <Footer />
  </body>
</html>
