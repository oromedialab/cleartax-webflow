---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/global-mandate-v2.css";
import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import HeroGlobalV2WithForm from "../sections/global/HeroGlobalV2WithForm.astro";
import SeamlessIntegration from "../sections/global/SeamlessIntegration.astro";
import TrustedLeadersV2 from "../sections/global/TrustedLeadersV2.astro";
import Footer from "../sections/_shared/Footer.astro";
import Mandate from "../sections/global/Mandate.astro";
import LogosStripGlobalV2 from "../sections/_shared/LogosStripGlobalV2.astro";
import USPDarkV2 from "../sections/global/USPDarkV2.astro";
import VideoSection from "../sections/global/VideoSection.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax — Global E-Invoicing Compliance Platform</title>
    <meta
      name="description"
      content="Simplify invoicing with ClearTax’s global e-invoicing solution. Automate invoice workflows, support country-specific mandates, integrate with your existing ERP, and streamline cross-border invoicing operations."
    />
    <meta
      name="keywords"
      content="global e-invoicing solution, international e-invoicing solution, global e-invoicing compliance, e invoicing system, global e-invoicing platform, e invoicing solutions, e invoicing solution providers, e invoicing software solutions, e invoicing software, cleartax e invoice solution"
    />
    <meta content="noindex, nofollow" name="robots" />
    <link
      rel="shortcut icon"
      type="image/png"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="256x256"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
    />
    <link
      rel="apple-touch-icon"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <!-- Preload critical above-the-fold assets -->
    <link
      rel="preload"
      href="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
      as="image"
      type="image/svg+xml"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb0cf19b34f198b94079cc_globe.webp"
      as="image"
      type="image/webp"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69eb0cf1c632b7e1def5a205_globe-gradient.webp"
      as="image"
      type="image/webp"
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="https://img.youtube.com/vi/UX0Yt61EdfY/maxresdefault.jpg"
      as="image"
      type="image/jpeg"
      fetchpriority="high"
    />

    <!-- Deferred script loader for performance -->
    <script is:inline>
      (function () {
        let scriptsLoaded = false;
        function loadHeavyScripts() {
          if (scriptsLoaded) return;
          scriptsLoaded = true;

          // Remove event listeners
          triggerEvents.forEach((e) =>
            window.removeEventListener(e, loadHeavyScripts, { passive: true }),
          );

          // Load Google Tag Manager
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != "dataLayer" ? "&l=" + l : "";
            j.async = true;
            j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, "script", "dataLayer", "GTM-P5NDQXGH");

          // Load Usercentrics autoblocker
          var blockScript = document.createElement("script");
          blockScript.src =
            "https://web.cmp.usercentrics.eu/modules/autoblocker.js";
          document.head.appendChild(blockScript);

          // Load Usercentrics loader
          var cmpScript = document.createElement("script");
          cmpScript.id = "usercentrics-cmp";
          cmpScript.src = "https://web.cmp.usercentrics.eu/ui/loader.js";
          cmpScript.setAttribute("data-settings-id", "utqqyaEbvbzrTk");
          cmpScript.async = true;
          document.head.appendChild(cmpScript);
        }

        const triggerEvents = [
          "mouseover",
          "mouseenter",
          "mousemove",
          "touchstart",
          "scroll",
          "keydown",
        ];
        triggerEvents.forEach((e) =>
          window.addEventListener(e, loadHeavyScripts, { passive: true }),
        );

        // Safety timeout to ensure scripts load even without interaction (e.g. for crawlers)
        setTimeout(loadHeavyScripts, 4000);

        // Clean URL hash on anchor link clicks & initial landing
        const setupHashCleaner = () => {
          try {
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
              anchor.addEventListener('click', function(e) {
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                  e.preventDefault();
                  targetElement.scrollIntoView({ behavior: 'smooth' });
                  history.pushState(null, document.title, window.location.pathname + window.location.search);
                }
              });
            });

            if (window.location.hash) {
              setTimeout(() => {
                history.replaceState(null, document.title, window.location.pathname + window.location.search);
              }, 1000);
            }
          } catch (e) { console.error('Anchor hash handler failed', e); }
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", setupHashCleaner);
        } else {
          setupHashCleaner();
        }
      })();
    </script>
    <!-- Preconnect to HubSpot CDNs -->
    <link rel="preconnect" href="https://js-na2.hsforms.net" />
    <link rel="preconnect" href="https://forms.hsforms.com" />
    <link rel="preconnect" href="https://forms-na2.hsforms.com" />

    <!-- HubSpot Embed Script -->
    <script is:inline src="https://js-na2.hsforms.net/forms/embed/v2.js"></script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-P5NDQXGH"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <NavbarGlobalV2 />
    <HeroGlobalV2WithForm />
    <LogosStripGlobalV2 />
    <VideoSection />
    <USPDarkV2 />
    <!-- <ScaleStats /> -->
    <Mandate />
    <SeamlessIntegration />
    <TrustedLeadersV2 />
    <!-- <ContactGlobalV2 /> -->
    <Footer />
  </body>
</html>
