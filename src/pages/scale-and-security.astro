---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/scale-and-security.css";
import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import Hero from "../sections/scale-and-security/Hero.astro";
import ScaleStats from "../sections/scale-and-security/ScaleStats.astro";
import SecurityFeatures from "../sections/scale-and-security/SecurityFeatures.astro";
import ContactForm from "../sections/_shared/ContactForm.astro";
import Footer from "../sections/_shared/Footer.astro";
import LogoStripScale from "../sections/scale-and-security/LogoStripScale.astro";
import Infrastructure from "../sections/scale-and-security/Infrastructure.astro";
import ContactFormScale from "../sections/_shared/ContactFormScale.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax — Scale & Security for Enterprise E-Invoicing</title>
    <meta
      name="description"
      content="The most robust and secure e-invoicing platform for global enterprises. Built for massive scale, 99.99% uptime, and SOC2 compliance."
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="shortcut icon" type="image/png" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />
    <link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />


    <!-- Premium Interactions -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add("js-enabled");

        const setup = () => {
          const elements = document.querySelectorAll(
            ".premium-reveal, .blur-reveal, .clip-reveal",
          );
          elements.forEach((el) => el.classList.add("is-ready"));

          // 1. Reveal Observer
          try {
            const revealObserver = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    revealObserver.unobserve(entry.target);
                  }
                });
              },
              { threshold: 0.1 },
            );
            elements.forEach((el) => revealObserver.observe(el));
          } catch (e) {
            console.error("Observer init failed", e);
          }
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", setup);
        } else {
          setup();
        }
      })();
    </script>

    <!-- Preconnect to HubSpot CDNs -->
    <link rel="preconnect" href="https://js-na2.hsforms.net" />
    <link rel="preconnect" href="https://forms.hsforms.com" />
    <link rel="preconnect" href="https://forms-na2.hsforms.com" />

    <!-- HubSpot Embed Script -->
    <script charset="utf-8" type="text/javascript" src="https://js-na2.hsforms.net/forms/embed/v2.js" is:inline async></script>
  </head>
  <body class="bg-white">
    <NavbarGlobalV2 />
    <main>
      <Hero />
      <LogoStripScale />
      <ScaleStats />
      <Infrastructure />
      <SecurityFeatures />
      <div id="contact">
        <ContactFormScale />
      </div>
    </main>
    <Footer />
  </body>
</html>
