---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/scale-and-security.css";
import Navbar from "../sections/_shared/Navbar.astro";
import Hero from "../sections/scale-and-security/Hero.astro";
import ScaleStats from "../sections/scale-and-security/ScaleStats.astro";
import SecurityFeatures from "../sections/scale-and-security/SecurityFeatures.astro";
import ContactForm from "../sections/_shared/ContactForm.astro";
import Footer from "../sections/_shared/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax — Scale & Security for Enterprise E-Invoicing</title>
    <meta
      name="description"
      content="The most robust and secure e-invoicing platform for global enterprises. Built for massive scale, 99.99% uptime, and SOC2 compliance."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    
    <!-- Premium Interactions -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1.1.13/dist/lenis.min.js"></script>
    <script is:inline>
      (function() {
        document.documentElement.classList.add('js-enabled');
        
        const setup = () => {
          const elements = document.querySelectorAll('.premium-reveal, .blur-reveal, .clip-reveal');
          elements.forEach(el => el.classList.add('is-ready'));

          // 1. Lenis Smooth Scroll
          try {
            if (typeof Lenis !== 'undefined') {
              const lenis = new Lenis({
                duration: 1.2,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                smoothWheel: true
              });
              function raf(time) {
                lenis.raf(time);
                requestAnimationFrame(raf);
              }
              requestAnimationFrame(raf);
            }
          } catch (e) { console.error('Lenis init failed', e); }

          // 2. Reveal Observer
          try {
            const revealObserver = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  revealObserver.unobserve(entry.target);
                }
              });
            }, { threshold: 0.1 });
            elements.forEach(el => revealObserver.observe(el));
          } catch (e) { console.error('Observer init failed', e); }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setup);
        } else {
          setup();
        }
      })();
    </script>
  </head>
  <body class="bg-white font-['Inter',sans-serif]">
    <Navbar countryLabel="Global" />
    <main>
      <Hero />
      <ScaleStats />
      <SecurityFeatures />
      <div id="contact">
        <ContactForm
          sheetName="globalRAD"
          originCountry="Global"
          thankYouUrl="/thankyou"
        />
      </div>
    </main>
    <Footer />
  </body>
</html>
