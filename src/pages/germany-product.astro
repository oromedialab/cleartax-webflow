---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/germany-product.css";

import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import Hero from "../sections/germany-product/Hero.astro";
import Logostrip from "../sections/_shared/LogosStripGlobalV2.astro";
import WhyCleartax from "../sections/germany-product/WhyCleartax.astro";
import ChangesAPAR from "../sections/germany-product/ChangesAPAR.astro";
import Integrations from "../sections/germany-product/Integrations.astro";
import FAQ from "../sections/germany-product/GermanyFAQ.astro";
import GermanyInfra from "../sections/germany-product/GermanyInfra.astro";
import GermanyTimeline from "../sections/germany-product/GermanyTimeline.astro";
import GermanyList from "../sections/germany-product/GermanyList.astro";
import GermanyCta from "../sections/germany-product/GermanyCta.astro";
import Footer from "../sections/_shared/Footer.astro";
import Roadmap from "../sections/germany-product/Roadmap.astro";
import Trust from "../sections/germany-product/Trust.astro";
import NonCompliance from "../sections/germany-product/NonCompliance.astro";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Germany E-Invoicing for CFOs & Heads of Tax | ClearTax</title>
    <meta
      name="description"
      content="The 2025/2027 German e-invoicing mandate is the easy part. ViDA 2030 is the real story. ClearTax is built for both — one platform, one integration, every European mandate."
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    
    <link
      rel="shortcut icon"
      type="image/png"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="256x256"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
    />
    <link
      rel="apple-touch-icon"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
    />

    <script charset="utf-8" type="text/javascript" src="https://js-na2.hsforms.net/forms/embed/v2.js" is:inline></script>
  </head>
  <body class="bg-white text-[#111827] antialiased">
    <NavbarGlobalV2 />
    <main id="main">
      <Hero />
      <Logostrip />
      <GermanyTimeline />
      <GermanyList />
      <Roadmap />
      <WhyCleartax />
      <NonCompliance />
      <GermanyInfra />
      <ChangesAPAR />
      <Integrations />
      <Trust />
      <FAQ />
      <GermanyCta />
    </main>
    <Footer />
  </body>
</html>
