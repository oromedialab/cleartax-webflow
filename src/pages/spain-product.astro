---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/spain-product.css";

import Navbar from "../sections/spain-product/Navbar.astro";
import Hero from "../sections/spain-product/Hero.astro";
import Logostrip from "../sections/_shared/Logostrip.astro";
import Mandate from "../sections/spain-product/Mandate.astro";
import PlayGround from "../sections/spain-product/Playground.astro";
import Clients from "../sections/spain-product/Clients.astro";
import Footer from "../sections/_shared/Footer.astro";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="description"
            content="ClearTax's e-invoicing software for Spain helps businesses comply with the Fawtara mandate. Get seamless ERP and PoS integration and go live with confidence."
        />
        <meta
            name="keywords"
            content="best e invoicing software, e invoicing software, e invoicing software in spain, best e invoicing software in spain, e invoicing software solution, e invoicing software solution in spain"
        />
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <link
            rel="canonical"
            href="https://www.cleartax.com/es/en/e-invoicing-software"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <link
            rel="shortcut icon"
            type="image/png"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="256x256"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
        />
        <link
            rel="apple-touch-icon"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
        />
        <script is:inline>
            (function () {
                let interactionTriggered = false;

                function loadThirdPartyScripts() {
                    if (interactionTriggered) return;
                    interactionTriggered = true;

                    // Cleanup event listeners
                    interactionEvents.forEach(function (event) {
                        window.removeEventListener(
                            event,
                            loadThirdPartyScripts,
                            { passive: true },
                        );
                    });

                    // Google Tag Manager
                    (function (w, d, s, l, i) {
                        w[l] = w[l] || [];
                        w[l].push({
                            "gtm.start": new Date().getTime(),
                            event: "gtm.js",
                        });
                        var f = d.getElementsByTagName(s)[0],
                            j = d.createElement(s),
                            dl = l != "dataLayer" ? "&l=" + l : "";
                        j.async = true;
                        j.src =
                            "https://www.googletagmanager.com/gtm.js?id=" +
                            i +
                            dl;
                        f.parentNode.insertBefore(j, f);
                    })(window, document, "script", "dataLayer", "GTM-P5NDQXGH");
                }

                const interactionEvents = [
                    "mousemove",
                    "mouseenter",
                    "mouseover",
                    "touchstart",
                    "scroll",
                    "keydown",
                ];
                interactionEvents.forEach(function (event) {
                    window.addEventListener(event, loadThirdPartyScripts, {
                        passive: true,
                    });
                });
            })();
        </script>
        <!-- Eagerly download the HubSpot embed script asynchronously without blocking parsing -->
        <script
            charset="utf-8"
            type="text/javascript"
            src="https://js-na2.hsforms.net/forms/embed/v2.js"
            is:inline
            async></script>
        <script is:inline>
            (function () {
                document.documentElement.classList.add("js-enabled");

                const setup = () => {
                    const elements = document.querySelectorAll(
                        ".premium-reveal, .blur-reveal, .clip-reveal",
                    );
                    elements.forEach((el) => el.classList.add("is-ready"));

                    // 1. Reveal Observer
                    try {
                        const revealObserver = new IntersectionObserver(
                            (entries) => {
                                entries.forEach((entry) => {
                                    if (entry.isIntersecting) {
                                        entry.target.classList.add(
                                            "is-visible",
                                        );
                                        revealObserver.unobserve(entry.target);
                                    }
                                });
                            },
                            { threshold: 0.1 },
                        );
                        elements.forEach((el) => revealObserver.observe(el));
                    } catch (e) {
                        console.error("Observer init failed", e);
                    }
                };

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", setup);
                } else {
                    setup();
                }
            })();
        </script>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
        />
        <script
            src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
            is:inline></script>
    </head>
    <body class="bg-white text-[#111827] antialiased">
        <Navbar />
        <main id="main">
            <Hero />
            <Logostrip />
            <Mandate />
            <PlayGround />
            <Clients />
        </main>
        <Footer />
    </body>
</html>
