---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/erp-connectivity.css";
import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import Hero from "../sections/erp-connectivity/Hero.astro";
import ERPGrid from "../sections/erp-connectivity/ERPGrid.astro";
import IntegrationModes from "../sections/erp-connectivity/IntegrationModes.astro";
import Footer from "../sections/_shared/Footer.astro";
import LogoStrip from "../sections/erp-connectivity/LogoStrip.astro";
import HowItWorks from "../sections/erp-connectivity/HowItWorks.astro";
import ERPData from "../sections/erp-connectivity/ERPData.astro";
import ERPRework from "../sections/erp-connectivity/ERPRework.astro";
import IntegrationPath from "../sections/erp-connectivity/IntegrationPath.astro";
import ContactFormScale from "../sections/_shared/ContactFormScale.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClearTax — Seamless ERP Connectivity for Global Compliance</title>
    <meta
      name="description"
      content="Automate e-invoicing, e-way bills, and tax filings directly from your ERP. Native connectors for SAP, Oracle, Microsoft Dynamics, Tally, and more."
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="shortcut icon" type="image/png" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png" />
    <link rel="icon" type="image/png" sizes="256x256" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />
    <link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png" />


    <!-- Premium Interactions -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add("js-enabled");

          const setup = () => {
          const elements = document.querySelectorAll(
            ".premium-reveal, .blur-reveal, .clip-reveal",
          );

          elements.forEach((el) => el.classList.add("is-ready"));
          
          // Initial trigger for elements already in view
          const triggerReveals = () => {
            elements.forEach((el) => {
              const rect = el.getBoundingClientRect();
              if (rect.top < window.innerHeight * 0.9) {
                el.classList.add("is-visible");
              }
            });
          };

          // 1. Reveal Observer
          try {
            const revealObserver = new IntersectionObserver(
              (entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    revealObserver.unobserve(entry.target);
                  }
                });
              },
              { threshold: 0.15 },
            );
            elements.forEach((el) => revealObserver.observe(el));
          } catch (e) {
            console.error("Observer init failed", e);
            triggerReveals(); // Fallback
          }
          
          triggerReveals();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", setup);
        } else {
          setup();
        }
      })();
    </script>
  </head>
  <body class="bg-[#FCFCFD] font-['Manrope',sans-serif]">
    <NavbarGlobalV2 />
    
    <main>
      <Hero />
      <LogoStrip />
      <HowItWorks />
      <ERPData />
      <ERPGrid />
      <ERPRework />
      <IntegrationModes />
      <IntegrationPath />
      <ContactFormScale
        sheetName="globalRAD"
          originCountry="Global"
          thankYouUrl="/thankyou"
       />
    </main>

    <Footer />

    <style is:global>
      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }
      
      /* Active state for reveal animations */
      .is-visible {
        opacity: 1 !important;
        transform: translateY(0) scale(1) !important;
        filter: blur(0) !important;
      }
    </style>
  </body>
</html>
