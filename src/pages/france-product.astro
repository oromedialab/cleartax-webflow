---
import "../styles/fonts.css"
import "../styles/shared.css"
import "../styles/.build/france-product.css"

import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import Hero from "../sections/france-product/Hero.astro";
import Footer from "../sections/_shared/Footer.astro";
import FranceInfrastructure from "../sections/france-product/FranceInfrastructure.astro";
import FranceCta from "../sections/france-product/FranceCta.astro";
import Track from "../sections/france-product/Track.astro";
import LogostripFrance from "../sections/france-product/LogostripFrance.astro";
import Ymodel from "../sections/france-product/Ymodel.astro";
import WhyClear from "../sections/france-product/WhyClear.astro";
import Deadline from "../sections/france-product/Deadline.astro";
import Report from "../sections/france-product/Report.astro";
---


<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>France E-Invoicing Compliance</title>
    <meta
        name="description"
        content="Comply with ZATCA’s e-invoicing mandate with ClearTax’s AI-powered platform. Generate, validate, and report compliant e-invoices instantly."
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="shortcut icon"
      type="image/png"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd7162c46439_32by32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="256x256"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
    />
    <link
      rel="apple-touch-icon"
      href="https://cdn.prod.website-files.com/63ede4a3da6dbd8997c46450_256by256.png"
    />
    <script charset="utf-8" type="text/javascript" src="https://js-na2.hsforms.net/forms/embed/v2.js"></script>
    <script is:inline>
      // HubSpot embed script must be loaded asy
    </script>
    <script is:inline>
            (function () {
                document.documentElement.classList.add("js-enabled");

                const setup = () => {
                    const elements = document.querySelectorAll(
                        ".premium-reveal, .blur-reveal, .clip-reveal",
                    );
                    elements.forEach((el) => el.classList.add("is-ready"));

                    // 1. Reveal Observer
                    try {
                        const revealObserver = new IntersectionObserver(
                            (entries) => {
                                entries.forEach((entry) => {
                                    if (entry.isIntersecting) {
                                        entry.target.classList.add(
                                            "is-visible",
                                        );
                                        revealObserver.unobserve(entry.target);
                                    }
                                });
                            },
                            { threshold: 0.1 },
                        );
                        elements.forEach((el) => revealObserver.observe(el));
                    } catch (e) {
                        console.error("Observer init failed", e);
                    }
                };

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", setup);
                } else {
                    setup();
                }
            })();
        </script>
  </head>
  <body class="bg-white text-[#111827] antialiased">
    <NavbarGlobalV2 />
    <main id="main">
      <Hero />
      <LogostripFrance />
      <Track />
      <Ymodel />
      <Deadline />
      <FranceInfrastructure />
      <!-- <WhyClear/> -->
      <Report />
      <FranceCta />
    </main>
    <Footer />
  </body>
</html>