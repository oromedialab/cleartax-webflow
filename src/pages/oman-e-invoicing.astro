---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/.build/oman-e-invoicing.css";
import Navbar from "../sections/oman-invoicing/Navbar.astro";
import LogoStripComp from "../sections/_shared/Logostrip.astro";
import ListOman from "../sections/oman-invoicing/ListOman.astro";
import Footer from "../sections/_shared/Footer.astro";
import OmanGrid from "../sections/oman-invoicing/OmanGrid.astro";
import OmanTimeline from "../sections/oman-invoicing/OmanTimeline.astro";
import ScaleOman from "../sections/oman-invoicing/ScaleOman.astro";
import TrustedOman from "../sections/oman-invoicing/TrustedOman.astro";
import OmanCta from "../sections/oman-invoicing/OmanCta.astro";
import HeroOman from "../sections/oman-invoicing/HeroOman.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Best E-invoicing Software in Oman | Get E-invoicing Compliance in Oman - ClearTax</title>
        <meta
            name="description"
            content="ClearTax's e-invoicing software for Oman helps businesses comply with the Fawtara mandate. Get seamless ERP and PoS integration and go live with confidence."
        />
        <meta name="keywords" content="best e invoicing software, e invoicing software, e invoicing software in oman, best e invoicing software in oman, e invoicing software solution, e invoicing software solution in oman">
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <link rel="canonical" href="https://www.cleartax.com/om/e-invoicing-software"/>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <!-- Preconnect to HubSpot and Third-party CDNs -->
        <link rel="preconnect" href="https://js-na2.hsforms.net" />
        <link rel="preconnect" href="https://forms.hsforms.com" />
        <link rel="preconnect" href="https://forms-na2.hsforms.com" />
        <link rel="preconnect" href="https://web.cmp.usercentrics.eu" />
        <link rel="preconnect" href="https://www.googletagmanager.com" />

        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
            />
        </noscript>
        <link
            rel="shortcut icon"
            type="image/png"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="256x256"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
        />
        <link
            rel="apple-touch-icon"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
        />

        <!-- Preload critical above-the-fold assets -->
        <link
            rel="preload"
            href="https://cdn.prod.website-files.com/69fda2cd307dcc6cf810e935/6a1d17a650966f1b3103a1e2_Hero-img.png"
            as="image"
            type="image/png"
            fetchpriority="high"
        />
        <link
            rel="preload"
            href="https://cdn.prod.website-files.com/6093bce33d9b4bae841b04e3/69dfcff6071b983201f5f097_logo-cleartax.svg"
            as="image"
            type="image/svg+xml"
            fetchpriority="high"
        />


        <!-- Deferred script loader for performance (HubSpot, GTM, Usercentrics) -->
        <script is:inline>
            (function () {
                let scriptsLoaded = false;
                function loadHeavyScripts() {
                    if (scriptsLoaded) return;
                    scriptsLoaded = true;

                    // Remove event listeners
                    triggerEvents.forEach((e) =>
                        window.removeEventListener(e, loadHeavyScripts, { passive: true }),
                    );

                    // Load HubSpot forms script
                    var hsScript = document.createElement("script");
                    hsScript.charset = "utf-8";
                    hsScript.type = "text/javascript";
                    hsScript.src = "https://js-na2.hsforms.net/forms/embed/v2.js";
                    document.head.appendChild(hsScript);

                    // Load Google Tag Manager
                    (function (w, d, s, l, i) {
                        w[l] = w[l] || [];
                        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
                        var f = d.getElementsByTagName(s)[0],
                            j = d.createElement(s),
                            dl = l != "dataLayer" ? "&l=" + l : "";
                        j.async = true;
                        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
                        f.parentNode.insertBefore(j, f);
                    })(window, document, "script", "dataLayer", "GTM-P5NDQXGH");

                    // Load Usercentrics autoblocker
                    var blockScript = document.createElement("script");
                    blockScript.src = "https://web.cmp.usercentrics.eu/modules/autoblocker.js";
                    document.head.appendChild(blockScript);

                    // Load Usercentrics loader
                    var cmpScript = document.createElement("script");
                    cmpScript.id = "usercentrics-cmp";
                    cmpScript.src = "https://web.cmp.usercentrics.eu/ui/loader.js";
                    cmpScript.setAttribute("data-settings-id", "utqqyaEbvbzrTk");
                    cmpScript.async = true;
                    document.head.appendChild(cmpScript);
                }

                const triggerEvents = [
                    "mouseover",
                    "mouseenter",
                    "mousemove",
                    "touchstart",
                    "scroll",
                    "keydown",
                ];
                triggerEvents.forEach((e) =>
                    window.addEventListener(e, loadHeavyScripts, { passive: true }),
                );

                // Safety timeout to ensure scripts load even without interaction (e.g. for crawlers)
                setTimeout(loadHeavyScripts, 4000);
            })();
        </script>
        <!-- Premium Interactions -->
        <script is:inline>
            (function () {
                document.documentElement.classList.add("js-enabled");

                const setup = () => {
                    const elements = document.querySelectorAll(
                        ".premium-reveal, .blur-reveal, .clip-reveal",
                    );
                    elements.forEach((el) => el.classList.add("is-ready"));

                    // 1. Reveal Observer
                    try {
                        const revealObserver = new IntersectionObserver(
                            (entries) => {
                                entries.forEach((entry) => {
                                    if (entry.isIntersecting) {
                                        entry.target.classList.add(
                                            "is-visible",
                                        );
                                        revealObserver.unobserve(entry.target);
                                    }
                                });
                            },
                            { threshold: 0.1 },
                        );
                        elements.forEach((el) => revealObserver.observe(el));
                    } catch (e) {
                        console.error("Observer init failed", e);
                    }
                };

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", setup);
                } else {
                    setup();
                }
            })();
        </script>
    </head>
    <body class="bg-white">
        <Navbar />
        <main>
            <HeroOman />
            <OmanTimeline />
            <ListOman />
            <OmanGrid />
            <ScaleOman />
            <TrustedOman />
            <LogoStripComp />
            <OmanCta />
        </main>
    </body>
    <Footer />
</html>
