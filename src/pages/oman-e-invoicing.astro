---
import "../styles/fonts.css";
import "../styles/shared.css";
import "../styles/oman-e-invoicing.css";
import NavbarGlobalV2 from "../sections/_shared/NavbarGlobalV2.astro";
import LogoStripComp from "../sections/clear-compliance-cloud/LogoStripComp.astro";
import ListOman from "../sections/oman-invoicing/ListOman.astro";
import Footer from "../sections/_shared/Footer.astro";
import OmanGrid from "../sections/oman-invoicing/OmanGrid.astro";
import OmanTimeline from "../sections/oman-invoicing/OmanTimeline.astro";
import SecurityOman from "../sections/oman-invoicing/SecurityOman.astro";
import ScaleOman from "../sections/oman-invoicing/ScaleOman.astro";
import TrustedOman from "../sections/oman-invoicing/TrustedOman.astro";
import HeroOman from "../sections/oman-invoicing/HeroOman.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Oman E-invoicing | ClearTax</title>
        <meta
            name="description"
            content="Comply with ZATCA’s e-invoicing mandate with ClearTax’s AI-powered platform. Generate, validate, and report compliant e-invoices instantly."
        />
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap"
        />
        <link
            rel="shortcut icon"
            type="image/png"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd7162c46439_32by32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="256x256"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
        />
        <link
            rel="apple-touch-icon"
            href="https://cdn.prod.website-files.com/63ede4a3da6dbd6b05c4612f/63ede4a3da6dbd8997c46450_256by256.png"
        />
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
        />
        <script
            is:inline
            defer
            src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
        ></script>

        <!-- Premium Interactions -->
        <script is:inline>
            (function () {
                document.documentElement.classList.add("js-enabled");

                const setup = () => {
                    const elements = document.querySelectorAll(
                        ".premium-reveal, .blur-reveal, .clip-reveal",
                    );
                    elements.forEach((el) => el.classList.add("is-ready"));

                    // 1. Reveal Observer
                    try {
                        const revealObserver = new IntersectionObserver(
                            (entries) => {
                                entries.forEach((entry) => {
                                    if (entry.isIntersecting) {
                                        entry.target.classList.add(
                                            "is-visible",
                                        );
                                        revealObserver.unobserve(entry.target);
                                    }
                                });
                            },
                            { threshold: 0.1 },
                        );
                        elements.forEach((el) => revealObserver.observe(el));
                    } catch (e) {
                        console.error("Observer init failed", e);
                    }
                };

                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", setup);
                } else {
                    setup();
                }
            })();
        </script>
    </head>
    <body class="bg-white">
        <NavbarGlobalV2 />
        <main>
            <HeroOman />
            <LogoStripComp />
            <OmanTimeline />
            <OmanGrid />
            <ListOman />
            <SecurityOman />
            <ScaleOman />
            <TrustedOman />
        </main>
    </body>
    <Footer />
</html>
