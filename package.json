{
  "name": "cleartax-webflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build:css",
    "dev": "concurrently -n css,astro -c magenta,cyan \"node scripts/build-css.mjs --watch --page=${PAGE:-all}\" \"astro dev\"",
    "dev:uae": "PAGE=uae npm run dev",
    "dev:global": "PAGE=global npm run dev",
    "build": "npm run build:css && astro build && node scripts/extract-embeds.mjs && node scripts/assemble-confirmations.mjs",
    "build:css": "node scripts/build-css.mjs",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "concurrently": "^9.0.0",
    "css-tree": "^3.2.1",
    "node-html-parser": "^6.1.13"
  }
}
